---
import '../styles/fonts.css';
import '../styles/global.css';

// Vite ?url imports resolve hashed font paths at build time for preloading
import cormorant400 from '@fontsource/cormorant-garamond/files/cormorant-garamond-latin-400-normal.woff2?url';
import cormorant600 from '@fontsource/cormorant-garamond/files/cormorant-garamond-latin-600-normal.woff2?url';
import inter400 from '@fontsource/inter/files/inter-latin-400-normal.woff2?url';
import inter500 from '@fontsource/inter/files/inter-latin-500-normal.woff2?url';
import inter600 from '@fontsource/inter/files/inter-latin-600-normal.woff2?url';

interface Props {
  title: string;
  description?: string;
  canonicalUrl?: string;
  ogType?: string;
  ogImage?: string;
  ogImageWidth?: number;
  ogImageHeight?: number;
  publishDate?: string;
  jsonLd?: object;
  bodyClass?: string;
  noindex?: boolean;
  citationMeta?: {
    title: string;
    authors: string[];
    date?: string;
    journal?: string;
    journalAbbrev?: string;
    volume?: string;
    issue?: string;
    firstPage?: string;
    lastPage?: string;
    doi?: string;
    pmid?: string;
    abstract?: string;
    keywords?: string;
  };
}

const {
  title,
  description = 'RRM Academy App Experience',
  canonicalUrl,
  ogType = 'website',
  ogImage,
  ogImageWidth = 1200,
  ogImageHeight = 630,
  publishDate,
  jsonLd,
  bodyClass,
  citationMeta,
  noindex,
} = Astro.props;

const fullTitle = (title.includes('RRM Academy') || title.startsWith('RRM ')) ? title : `${title} | RRM Academy`;
const rawCanonical = canonicalUrl || Astro.url.href;
const canonicalObj = new URL(rawCanonical);
canonicalObj.pathname = canonicalObj.pathname.endsWith('/') ? canonicalObj.pathname : `${canonicalObj.pathname}/`;
const canonical = canonicalObj.href;
const siteOrigin = 'https://rrmacademy.org';

function routeToOgSlug(pathname) {
  if (pathname === '/' || pathname === '') return 'homepage';
  const paginationMatch = pathname.match(/^\/app\/(library|commentary)\/page\/\d+\/?$/);
  if (paginationMatch) return paginationMatch[1];
  return pathname.replace(/^\/|\/$/g, '').replace(/\//g, '-');
}
const ogSlug = routeToOgSlug(Astro.url.pathname);
const conventionOgPath = `/images/og/og-${ogSlug}.png`;
const resolvedOgImage = ogImage
  ? (ogImage.startsWith('http') ? ogImage : `${siteOrigin}${ogImage}`)
  : `${siteOrigin}${conventionOgPath}`;
const resolvedTwitterImage = resolvedOgImage.endsWith('.webp')
  ? resolvedOgImage.replace(/\.webp$/, '.jpg')
  : resolvedOgImage;
---
<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
  <meta name="format-detection" content="telephone=no" />
  {noindex && <meta name="robots" content="noindex, nofollow" />}
  <title>{fullTitle}</title>
  <script is:inline>
    (function() {
      var saved = localStorage.getItem('rrm_theme');
      if (saved) {
        document.documentElement.setAttribute('data-theme', saved);
      } else if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
        document.documentElement.setAttribute('data-theme', 'dark');
        localStorage.setItem('rrm_theme', 'dark');
      }
    })();
  </script>
  <script is:inline>
    if (!sessionStorage.getItem('entry_ref') && !document.cookie.includes('entry_ref=')) {
      var r = document.referrer, u = location.href;
      sessionStorage.setItem('entry_ref', r);
      sessionStorage.setItem('entry_url', u);
      document.cookie = 'entry_ref=' + encodeURIComponent(r) + ';path=/;SameSite=Lax;Secure';
      document.cookie = 'entry_url=' + encodeURIComponent(u) + ';path=/;SameSite=Lax;Secure';
    }
  </script>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />

  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content={ogType} />
  <meta property="og:url" content={canonical} />
  <meta property="og:site_name" content="RRM Academy" />
  <meta property="og:locale" content="en_US" />
  <meta property="og:image" content={resolvedOgImage} />
  <meta property="og:image:width" content={String(ogImageWidth)} />
  <meta property="og:image:height" content={String(ogImageHeight)} />
  <meta property="og:image:alt" content={title} />
  {ogType === 'article' && publishDate && <meta property="article:published_time" content={publishDate} />}

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={resolvedTwitterImage} />
  <meta name="twitter:site" content="@rrmacademy" />
  <meta name="twitter:creator" content="@rrmacademy" />

  {citationMeta && (
    <>
      <meta name="citation_title" content={citationMeta.title} />
      {citationMeta.authors.map(author => (
        <meta name="citation_author" content={author} />
      ))}
      {citationMeta.date && <meta name="citation_publication_date" content={citationMeta.date} />}
      {citationMeta.journal && <meta name="citation_journal_title" content={citationMeta.journal} />}
      {citationMeta.journalAbbrev && <meta name="citation_journal_abbrev" content={citationMeta.journalAbbrev} />}
      {citationMeta.volume && <meta name="citation_volume" content={citationMeta.volume} />}
      {citationMeta.issue && <meta name="citation_issue" content={citationMeta.issue} />}
      {citationMeta.firstPage && <meta name="citation_firstpage" content={citationMeta.firstPage} />}
      {citationMeta.lastPage && <meta name="citation_lastpage" content={citationMeta.lastPage} />}
      {citationMeta.doi && <meta name="citation_doi" content={citationMeta.doi} />}
      {citationMeta.pmid && <meta name="citation_pmid" content={citationMeta.pmid} />}
      {citationMeta.abstract && <meta name="citation_abstract" content={citationMeta.abstract} />}
      {citationMeta.keywords && <meta name="citation_keywords" content={citationMeta.keywords} />}
    </>
  )}

  <link rel="preconnect" href="https://static.cloudflareinsights.com" crossorigin />
  <link rel="preload" href={cormorant400} as="font" type="font/woff2" crossorigin />
  <link rel="preload" href={cormorant600} as="font" type="font/woff2" crossorigin />
  <link rel="preload" href={inter400} as="font" type="font/woff2" crossorigin />
  <link rel="preload" href={inter500} as="font" type="font/woff2" crossorigin />
  <link rel="preload" href={inter600} as="font" type="font/woff2" crossorigin />
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

  {jsonLd ? (
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  ) : (
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "WebSite",
          "@id": "https://rrmacademy.org/#website",
          "url": "https://rrmacademy.org",
          "name": "RRM Academy",
          "description": "Nonprofit education in restorative reproductive medicine, NaProTechnology, and evidence-based women's health."
        }
      ]
    })} />
  )}
</head>
<body class="app-body">
  <div class="app-layout">
    <!-- Desktop Sidebar -->
    <aside class="app-sidebar">
      <div class="app-sidebar-header">
        <a href="/" class="app-logo">
          <span class="app-logo__text">RRM Academy</span>
        </a>
      </div>
      <nav class="app-sidebar-nav">
        <ul>
          <li>
            <a href="/app/library/" class:list={[{ 'active': Astro.url.pathname.startsWith('/app/library') }]}>
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"/></svg>
              <span>Library</span>
            </a>
          </li>
          <li>
            <a href="/app/commentary/" class:list={[{ 'active': Astro.url.pathname.startsWith('/app/commentary') }]}>
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
              <span>Commentary</span>
            </a>
          </li>
          <li>
            <a href="/app/library/saved/" class:list={[{ 'active': Astro.url.pathname.startsWith('/app/library/saved') }]}>
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m19 21-7-4-7 4V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v16z"/></svg>
              <span>Saved</span>
            </a>
          </li>
        </ul>
      </nav>
      <div class="app-sidebar-footer">
        <button class="app-theme-toggle" id="theme-toggle" aria-label="Toggle theme">
          <svg class="sun-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>
          <svg class="moon-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
          <svg class="eink-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/><path d="M12 6v7"/></svg>
          <span class="theme-label">Theme</span>
        </button>
        <a href="/account/" class="app-account-link">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          <span>Account</span>
        </a>
      </div>
    </aside>

    <!-- Main Content Area -->
    <main class:list={["app-main-content", bodyClass]}>
      <!-- Mobile Header (Visible only on small screens) -->
      <header class="app-mobile-header">
        <a href="/" class="app-logo">
          <span class="app-logo__text">RRM Academy</span>
        </a>
        <div class="app-mobile-actions">
          <!-- Optional Theme Toggle or search icon -->
        </div>
      </header>
      
      <!-- Content Viewport -->
      <div class="app-scroll-area">
        <slot />
      </div>
    </main>

    <!-- Mobile Bottom Nav -->
    <nav class="app-bottom-nav">
      <ul>
        <li>
          <a href="/app/library/" class:list={[{ 'active': Astro.url.pathname.startsWith('/app/library') }]}>
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"/></svg>
            <span>Library</span>
          </a>
        </li>
        <li>
          <a href="/app/commentary/" class:list={[{ 'active': Astro.url.pathname.startsWith('/app/commentary') }]}>
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
            <span>Commentary</span>
          </a>
        </li>
        <li>
          <a href="/app/library/saved/">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m19 21-7-4-7 4V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v16z"/></svg>
            <span>Saved</span>
          </a>
        </li>
        <li>
          <a href="/account/">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            <span>Account</span>
          </a>
        </li>
      </ul>
    </nav>

    <!-- Theme toggle script -->
    <script is:inline>
      (function() {
        var toggle = document.getElementById('theme-toggle');
        if (!toggle) return;
        
        toggle.addEventListener('click', function() {
          var html = document.documentElement;
          var current = html.getAttribute('data-theme') || 'light';
          var next = current === 'light' ? 'dark' : current === 'dark' ? 'eink' : 'light';
          html.setAttribute('data-theme', next);
          localStorage.setItem('rrm_theme', next);
        });
      })();
    </script>
  </div>
</body>
</html>

<style>
  /* App Shell Base Styles */
  .app-body {
    margin: 0;
    padding: 0;
    height: 100vh;
    height: 100dvh;
    overflow: hidden; /* Prevent body scroll, handle scroll in app-scroll-area */
    background-color: var(--bg-surface); /* Assuming an e-ink light background */
    color: var(--text-primary);
  }

  .app-layout {
    display: flex;
    height: 100%;
    width: 100%;
  }

  /* Typography alignment with design system */
  .app-logo__text {
    font-family: 'Cormorant Garamond', 'Georgia', serif;
    font-weight: 600;
    font-size: 1.625rem;
    color: var(--text-primary);
    text-decoration: none;
  }
  
  .app-logo {
    text-decoration: none;
  }

  /* ----------------------
     Desktop Sidebar
     ---------------------- */
  .app-sidebar {
    display: none;
    flex-direction: column;
    width: 260px;
    height: 100%;
    background: var(--bg-header); /* Slightly different from main content? */
    border-right: 1px solid var(--border-light);
    flex-shrink: 0;
  }

  .app-sidebar-header {
    padding: var(--space-6);
    height: 72px;
    display: flex;
    align-items: center;
  }

  .app-sidebar-nav {
    flex: 1;
    overflow-y: auto;
    padding: var(--space-4) 0;
  }

  .app-sidebar-nav ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .app-sidebar-nav li {
    padding: 2px var(--space-4);
  }

  .app-sidebar-nav a {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-2) var(--space-3);
    color: var(--text-secondary);
    text-decoration: none;
    font-family: 'Inter', sans-serif;
    font-size: 0.9375rem;
    font-weight: 500;
    border-radius: var(--radius-md);
    transition: all 0.15s;
  }

  .app-sidebar-nav a:hover {
    color: var(--accent);
    background: color-mix(in srgb, var(--accent) 8%, transparent);
  }

  .app-sidebar-nav a.active {
    color: var(--accent);
    background: color-mix(in srgb, var(--accent) 8%, transparent);
  }

  .app-sidebar-footer {
    padding: var(--space-4);
    border-top: 1px solid var(--border-light);
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .app-theme-toggle {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-2) var(--space-3);
    color: var(--text-secondary);
    background: none;
    border: none;
    font-family: 'Inter', sans-serif;
    font-size: 0.9375rem;
    font-weight: 500;
    border-radius: var(--radius-md);
    cursor: pointer;
    transition: all 0.15s;
    width: 100%;
    text-align: left;
  }

  .app-theme-toggle:hover {
    color: var(--accent);
    background: color-mix(in srgb, var(--accent) 8%, transparent);
  }

  .app-theme-toggle .sun-icon,
  .app-theme-toggle .moon-icon,
  .app-theme-toggle .eink-icon {
    display: none;
  }

  [data-theme="light"] .app-theme-toggle .sun-icon {
    display: block;
  }

  [data-theme="dark"] .app-theme-toggle .moon-icon {
    display: block;
  }

  [data-theme="eink"] .app-theme-toggle .eink-icon {
    display: block;
  }

  .app-account-link {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-2) var(--space-3);
    color: var(--text-secondary);
    text-decoration: none;
    font-family: 'Inter', sans-serif;
    font-size: 0.9375rem;
    border-radius: var(--radius-md);
    transition: background 0.15s;
  }
  
  .app-account-link:hover {
    background: color-mix(in srgb, var(--accent) 8%, transparent);
  }

  /* ----------------------
     Main Content
     ---------------------- */
  .app-main-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    height: 100%;
    position: relative;
    overflow: hidden; /* Scroll inside inner area */
  }

  .app-scroll-area {
    flex: 1;
    overflow-y: auto;
    -webkit-overflow-scrolling: touch; /* Smooth scrolling on iOS */
  }

  /* ----------------------
     Mobile Header
     ---------------------- */
  .app-mobile-header {
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 var(--space-4);
    background: var(--bg-header);
    border-bottom: 1px solid var(--border-light);
    flex-shrink: 0;
  }

  /* ----------------------
     Mobile Bottom Nav
     ---------------------- */
  .app-bottom-nav {
    display: block;
    height: 64px;
    background: var(--bg-header);
    border-top: 1px solid var(--border-light);
    flex-shrink: 0;
    padding-bottom: env(safe-area-inset-bottom); /* iOS safe area */
  }

  .app-bottom-nav ul {
    display: flex;
    list-style: none;
    margin: 0;
    padding: 0;
    height: 100%;
  }

  .app-bottom-nav li {
    flex: 1;
  }

  .app-bottom-nav a {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    height: 100%;
    gap: 4px;
    color: var(--text-tertiary);
    text-decoration: none;
    font-family: 'Inter', sans-serif;
    font-size: 0.6875rem;
  }

  .app-bottom-nav a.active {
    color: var(--accent);
  }

  .app-bottom-nav svg {
    display: block;
    transition: transform 0.15s;
  }
  
  .app-bottom-nav a:active svg {
    transform: scale(0.9);
  }

  /* Responsive Breakpoints */
  @media (min-width: 769px) {
    .app-sidebar {
      display: flex;
    }
    .app-mobile-header {
      display: none;
    }
    .app-bottom-nav {
      display: none;
    }
  }
</style>
