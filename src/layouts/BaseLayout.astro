---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/fonts.css';
import '../styles/global.css';

// Vite ?url imports resolve hashed font paths at build time for preloading
import cormorant400 from '@fontsource/cormorant-garamond/files/cormorant-garamond-latin-400-normal.woff2?url';
import cormorant600 from '@fontsource/cormorant-garamond/files/cormorant-garamond-latin-600-normal.woff2?url';
import inter400 from '@fontsource/inter/files/inter-latin-400-normal.woff2?url';
import inter500 from '@fontsource/inter/files/inter-latin-500-normal.woff2?url';
import inter600 from '@fontsource/inter/files/inter-latin-600-normal.woff2?url';

interface Props {
  title: string;
  description?: string;
  canonicalUrl?: string;
  ogType?: string;
  ogImage?: string;
  ogImageWidth?: number;
  ogImageHeight?: number;
  publishDate?: string;
  jsonLd?: object;
  bodyClass?: string;
  noindex?: boolean;
  markdownUrl?: string;
  citationMeta?: {
    title: string;
    authors: string[];      // One meta tag per author
    date?: string;          // Format: YYYY/MM/DD or YYYY
    journal?: string;
    journalAbbrev?: string;
    volume?: string;
    issue?: string;
    firstPage?: string;
    lastPage?: string;
    doi?: string;
    pmid?: string;
    abstract?: string;
    keywords?: string;      // Semicolon-separated
  };
}

const {
  title,
  description = 'The largest free collection of academic references related to restorative reproductive medicine.',
  canonicalUrl,
  ogType = 'website',
  ogImage,
  ogImageWidth = 1200,
  ogImageHeight = 630,
  publishDate,
  jsonLd,
  bodyClass,
  citationMeta,
  noindex,
  markdownUrl,
} = Astro.props;

const fullTitle = (title.includes('RRM Academy') || title.startsWith('RRM ')) ? title : `${title} | RRM Academy`;
const rawCanonical = canonicalUrl || Astro.url.href;
const canonicalObj = new URL(rawCanonical);
canonicalObj.pathname = canonicalObj.pathname.endsWith('/') ? canonicalObj.pathname : `${canonicalObj.pathname}/`;
const canonical = canonicalObj.href;
const siteOrigin = 'https://rrmacademy.org';
// Convention-based OG image: derive slug from URL path
function routeToOgSlug(pathname) {
  if (pathname === '/' || pathname === '') return 'homepage';
  const paginationMatch = pathname.match(/^\/(library|commentary)\/page\/\d+\/?$/);
  if (paginationMatch) return paginationMatch[1];
  return pathname.replace(/^\/|\/$/g, '').replace(/\//g, '-');
}
const ogSlug = routeToOgSlug(Astro.url.pathname);
const conventionOgPath = `/images/og/og-${ogSlug}.png`;
const resolvedOgImage = ogImage
  ? (ogImage.startsWith('http') ? ogImage : `${siteOrigin}${ogImage}`)
  : `${siteOrigin}${conventionOgPath}`;
// Twitter requires JPG/PNG — swap .webp for .jpg for twitter:image only
const resolvedTwitterImage = resolvedOgImage.endsWith('.webp')
  ? resolvedOgImage.replace(/\.webp$/, '.jpg')
  : resolvedOgImage;
---
<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="format-detection" content="telephone=no" />
  {noindex && <meta name="robots" content="noindex, nofollow" />}
  <title>{fullTitle}</title>
  <script is:inline>
    // Apply saved theme before first paint to prevent flash
    (function() {
      var saved = localStorage.getItem('rrm_theme');
      if (saved) {
        document.documentElement.setAttribute('data-theme', saved);
      } else if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
        document.documentElement.setAttribute('data-theme', 'dark');
        localStorage.setItem('rrm_theme', 'dark');
      }
    })();
  </script>
  <script is:inline>
    // Capture original entry source on first page load.
    // sessionStorage: tab-scoped, used by checkout pages for Stripe metadata.
    // Cookies: sent with every request, read server-side by buildSourceParams
    // so ALL GA4 conversion events get correct source attribution automatically.
    if (!sessionStorage.getItem('entry_ref') && !document.cookie.includes('entry_ref=')) {
      var r = document.referrer, u = location.href;
      sessionStorage.setItem('entry_ref', r);
      sessionStorage.setItem('entry_url', u);
      document.cookie = 'entry_ref=' + encodeURIComponent(r) + ';path=/;SameSite=Lax;Secure';
      document.cookie = 'entry_url=' + encodeURIComponent(u) + ';path=/;SameSite=Lax;Secure';
    }
  </script>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <link rel="alternate" hreflang="en" href={canonical} />
  <link rel="alternate" hreflang="x-default" href={canonical} />
  {markdownUrl && <link rel="alternate" type="text/markdown" href={markdownUrl} title="Markdown" />}

  <!-- Open Graph -->
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content={ogType} />
  <meta property="og:url" content={canonical} />
  <meta property="og:site_name" content="RRM Academy" />
  <meta property="og:locale" content="en_US" />
  <meta property="og:image" content={resolvedOgImage} />
  <meta property="og:image:width" content={String(ogImageWidth)} />
  <meta property="og:image:height" content={String(ogImageHeight)} />
  <meta property="og:image:alt" content={title} />
  {ogType === 'article' && publishDate && <meta property="article:published_time" content={publishDate} />}

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={resolvedTwitterImage} />
  <meta name="twitter:site" content="@rrmacademy" />
  <meta name="twitter:creator" content="@rrmacademy" />

  <!-- Highwire Press / Zotero citation meta -->
  {citationMeta && (
    <>
      <meta name="citation_title" content={citationMeta.title} />
      {citationMeta.authors.map(author => (
        <meta name="citation_author" content={author} />
      ))}
      {citationMeta.date && <meta name="citation_publication_date" content={citationMeta.date} />}
      {citationMeta.journal && <meta name="citation_journal_title" content={citationMeta.journal} />}
      {citationMeta.journalAbbrev && <meta name="citation_journal_abbrev" content={citationMeta.journalAbbrev} />}
      {citationMeta.volume && <meta name="citation_volume" content={citationMeta.volume} />}
      {citationMeta.issue && <meta name="citation_issue" content={citationMeta.issue} />}
      {citationMeta.firstPage && <meta name="citation_firstpage" content={citationMeta.firstPage} />}
      {citationMeta.lastPage && <meta name="citation_lastpage" content={citationMeta.lastPage} />}
      {citationMeta.doi && <meta name="citation_doi" content={citationMeta.doi} />}
      {citationMeta.pmid && <meta name="citation_pmid" content={citationMeta.pmid} />}
      {citationMeta.abstract && <meta name="citation_abstract" content={citationMeta.abstract} />}
      {citationMeta.keywords && <meta name="citation_keywords" content={citationMeta.keywords} />}
    </>
  )}

  <!-- Preconnect to third-party origins used on every page -->
  <link rel="preconnect" href="https://static.cloudflareinsights.com" crossorigin />

  <!-- Preload all five font weights used across most pages -->
  <link rel="preload" href={cormorant400} as="font" type="font/woff2" crossorigin />
  <link rel="preload" href={cormorant600} as="font" type="font/woff2" crossorigin />
  <link rel="preload" href={inter400} as="font" type="font/woff2" crossorigin />
  <link rel="preload" href={inter500} as="font" type="font/woff2" crossorigin />
  <link rel="preload" href={inter600} as="font" type="font/woff2" crossorigin />

  <!-- Favicon -->
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

  {jsonLd ? (
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  ) : (
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "Organization",
          "@id": "https://rrmacademy.org/#organization",
          "name": "RRM Academy",
          "url": "https://rrmacademy.org",
          "description": "RRM Academy is a trusted nonprofit educational platform and reference source for restorative reproductive medicine (RRM), NaProTechnology, fertility awareness-based methods, endometriosis excision surgery, and reproductive endocrinology. The RRM Research Library is the largest freely accessible collection of peer-reviewed academic references on these topics available online.",
          "founder": {
            "@type": "Person",
            "name": "Dr. Naomi Whittaker",
            "jobTitle": "Board-Certified OB/GYN, NaProTechnology Fellowship Trained"
          },
          "knowsAbout": [
            "Restorative Reproductive Medicine",
            "NaProTechnology",
            "Fertility Awareness-Based Methods",
            "Endometriosis Excision Surgery",
            "Reproductive Endocrinology",
            "Natural Family Planning",
            "Hormonal Health",
            "PCOS",
            "Infertility Diagnosis and Treatment"
          ],
          "sameAs": [
            "https://www.instagram.com/rrmacademy/",
            "https://www.youtube.com/@rrmacademy"
          ]
        },
        {
          "@type": "WebSite",
          "@id": "https://rrmacademy.org/#website",
          "url": "https://rrmacademy.org",
          "name": "RRM Academy",
          "description": "Nonprofit education in restorative reproductive medicine, NaProTechnology, and evidence-based women's health.",
          "publisher": { "@id": "https://rrmacademy.org/#organization" },
          "potentialAction": {
            "@type": "SearchAction",
            "target": "https://rrmacademy.org/library/?q={search_term_string}",
            "query-input": "required name=search_term_string"
          }
        }
      ]
    })} />
  )}
</head>
<body class:list={[bodyClass]}>
  <Header />
  <main>
    <slot />
  </main>
  <Footer />
</body>
</html>
