---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import pageDates from '../data/page-dates.json';
import { OG_VERSION } from '../lib/og-config';
import '../styles/fonts.css';
import '../styles/global.css';

// Vite ?url imports resolve hashed font paths at build time for preloading
import cormorant400 from '@fontsource/cormorant-garamond/files/cormorant-garamond-latin-400-normal.woff2?url';
import cormorant600 from '@fontsource/cormorant-garamond/files/cormorant-garamond-latin-600-normal.woff2?url';
import inter400 from '@fontsource/inter/files/inter-latin-400-normal.woff2?url';
import inter500 from '@fontsource/inter/files/inter-latin-500-normal.woff2?url';
import inter600 from '@fontsource/inter/files/inter-latin-600-normal.woff2?url';

interface Props {
  title: string;
  description?: string;
  canonicalUrl?: string;
  ogType?: string;
  ogImage?: string;
  ogImageWidth?: number;
  ogImageHeight?: number;
  publishDate?: string;
  lastModified?: string;
  jsonLd?: object;
  bodyClass?: string;
  noindex?: boolean;
  markdownUrl?: string;
  citationMeta?: {
    title: string;
    authors: string[];      // One meta tag per author
    date?: string;          // Format: YYYY/MM/DD or YYYY
    journal?: string;
    journalAbbrev?: string;
    volume?: string;
    issue?: string;
    firstPage?: string;
    lastPage?: string;
    doi?: string;
    pmid?: string;
    abstract?: string;
    keywords?: string;      // Semicolon-separated
  };
}

const {
  title,
  description = 'The largest free collection of academic references related to restorative reproductive medicine.',
  canonicalUrl,
  ogType = 'website',
  ogImage,
  ogImageWidth = 1200,
  ogImageHeight = 630,
  publishDate,
  lastModified,
  jsonLd,
  bodyClass,
  citationMeta,
  noindex,
  markdownUrl,
} = Astro.props;

const fullTitle = (title.includes('RRM Academy') || title.startsWith('RRM ')) ? title : `${title} | RRM Academy`;

// Auto-resolve lastModified from page-dates.json unless explicitly provided.
// Page-dates is git-derived for static pages + D1 updated_at for content.
const resolvedLastModified = (() => {
  if (lastModified) return lastModified.match(/^\d{4}-\d{2}-\d{2}/)?.[0] || null;
  const p = Astro.url.pathname;
  const key = p.endsWith('/') ? p : p + '/';
  return (pageDates.dates as Record<string, string>)[key] || null;
})();

const rawCanonical = canonicalUrl || Astro.url.href;
const canonicalObj = new URL(rawCanonical);
canonicalObj.pathname = canonicalObj.pathname.endsWith('/') ? canonicalObj.pathname : `${canonicalObj.pathname}/`;
const canonical = canonicalObj.href;
const siteOrigin = 'https://rrmacademy.org';
// Convention-based OG image: derive slug from URL path, served on-demand by
// functions/og/[[path]].js. Unknown slugs return a branded fallback card.
// Bump OG_VERSION in src/lib/og-config.ts to force scraper re-unfurl after
// palette or template changes.
function routeToOgSlug(pathname) {
  if (pathname === '/' || pathname === '') return 'homepage';
  const paginationMatch = pathname.match(/^\/(library|commentary)\/page\/\d+\/?$/);
  if (paginationMatch) return paginationMatch[1];
  return pathname.replace(/^\/|\/$/g, '').replace(/\//g, '-');
}
const ogSlug = routeToOgSlug(Astro.url.pathname);
const conventionOgPath = `/og/${ogSlug}.png?v=${OG_VERSION}`;
// RSS autodiscovery: surface the right feed when the page lives under a feed-bearing section.
const rssFeed = (() => {
  const p = Astro.url.pathname;
  if (p === '/library/' || p.startsWith('/library/')) return { href: '/library/rss.xml', title: 'RRM Academy Research Library' };
  if (p === '/commentary/' || p.startsWith('/commentary/')) return { href: '/commentary/rss.xml', title: 'RRM Academy Commentary' };
  return null;
})();
const resolvedOgImage = ogImage
  ? (ogImage.startsWith('http') ? ogImage : `${siteOrigin}${ogImage}`)
  : `${siteOrigin}${conventionOgPath}`;
// Twitter requires JPG/PNG — swap .webp for .jpg for twitter:image only
const resolvedTwitterImage = resolvedOgImage.endsWith('.webp')
  ? resolvedOgImage.replace(/\.webp$/, '.jpg')
  : resolvedOgImage;
---
<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="format-detection" content="telephone=no" />
  {noindex && <meta name="robots" content="noindex, nofollow" />}
  <title>{fullTitle}</title>
  <script is:inline>
    // Apply saved theme before first paint to prevent flash
    (function() {
      var saved = localStorage.getItem('rrm_theme');
      if (saved) {
        document.documentElement.setAttribute('data-theme', saved);
      } else {
        var initial = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
        document.documentElement.setAttribute('data-theme', initial);
        localStorage.setItem('rrm_theme', initial);
      }
    })();
  </script>
  <script is:inline>
    // Capture original entry source on first page load.
    // sessionStorage: tab-scoped, used by checkout pages for Stripe metadata.
    // Cookies: sent with every request, read server-side by buildSourceParams
    // so ALL GA4 conversion events get correct source attribution automatically.
    if (!sessionStorage.getItem('entry_ref') && !document.cookie.includes('entry_ref=')) {
      var r = document.referrer, u = location.href;
      sessionStorage.setItem('entry_ref', r);
      sessionStorage.setItem('entry_url', u);
      document.cookie = 'entry_ref=' + encodeURIComponent(r) + ';path=/;SameSite=Lax;Secure';
      document.cookie = 'entry_url=' + encodeURIComponent(u) + ';path=/;SameSite=Lax;Secure';
    }
  </script>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <link rel="alternate" hreflang="en" href={canonical} />
  <link rel="alternate" hreflang="x-default" href={canonical} />
  {markdownUrl && <link rel="alternate" type="text/markdown" href={markdownUrl} title="Markdown" />}
  {rssFeed && <link rel="alternate" type="application/rss+xml" href={rssFeed.href} title={rssFeed.title} />}

  <!-- Open Graph -->
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content={ogType} />
  <meta property="og:url" content={canonical} />
  <meta property="og:site_name" content="RRM Academy" />
  <meta property="og:locale" content="en_US" />
  <meta property="og:image" content={resolvedOgImage} />
  <meta property="og:image:width" content={String(ogImageWidth)} />
  <meta property="og:image:height" content={String(ogImageHeight)} />
  <meta property="og:image:alt" content={title} />
  {ogType === 'article' && publishDate && <meta property="article:published_time" content={publishDate} />}
  {resolvedLastModified && <meta property="article:modified_time" content={resolvedLastModified} />}
  {resolvedLastModified && <meta name="last-modified" content={resolvedLastModified} />}

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={resolvedTwitterImage} />
  <meta name="twitter:site" content="@rrmacademy" />
  <meta name="twitter:creator" content="@rrmacademy" />

  <!-- Highwire Press / Zotero citation meta -->
  {citationMeta && (
    <>
      <meta name="citation_title" content={citationMeta.title} />
      {citationMeta.authors.map(author => (
        <meta name="citation_author" content={author} />
      ))}
      {citationMeta.date && <meta name="citation_publication_date" content={citationMeta.date} />}
      {citationMeta.journal && <meta name="citation_journal_title" content={citationMeta.journal} />}
      {citationMeta.journalAbbrev && <meta name="citation_journal_abbrev" content={citationMeta.journalAbbrev} />}
      {citationMeta.volume && <meta name="citation_volume" content={citationMeta.volume} />}
      {citationMeta.issue && <meta name="citation_issue" content={citationMeta.issue} />}
      {citationMeta.firstPage && <meta name="citation_firstpage" content={citationMeta.firstPage} />}
      {citationMeta.lastPage && <meta name="citation_lastpage" content={citationMeta.lastPage} />}
      {citationMeta.doi && <meta name="citation_doi" content={citationMeta.doi} />}
      {citationMeta.pmid && <meta name="citation_pmid" content={citationMeta.pmid} />}
      {citationMeta.abstract && <meta name="citation_abstract" content={citationMeta.abstract} />}
      {citationMeta.keywords && <meta name="citation_keywords" content={citationMeta.keywords} />}
    </>
  )}

  <!-- Preconnect to third-party origins used on every page -->
  <link rel="preconnect" href="https://static.cloudflareinsights.com" crossorigin />

  <!-- Preload all five font weights used across most pages -->
  <link rel="preload" href={cormorant400} as="font" type="font/woff2" crossorigin />
  <link rel="preload" href={cormorant600} as="font" type="font/woff2" crossorigin />
  <link rel="preload" href={inter400} as="font" type="font/woff2" crossorigin />
  <link rel="preload" href={inter500} as="font" type="font/woff2" crossorigin />
  <link rel="preload" href={inter600} as="font" type="font/woff2" crossorigin />

  <!-- Favicon -->
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

  {jsonLd ? (
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  ) : (
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "Organization",
          "@id": "https://rrmacademy.org/#organization",
          "name": "RRM Academy",
          "url": "https://rrmacademy.org",
          "description": "RRM Academy is a trusted nonprofit educational platform and reference source for restorative reproductive medicine (RRM), NaProTechnology, fertility awareness-based methods, endometriosis excision surgery, and reproductive endocrinology. The RRM Research Library is the largest freely accessible collection of peer-reviewed academic references on these topics available online.",
          "founder": { "@id": "https://rrmacademy.org/#naomi-whittaker" },
          "knowsAbout": [
            "Restorative Reproductive Medicine",
            "NaProTechnology",
            "Fertility Awareness-Based Methods",
            "Endometriosis Excision Surgery",
            "Reproductive Endocrinology",
            "Natural Family Planning",
            "Hormonal Health",
            "PCOS",
            "Infertility Diagnosis and Treatment"
          ],
          "sameAs": [
            "https://www.instagram.com/rrmacademy/",
            "https://www.youtube.com/@rrmacademy",
            "https://www.linkedin.com/company/rrmacademy"
          ],
          "publishingPrinciples": "https://rrmacademy.org/policies/editorial/",
          "correctionsPolicy": "https://rrmacademy.org/policies/corrections/",
          "verificationFactCheckingPolicy": "https://rrmacademy.org/policies/fact-checking/"
        },
        {
          "@type": "WebSite",
          "@id": "https://rrmacademy.org/#website",
          "url": "https://rrmacademy.org",
          "name": "RRM Academy",
          "description": "Nonprofit education in restorative reproductive medicine, NaProTechnology, and evidence-based women's health.",
          "publisher": { "@id": "https://rrmacademy.org/#organization" },
          "potentialAction": {
            "@type": "SearchAction",
            "target": "https://rrmacademy.org/library/?q={search_term_string}",
            "query-input": "required name=search_term_string"
          }
        }
      ]
    })} />
  )}
</head>
<body class:list={[bodyClass]}>
  <Header />
  <main>
    <slot />
  </main>
  <Footer />

  <script is:inline>
    // WebMCP tool exposure for AI agents browsing the page.
    // Spec: https://webmachinelearning.github.io/webmcp/
    // Validator: https://isitagentready.com (checks navigator.modelContext on load)
    (function registerWebMCPTools() {
      if (typeof navigator === 'undefined') return;
      var mc = navigator.modelContext;
      if (!mc || typeof mc.registerTool !== 'function') return;

      var controller = typeof AbortController === 'function' ? new AbortController() : null;
      var signal = controller ? controller.signal : undefined;

      var tools = [
        {
          name: 'search_rrm_library',
          description: 'Search the RRM Academy research library (3,370+ peer-reviewed articles on restorative reproductive medicine, NaProTechnology, endometriosis excision, fertility awareness-based methods, PCOS, and reproductive endocrinology). Returns ranked results with titles, authors, year, and library URLs.',
          inputSchema: {
            type: 'object',
            properties: {
              query: { type: 'string', description: 'Natural-language search query.', minLength: 2, maxLength: 500 },
              limit: { type: 'integer', description: 'Max results to return (1-20).', minimum: 1, maximum: 20, default: 10 }
            },
            required: ['query']
          },
          execute: async function (args) {
            var limit = Math.max(1, Math.min(20, args.limit || 10));
            var url = '/api/search/semantic?q=' + encodeURIComponent(args.query) + '&limit=' + limit;
            var res = await fetch(url, { headers: { 'Accept': 'application/json' } });
            if (!res.ok) throw new Error('Search failed: HTTP ' + res.status);
            var data = await res.json();
            return { results: (data.results || []).slice(0, limit).map(function (r) {
              return { title: r.title, url: r.url, snippet: r.snippet, type: r.type, score: r.score };
            }) };
          }
        },
        {
          name: 'ask_rrm_academy',
          description: 'Ask a natural-language question about restorative reproductive medicine. Answered by RRM Academy\'s conversational AI grounded in the research library. Requires authentication; anonymous callers receive a sign-in URL.',
          inputSchema: {
            type: 'object',
            properties: {
              question: { type: 'string', description: 'Natural-language question.', minLength: 3, maxLength: 500 }
            },
            required: ['question']
          },
          execute: async function (args) {
            var res = await fetch('/api/ask', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ message: args.question })
            });
            var data = await res.json().catch(function () { return {}; });
            if (res.status === 401) {
              return { error: 'authentication_required', signin_url: 'https://rrmacademy.org/login' };
            }
            if (res.status === 429) {
              return { error: 'rate_limited', detail: 'Daily /ask quota exceeded.' };
            }
            if (!res.ok) throw new Error('Ask failed: HTTP ' + res.status);
            return data;
          }
        },
        {
          name: 'navigate_to_section',
          description: 'Navigate this browser tab to a major RRM Academy section (pillar guides, library, FAQs, commentary, courses, glossary, community).',
          inputSchema: {
            type: 'object',
            properties: {
              section: {
                type: 'string',
                enum: ['home', 'library', 'faqs', 'commentary', 'courses', 'glossary', 'community', 'naprotechnology', 'what-is-rrm', 'femm', 'neofertility', 'common-questions-about-rrm', 'donate', 'contact'],
                description: 'Named site section.'
              }
            },
            required: ['section']
          },
          execute: async function (args) {
            var map = {
              home: '/',
              library: '/library/',
              faqs: '/faqs/',
              commentary: '/commentary/',
              courses: '/courses/',
              glossary: '/glossary/',
              community: '/community/',
              naprotechnology: '/naprotechnology/',
              'what-is-rrm': '/what-is-rrm/',
              femm: '/femm/',
              neofertility: '/neofertility/',
              'common-questions-about-rrm': '/common-questions-about-rrm/',
              donate: '/donate/',
              contact: '/contact/'
            };
            var path = map[args.section];
            if (!path) throw new Error('Unknown section: ' + args.section);
            window.location.assign(path);
            return { navigated_to: path };
          }
        }
      ];

      for (var i = 0; i < tools.length; i++) {
        try {
          mc.registerTool(tools[i], signal ? { signal: signal } : undefined);
        } catch (err) {
          // Swallow: some shims reject duplicate registration on hot reload
        }
      }
    })();
  </script>
</body>
</html>
