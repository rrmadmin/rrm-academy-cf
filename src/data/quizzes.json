{
  "mc-intro-3": {
    "type": "quiz",
    "title": "Pre-Class Quiz on Endometriosis & Surgery",
    "description": "Test your baseline knowledge before starting the course. Your score will not affect your certificate.",
    "passingScore": null,
    "questions": [
      {
        "id": "pre-q1",
        "text": "What is the total number of stages of endometriosis?",
        "options": ["3", "4", "6", "7"],
        "correctIndex": 1
      },
      {
        "id": "pre-q2",
        "text": "What are the main subspecialties of OBGYN?",
        "options": [
          "Obstetrics, Gynecology, Reproductive Endocrinology and Infertility",
          "Reproductive Immunology, Obstetrics, Gynecology",
          "Reproductive Endocrinology and Infertility, Gynecology Oncology, Minimally Invasive Gyn Surgery",
          "Napro, Gynecology Oncology, Reproductive Endocrinology and Infertility"
        ],
        "correctIndex": 2
      },
      {
        "id": "pre-q3",
        "text": "Which tool(s) can be used in endometriosis surgery?",
        "options": [
          "Robot",
          "Non-robotic laparoscopy",
          "Laser",
          "Electrocautery",
          "All of the above",
          "A & D"
        ],
        "correctIndex": 4
      },
      {
        "id": "pre-q4",
        "text": "Which theory of endometriosis origin is the most commonly taught in medical school?",
        "options": [
          "Retrograde menstruation",
          "Embryologic",
          "Multifactorial",
          "None of the above"
        ],
        "correctIndex": 0
      },
      {
        "id": "pre-q5",
        "text": "Which method(s) can be used to prevent adhesions?",
        "options": [
          "Hemostasis",
          "Minimize thermal damage",
          "Seprafilm",
          "Gortex",
          "All of the above",
          "B & C"
        ],
        "correctIndex": 4
      },
      {
        "id": "pre-q6",
        "text": "What does endometriosis look like?",
        "options": [
          "Black",
          "Brown",
          "Clear blebs",
          "White",
          "Halo",
          "All of the above",
          "A & B"
        ],
        "correctIndex": 5
      },
      {
        "id": "pre-q7",
        "text": "Which technique(s) are an important part of a diagnostic laparoscopy?",
        "options": [
          "Quick technique",
          "Mapping the abdomen",
          "Minimal incisions"
        ],
        "correctIndex": 1
      },
      {
        "id": "pre-q8",
        "text": "Which organ(s) does endometriosis grow on?",
        "options": [
          "Bowel",
          "Appendix",
          "Diaphragm",
          "Bladder",
          "None of the above",
          "All of the above"
        ],
        "correctIndex": 5
      }
    ]
  },
  "mc-intro-4": {
    "type": "questionnaire",
    "title": "Pre-Class Questionnaire",
    "description": "Help us understand your background and expectations. There are no right or wrong answers.",
    "questions": [
      {
        "id": "preq-q1",
        "text": "What are your current expectations for the masterclass?",
        "type": "freetext"
      },
      {
        "id": "preq-q2",
        "text": "What do you hope to gain from the class?",
        "type": "freetext"
      },
      {
        "id": "preq-q3",
        "text": "What problem are you hoping to solve?",
        "type": "freetext"
      },
      {
        "id": "preq-q4",
        "text": "How would you describe yourself?",
        "type": "multiselect",
        "options": ["I am an Endo Warrior", "I care for women with endometriosis"]
      },
      {
        "id": "preq-q5",
        "text": "Speaking to a surgeon about endometriosis?",
        "type": "likert",
        "prefix": "How confident do you feel...",
        "scale": { "min": 0, "max": 5, "labels": ["Not confident", "1", "2", "3", "4", "Very confident"] }
      },
      {
        "id": "preq-q6",
        "text": "Knowing what questions to ask to screen a surgeon?",
        "type": "likert",
        "prefix": "How confident do you feel...",
        "scale": { "min": 0, "max": 5, "labels": ["Not confident", "1", "2", "3", "4", "Very confident"] }
      },
      {
        "id": "preq-q7",
        "text": "Making a decision whether surgery is right for you (or your patient)?",
        "type": "likert",
        "prefix": "How confident do you feel...",
        "scale": { "min": 0, "max": 5, "labels": ["Not confident", "1", "2", "3", "4", "Very confident"] }
      },
      {
        "id": "preq-q8",
        "text": "Describing what endometriosis is?",
        "type": "likert",
        "prefix": "How confident do you feel...",
        "scale": { "min": 0, "max": 5, "labels": ["Not confident", "1", "2", "3", "4", "Very confident"] }
      },
      {
        "id": "preq-q9",
        "text": "Describing the different appearances of endometriosis?",
        "type": "likert",
        "prefix": "How confident do you feel...",
        "scale": { "min": 0, "max": 5, "labels": ["Not confident", "1", "2", "3", "4", "Very confident"] }
      },
      {
        "id": "preq-q10",
        "text": "I understand the purpose of diagnostic surgery.",
        "type": "likert",
        "scale": { "min": 0, "max": 5, "labels": ["Not confident", "1", "2", "3", "4", "Very confident"] }
      },
      {
        "id": "preq-q11",
        "text": "I understand the theories of endometriosis origin.",
        "type": "likert",
        "scale": { "min": 0, "max": 5, "labels": ["Not confident", "1", "2", "3", "4", "Very confident"] }
      },
      {
        "id": "preq-q12",
        "text": "I understand the basics of adhesion prevention.",
        "type": "likert",
        "scale": { "min": 0, "max": 5, "labels": ["Not confident", "1", "2", "3", "4", "Very confident"] }
      },
      {
        "id": "preq-q13",
        "text": "Your comfort level having a Gortex membrane placed?",
        "type": "likert",
        "scale": { "min": 0, "max": 5, "labels": ["Not comfortable", "1", "2", "3", "4", "Very comfortable"] }
      },
      {
        "id": "preq-q14",
        "text": "How likely are you to choose a NaPro trained surgeon (if one is available)?",
        "type": "likert",
        "scale": { "min": 0, "max": 5, "labels": ["Not likely", "1", "2", "3", "4", "Very likely"] }
      },
      {
        "id": "preq-q15",
        "text": "What is your comfort level going to any Ob/Gyn without researching beforehand for endometriosis symptoms?",
        "type": "likert",
        "scale": { "min": 0, "max": 5, "labels": ["Not comfortable", "1", "2", "3", "4", "Very comfortable"] }
      },
      {
        "id": "preq-q16",
        "text": "Comfort level with your surgeon using electrocautery for fertility surgery",
        "type": "likert",
        "scale": { "min": 0, "max": 5, "labels": ["Not comfortable", "1", "2", "3", "4", "Very comfortable"] }
      },
      {
        "id": "preq-q17",
        "text": "Comfort level advising patients or friends about endometriosis surgery",
        "type": "likert",
        "scale": { "min": 0, "max": 5, "labels": ["Not comfortable", "1", "2", "3", "4", "Very comfortable"] }
      }
    ]
  },
