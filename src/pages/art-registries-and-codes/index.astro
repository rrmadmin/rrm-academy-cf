        { '@type': 'WebPageElement', name: 'DIR Jahrbuch (Germany)', url: `${PAGE_URL}#dir` },
        { '@type': 'WebPageElement', name: 'ESHRE EIM (Europe)', url: `${PAGE_URL}#eshre-eim` },
      ],
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://rrmacademy.org/' },
        { '@type': 'ListItem', position: 2, name: 'Guides', item: 'https://rrmacademy.org/guides/' },
        { '@type': 'ListItem', position: 3, name: 'ART Registries and Codes of Practice', item: PAGE_URL },
      ],
    },
