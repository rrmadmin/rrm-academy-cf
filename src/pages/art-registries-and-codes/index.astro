---
import BaseLayout from '../../layouts/BaseLayout.astro';
import MaybeShell from '../../components/MaybeShell.astro';
import SectionTocChips from '../../components/SectionTocChips.astro';
import { isShellEnabled } from '../../lib/shell-routes';
import BackToTop from '../../components/BackToTop.astro';
import LastUpdated from '../../components/LastUpdated.astro';
import pageDates from '../../data/page-dates.json';
import artRegistries from '../../data/art-registries.json';

const SHELL_ENABLED = isShellEnabled('guides');

const TOC_ITEMS = [
  { href: '#key-takeaways', label: 'Key Takeaways' },
  { href: '#what-are-art-registries-and-codes', label: 'What Are ART Registries and Codes of Practice?' },
  { href: '#national-codes-of-practice', label: 'National Codes of Practice' },
  { href: '#national-registries', label: 'National Registries' },
  { href: '#measure-and-miss', label: 'What Registries Measure Well and Miss' },
  { href: '#how-rrm-academy-uses-these', label: 'How RRM Academy Uses These' },
  { href: '#all-records', label: 'All Registry and Code Records' },
  { href: '#faq', label: 'Frequently Asked Questions' },
];

const PAGE_PATH = '/art-registries-and-codes/';
const LAST_MODIFIED = pageDates.dates[PAGE_PATH] || '2026-05-11';
const PAGE_URL = 'https://rrmacademy.org/art-registries-and-codes/';
const LIBRARY_BASE = 'https://rrmacademy.org/library/';

// Build ItemList entries from the SSOT. Codes first (in declaration order),
// then registries sorted by year DESC with ICMART (Global) last as a global aggregator.
const codeItems = artRegistries.codes_of_practice.map((entry, idx) => ({
  '@type': 'ListItem' as const,
  position: idx + 1,
  item: {
    '@type': 'CreativeWork',
    name: `${entry.title}${entry.edition ? ` (${entry.edition})` : ''}`,
    datePublished: String(entry.year),
    publisher: entry.issuer,
    url: `${LIBRARY_BASE}${entry.library_slug}/`,
    about: { '@type': 'Place', name: entry.jurisdiction },
  },
}));

const registryOrdered = [...artRegistries.national_registries].sort((a, b) => {
  // ICMART (Global) is forced last
  if (a.country === 'Global' && b.country !== 'Global') return 1;
  if (b.country === 'Global' && a.country !== 'Global') return -1;
  return (b.year || 0) - (a.year || 0);
});

const registryItems = registryOrdered.map((entry, idx) => ({
  '@type': 'ListItem' as const,
  position: codeItems.length + idx + 1,
  item: {
    '@type': 'CreativeWork',
    name: entry.title,
    datePublished: String(entry.year),
    publisher: entry.operator,
    url: `${LIBRARY_BASE}${entry.library_slug}/`,
    about: { '@type': 'Place', name: entry.country },
  },
}));

const itemListSchema = {
  '@type': 'ItemList',
  name: 'National ART Registries and Codes of Practice',
  description:
    'Curated set of national ART registries, codes of practice, and statutory frameworks indexed in the RRM Academy Research Library.',
  numberOfItems: codeItems.length + registryItems.length,
  itemListOrder: 'https://schema.org/ItemListUnordered',
  itemListElement: [...codeItems, ...registryItems],
};

// Single JSON-LD @graph block with 4 nodes.
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
