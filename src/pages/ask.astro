---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Ask RRM Academy"
  description="Ask a question about restorative reproductive medicine. Answers drawn from the RRM Academy research library."
  canonicalUrl="https://rrmacademy.org/ask/"
  noindex
>
  <section class="ask-page">
    <div class="container">
      <header class="ask-header">
        <p class="ask-eyebrow">Research Preview</p>
        <h1>Ask RRM Academy</h1>
        <p class="ask-sub">Answers drawn from our research library, FAQs, and pillar guides.</p>
      </header>

      <div class="ask-thread" id="ask-thread" aria-live="polite"></div>

      <form class="ask-form" id="ask-form" autocomplete="off">
        <label for="ask-input" class="sr-only">Your question</label>
        <textarea
          id="ask-input"
          name="message"
          rows="2"
          maxlength="500"
          placeholder="What does RRM say about PCOS and progesterone?"
          required
        ></textarea>
        <div class="ask-form__row">
          <span class="ask-count" id="ask-count">0 / 500</span>
          <button type="submit" class="btn btn--primary" id="ask-submit">Ask</button>
        </div>
      </form>

      <p class="ask-footnote">
        This is AI-generated and still learning. Always verify against the cited library sources.
        Library search remains the primary tool for researchers -- head to
        <a href="/library/">/library/</a> for the full database.
      </p>
    </div>
  </section>

  <script is:inline>
    (function () {
      var form = document.getElementById('ask-form');
      var input = document.getElementById('ask-input');
      var thread = document.getElementById('ask-thread');
      var submit = document.getElementById('ask-submit');
      var count = document.getElementById('ask-count');

      function updateCount() { count.textContent = input.value.length + ' / 500'; }
      input.addEventListener('input', updateCount);
      updateCount();

      // Rotating example placeholders (only while input is empty + unfocused)
      var examples = [
        'What does RRM say about PCOS and progesterone?',
        'How does NaProTechnology treat endometriosis?',
        'Can FABMs help identify ovulatory dysfunction?',
        'What are the success rates of RRM for unexplained infertility?',
        'How does excision surgery compare to ablation for endometriosis?',
        'What is the evidence behind excision surgery for endometriosis?',
        'How does RRM differ from IVF for recurrent miscarriage?',
        'What role does luteal phase support play in RRM?'
      ];
      var pIdx = 0;
      function rotatePlaceholder() {
        if (document.activeElement === input || input.value !== '') return;
        input.classList.add('placeholder-fading');
        setTimeout(function () {
          pIdx = (pIdx + 1) % examples.length;
          input.placeholder = examples[pIdx];
          input.classList.remove('placeholder-fading');
        }, 400);
      }
      setInterval(rotatePlaceholder, 4500);

      // Cmd+Enter (Mac) or Ctrl+Enter (Win/Linux) submits the form
      input.addEventListener('keydown', function (e) {
        if (e.key === 'Enter' && (e.metaKey || e.ctrlKey)) {
          e.preventDefault();
          if (typeof form.requestSubmit === 'function') form.requestSubmit();
          else form.dispatchEvent(new Event('submit', { cancelable: true }));
        }
      });

      function escapeHtml(s) {
        return String(s)
          .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
          .replace(/"/g, '&quot;').replace(/'/g, '&#39;');
      }

      function renderMarkdown(text) {
        var s = escapeHtml(text);
        // Bold: **text**
        s = s.replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>');
        // Italic: *text* (after bold so ** doesn't collide)
        s = s.replace(/(^|[^*])\*([^*\n]+)\*(?!\*)/g, '$1<em>$2</em>');
        // Convert URLs to clickable links (including those in parens)
        s = s.replace(/(https?:\/\/[^\s<)"]+)/g, function (url) {
          var clean = url.replace(/[.,;:!?]+$/, '');
          var tail = url.slice(clean.length);
          return '<a href="' + clean + '" rel="noopener" target="_blank">' + clean + '</a>' + tail;
        });
        // Numbered list items: lines starting with "N. "
        var lines = s.split('\n');
        var out = [];
        var inList = false;
        for (var i = 0; i < lines.length; i++) {
          var line = lines[i];
          if (/^\s*\d+\.\s+/.test(line)) {
            if (!inList) { out.push('<ol>'); inList = true; }
            out.push('<li>' + line.replace(/^\s*\d+\.\s+/, '') + '</li>');
          } else {
            if (inList) { out.push('</ol>'); inList = false; }
            out.push(line);
          }
        }
        if (inList) out.push('</ol>');
        s = out.join('\n');
        // Paragraph breaks on blank lines
        var paras = s.split(/\n\s*\n+/);
        return paras.map(function (p) {
          if (p.trim().indexOf('<ol>') === 0 || p.trim().indexOf('<ul>') === 0) return p;
          return '<p>' + p.replace(/\n/g, '<br>') + '</p>';
        }).join('');
      }

      function renderCitations(list) {
        if (!list || !list.length) return '';
        var items = list.map(function (c) {
          var url = c.url || '#';
          var title = c.title || url;
          return '<li><a href="' + escapeHtml(url) + '" rel="noopener">' + escapeHtml(title) + '</a></li>';
        }).join('');
        return '<ul class="ask-citations">' + items + '</ul>';
      }

      function appendMessage(role, text, citations) {
        var wrap = document.createElement('div');
        wrap.className = 'ask-msg ask-msg--' + role;
        var bodyHtml = role === 'assistant'
          ? renderMarkdown(text)
          : '<p>' + escapeHtml(text).replace(/\n/g, '<br>') + '</p>';
        var body = '<div class="ask-msg__body">' + bodyHtml + '</div>';
        if (role === 'assistant') body += renderCitations(citations);
        wrap.innerHTML = body;
        thread.appendChild(wrap);
        wrap.scrollIntoView({ behavior: 'smooth', block: 'end' });
      }

      function appendLoading() {
        var wrap = document.createElement('div');
        wrap.className = 'ask-msg ask-msg--assistant ask-msg--loading';
        wrap.innerHTML = '<div class="ask-msg__body"><span class="ask-dots"><span></span><span></span><span></span></span></div>';
        thread.appendChild(wrap);
        wrap.scrollIntoView({ behavior: 'smooth', block: 'end' });
        return wrap;
      }

      function appendError(msg) {
        var wrap = document.createElement('div');
        wrap.className = 'ask-msg ask-msg--error';
        wrap.innerHTML = '<div class="ask-msg__body">' + escapeHtml(msg) + '</div>';
        thread.appendChild(wrap);
      }

      form.addEventListener('submit', function (e) {
        e.preventDefault();
        var message = input.value.trim();
        if (message.length < 2) return;

        appendMessage('user', message, null);
        input.value = '';
        updateCount();
        submit.disabled = true; submit.textContent = 'Asking...';
        var loader = appendLoading();

        fetch('/api/ask', {
          method: 'POST',
          credentials: 'same-origin',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ message: message }),
        })
          .then(function (r) {
            return r.json().then(function (data) { return { status: r.status, data: data }; });
          })
          .then(function (res) {
            if (loader.parentNode) loader.parentNode.removeChild(loader);
            var d = res.data || {};
            // CF Pages /* headers rule can mangle non-200 status codes, so key
            // decisions off the JSON body's error field as well as res.status.
            if (d.answer) {
              appendMessage('assistant', d.answer, d.citations);
            } else if (d.error === 'unauthorized' || res.status === 401) {
              window.location.href = '/signup/?next=/ask';
            } else if (d.error === 'rate_limited' || res.status === 429) {
              appendError('You have reached today\u2019s question limit. Come back tomorrow.');
            } else if (d.error === 'forbidden' || res.status === 403) {
              appendError('This account cannot use /ask right now.');
            } else if (d.error === 'upstream_timeout' || res.status === 504) {
              appendError('The answer is taking longer than expected. Please try again.');
            } else if (d.error === 'upstream_error' || res.status === 502) {
              appendError('Research layer is unreachable. Please try again in a moment.');
            } else {
              appendError('Something went wrong. Please try again.');
            }
          })
          .catch(function () {
            if (loader.parentNode) loader.parentNode.removeChild(loader);
            appendError('Network error. Please try again.');
          })
          .then(function () {
            submit.disabled = false; submit.textContent = 'Ask';
            input.focus();
          });
      });
    })();
  </script>
</BaseLayout>

<style is:global>
  .ask-page { padding: var(--space-10) 0 var(--space-16); min-height: 60vh; }
  .ask-header { max-width: 720px; margin: 0 auto var(--space-8); text-align: center; }
  .ask-eyebrow {
    display: inline-block; text-transform: uppercase; letter-spacing: 0.08em;
    font-size: 0.75rem; font-weight: 600;
    color: color-mix(in srgb, var(--accent) 70%, var(--text-secondary));
    background: color-mix(in srgb, var(--accent) 6%, var(--bg-surface));
    border: 1px solid color-mix(in srgb, var(--accent) 20%, var(--border-color));
    padding: 2px 10px; border-radius: var(--radius-pill); margin-bottom: var(--space-3);
  }
  .ask-header h1 { font-size: 2rem; margin-bottom: var(--space-3); }
  .ask-sub { color: var(--text-secondary); font-size: 0.9375rem; line-height: 1.5; }

  .ask-thread { max-width: 720px; margin: 0 auto var(--space-6); display: flex; flex-direction: column; gap: var(--space-5); }
  .ask-msg { font-size: 0.9375rem; line-height: 1.55; }
  .ask-msg--user {
    align-self: flex-end; max-width: 80%;
    background: color-mix(in srgb, var(--accent) 14%, transparent);
    border: 1px solid color-mix(in srgb, var(--accent) 28%, transparent);
    color: var(--text-primary);
    padding: var(--space-3) var(--space-5);
    border-radius: var(--radius-lg) var(--radius-lg) var(--radius-sm) var(--radius-lg);
  }
  .ask-msg--assistant {
    align-self: stretch; max-width: 100%;
    background: transparent; border: none;
    padding: 0 0 0 var(--space-5);
    border-left: 2px solid var(--accent);
  }
  .ask-msg--error { background: rgba(192,57,43,0.05); border: 1px solid var(--color-error); color: var(--color-error); padding: var(--space-3) var(--space-5); border-radius: var(--radius-lg); }
  .ask-msg__body { word-wrap: break-word; overflow-wrap: anywhere; }
  .ask-msg__body p { margin: 0 0 var(--space-3); }
  .ask-msg__body p:last-child { margin-bottom: 0; }
  .ask-msg__body ol { margin: 0 0 var(--space-3); padding-left: var(--space-6); display: flex; flex-direction: column; gap: var(--space-2); }
  .ask-msg__body ol li { padding-left: var(--space-1); }
  .ask-msg__body a { color: var(--accent); text-decoration: underline; word-break: break-all; }
  .ask-msg__body a:hover { color: var(--accent-hover); }
  .ask-msg__body strong { font-weight: 600; }
  .ask-citations { list-style: none; padding: 0; margin: var(--space-3) 0 0; display: flex; flex-direction: column; gap: var(--space-1); font-size: 0.8125rem; }
  .ask-citations a { color: var(--accent); text-decoration: underline; }
  .ask-citations a:hover { color: var(--accent-hover); }

  .ask-dots { display: inline-flex; gap: 4px; }
  .ask-dots span {
    width: 6px; height: 6px; border-radius: 50%; background: var(--text-muted);
    animation: ask-bounce 1s infinite;
  }
  .ask-dots span:nth-child(2) { animation-delay: 0.15s; }
  .ask-dots span:nth-child(3) { animation-delay: 0.3s; }
  @keyframes ask-bounce {
    0%, 80%, 100% { transform: scale(0.6); opacity: 0.4; }
    40% { transform: scale(1); opacity: 1; }
  }

  .ask-form {
    max-width: 720px; margin: 0 auto var(--space-4);
    background: var(--bg-surface); border: 1.5px solid var(--border-color);
    border-radius: var(--radius-lg); padding: var(--space-4);
  }
  .ask-form textarea {
    width: 100%; border: none; background: transparent; resize: vertical;
    font-family: 'Inter', sans-serif; font-size: 1rem; color: var(--text-primary);
    line-height: 1.5;
  }
  .ask-form textarea:focus { outline: none; }
  .ask-form textarea::placeholder {
    color: var(--text-muted);
    opacity: 0.65;
    font-style: italic;
    transition: opacity 0.4s;
  }
  .ask-form textarea.placeholder-fading::placeholder {
    opacity: 0;
  }
  .ask-form__row { display: flex; justify-content: space-between; align-items: center; margin-top: var(--space-3); }
  .ask-count { font-size: 0.75rem; color: var(--text-muted); font-variant-numeric: tabular-nums; }

  .ask-footnote { max-width: 720px; margin: 0 auto; text-align: center; font-size: 0.8125rem; color: var(--text-muted); }
  .ask-footnote a { color: var(--accent); text-decoration: underline; }

  .sr-only { position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0,0,0,0); border: 0; }
</style>
