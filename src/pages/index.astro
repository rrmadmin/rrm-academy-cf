---
import BaseLayout from '../layouts/BaseLayout.astro';
import { fetchAllArticles } from '../lib/airtable';

const articles = await fetchAllArticles();
const articleCount = articles.length;

const wixBase = 'https://www.rrmacademy.org';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'EducationalOrganization',
  name: 'RRM Academy',
  alternateName: 'Restorative Reproductive Medicine Academy',
  url: 'https://rrmacademy.org',
  description: 'The leading educational platform for patients and professionals seeking to understand and apply Restorative Reproductive Medicine.',
  founder: {
    '@type': 'Person',
    name: 'Dr. Naomi Whittaker',
    jobTitle: 'Board-Certified OB/GYN',
    honorificPrefix: 'Dr.',
  },
  nonprofitStatus: '501(c)(3)',
  areaServed: 'Global',
};
---
<BaseLayout
  title="RRM Academy — Stop Managing Symptoms. Start Restoring Health."
  description="RRM Academy is the leading educational platform for Restorative Reproductive Medicine. Access 3,000+ research articles, expert courses, and resources for patients and professionals."
  canonicalUrl="https://rrmacademy.org/"
  jsonLd={jsonLd}
>
  <article class="hp">
    <!-- Hero -->
    <header class="hp-hero">
      <div class="container container--narrow">
        <h1>Stop Managing Symptoms.<br/><span class="hp-hero__light">Start Restoring Health.</span></h1>
        <p class="hp-hero__subtitle">
          Evidence-based reproductive medicine education for patients and professionals who want real answers.
        </p>
        <div class="hp-hero__links">
          <a href={`${wixBase}/courses`} class="btn btn--primary">Explore Courses</a>
          <a href="/library" class="btn btn--secondary">Find RRM Research</a>
        </div>
      </div>
      <div class="hp-hero__trust">
        <p class="hp-trust__tagline">Backed by {articleCount.toLocaleString()} peer-reviewed resources and covered by international news.</p>
        <div class="hp-trust__logos">
          <span class="hp-trust__logo hp-trust__logo--nejm">New England Journal of Medicine</span>
          <span class="hp-trust__logo hp-trust__logo--jama">JAMA</span>
          <span class="hp-trust__logo hp-trust__logo--lancet">The Lancet</span>
          <span class="hp-trust__logo hp-trust__logo--nyt" aria-label="The New York Times"><svg viewBox="0 0 184.5 25" fill="currentColor" aria-hidden="true"><path d="M14.6 2.6c0-2-2-2.7-3.6-2.6v.2q1.6.1 1.7 1.1t-1.2 1q-1.3-.1-3.2-.8A12 12 0 0 0 4.7.6C2.7.6 1 2.1 1 4c0 1.5 1.2 2 1.7 2.2V6q-.5-.2-.5-1 0-1.1 1.4-1.3 1.5 0 3.8.9l3.8.8v3.3l-1.6 1.3 1.6 1.4V16q-1.3.6-2.6.6-2.3 0-4-1.7l4.3-2V5.6L3.8 8.1A6 6 0 0 1 6.4 5v-.1C3.4 5.7.5 8.6.5 12c0 4.2 3.4 7.3 7.2 7.3 4.2 0 6.7-3.3 6.6-6.8a7 7 0 0 1-2.8 3.3v-4.4l1.6-1.3-1.6-1.4V5.5c1.5 0 3-1 3-3M5.9 14.2l-1.2.6q-1.2-1.5-1.2-4 0-1.2.3-2.4l2.1-1zm19.5-5.7-.8.6L22 6.8 19 9V.5l-3.9 2.7q.9 0 1 1.4v11.8l-1.3 1 .1.1.7-.4 2.3 2.1 3.1-2V17l-.9.5-1-1V9.2l.7-.5 1.7 1.4v6.2c0 4-.9 4.8-2.6 5.4v.1c2.9.1 5.5-.9 5.5-5.9V9.3l1-.8zm5.2 10.8 4.5-3.6-.1-.2-2.4 1.9-2.7-2.2v-1.3l4.7-3.3L32 6.8 27 9.7v6.8l-1 .8.1.1 1-.8zm-.7-5.7V8.4l2.3 3.5zM53.6 1.6q0-.4-.2-1Q53 2.1 51.7 2t-2-1l-3 3.5h.2l.9-.9q.7.8 2.6 1.1v8.6l-6-10.5c-.5-.7-1.3-2-2.7-2-1.6 0-2.9 1.5-2.7 3.8h.1c.2-.5.5-1.3 1.2-1.3s1 .5 1.3 1v3.4q-3 0-3 2.4c0 .6.5 1.9 1.8 2.1q-.3-.3-.3-.7 0-.9 1.1-.9h.4V15c-2.2 0-3.9 1.3-3.9 3.3s1.7 3 3.5 2.8q-1.7-.3-1.7-1.5 0-1.4 1.5-1.4c1.5 0 1.4.5 2 1.1l2.9-3.3-.2-.1-.7.8c-1.1-1-1.9-1.4-3.2-1.6V4.7l8.4 14.5h.4V4.7c1.6 0 3-1.3 3-3m2.9 17.5 4.5-3.7-.1-.1-2.4 1.8-2.7-2.1v-1.3l4.7-3.3L58 6.8l-5.2 2.8v6.8l-1 .8.1.2 1-.8zm-.7-5.7V8.3L58 12zM77 8l-.7.5-2-1.7-2.3 2 1 1v7.7l-2.4-1.6V9.6l.9-.6L69 6.8l-2.2 2 1 1v7.4l-.2.1-2.2-1.6V9.6c0-1.4-.7-1.9-1.6-2.4q-1.2-.7-1.2-1.7c0-.7.7-1 1-1.2-.9 0-3 .8-3.1 2.8q0 1.4 1 2 .9.5 1 1.8v6l-1 .8v.1l1-.7 2.7 2 2.5-1.7 2.7 1.8L76 16V9l1.2-.9zM95 2l-1 1-2.3-2-3.1 2.4V1.2h-.2v17l-1.9-.4V3.6c0-1-.7-2.5-2.6-2.5s-3 1.6-3 3h.1q.2-1.1 1.1-1.2 1.4-.3 1.2 1.7v4q-2.7.4-2.8 2.4c0 .7.4 2 1.8 2v-.1q-.7-.3-.6-.7.1-.9 1.4-.8h.2V18q-2.2 1-2.2 2.8c0 1.7 1.3 3 3.4 3q2 0 3.7-.5l2.8-.4q1.2 0 1.2.9t-.7 1.2q2.6-.4 2.7-2.7c0-2.3-1.5-2.6-3.2-2.6q-1.5 0-3.7.6l-3.1.5c-.7 0-1.6-.4-1.6-1.3q-.1-1.5 2.5-1.6 1.4 0 3 .4 1.8.6 3.2.7c1.5 0 2.8-.6 2.8-2.8V3.3l1-1zM91 9q-.4.5-1.1.5-.8-.1-1.1-.5v-5l.7-.7 1.5 1.3zm0 2.4q-.3-.4-1.1-.5-1 .1-1.1.5V9.1q.3.4 1 .5 1 0 1.2-.5zm0 5.1c0 .8-.4 1.8-1.5 1.8h-.7v-6.6q.3-.5 1.1-.6.7 0 1.1.6zm8.8 2.7 5-3V9l-3.2-2.3-5 2.9v6.7l-1 .8v.2l.9-.7zm-.4-3.5V8.3l2.5 1.9v7.3zm15-8.7-1 .5q-.8 0-1.2-.6l-1.9 2-1.9-2-3 2.1v.2l.9-.6 1.1 1.3v6.6l-1.3 1v.1l.8-.4 2.5 2 3.1-2-.1-.2-.8.5-1.3-1.1V9q.7 1 1.8 1c1.3 0 2.2-1.5 2.3-3m11.9 9.8-1 .5-5.1-7.7.2-.4q.7.7 2.2.8 2.4 0 2.6-3.2a2 2 0 0 1-1.7.8q-1-.1-1.7-.8l-3.5 5.2 4.7 7.2 3.4-2.3zm-6.3.1-.8.6-1-1.1V.4l-4 2.8q.9 0 1 1.4v11.8l-1.3 1 .1.1.7-.4 2.3 2.1 3.1-2zm22.9-14.3c0-2-2-2.7-3.5-2.6v.2q1.6.1 1.7 1.1t-1.3 1q-1.3-.1-3.2-.8a12 12 0 0 0-3.6-.9c-2 0-3.5 1.5-3.5 3.4 0 1.5 1.1 2 1.6 2.2V6q-.5-.2-.5-1c0-.6.4-1.3 1.5-1.3q1.3.1 3.8.8l3.7 1v3.2l-1.6 1.3 1.6 1.4v4.4q-1.2.7-2.6.7a5 5 0 0 1-4-1.7l4.3-2V5.6L132 8.1a6 6 0 0 1 2.6-3.1v-.1c-3 .8-5.9 3.7-5.9 7.2 0 4.2 3.4 7.3 7.2 7.3 4.2 0 6.7-3.3 6.7-6.8h-.1a7 7 0 0 1-2.8 3.3v-4.4l1.7-1.3-1.7-1.4V5.5c1.5 0 3.1-1 3.1-3M134 14.2l-1.2.7q-1.1-1.5-1.2-4.1 0-1.2.3-2.4l2.2-1zm12-12.3-2.2 1.9 1.8 2 2.2-1.8zm3.3 15.2-.8.5-1.1-1V9.2l.9-.8-.1-.1-.8.6-1.8-2.2-3 2.1.2.2.7-.5 1 1.2v6.6l-1.3 1v.2l.8-.5 2.3 2.1 3-2zm16.6-.1-.7.5-1.2-1.1v-7l1-.8-.2-.1-.8.6-2.5-2.2-2.8 2.2-2.4-2.2-2.8 2.1-1.8-2.1-3 2 .1.2.8-.5 1 1.3v6.6l-.8.8 2.4 2 2.3-2-1-1v-7l.6-.5 1.7 1.5v6.2l-.7.8 2.3 2 2.3-2-1-1v-7l.6-.5 1.8 1.5v6l-.7.8 2.4 2.2L166 17zm8.6-1.5-2.4 1.8-2.7-2v-1.4l4.7-3.3-2.4-3.7-5.2 2.9v6.9l3.6 2.6 4.5-3.6zm-5-1.9V8.4l2.2 3.5zm14-1-2-1.5a5 5 0 0 0 1.8-3.7v-.7h-.1q-.3 1-1.5 1c-1.2 0-1.3-.4-1.8-1l-4.6 2.6v3.7l1.8 1.4c-1.8 1.6-2.1 2.5-2.1 3.4s.5 1.7 1.4 2v-.1q-.2-.2-.3-.8c0-.3.3-.9 1.1-.9 1 0 1.6.7 2 1l4.3-2.6zm-1-3c-.7 1.2-2.2 2.4-3.1 3.1l-1.1-1V8.2q.7 1.7 2.5 1.8 1 0 1.7-.4m-2 8.1q-.7-1.9-2.8-2-.6-.1-2 .5c.5-.8 1.9-2.2 3.7-3.3l1.2 1z"/></svg></span>
          <span class="hp-trust__logo hp-trust__logo--nbc">NBC News</span>
          <span class="hp-trust__logo hp-trust__logo--guardian">The Guardian</span>
          <span class="hp-trust__logo hp-trust__logo--wp">The Washington Post</span>
          <span class="hp-trust__logo hp-trust__logo--fs">Fertility &amp; Sterility</span>
        </div>
      </div>
    </header>

    <div class="page-body">
    <!-- Intro -->
    <section class="hp-section">
      <div class="container container--narrow">
        <p>
          Have you ever been told your painful periods are "normal"? That birth control is your only
          option? Or that IVF is your only path to pregnancy? You are not alone. And you deserve better.
        </p>
        <p>
          RRM Academy is the leading educational platform for patients and professionals seeking to
          understand and apply Restorative Reproductive Medicine (RRM). Guided by the expertise of
          our founder, Dr. Naomi Whittaker, and a community of RRM-trained professionals, we provide
          the evidence-based tools to find the root cause of your health issues and restore your body
          to its natural, healthy function.
        </p>
      </div>
    </section>

    <!-- Analogy -->
    <section class="hp-section hp-section--alt">
      <div class="container container--narrow">
        <h2>Let's start with an analogy.</h2>
        <p>
          When the check engine light comes on in your car, you don't just put a piece of tape over
          it. You look under the hood to find out why the light is on. For over 50 years, women's
          healthcare has been putting tape over the check engine light.
        </p>
        <p>
          So, what's the alternative? It's an approach called Restorative Reproductive Medicine (RRM).
        </p>
        <p>
          RRM isn't a single treatment; it's a medical and surgical model of care that works
          cooperatively with your body. It's the "under the hood" approach. It investigates the
          fundamental "why" behind your symptoms. By identifying and treating the underlying
          cause&mdash;be it hormonal, anatomical, or inflammatory&mdash;we can restore your body's
          natural, healthy function. RRM is not about symptom suppression. It's about authentic healing.
        </p>
      </div>
    </section>

    <!-- How RRM Works -->
    <section class="hp-section">
      <div class="container container--narrow">
        <h2>How RRM Works in Practice</h2>
        <p>
          It's a progressive process, and it starts with listening. Our educational philosophy is
          built on a simple idea: you deserve to understand your body. Let's walk through the core
          principles that guide our curriculum for both patients and professionals.
        </p>
        <p>
          <strong>First, we identify the cause.</strong> Your body's signals&mdash;the painful
          periods, the irregular cycles&mdash;are the clues that have likely been ignored. We teach
          you how to chart your cycle, turning your experiences into valuable data. For a
          NaPro-trained OB/GYN, that chart is like an EKG for a cardiologist; it helps uncover
          the root cause of your health issues.
        </p>
        <p>
          <strong>Then, we treat the condition.</strong> Once we know the why, we can discover
          targeted medical and surgical treatments that address the underlying disease. If you have
          endometriosis, the goal isn't just to manage the pain; it's to skillfully resect the
          disease itself&mdash;like carefully removing weeds from a garden so the flowers can grow.
        </p>
        <p>
          <strong>Next, we work to restore normal function.</strong> The ultimate goal is to restore
          your body's natural hormonal balance and reproductive function. A healthy system is a
          fertile system. This approach can lead to improved fertility and healthier pregnancies
          because we've fixed the broken pipe instead of just using buckets to catch the leak.
        </p>
        <p>
          <strong>Finally, we cooperate with the body.</strong> RRM works in harmony with your
          natural cycle. You will learn to understand and appreciate your body's intricate design,
          becoming an active, empowered partner in your own healthcare journey. We're not fighting
          your body; we're working with it.
        </p>
      </div>
    </section>

    <!-- A Different Path -->
    <section class="hp-section hp-section--alt">
      <div class="container container--narrow">
        <h2>A Different Path: Fixing the Problem, Not Just Catching the Leak</h2>
        <p>
          Understanding your options is the first step toward empowerment. RRM offers a different
          philosophy and pathway compared to many conventional treatments. The distinction is not
          just in the tools we use, but in the fundamental goal of our approach.
        </p>

        <div class="hp-comparison">
          <div class="hp-comparison__col">
            <h3>The RRM Approach: Fixing the Broken Pipe</h3>
            <ul>
              <li><strong>Primary Goal:</strong> Identify and treat the root cause of the problem.</li>
              <li><strong>Focus:</strong> Restoring the body to its normal, healthy function.</li>
              <li><strong>Your Role:</strong> You are an active, educated partner in your healthcare journey.</li>
            </ul>
          </div>
          <div class="hp-comparison__col">
            <h3>The Conventional Approach: Using Buckets to Catch the Leak</h3>
            <ul>
              <li><strong>Primary Goal:</strong> Suppress symptoms or bypass the problem (e.g., IVF).</li>
              <li><strong>Focus:</strong> Managing the condition or achieving a specific outcome (e.g., pregnancy).</li>
              <li><strong>Your Role:</strong> You are often a passive recipient of a standardized protocol.</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- You Are in the Right Place -->
    <section class="hp-section">
      <div class="container container--narrow">
        <h2>You Are in the Right Place</h2>
        <p>
          Our educational resources are designed to meet you exactly where you are on your health journey.
        </p>

        <h3>For Patients and Individuals</h3>
        <p>You are in the right place if you are experiencing:</p>
        <ul>
          <li><strong>Infertility or Subfertility</strong> and want to understand why you are not conceiving.</li>
          <li><strong>Recurrent Miscarriage</strong> and are seeking answers and a proactive approach.</li>
          <li><strong>Painful or Irregular Cycles</strong> and have been told your suffering is "normal."</li>
          <li><strong>Conditions like PCOS &amp; Endometriosis</strong> and want a treatment plan that goes beyond symptom management.</li>
          <li><strong>A Desire to Avoid ART</strong> for personal, ethical, or medical reasons.</li>
        </ul>

        <h3>For Medical Professionals</h3>
        <p>You are in the right place if you are a:</p>
        <ul>
          <li><strong>Physician</strong> (OB/GYN, Family Med) wanting to offer patients effective, restorative alternatives to hormonal contraception and ART.</li>
          <li><strong>Midwife or Nurse Practitioner</strong> looking to deepen your expertise in fertility awareness and root-cause treatments.</li>
          <li><strong>Fertility Support Professional</strong> who wishes to understand how restorative diagnostics, medicine, and surgery can support your practice.</li>
        </ul>
      </div>
    </section>

    <!-- Guided by Expertise -->
    <section class="hp-section hp-section--alt">
      <div class="container container--narrow">
        <h2>Guided by Expertise, Driven by Compassion</h2>
        <blockquote>
          <p>
            "I'll never forget a patient I saw during my residency. She had a history of miscarriages
            and was pregnant again, terrified. I ordered a progesterone level, which came back low. My
            attending physician told me to do nothing. He said, 'If she's going to miscarry, she's
            going to miscarry.' That moment broke my heart. It was a feeling of professional repulsion.
            I knew there had to be a better way than just watching and waiting for the worst to happen."
          </p>
          <cite>Dr. Naomi Whittaker, Founder of RRM Academy</cite>
        </blockquote>
        <p>
          That experience is the driving force behind RRM Academy. Dr. Whittaker, a board-certified
          OB/GYN specializing in restorative surgery, founded this platform to fill a critical gap:
          patients were not being heard, and clinicians lacked training in the cooperative approaches
          that could truly heal.
        </p>
        <p>
          Today, RRM Academy is a global community of patients and professionals committed to a better
          standard of care. Our curriculum, guided by Dr. Whittaker and taught by a faculty of
          RRM-trained experts, is designed to empower you with knowledge and equip you with the tools
          for authentic, restorative healing.
        </p>
        <p>
          <a href={`${wixBase}/commentary/categories/rrm-physicians`}>Meet Our Founder, Dr. Naomi Whittaker MD &rarr;</a>
        </p>
      </div>
    </section>

    <!-- Your Questions, Answered -->
    <section class="hp-section">
      <div class="container container--narrow">
        <h2>Your Questions, Answered</h2>

        <ul>
          <li>
            <strong>Is RRM evidence-based?</strong> RRM is grounded in established medical science
            and supported by peer-reviewed research. For certain tubal issues, restorative surgery
            has higher success rates than IVF. We provide full access to our
            <a href="/library">Research Library</a> so you can review the evidence for yourself.
          </li>
          <li>
            <strong>Can RRM help me if I have PCOS?</strong> Absolutely. RRM professionals
            investigate whether you have insulin-resistant or adrenal PCOS, then use a measured
            approach&mdash;starting with lifestyle, then supplements, then medical support if
            needed&mdash;to restore your body's natural ovulatory function.
          </li>
          <li>
            <strong>Do I need to stop working with my current doctor?</strong> Not necessarily.
            Our first goal is to empower you with knowledge so you can have more informed
            conversations with your current provider. Others may choose to seek out an
            RRM-trained practitioner. The choice is always yours.
          </li>
        </ul>
      </div>
    </section>

    <!-- Latest Insights -->
    <section class="hp-section hp-section--alt">
      <div class="container container--narrow">
        <h2>Latest Insights</h2>
        <p>
          <a href="/library"><strong>Research Library</strong></a> &ndash; The largest collection
          of RRM-related research available with the newest studies in women's health and fertility.
        </p>
        <p>
          <a href={`${wixBase}/commentary/categories/rrm-physicians`}><strong>Physician Spotlights</strong></a> &ndash;
          First-person interviews with leading RRM professionals.
        </p>
        <p>
          <a href={`${wixBase}/commentary`}><strong>Expert Commentary</strong></a> &ndash;
          In-depth articles on policy, patient advocacy, and integrative care trends.
        </p>
      </div>
    </section>

    <!-- CTA -->
    <section class="hp-section">
      <div class="container container--narrow hp-cta">
        <h2>Begin Your Journey to Answers</h2>
        <p class="hp-cta__tagline">Your Health. Your Knowledge. Your Future.</p>
        <p>
          Whether you are a patient seeking answers or a professional seeking excellence, RRM Academy
          is here to support you. Join thousands of individuals who have stopped settling for temporary
          fixes and have discovered a path to true, lasting wellness.
        </p>
        <div class="hp-cta__links">
          <a href={`${wixBase}/courses`} class="btn btn--primary">Explore Courses</a>
          <a href="/library" class="btn btn--secondary">Access the Research Library</a>
        </div>
      </div>
    </section>
    </div>
  </article>
</BaseLayout>

<style>
  /* ═══════════════════════════════════════════
     HOMEPAGE — text-focused editorial layout
     ═══════════════════════════════════════════ */

  .hp {
    font-size: 1rem;
    line-height: 1.75;
    color: var(--text-primary);
  }

  .hp h2 {
    font-size: clamp(1.75rem, 1.25rem + 1.5vw, 2.75rem);
    letter-spacing: -0.02em;
    margin-bottom: var(--space-6);
  }

  .hp h3 {
    font-size: 1.5rem;
    margin-top: var(--space-8);
    margin-bottom: var(--space-3);
  }

  .hp p {
    margin-bottom: 1.25em;
  }

  .hp ul {
    padding-left: var(--space-6);
    margin-bottom: 1.25em;
  }

  .hp li {
    margin-bottom: var(--space-3);
    line-height: 1.7;
  }

  .hp strong {
    color: var(--text-primary);
    font-weight: 600;
  }

  /* Sections — letter-line handled by global .page-body */
  .hp-section {
    padding: 0;
  }

  /* Hero */
  .hp-hero {
    min-height: calc(100vh - 56px);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    position: relative;
    background: radial-gradient(circle at 15% 84%, rgba(114,94,126,0) 0%, rgba(152,125,168,0) 39.84375%, rgba(201,184,211,0.43) 66.40%, #DAD3E7 90.19%);
    padding: var(--space-12) 0;
    padding-bottom: 180px;
  }

  [data-theme="dark"] .hp-hero {
    background: radial-gradient(circle at 15% 84%, rgba(114,94,126,0) 0%, rgba(100,82,110,0) 39.84375%, rgba(61,51,69,0.43) 66.40%, #2e2636 90.19%);
  }

  .hp-hero h1 {
    font-size: clamp(2rem, 1.2rem + 3.5vw, 4.25rem);
    line-height: 1.08;
    letter-spacing: -0.03em;
    margin-bottom: var(--space-6);
    color: var(--text-primary);
  }

  .hp-hero__light {
    font-weight: 400;
    color: var(--text-secondary);
  }

  .hp-hero__subtitle {
    font-size: 1.125rem;
    line-height: 1.75;
    color: var(--text-secondary);
    margin-bottom: var(--space-5);
  }

  .hp-hero__links {
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  @media (max-width: 768px) {
    .hp-hero {
      min-height: calc(100vh - 56px);
      padding: var(--space-10) 0 var(--space-8);
      justify-content: flex-start;
      padding-top: 18vh;
    }
    .hp-hero h1 {
      margin-bottom: var(--space-4);
    }
    .hp-hero__subtitle {
      font-size: 0.9375rem;
