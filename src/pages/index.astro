---
import BaseLayout from '../layouts/BaseLayout.astro';
import { fetchAllArticles } from '../lib/airtable';
import coursesData from '../data/courses.json';

const articles = await fetchAllArticles();
const articleCount = articles.length;

const liveCourseCount = coursesData.filter((c: any) => !c.comingSoon).length;

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebSite',
      '@id': 'https://rrmacademy.org/#website',
      name: 'RRM Academy',
      url: 'https://rrmacademy.org/',
      publisher: { '@id': 'https://rrmacademy.org/#organization' },
      potentialAction: {
        '@type': 'SearchAction',
        target: {
          '@type': 'EntryPoint',
          urlTemplate: 'https://rrmacademy.org/library/?q={search_term_string}',
        },
        'query-input': 'required name=search_term_string',
      },
    },
    {
      '@type': 'EducationalOrganization',
      '@id': 'https://rrmacademy.org/#organization',
      name: 'RRM Academy',
      alternateName: 'Restorative Reproductive Medicine Academy',
      url: 'https://rrmacademy.org/',
      description: 'The leading educational platform for patients and professionals seeking to understand and apply Restorative Reproductive Medicine.',
      foundingDate: '2023',
      founder: {
        '@type': 'Person',
        '@id': 'https://rrmacademy.org/#naomi-whittaker',
        name: 'Dr. Naomi Whittaker',
        jobTitle: 'Board-Certified OB/GYN',
        honorificPrefix: 'Dr.',
        url: 'https://rrmacademy.org/commentary/rrm-spotlight-naomi-whittaker-md/',
        image: 'https://rrmacademy.org/images/authors/naomi-whittaker.webp',
        sameAs: [
          'https://www.instagram.com/napro_fertility_surgeon/',
          'https://www.linkedin.com/in/naomi-whittaker-md-906b13101/',
        ],
      },
      nonprofitStatus: '501(c)(3)',
      areaServed: 'Global',
      parentOrganization: {
        '@type': 'NonprofitOrganization',
        name: 'Restorative Reproductive Medicine Foundation',
        taxID: '93-4594315',
        nonprofitStatus: '501(c)(3)',
      },
      sameAs: [
        'https://www.linkedin.com/company/rrm-academy',
        'https://www.instagram.com/rrmacademy',
      ],
      contactPoint: {
        '@type': 'ContactPoint',
        contactType: 'customer support',
        url: 'https://rrmacademy.org/contact/',
      },
      hasOfferCatalog: {
        '@type': 'OfferCatalog',
        name: 'RRM Academy Courses',
        url: 'https://rrmacademy.org/courses/',
        numberOfItems: liveCourseCount,
      },
    },
    {
      '@type': 'FAQPage',
      '@id': 'https://rrmacademy.org/#faq',
      mainEntity: [
        {
          '@type': 'Question',
          name: 'Is Restorative Reproductive Medicine backed by real evidence?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'Yes. The RRM Academy Research Library contains thousands of peer-reviewed articles published in medical journals. These are published studies, not opinion pieces. You can read them yourself and follow the citations.',
          },
        },
        {
          '@type': 'Question',
          name: 'Will RRM Academy help me advocate for myself with my doctors?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'That is exactly what it is for. Students leave knowing how to screen a surgeon, what to expect from a real diagnostic workup, and how to tell the difference between a provider who is investigating their condition and one who is just suppressing their symptoms.',
          },
        },
        {
          '@type': 'Question',
          name: 'I am not a medical professional. Is RRM Academy for me?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'Many of our students are patients, not clinicians. The courses are built so that anyone dealing with a reproductive health challenge can understand what is happening in their body, what their options are, and what good care looks like.',
          },
        },
        {
          '@type': 'Question',
          name: 'How do I find a surgeon or provider I can trust?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'Start with the right questions. Do they perform excision, not ablation? Do they evaluate both partners? Do they chart cycles before diagnosing? RRM Academy gives you the knowledge to evaluate any provider, not just the ones on a list.',
          },
        },
      ],
    },
  ],
};
---
<BaseLayout
  title="RRM Academy | Evidence-Based Reproductive Medicine Education"
  description="RRM Academy offers evidence-based education in Restorative Reproductive Medicine. Courses, a research library, and expert guidance for patients and clinicians."
  canonicalUrl="https://rrmacademy.org/"
  jsonLd={jsonLd}
>
  <div class="hp">
    <!-- Hero -->
    <header class="hp-hero">
      <div class="container container--narrow">
        <p class="hp-hero__descriptor animate-enter" style="--stagger: 0;">Evidence-Based Reproductive Medicine Education</p>
        <h1 class="animate-enter" style="--stagger: 1;">The Education Your Doctor Didn't Get</h1>
        <p class="hp-hero__subtitle animate-enter" style="--stagger: 2;">
          Courses and a {articleCount.toLocaleString()}-article library built for the day you realized suppressive medicine wasn't a plan.
        </p>
        <div class="hp-hero__links animate-enter" style="--stagger: 3;">
          <a href="/courses/" class="btn btn--primary">Explore Courses</a>
          <a href="/library/" class="btn btn--secondary">Browse {articleCount.toLocaleString()} Studies</a>
        </div>
      </div>
      <div class="hp-hero__trust animate-enter" style="--stagger: 4;">
        <p class="hp-trust__tagline">{articleCount.toLocaleString()} peer-reviewed studies in our research library</p>
        <div class="hp-trust__logos">
          <span class="hp-trust__logo hp-trust__logo--nejm">New England Journal of Medicine</span>
          <span class="hp-trust__logo hp-trust__logo--jama">JAMA</span>
          <span class="hp-trust__logo hp-trust__logo--lancet">The Lancet</span>
