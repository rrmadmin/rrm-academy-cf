---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogCard from '../../components/BlogCard.astro';
import AppShellChrome from '../../components/AppShellChrome.astro';
import { fetchAllPosts } from '../../lib/blog';
import { isShellEnabled } from '../../lib/shell-routes';

const SHELL_ENABLED = isShellEnabled('commentary');

const posts = await fetchAllPosts();

const PER_PAGE = 6;
const displayPosts = posts.slice(0, PER_PAGE);

// Linked @graph: Blog -> WebSite -> Organization all referenced by @id.
// Blog node carries BreadcrumbList + identifies lead author via @id-ref.
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Blog',
      '@id': 'https://rrmacademy.org/commentary/#blog',
      name: 'RRM Academy Commentary',
      description: 'Expert clinical perspectives on restorative reproductive medicine from RRM Academy.',
      url: 'https://rrmacademy.org/commentary/',
      inLanguage: 'en',
      isPartOf: { '@id': 'https://rrmacademy.org/#website' },
      about: { '@id': 'https://rrmacademy.org/#organization' },
      publisher: { '@id': 'https://rrmacademy.org/#organization' },
      author: { '@id': 'https://rrmacademy.org/#naomi-whittaker' },
      breadcrumb: { '@id': 'https://rrmacademy.org/commentary/#breadcrumb' },
    },
    {
      '@type': 'WebSite',
      '@id': 'https://rrmacademy.org/#website',
      url: 'https://rrmacademy.org/',
      name: 'RRM Academy',
      publisher: { '@id': 'https://rrmacademy.org/#organization' },
      potentialAction: {
        '@type': 'SearchAction',
        target: {
          '@type': 'EntryPoint',
          urlTemplate: 'https://rrmacademy.org/library/?q={search_term_string}',
        },
        'query-input': 'required name=search_term_string',
      },
    },
    {
      '@type': 'Organization',
      '@id': 'https://rrmacademy.org/#organization',
      name: 'RRM Academy',
      url: 'https://rrmacademy.org/',
    },
    {
      '@type': 'BreadcrumbList',
      '@id': 'https://rrmacademy.org/commentary/#breadcrumb',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://rrmacademy.org/' },
        { '@type': 'ListItem', position: 2, name: 'Commentary', item: 'https://rrmacademy.org/commentary/' },
      ],
    },
  ],
};
---
<BaseLayout
  chrome={SHELL_ENABLED ? 'shell' : 'default'}
  title="RRM Articles | Research, Policy & Patient Advocacy"
  description="Expert commentary on restorative reproductive medicine from Dr. Naomi Whittaker. Research updates, patient advocacy, and clinical insights."
  canonicalUrl="https://rrmacademy.org/commentary"
  jsonLd={jsonLd}
>
  {SHELL_ENABLED ? (
    <AppShellChrome context="index" currentPath={Astro.url.pathname}>
      <!-- Hero -->
      <section class="commentary-hero" data-pagefind-ignore="all">
        <div class="container">
          <h1 class="animate-enter" style="--stagger: 0;">RRM Articles &amp; Commentary</h1>
          <p class="commentary-hero__subtitle animate-enter" style="--stagger: 1;">
            Expert clinical perspectives on restorative reproductive medicine
          </p>
        </div>
      </section>

      <!-- Recent Posts -->
      <section class="section commentary-posts animate-enter" style="--stagger: 2;" data-pagefind-ignore="all">
        <div class="container">
          <div class="section-header">
            <h2 class="section-label">Recent posts</h2>
            <span class="meta-count">{posts.length} articles</span>
          </div>
          <div class="blog-grid">
            {displayPosts.map((post, i) => (
              <BlogCard post={post} eager={i < 3} />
            ))}
          </div>

          {posts.length > PER_PAGE && (
            <div class="view-all">
              <a href="/commentary/page/2/" class="btn btn--secondary">View all posts &rarr;</a>
            </div>
          )}
        </div>

      </section>

      <section class="commentary-intro">
        <div class="container container--narrow">
          <p>
            The commentary section brings together clinical explainers, physician spotlights, patient stories, and research highlights from across the RRM community. Topics span endometriosis, PCOS, fertility, postpartum care, and the policy gaps that slow diagnosis and access to restorative treatment. <a href="/commentary/rrm-spotlight-naomi-whittaker-md/">Dr. Naomi Whittaker</a> contributes clinical pieces alongside other RRM physicians, practitioners, and patients willing to share their experience.
          </p>
          <p>
            Some posts translate findings directly from our <a href="/library/">Research Library</a> of more than 3,000 peer-reviewed articles. Others are personal, organizational, or advocacy-focused. All of them reflect the same core conviction: that accurate information, offered clearly, changes outcomes.
          </p>
        </div>
      </section>

      <!-- CTA -->
      <section class="commentary-cta" data-pagefind-ignore="all">
        <div class="container container--narrow">
          <h2>Take the next step</h2>
          <p>Learn more about your body, your options, and what real care looks like.</p>
          <div class="commentary-cta__links">
            <a href="/endo-survey/" class="btn btn--primary">Take the Endo Self-Survey</a>
            <a href="/courses/" class="btn btn--secondary">Explore Courses</a>
          </div>
        </div>
      </section>
    </AppShellChrome>
  ) : (
    <Fragment>
      <!-- Hero -->
      <section class="commentary-hero" data-pagefind-ignore="all">
        <div class="container">
          <h1 class="animate-enter" style="--stagger: 0;">RRM Articles &amp; Commentary</h1>
          <p class="commentary-hero__subtitle animate-enter" style="--stagger: 1;">
            Expert clinical perspectives on restorative reproductive medicine
          </p>
        </div>
      </section>

      <!-- Recent Posts -->
      <section class="section commentary-posts animate-enter" style="--stagger: 2;" data-pagefind-ignore="all">
        <div class="container">
          <div class="section-header">
            <h2 class="section-label">Recent posts</h2>
            <span class="meta-count">{posts.length} articles</span>
          </div>
          <div class="blog-grid">
            {displayPosts.map((post, i) => (
              <BlogCard post={post} eager={i < 3} />
            ))}
          </div>

          {posts.length > PER_PAGE && (
            <div class="view-all">
              <a href="/commentary/page/2/" class="btn btn--secondary">View all posts &rarr;</a>
            </div>
          )}
        </div>

      </section>

      <section class="commentary-intro">
        <div class="container container--narrow">
          <p>
            The commentary section brings together clinical explainers, physician spotlights, patient stories, and research highlights from across the RRM community. Topics span endometriosis, PCOS, fertility, postpartum care, and the policy gaps that slow diagnosis and access to restorative treatment. <a href="/commentary/rrm-spotlight-naomi-whittaker-md/">Dr. Naomi Whittaker</a> contributes clinical pieces alongside other RRM physicians, practitioners, and patients willing to share their experience.
          </p>
          <p>
            Some posts translate findings directly from our <a href="/library/">Research Library</a> of more than 3,000 peer-reviewed articles. Others are personal, organizational, or advocacy-focused. All of them reflect the same core conviction: that accurate information, offered clearly, changes outcomes.
          </p>
        </div>
      </section>

      <!-- CTA -->
      <section class="commentary-cta" data-pagefind-ignore="all">
        <div class="container container--narrow">
          <h2>Take the next step</h2>
          <p>Learn more about your body, your options, and what real care looks like.</p>
          <div class="commentary-cta__links">
            <a href="/endo-survey/" class="btn btn--primary">Take the Endo Self-Survey</a>
            <a href="/courses/" class="btn btn--secondary">Explore Courses</a>
          </div>
        </div>
      </section>
    </Fragment>
  )}
</BaseLayout>

<style>
  @keyframes enter {
    from { opacity: 0; transform: translateY(8px); filter: blur(4px); }
  }
  .animate-enter {
    animation: enter 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94) both;
    animation-delay: calc(100ms * var(--stagger, 0));
  }
  @media (prefers-reduced-motion: reduce) {
    .animate-enter { animation: none; }
  }

  .commentary-hero {
    padding: var(--space-8) 0 0;
  }
  .commentary-hero h1 {
    /* Size inherited from global <h1> clamp() — H1 harmony (Brian 2026-05-08). */
    margin-bottom: var(--space-3);
  }
  .commentary-hero__subtitle {
    font-size: 0.9375rem;
    color: var(--text-secondary);
    max-width: 520px;
  }

  .commentary-posts {
    padding-top: 0;
  }

  .commentary-intro {
    padding: var(--space-2) 0 var(--space-6);
  }
  .commentary-intro p {
    font-family: 'Inter', sans-serif;
    font-size: 0.9375rem;
    line-height: 1.8;
    color: var(--text-secondary);
    margin: 0 0 var(--space-4) 0;
  }
  .commentary-intro p:last-child {
    margin-bottom: 0;
  }
  .commentary-intro a {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .commentary-intro a:hover {
    color: var(--accent-hover);
  }

  /* Section labels — understated */
  .section-label {
    font-size: 0.6875rem;
    font-family: 'Inter', sans-serif;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-secondary);
    margin-bottom: var(--space-4);
  }
  @media (min-width: 769px) {
    .section-label {
      font-size: 0.75rem;
      margin-bottom: var(--space-5);
    }
  }

  .view-all {
    text-align: center;
    margin-top: var(--space-10);
  }

  /* CTA */
  .commentary-cta {
    text-align: center;
    padding: var(--space-10) 0;
    border-top: 1px solid var(--border-color);
  }
  .commentary-cta h2 {
    font-size: 1.5rem;
    margin-bottom: var(--space-3);
  }
  .commentary-cta p {
    font-size: 0.9375rem;
    color: var(--text-secondary);
    margin-bottom: var(--space-5);
  }
  .commentary-cta__links {
    display: flex;
    gap: var(--space-4);
    justify-content: center;
    flex-wrap: wrap;
  }

</style>
