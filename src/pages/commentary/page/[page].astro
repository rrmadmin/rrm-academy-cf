---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import BlogCard from '../../../components/BlogCard.astro';
import { fetchAllPosts } from '../../../lib/blog';

export async function getStaticPaths() {
  const PER_PAGE = 6;
  const posts = await fetchAllPosts();
  const totalPages = Math.max(1, Math.ceil(posts.length / PER_PAGE));

  return Array.from({ length: totalPages }, (_, i) => ({
    params: { page: String(i + 1) },
    props: { currentPage: i + 1, totalPages },
  }));
}

interface Props {
  currentPage: number;
  totalPages: number;
}

const PER_PAGE = 6;
const { currentPage, totalPages } = Astro.props;
const posts = await fetchAllPosts();
const start = (currentPage - 1) * PER_PAGE;
const pagePosts = posts.slice(start, start + PER_PAGE);

// Pagination range
const range: (number | '...')[] = [];
const delta = 2;
for (let i = 1; i <= totalPages; i++) {
  if (i === 1 || i === totalPages || (i >= currentPage - delta && i <= currentPage + delta)) {
    range.push(i);
  } else if (range[range.length - 1] !== '...') {
    range.push('...');
  }
}
---
<BaseLayout
  title={`Commentary - Page ${currentPage}`}
  description={`Page ${currentPage} of ${totalPages} - Browse all commentary from RRM Academy.`}
  canonicalUrl={`https://rrmacademy.org/commentary/page/${currentPage}`}
>
  <section class="browse-page" data-pagefind-ignore="all">
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/commentary/">Commentary</a>
        <span aria-hidden="true"> &rsaquo; </span>
        <span>Page {currentPage}</span>
      </nav>

      <div class="browse-header">
        <div>
          <h1>All commentary</h1>
          {pagePosts.length > 0 && (
            <p class="browse-meta">
              Showing {start + 1}&ndash;{Math.min(start + PER_PAGE, posts.length)} of {posts.length}
            </p>
          )}
        </div>
      </div>

      {pagePosts.length > 0 ? (
        <div class="blog-grid">
          {pagePosts.map(post => (
            <BlogCard post={post} />
          ))}
        </div>
      ) : (
        <p class="empty-state">No commentary posts yet.</p>
      )}

      <nav class="pagination" aria-label="Pagination">
        {currentPage > 1 && (
          <a href={currentPage === 2 ? '/commentary/page/1/' : `/commentary/page/${currentPage - 1}/`}>&laquo; Prev</a>
        )}
        {range.map(item => (
          item === '...' ? (
            <span class="ellipsis">&hellip;</span>
          ) : item === currentPage ? (
            <span class="current">{item}</span>
          ) : (
            <a href={`/commentary/page/${item}/`}>{item}</a>
          )
        ))}
        {currentPage < totalPages && (
          <a href={`/commentary/page/${currentPage + 1}/`}>Next &raquo;</a>
        )}
      </nav>
    </div>
  </section>
</BaseLayout>

<style>
  h1 {
    margin-bottom: var(--space-1);
  }
</style>
