---
import BaseLayout from '../../layouts/BaseLayout.astro';
import MaybeShell from '../../components/MaybeShell.astro';
import { isShellEnabled } from '../../lib/shell-routes';

const SHELL_ENABLED = isShellEnabled('community');
---
<BaseLayout
  title="Members | Save the Uterus Club"
  description="Members of the Save the Uterus Club community."
  noindex
  chrome={SHELL_ENABLED ? 'shell' : 'default'}
>
  <MaybeShell enabled={SHELL_ENABLED} context="page" currentPath={Astro.url.pathname}>
  <section class="members-page">
    <div class="container">

      <!-- Loading state -->
      <div id="members-loading" class="members-loading">
        <p>Loading...</p>
      </div>

      <!-- Gate: non-members -->
      <div id="members-gate" hidden>
        <div class="gate-hero">
          <h1 class="hero-title">Members</h1>
          <p class="gate-description">The member directory is only available to Save the Uterus Club members.</p>
          <div class="gate-actions">
            <a href="/save-the-uterus-club/" class="btn btn--primary btn--lg">Join the Save the Uterus Club</a>
          </div>
        </div>
      </div>

      <!-- Feed: member grid -->
      <div id="members-feed" hidden>
        <div class="feed-header">
          <a href="/community/" class="back-link">&larr; Back to Community</a>
          <h2 class="feed-title">Members</h2>
        </div>
        <div id="members-grid" class="members-grid"></div>
      </div>

    </div>
  </section>
  </MaybeShell>

  <script is:inline>
    (function () {
      var currentUserRole = null;

      var TIER_DISPLAY = {
        member: '\u{1F43B} Member',
        hero: '\u{1F496} Hero',
        superhero: '\u{1F9B8}\u200D\u2640\uFE0F Superhero',
      };

      var ROLE_DISPLAY = {
        mod: 'Moderator',
        admin: 'Admin',
        superadmin: 'Admin',
      };

      function timeAgo(dateStr) {
        if (!dateStr) return '';
        var now = new Date();
        var then = new Date(dateStr);
        var diff = Math.floor((now.getTime() - then.getTime()) / 1000);
        if (diff < 60) return 'now';
        var mins = Math.floor(diff / 60);
        if (mins < 60) return mins + 'm ago';
        var hours = Math.floor(mins / 60);
        if (hours < 24) return hours + 'h ago';
        var days = Math.floor(hours / 24);
        if (days < 7) return days + 'd ago';
        var months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
        if (then.getFullYear() === now.getFullYear()) {
          return months[then.getMonth()] + ' ' + then.getDate();
        }
        return months[then.getMonth()] + ' ' + then.getDate() + ', ' + then.getFullYear();
      }

      function escapeHtml(str) {
        if (!str) return '';
        return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
      }

      function isStaff(role) {
        return role === 'mod' || role === 'admin' || role === 'superadmin';
      }

      function renderMembers(members) {
        var grid = document.getElementById('members-grid');
        if (!members.length) {
          grid.innerHTML = '<p class="members-empty">No members found.</p>';
          return;
        }

        var html = '';
        for (var i = 0; i < members.length; i++) {
          var m = members[i];
          var initial = (m.name || 'M').charAt(0).toUpperCase();
          var avatarHtml;
          if (m.avatarUrl) {
            avatarHtml = '<img class="member-avatar" src="' + escapeHtml(m.avatarUrl) + '" alt="" />';
          } else {
            avatarHtml = '<div class="member-avatar member-avatar--initial">' + escapeHtml(initial) + '</div>';
          }

          var badgesHtml = '';
          if (isStaff(m.role)) {
            badgesHtml += '<span class="post-role-badge">' + escapeHtml(ROLE_DISPLAY[m.role] || m.role) + '</span>';
          } else if (m.tier && TIER_DISPLAY[m.tier]) {
            badgesHtml += '<span class="post-tier-badge post-tier-badge--' + escapeHtml(m.tier) + '">' + escapeHtml(TIER_DISPLAY[m.tier]) + '</span>';
          }

          var achieveHtml = '';
          if (m.achievements && m.achievements.length) {
            for (var j = 0; j < m.achievements.length; j++) {
              achieveHtml += '<span class="achievement-badge">' + escapeHtml(m.achievements[j]) + '</span>';
            }
          }

          var activityHtml = '';
          if (m.lastActive) {
            activityHtml = '<span class="member-activity">Active ' + timeAgo(m.lastActive) + '</span>';
          } else {
            activityHtml = '<span class="member-activity member-activity--none">No posts yet</span>';
          }

          var banHtml = '';
          if (currentUserRole && (currentUserRole === 'admin' || currentUserRole === 'superadmin') && !isStaff(m.role)) {
            banHtml = '<button class="btn btn--text btn--sm member-ban-btn" data-user-id="' + escapeHtml(m.id) + '" data-user-name="' + escapeHtml(m.name) + '">Ban</button>';
          }

          var ringClass = '';
          if (isStaff(m.role)) ringClass = ' member-card--staff';
          else if (m.tier === 'superhero') ringClass = ' member-card--superhero';
          else if (m.tier === 'hero') ringClass = ' member-card--hero';

          html += '<div class="member-card' + ringClass + '">';
          html += '<div class="member-card__avatar-wrap">';
          html += avatarHtml;
          html += '</div>';
          html += '<div class="member-card__body">';
          html += '<h3 class="member-name">' + escapeHtml(m.name) + '</h3>';
          if (badgesHtml) {
            html += '<div class="member-card__badge-row">' + badgesHtml + '</div>';
          }
          if (achieveHtml) {
            html += '<div class="member-achievements">' + achieveHtml + '</div>';
          }
          html += '<div class="member-card__meta">' + activityHtml + '</div>';
          if (banHtml) html += '<div class="member-card__admin">' + banHtml + '</div>';
          html += '</div>';
          html += '</div>';
        }
        grid.innerHTML = html;
      }

      async function init() {
        var loadingEl = document.getElementById('members-loading');
        var gateEl = document.getElementById('members-gate');
        var feedEl = document.getElementById('members-feed');

        try {
          var statusRes = await fetch('/api/community/status', { credentials: 'same-origin' });
          var statusData = await statusRes.json();

          if (!statusData.ok || statusData.access !== 'member') {
            loadingEl.hidden = true;
            gateEl.hidden = false;
            return;
          }

          currentUserRole = statusData.role || 'member';

          var membersRes = await fetch('/api/community/members', { credentials: 'same-origin' });
          var membersData = await membersRes.json();

          loadingEl.hidden = true;
          feedEl.hidden = false;

          if (membersData.ok) {
            renderMembers(membersData.members);
          } else {
            document.getElementById('members-grid').innerHTML =
              '<p class="members-empty">Unable to load members.</p>';
          }
        } catch (err) {
          console.error('Members page error:', err);
          loadingEl.hidden = true;
          gateEl.hidden = false;
        }
      }

      init();

      document.addEventListener('click', function (e) {
        var banBtn = e.target.closest('.member-ban-btn');
        if (!banBtn) return;
        var userId = banBtn.getAttribute('data-user-id');
        var userName = banBtn.getAttribute('data-user-name');
        if (!confirm('Ban ' + userName + '? This blocks their login immediately.')) return;
        var deleteContent = confirm('Also remove all posts and comments by ' + userName + '?');
        banBtn.disabled = true;
        banBtn.textContent = 'Banning...';
        fetch('/api/community/ban', {
          method: 'POST',
          credentials: 'same-origin',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ userId: userId, deleteContent: deleteContent }),
        })
          .then(function (r) { return r.json(); })
          .then(function (data) {
            if (data.ok) {
              banBtn.closest('.member-card').remove();
            } else {
              banBtn.disabled = false;
              banBtn.textContent = 'Ban';
              alert(data.error || 'Ban failed.');
            }
          })
          .catch(function () {
            banBtn.disabled = false;
            banBtn.textContent = 'Ban';
          });
      });
    })();
  </script>

  <style is:global>
    .members-page {
      max-width: 960px;
      margin: 0 auto;
      padding: 32px 16px 64px;
    }
    .members-loading {
      text-align: center;
      padding: 64px 0;
      color: var(--text-tertiary);
    }

    /* Gate */
    .gate-hero {
      text-align: center;
      padding: 64px 0;
    }
    .hero-title {
      font-size: 28px;
      font-weight: 700;
      margin: 0 0 12px;
    }
    .gate-description {
      color: var(--text-secondary);
      font-size: 16px;
      margin: 0 0 24px;
      max-width: 480px;
      margin-left: auto;
      margin-right: auto;
    }
    .gate-actions {
      margin-top: 16px;
    }

    /* Feed header */
    .feed-header {
      margin-bottom: 24px;
    }
    .back-link {
      display: inline-block;
      font-size: 14px;
      color: var(--text-secondary);
      text-decoration: none;
      margin-bottom: 8px;
    }
    .back-link:hover {
      color: var(--text-primary);
    }
    .feed-title {
      font-size: 24px;
      font-weight: 700;
      margin: 0;
    }

    /* Grid */
    .members-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
      gap: 20px;
    }
    .members-empty {
      text-align: center;
      color: var(--text-tertiary);
      padding: 48px 0;
      grid-column: 1 / -1;
    }

    /* Member card -- vertical, avatar-forward */
    .member-card {
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      gap: 12px;
      padding: 24px 16px 20px;
      background: var(--surface, #ffffff);
      border: 1px solid var(--border, #e8e2d8);
      border-radius: 16px;
      transition: transform 180ms ease, box-shadow 180ms ease, border-color 180ms ease;
      position: relative;
    }
    .member-card:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 24px rgba(31, 41, 55, 0.06);
      border-color: var(--accent, #c97b63);
    }

    /* Avatar with tier-themed ring */
    .member-card__avatar-wrap {
      position: relative;
      padding: 3px;
      border-radius: 50%;
      background: var(--border, #e8e2d8);
      flex-shrink: 0;
    }
    .member-card--hero .member-card__avatar-wrap {
      background: linear-gradient(135deg, #f5c773, #d4a574);
    }
    .member-card--superhero .member-card__avatar-wrap {
      background: linear-gradient(135deg, #c97b63, #9a5d4a);
    }
    .member-card--staff .member-card__avatar-wrap {
      background: linear-gradient(135deg, #a78bfa, #7c3aed);
    }
    .member-avatar {
      width: 88px;
      height: 88px;
      border-radius: 50%;
      object-fit: cover;
      display: block;
      background: var(--neutral-100, #f5f5f5);
      box-shadow: 0 0 0 3px var(--surface, #ffffff);
    }
    .member-avatar--initial {
      display: flex;
      align-items: center;
      justify-content: center;
      background: var(--neutral-200, #e5e5e5);
      color: var(--text-secondary, #666);
      font-size: 34px;
      font-weight: 600;
      font-family: var(--font-display, Georgia, serif);
      line-height: 1;
    }

    /* Body */
    .member-card__body {
      width: 100%;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 6px;
      min-width: 0;
    }
    .member-name {
      font-size: 16px;
      font-weight: 600;
      color: var(--text-primary);
      margin: 0;
      max-width: 100%;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
      line-height: 1.3;
    }
    .member-card__badge-row {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 6px;
      flex-wrap: wrap;
    }

    /* Badges (page-local; intentionally distinct from feed) */
    .post-role-badge {
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: #7c3aed;
      background: #f3eeff;
      padding: 3px 8px;
      border-radius: 6px;
      line-height: 1.2;
    }
    .post-tier-badge {
      font-size: 11px;
      font-weight: 600;
      padding: 3px 9px;
      border-radius: 999px;
      line-height: 1.3;
      display: inline-flex;
      align-items: center;
      gap: 3px;
    }
    .post-tier-badge--member {
      background: var(--neutral-100, #f5f5f5);
      color: var(--text-secondary, #555);
    }
    .post-tier-badge--hero {
      background: #fef3c7;
      color: #92400e;
    }
    .post-tier-badge--superhero {
      background: #fce7f3;
      color: #9d174d;
    }

    /* Achievement chips */
    .member-achievements {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 4px;
      margin-top: 2px;
      max-width: 100%;
    }
    .achievement-badge {
      font-size: 10px;
      font-weight: 500;
      color: var(--text-secondary, #555);
      background: rgba(201, 123, 99, 0.08);
      border: 1px solid rgba(201, 123, 99, 0.18);
      padding: 2px 7px;
      border-radius: 999px;
      line-height: 1.4;
    }

    /* Meta + admin actions */
    .member-card__meta {
      margin-top: 6px;
      width: 100%;
    }
    .member-activity {
      display: block;
      font-size: 11px;
      color: var(--text-tertiary, #888);
      letter-spacing: 0.02em;
    }
    .member-activity--none {
      font-style: italic;
      opacity: 0.7;
    }
    .member-card__admin {
      margin-top: 8px;
      padding-top: 8px;
      border-top: 1px dashed var(--border, #e8e2d8);
      width: 100%;
    }
    .member-ban-btn {
      color: var(--text-tertiary, #888);
      font-size: 11px;
      letter-spacing: 0.04em;
    }
    .member-ban-btn:hover {
      color: var(--color-error, #b91c1c);
    }

    /* Responsive */
    @media (max-width: 600px) {
      .members-grid {
        grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
        gap: 14px;
      }
      .members-page {
        padding: 24px 12px 48px;
      }
      .member-card {
        padding: 18px 12px 16px;
      }
      .member-avatar {
        width: 72px;
        height: 72px;
      }
    }
  </style>
</BaseLayout>
