---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout
  title="RRM Community | Connect with Patients & Providers"
  description="Join the RRM Academy community. Connect with patients and healthcare providers committed to restorative reproductive medicine."
  canonicalUrl="https://rrmacademy.org/community"
  noindex
>
  <section class="community-page">
    <div class="container">

      <!-- Loading state -->
      <div id="community-loading" class="community-loading">
        <p>Loading...</p>
      </div>

      <!-- Gate: non-members -->
      <div id="community-gate" hidden>
        <div class="gate-hero">
          <h1 class="hero-title">Save the Uterus Club</h1>
          <p class="gate-description">The Save the Uterus Club is a private community for patients, advocates, and medical professionals committed to restorative reproductive medicine. Members get access to exclusive announcements, events, resources, and direct discussions with the RRM Academy team.</p>
          <div class="gate-actions">
            <a href="/save-the-uterus-club/" class="btn btn--primary btn--lg">Join the Save the Uterus Club</a>
          </div>
          <div class="gate-instagram">
            <p>Not ready to join? <a href="https://www.instagram.com/direct/t/7768750249851959/" target="_blank" rel="noopener noreferrer">Join our free Uterus Allies group on Instagram</a></p>
          </div>
        </div>
      </div>

      <!-- Feed: members -->
      <div id="community-feed" hidden>

        <div class="feed-header">
          <h2 class="feed-title">Save the Uterus Club</h2>
          <p class="feed-welcome">Welcome, <span id="feed-user-name"></span></p>
        </div>

        <!-- Filter tabs -->
        <div class="feed-tabs" role="tablist">
          <button class="feed-tab active" role="tab" data-type="">All</button>
          <button class="feed-tab" role="tab" data-type="announcement">Announcements</button>
          <button class="feed-tab" role="tab" data-type="event">Events</button>
          <button class="feed-tab" role="tab" data-type="resource">Resources</button>
          <button class="feed-tab" role="tab" data-type="discussion">Discussions</button>
        </div>

        <!-- Compose trigger -->
        <div class="compose-trigger" id="compose-trigger">
          <span class="compose-trigger__avatar" id="compose-avatar"></span>
          <span class="compose-trigger__text">What's on your mind?</span>
        </div>

        <!-- Compose form (initially hidden) -->
        <div class="compose-card" id="compose-card" hidden>
          <form id="compose-form">
            <div class="form-group">
              <input class="form-input compose-title-input" type="text" id="compose-title" name="title" required maxlength="200" placeholder="Title" />
            </div>
            <div class="form-group">
              <textarea class="form-textarea" id="compose-body" name="body" rows="4" placeholder="Share details, a question, or a thought..."></textarea>
            </div>

            <div class="compose-image-bar">
              <label class="btn btn--secondary btn--sm compose-image-btn" for="compose-image-input">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/></svg>
                Add Image
              </label>
              <input type="file" id="compose-image-input" accept="image/jpeg,image/png,image/webp,image/gif" hidden />
              <div id="compose-image-preview" class="compose-image-preview" hidden></div>
            </div>

            <!-- Staff-only type selector -->
            <div id="compose-type-group" class="form-group" hidden>
              <label class="form-label" for="compose-type">Post type</label>
              <select class="form-input form-select" id="compose-type" name="type">
                <option value="discussion">Discussion</option>
                <option value="announcement">Announcement</option>
                <option value="event">Event</option>
                <option value="resource">Resource</option>
              </select>
            </div>

            <!-- Event fields (shown when type=event) -->
            <div id="compose-event-fields" hidden>
              <div class="form-group">
                <label class="form-label" for="compose-event-date">Event date</label>
                <input class="form-input" type="datetime-local" id="compose-event-date" name="eventDate" />
              </div>
              <div class="form-group">
                <label class="form-label" for="compose-event-link">Event link</label>
                <input class="form-input" type="url" id="compose-event-link" name="eventLink" placeholder="https://..." />
              </div>
            </div>

            <!-- Resource fields (shown when type=resource) -->
            <div id="compose-resource-fields" hidden>
              <div class="form-group">
                <label class="form-label" for="compose-resource-url">Resource URL</label>
                <input class="form-input" type="url" id="compose-resource-url" name="resourceUrl" placeholder="https://..." />
              </div>
            </div>

            <div id="compose-error" class="compose-feedback compose-feedback--error" hidden>
              <p id="compose-error-text"></p>
            </div>

            <div class="compose-actions">
              <button type="button" class="btn btn--secondary btn--sm" id="compose-cancel-btn">Cancel</button>
              <button type="submit" class="btn btn--primary btn--sm" id="compose-submit-btn">Post</button>
            </div>
          </form>
        </div>

        <!-- Post list -->
        <div id="post-list" class="post-list"></div>

        <!-- Load more -->
        <div id="load-more-wrap" class="load-more-wrap" hidden>
          <button id="load-more-btn" class="btn btn--secondary">Load more</button>
        </div>

        <!-- Empty state -->
        <div id="posts-empty" class="posts-empty" hidden>
          <p>No posts yet. Be the first to share something with the community.</p>
        </div>

      </div>

      <!-- Edit modal -->
      <div id="edit-modal" class="edit-modal" hidden>
        <div class="edit-modal__backdrop"></div>
        <div class="edit-modal__card">
          <h2 class="edit-modal__heading">Edit Post</h2>
          <form id="edit-modal-form">
            <div class="form-group">
              <label class="form-label" for="edit-modal-title">Title</label>
              <input class="form-input" type="text" id="edit-modal-title" name="title" required maxlength="200" />
            </div>
            <div class="form-group">
              <label class="form-label" for="edit-modal-body">Body</label>
              <textarea class="form-textarea" id="edit-modal-body" name="body" rows="6" maxlength="10000"></textarea>
            </div>
            <div class="compose-image-bar">
              <label class="btn btn--secondary btn--sm compose-image-btn" for="edit-modal-image-input">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/></svg>
                Add Image
              </label>
              <input type="file" id="edit-modal-image-input" accept="image/jpeg,image/png,image/webp,image/gif" hidden />
              <div id="edit-modal-image-preview" class="compose-image-preview" hidden></div>
            </div>
            <div id="edit-modal-event-fields" hidden>
              <div class="form-group">
                <label class="form-label" for="edit-modal-event-date">Event date</label>
                <input class="form-input" type="datetime-local" id="edit-modal-event-date" name="eventDate" />
              </div>
              <div class="form-group">
                <label class="form-label" for="edit-modal-event-link">Event link</label>
                <input class="form-input" type="url" id="edit-modal-event-link" name="eventLink" placeholder="https://..." />
              </div>
            </div>
            <div id="edit-modal-resource-fields" hidden>
              <div class="form-group">
                <label class="form-label" for="edit-modal-resource-url">Resource URL</label>
                <input class="form-input" type="url" id="edit-modal-resource-url" name="resourceUrl" placeholder="https://..." />
              </div>
            </div>
            <div id="edit-modal-error" class="compose-feedback compose-feedback--error" hidden>
              <p id="edit-modal-error-text"></p>
            </div>
            <div class="edit-modal__actions">
              <button type="button" class="btn btn--secondary btn--sm" id="edit-modal-cancel">Cancel</button>
              <button type="submit" class="btn btn--primary btn--sm" id="edit-modal-save">Save Changes</button>
            </div>
          </form>
        </div>
      </div>

    </div>
  </section>

  <script is:inline>
    (function () {
      var STAFF_ROLES = ['superadmin', 'admin', 'mod'];
      var ADMIN_ROLES = ['superadmin', 'admin'];
      var EMOJIS = ['\u2764\uFE0F', '\uD83D\uDC4F', '\uD83D\uDD25', '\uD83D\uDCA1', '\uD83D\uDE4F', '\uD83D\uDE22'];
      var PAGE_SIZE = 20;

      var loadingEl = document.getElementById('community-loading');
      var gateEl = document.getElementById('community-gate');
      var feedEl = document.getElementById('community-feed');
      var userNameEl = document.getElementById('feed-user-name');
      var postListEl = document.getElementById('post-list');
      var loadMoreWrap = document.getElementById('load-more-wrap');
      var loadMoreBtn = document.getElementById('load-more-btn');
      var postsEmpty = document.getElementById('posts-empty');
      var composeTrigger = document.getElementById('compose-trigger');
      var composeCard = document.getElementById('compose-card');
      var composeAvatar = document.getElementById('compose-avatar');
      var composeCancelBtn = document.getElementById('compose-cancel-btn');
      var composeForm = document.getElementById('compose-form');
      var composeTitle = document.getElementById('compose-title');
      var composeBody = document.getElementById('compose-body');
      var composeTypeGroup = document.getElementById('compose-type-group');
      var composeType = document.getElementById('compose-type');
      var composeEventFields = document.getElementById('compose-event-fields');
      var composeResourceFields = document.getElementById('compose-resource-fields');
      var composeError = document.getElementById('compose-error');
      var composeErrorText = document.getElementById('compose-error-text');
      var composeSubmitBtn = document.getElementById('compose-submit-btn');
      var composeImageInput = document.getElementById('compose-image-input');
      var composeImagePreview = document.getElementById('compose-image-preview');
      var tabs = document.querySelectorAll('.feed-tab');

      // Edit modal refs
      var editModalEl = document.getElementById('edit-modal');
      var editModalForm = document.getElementById('edit-modal-form');
      var editModalTitle = document.getElementById('edit-modal-title');
      var editModalBody = document.getElementById('edit-modal-body');
      var editModalEventFields = document.getElementById('edit-modal-event-fields');
      var editModalEventDate = document.getElementById('edit-modal-event-date');
      var editModalEventLink = document.getElementById('edit-modal-event-link');
      var editModalResourceFields = document.getElementById('edit-modal-resource-fields');
      var editModalResourceUrl = document.getElementById('edit-modal-resource-url');
      var editModalError = document.getElementById('edit-modal-error');
      var editModalErrorText = document.getElementById('edit-modal-error-text');
      var editModalSave = document.getElementById('edit-modal-save');
      var editModalCancel = document.getElementById('edit-modal-cancel');
      var editModalImageInput = document.getElementById('edit-modal-image-input');
      var editModalImagePreview = document.getElementById('edit-modal-image-preview');

      var currentUser = null;
      var activeType = '';
      var lastCreatedAt = null;
      var allPostsLoaded = false;
      var commentsCache = {};
      var editingPost = null;
      var editingCard = null;

      // --- Status check ---
      fetch('/api/community/status', { credentials: 'same-origin' })
        .then(function (r) { return r.json(); })
        .then(function (data) {
          loadingEl.hidden = true;
          if (!data.ok || !data.user) {
            gateEl.hidden = false;
            return;
          }
          if (data.access === 'member') {
            currentUser = data.user;
            userNameEl.textContent = currentUser.name || 'Member';
            setupFeed();
            feedEl.hidden = false;
          } else {
            gateEl.hidden = false;
          }
        })
        .catch(function () {
          loadingEl.hidden = true;
          gateEl.hidden = false;
        });

      // --- Feed setup ---
      function setupFeed() {
        var isStaff = STAFF_ROLES.indexOf(currentUser.role) !== -1;
        if (isStaff) {
          composeTypeGroup.hidden = false;
        }

        // Set compose avatar
        if (currentUser.avatarUrl) {
          var img = document.createElement('img');
          img.src = currentUser.avatarUrl;
          img.alt = currentUser.name || 'Member';
          img.className = 'compose-trigger__avatar-img';
          composeAvatar.textContent = '';
          composeAvatar.appendChild(img);
        } else {
          composeAvatar.textContent = (currentUser.name || 'M').charAt(0).toUpperCase();
        }

        // Compose trigger → expand form
        composeTrigger.addEventListener('click', function () {
          composeTrigger.hidden = true;
          composeCard.hidden = false;
          composeTitle.focus();
        });

        // Cancel → collapse form
        composeCancelBtn.addEventListener('click', function () {
          composeCard.hidden = true;
          composeTrigger.hidden = false;
          composeTitle.value = '';
          composeBody.value = '';
          composeError.hidden = true;
          composeImageInput.value = '';
          composeImagePreview.hidden = true;
          composeImagePreview.innerHTML = '';
        });

        // --- Image upload handler (shared by compose + edit) ---
        function wireImageUpload(fileInput, previewEl, bodyTextarea, errorEl, errorTextEl) {
          fileInput.addEventListener('change', function () {
            var file = fileInput.files[0];
            if (!file) return;
            if (file.size > 5 * 1024 * 1024) {
              errorTextEl.textContent = 'Image too large (max 5 MB).';
              errorEl.hidden = false;
              fileInput.value = '';
              return;
            }
            previewEl.hidden = false;
            previewEl.innerHTML = '<span class="compose-image-preview__uploading">Uploading...</span>';

            var fd = new FormData();
            fd.append('file', file);
            fetch('/api/community/upload', { method: 'POST', credentials: 'same-origin', body: fd })
              .then(function (r) { return r.json(); })
              .then(function (data) {
                if (data.error) {
                  previewEl.hidden = true;
                  errorTextEl.textContent = data.error;
                  errorEl.hidden = false;
                } else {
                  var imgTag = '![image](' + data.url + ')';
                  var body = bodyTextarea.value;
                  bodyTextarea.value = body + (body ? '\n' : '') + imgTag;
                  previewEl.innerHTML = '<img src="' + data.url + '" class="compose-image-preview__thumb" />'
                    + '<button type="button" class="compose-image-preview__remove" title="Remove">&times;</button>';
                  previewEl.querySelector('.compose-image-preview__remove').addEventListener('click', function () {
                    bodyTextarea.value = bodyTextarea.value.replace(imgTag, '').trim();
                    previewEl.hidden = true;
                    previewEl.innerHTML = '';
                    fileInput.value = '';
                  });
                }
              })
              .catch(function () {
                previewEl.hidden = true;
                errorTextEl.textContent = 'Image upload failed.';
                errorEl.hidden = false;
              });
          });
        }

        wireImageUpload(composeImageInput, composeImagePreview, composeBody, composeError, composeErrorText);
        wireImageUpload(editModalImageInput, editModalImagePreview, editModalBody, editModalError, editModalErrorText);

        loadPosts(false);
      }

      // --- Type selector change ---
      composeType.addEventListener('change', function () {
        var val = composeType.value;
        composeEventFields.hidden = val !== 'event';
        composeResourceFields.hidden = val !== 'resource';
      });

      // --- Tab clicks ---
      for (var i = 0; i < tabs.length; i++) {
        (function (tab) {
          tab.addEventListener('click', function () {
            for (var j = 0; j < tabs.length; j++) {
              tabs[j].classList.remove('active');
            }
            tab.classList.add('active');
            activeType = tab.getAttribute('data-type') || '';
            lastCreatedAt = null;
            allPostsLoaded = false;
            postListEl.innerHTML = '';
            postsEmpty.hidden = true;
            loadPosts(false);
          });
        })(tabs[i]);
      }

      // --- Load posts ---
      function loadPosts(append) {
        var url = '/api/community/posts?channel=stuc&limit=' + PAGE_SIZE;
        if (activeType) url += '&type=' + encodeURIComponent(activeType);
        if (append && lastCreatedAt) url += '&before=' + encodeURIComponent(lastCreatedAt);

        loadMoreBtn.disabled = true;
        loadMoreBtn.textContent = 'Loading...';

        fetch(url, { credentials: 'same-origin' })
          .then(function (r) { return r.json(); })
          .then(function (data) {
            loadMoreBtn.disabled = false;
            loadMoreBtn.textContent = 'Load more';
            if (!data.ok || !data.posts) return;

            var posts = data.posts;
            if (posts.length < PAGE_SIZE) {
              allPostsLoaded = true;
              loadMoreWrap.hidden = true;
            } else {
              loadMoreWrap.hidden = false;
            }

            if (posts.length === 0 && !append) {
              postsEmpty.hidden = false;
              return;
            }
            postsEmpty.hidden = true;

            for (var k = 0; k < posts.length; k++) {
              postListEl.appendChild(renderPostCard(posts[k]));
              lastCreatedAt = posts[k].createdAt;
            }
          })
          .catch(function () {
            loadMoreBtn.disabled = false;
            loadMoreBtn.textContent = 'Load more';
          });
      }

      // --- Load more ---
      loadMoreBtn.addEventListener('click', function () {
        if (!allPostsLoaded) loadPosts(true);
      });

      // --- Compose form submit ---
      composeForm.addEventListener('submit', function (e) {
        e.preventDefault();
        composeError.hidden = true;

        var title = composeTitle.value.trim();
        if (!title) {
          composeErrorText.textContent = 'Title is required.';
          composeError.hidden = false;
          return;
        }

        var isStaff = STAFF_ROLES.indexOf(currentUser.role) !== -1;
        var type = isStaff ? composeType.value : 'discussion';
        var payload = {
          type: type,
          title: title,
          body: composeBody.value
        };

        if (type === 'event') {
          var eventDate = document.getElementById('compose-event-date').value;
          var eventLink = document.getElementById('compose-event-link').value.trim();
          if (eventDate) payload.eventDate = eventDate;
          if (eventLink) payload.eventLink = eventLink;
        }
        if (type === 'resource') {
          var resourceUrl = document.getElementById('compose-resource-url').value.trim();
          if (resourceUrl) payload.resourceUrl = resourceUrl;
        }

        composeSubmitBtn.disabled = true;
        composeSubmitBtn.textContent = 'Posting...';

        fetch('/api/community/posts', {
          method: 'POST',
          credentials: 'same-origin',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload)
        })
          .then(function (r) { return r.json(); })
          .then(function (data) {
            composeSubmitBtn.disabled = false;
            composeSubmitBtn.textContent = 'Post';
            if (data.ok && data.post) {
              composeTitle.value = '';
              composeBody.value = '';
              composeImageInput.value = '';
              composeImagePreview.hidden = true;
              composeImagePreview.innerHTML = '';
              composeCard.hidden = true;
              composeTrigger.hidden = false;
              if (isStaff) {
                composeType.value = 'discussion';
                composeEventFields.hidden = true;
                composeResourceFields.hidden = true;
              }
              postListEl.insertBefore(renderPostCard(data.post), postListEl.firstChild);
              postsEmpty.hidden = true;
            } else {
              composeErrorText.textContent = data.error || 'Failed to create post.';
              composeError.hidden = false;
            }
          })
          .catch(function () {
            composeSubmitBtn.disabled = false;
            composeSubmitBtn.textContent = 'Post';
            composeErrorText.textContent = 'Network error. Please try again.';
            composeError.hidden = false;
          });
      });

      // --- Render post card ---
      function renderPostCard(post) {
        var card = document.createElement('article');
        card.className = 'post-card';
        card.setAttribute('data-post-id', post.id);

        var isAdmin = ADMIN_ROLES.indexOf(currentUser.role) !== -1;
        var isMod = STAFF_ROLES.indexOf(currentUser.role) !== -1;
        var authorIsStaff = STAFF_ROLES.indexOf(post.authorRole) !== -1;

        // Context line (pinned / type label) — above main layout, indented
        if (post.pinned || post.type !== 'discussion') {
          var context = document.createElement('div');
          context.className = 'post-context';
          if (post.pinned) {
            var pinLabel = document.createElement('span');
            pinLabel.className = 'post-context__label post-context__label--pinned';
            pinLabel.textContent = 'Pinned';
            context.appendChild(pinLabel);
          }
          if (post.type !== 'discussion') {
            var typeLabel = document.createElement('span');
            typeLabel.className = 'post-context__label post-context__label--' + post.type;
            typeLabel.textContent = capitalize(post.type);
            context.appendChild(typeLabel);
          }
          card.appendChild(context);
        }

        // Main layout: avatar + content
        var layout = document.createElement('div');
        layout.className = 'post-card__layout';

        var avatar;
        if (post.authorAvatar) {
          avatar = document.createElement('img');
          avatar.className = 'post-avatar post-avatar--img';
          avatar.src = post.authorAvatar;
          avatar.alt = post.authorName || 'Member';
          avatar.loading = 'lazy';
        } else {
          avatar = document.createElement('span');
          avatar.className = 'post-avatar';
          avatar.textContent = ((post.authorName || 'M').charAt(0)).toUpperCase();
        }
        if (authorIsStaff) avatar.classList.add('post-avatar--staff');
        layout.appendChild(avatar);

        var main = document.createElement('div');
        main.className = 'post-card__main';

        // Header: name + role + · + time + controls
        var header = document.createElement('div');
        header.className = 'post-card__header';

        var authorName = document.createElement('span');
        authorName.className = 'post-author-name';
        authorName.textContent = post.authorName || 'Member';
        header.appendChild(authorName);

        if (authorIsStaff) {
          var roleBadge = document.createElement('span');
          roleBadge.className = 'post-role-badge';
          roleBadge.textContent = capitalize(post.authorRole);
          header.appendChild(roleBadge);
        }

        var sep = document.createElement('span');
        sep.className = 'post-sep';
        sep.textContent = '\u00B7';
        header.appendChild(sep);

        var timeEl = document.createElement('span');
        timeEl.className = 'post-time';
        timeEl.textContent = timeAgo(post.createdAt);
        header.appendChild(timeEl);

        if (isAdmin || isMod) {
          var controls = document.createElement('div');
          controls.className = 'post-card__controls';
          if (isMod) {
            var pinBtn = document.createElement('button');
            pinBtn.className = 'ctrl-btn';
            pinBtn.textContent = post.pinned ? 'Unpin' : 'Pin';
            pinBtn.addEventListener('click', function (ev) {
              ev.stopPropagation();
              togglePin(post.id, !post.pinned, pinBtn, card);
            });
            controls.appendChild(pinBtn);
          }
          if (isAdmin) {
            var editBtn = document.createElement('button');
            editBtn.className = 'ctrl-btn';
            editBtn.textContent = 'Edit';
            editBtn.addEventListener('click', function (ev) {
              ev.stopPropagation();
              openEditModal(post, card);
            });
            controls.appendChild(editBtn);

            var delBtn = document.createElement('button');
            delBtn.className = 'ctrl-btn ctrl-btn--danger';
            delBtn.textContent = 'Delete';
            delBtn.addEventListener('click', function (ev) {
              ev.stopPropagation();
              deletePost(post.id, card);
            });
            controls.appendChild(delBtn);
          }
          header.appendChild(controls);
        }

        main.appendChild(header);

        // Title (span, not link — no navigation)
        var titleSpan = document.createElement('span');
        titleSpan.className = 'post-card__title';
        titleSpan.textContent = post.title;
        main.appendChild(titleSpan);

        // Body (full text, collapsible if long)
        if (post.body) {
          var bodyEl = document.createElement('div');
          bodyEl.className = 'post-card__body';
          bodyEl.innerHTML = linkify(post.body);
          var isLong = post.body.length > 280;
          if (isLong) bodyEl.classList.add('post-card__body--collapsed');
          main.appendChild(bodyEl);
          if (isLong) {
            var toggle = document.createElement('button');
            toggle.className = 'show-more-btn';
            toggle.textContent = 'Show more';
            toggle.addEventListener('click', function (ev) {
              ev.stopPropagation();
              var collapsed = bodyEl.classList.toggle('post-card__body--collapsed');
              toggle.textContent = collapsed ? 'Show more' : 'Show less';
            });
            main.appendChild(toggle);
          }
        }

        // Actions bar
        var actions = document.createElement('div');
        actions.className = 'post-card__actions';

        var reactionBar = document.createElement('div');
        reactionBar.className = 'reaction-bar';
        var reactions = post.reactions || {};
        var userReactions = post.myReactions || [];

        for (var e = 0; e < EMOJIS.length; e++) {
          (function (emoji) {
            var count = reactions[emoji] || 0;
            var isActive = userReactions.indexOf(emoji) !== -1;
            var rBtn = document.createElement('button');
            rBtn.className = 'reaction-btn' + (isActive ? ' reaction-btn--active' : '');
            rBtn.setAttribute('data-emoji', emoji);
            rBtn.innerHTML = '<span class="reaction-emoji">' + emoji + '</span>' + (count > 0 ? '<span class="reaction-count">' + count + '</span>' : '');
            if (count === 0 && !isActive) rBtn.classList.add('reaction-btn--empty');
            rBtn.addEventListener('click', function (ev) {
              ev.stopPropagation();
              toggleReaction(post.id, emoji, rBtn, reactions, userReactions);
            });
            reactionBar.appendChild(rBtn);
          })(EMOJIS[e]);
        }
        actions.appendChild(reactionBar);

        // Comment count (button, toggles expand)
        var commentCount = document.createElement('button');
        commentCount.className = 'post-comment-count';
        var cc = post.commentCount || 0;
        commentCount.textContent = cc === 1 ? '1 comment' : cc + ' comments';
        commentCount.addEventListener('click', function (ev) {
          ev.stopPropagation();
          toggleExpand(post, card);
        });
        actions.appendChild(commentCount);

        main.appendChild(actions);

        // Comments container (hidden by default)
        var commentsContainer = document.createElement('div');
        commentsContainer.className = 'post-comments';
        commentsContainer.hidden = true;
        main.appendChild(commentsContainer);

        layout.appendChild(main);
        card.appendChild(layout);

        // Card click → expand/collapse (not navigate)
        card.addEventListener('click', function (ev) {
          if (ev.target.tagName === 'A' || ev.target.tagName === 'BUTTON' || ev.target.tagName === 'TEXTAREA' || ev.target.tagName === 'INPUT' || ev.target.closest('a') || ev.target.closest('button') || ev.target.closest('textarea') || ev.target.closest('input') || ev.target.closest('.post-comments')) return;
          toggleExpand(post, card);
        });

        return card;
      }

      // --- Toggle reaction (post) ---
      function toggleReaction(postId, emoji, btn, reactions, userReactions) {
        btn.disabled = true;
        fetch('/api/community/reactions', {
          method: 'POST',
          credentials: 'same-origin',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ targetType: 'post', targetId: postId, emoji: emoji })
        })
          .then(function (r) { return r.json(); })
          .then(function (data) {
            btn.disabled = false;
            if (!data.ok) return;

            if (data.action === 'added') {
              userReactions.push(emoji);
              reactions[emoji] = (reactions[emoji] || 0) + 1;
              btn.classList.add('reaction-btn--active');
            } else {
              var idx = userReactions.indexOf(emoji);
              if (idx !== -1) userReactions.splice(idx, 1);
              reactions[emoji] = Math.max(0, (reactions[emoji] || 1) - 1);
              btn.classList.remove('reaction-btn--active');
            }

            var count = reactions[emoji] || 0;
            btn.innerHTML = '<span class="reaction-emoji">' + emoji + '</span>' + (count > 0 ? '<span class="reaction-count">' + count + '</span>' : '');
            if (count === 0 && userReactions.indexOf(emoji) === -1) {
              btn.classList.add('reaction-btn--empty');
            } else {
              btn.classList.remove('reaction-btn--empty');
            }
          })
          .catch(function () { btn.disabled = false; });
      }

      // --- Pin/unpin ---
      function togglePin(postId, pinned, btn, card) {
        btn.disabled = true;
        btn.textContent = pinned ? 'Pinning...' : 'Unpinning...';
        fetch('/api/community/posts', {
          method: 'PATCH',
          credentials: 'same-origin',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ postId: postId, pinned: pinned })
        })
          .then(function (r) { return r.json(); })
          .then(function (data) {
            btn.disabled = false;
            if (data.ok) {
              btn.textContent = pinned ? 'Unpin' : 'Pin';
              var existing = card.querySelector('.post-context__label--pinned');
              if (pinned && !existing) {
                var context = card.querySelector('.post-context');
                if (!context) {
                  context = document.createElement('div');
                  context.className = 'post-context';
                  card.insertBefore(context, card.firstChild);
                }
                var label = document.createElement('span');
                label.className = 'post-context__label post-context__label--pinned';
                label.textContent = 'Pinned';
                context.insertBefore(label, context.firstChild);
              } else if (!pinned && existing) {
                var parentCtx = existing.parentNode;
                parentCtx.removeChild(existing);
                if (parentCtx.children.length === 0) parentCtx.parentNode.removeChild(parentCtx);
              }
            } else {
              btn.textContent = pinned ? 'Pin' : 'Unpin';
            }
          })
          .catch(function () {
            btn.disabled = false;
            btn.textContent = pinned ? 'Pin' : 'Unpin';
          });
      }

      // --- Delete post ---
      function deletePost(postId, card) {
        if (!confirm('Delete this post? This cannot be undone.')) return;
        fetch('/api/community/posts', {
          method: 'DELETE',
          credentials: 'same-origin',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ postId: postId })
        })
          .then(function (r) { return r.json(); })
          .then(function (data) {
            if (data.ok) {
              card.parentNode.removeChild(card);
              if (postListEl.children.length === 0) postsEmpty.hidden = false;
            }
          });
      }

      // --- Helpers ---
      function capitalize(s) {
        if (!s) return '';
        return s.charAt(0).toUpperCase() + s.slice(1);
      }

      function pad2(n) { return n < 10 ? '0' + n : '' + n; }

      function escapeHtml(str) {
        var div = document.createElement('div');
        div.appendChild(document.createTextNode(str || ''));
        return div.innerHTML;
      }

      function linkify(text) {
        if (!text) return '';
        var s = text.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');

        // 1. Image markdown: ![alt](url) → <img>
        s = s.replace(/!\[([^\]]*)\]\((https?:\/\/[^\s)]+|\/api\/assets\/[^\s)]+)\)/g,
          '<img src="$2" alt="$1" class="post-inline-img" loading="lazy" />');

        // 2. Markdown links: [text](url)
        s = s.replace(/\[([^\]]+)\]\((https?:\/\/[^\s)]+)\)/g,
          '<a href="$2" target="_blank" rel="noopener">$1</a>');

        // 3. Bare https/http URLs (already linked ones are skipped because they're now <a> tags)
        s = s.replace(/(^|[\s(])(https?:\/\/[^\s<)]+)/gm,
          '$1<a href="$2" target="_blank" rel="noopener">$2</a>');

        // 4. Bare domain URLs (no protocol): word.tld/optional-path
        s = s.replace(/(^|[\s(])([a-zA-Z0-9][\w.-]*\.(?:com|org|net|edu|gov|io|co|us|uk|dev|app|me|info|health)(?:\/[^\s<)]*)?)/gm,
          function (match, prefix, url) {
            return prefix + '<a href="https://' + url + '" target="_blank" rel="noopener">' + url + '</a>';
          });

        return s;
      }

      function timeAgo(dateStr) {
        if (!dateStr) return '';
        var now = new Date();
        var then = new Date(dateStr);
        var diff = Math.floor((now.getTime() - then.getTime()) / 1000);
        if (diff < 60) return 'now';
        var mins = Math.floor(diff / 60);
        if (mins < 60) return mins + 'm';
        var hours = Math.floor(mins / 60);
        if (hours < 24) return hours + 'h';
        var days = Math.floor(hours / 24);
        if (days < 7) return days + 'd';
        var months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
        if (then.getFullYear() === now.getFullYear()) {
          return months[then.getMonth()] + ' ' + then.getDate();
        }
        return months[then.getMonth()] + ' ' + then.getDate() + ', ' + then.getFullYear();
      }

      // --- Expand/collapse ---
      function toggleExpand(post, card) {
        var expanded = card.classList.toggle('post-card--expanded');
        var bodyEl = card.querySelector('.post-card__body');
        var showMoreBtn = card.querySelector('.show-more-btn');
        var commentsContainer = card.querySelector('.post-comments');

        if (expanded) {
          // Expand: show full body, show comments
          if (bodyEl) bodyEl.classList.remove('post-card__body--collapsed');
          if (showMoreBtn) showMoreBtn.textContent = 'Show less';
          if (commentsContainer) {
            commentsContainer.hidden = false;
            if (!commentsCache[post.id]) {
              loadComments(post.id, commentsContainer);
            }
          }
        } else {
          // Collapse: re-collapse long body, hide comments
          if (bodyEl && post.body && post.body.length > 280) {
            bodyEl.classList.add('post-card__body--collapsed');
          }
          if (showMoreBtn && post.body && post.body.length > 280) {
            showMoreBtn.textContent = 'Show more';
          }
          if (commentsContainer) commentsContainer.hidden = true;
        }
      }

      // --- Load comments ---
      function loadComments(postId, container) {
        container.innerHTML = '<p class="comments-loading">Loading comments...</p>';
        fetch('/api/community/comments?postId=' + encodeURIComponent(postId), { credentials: 'same-origin' })
          .then(function (r) { return r.json(); })
          .then(function (data) {
            if (data.ok) {
              commentsCache[postId] = data.comments || [];
            } else {
              commentsCache[postId] = [];
            }
            renderCommentsSection(postId, container);
          })
          .catch(function () {
            commentsCache[postId] = [];
            renderCommentsSection(postId, container);
          });
      }

      // --- Render comments section ---
      function renderCommentsSection(postId, container) {
        var comments = commentsCache[postId] || [];
        var html = '';

        // Compose area
        html += '<div class="comment-compose-inline">';
        html += '<textarea class="form-input form-textarea form-textarea--sm comment-compose-textarea" rows="2" maxlength="2000" placeholder="Write a comment..." data-post-id="' + escapeHtml(postId) + '"></textarea>';
        html += '<div class="comment-compose-inline__actions">';
        html += '<button class="btn btn--primary btn--sm comment-submit-btn" data-post-id="' + escapeHtml(postId) + '">Post</button>';
        html += '</div>';
        html += '</div>';

        if (comments.length === 0) {
          html += '<p class="comments-empty">No comments yet. Be the first to share your thoughts.</p>';
        } else {
          html += '<div class="comments-list-inline">';
          for (var i = 0; i < comments.length; i++) {
            html += renderCommentHtml(comments[i], postId, false);
            if (comments[i].replies && comments[i].replies.length) {
              for (var j = 0; j < comments[i].replies.length; j++) {
                html += renderCommentHtml(comments[i].replies[j], postId, true);
              }
            }
          }
          html += '</div>';
        }

        container.innerHTML = html;
      }

      // --- Render single comment HTML ---
      function renderCommentHtml(c, postId, isReply) {
        var userRole = currentUser.role || 'member';
        var isStaff = STAFF_ROLES.indexOf(userRole) !== -1;
        var canDelete = c.isOwn || isStaff;
        var authorIsStaff = STAFF_ROLES.indexOf(c.authorRole) !== -1;
        var initial = ((c.authorName || 'M').charAt(0)).toUpperCase();

        var html = '<div class="comment' + (isReply ? ' comment--reply' : '') + '" data-comment-id="' + escapeHtml(c.id) + '">';
        html += '<div class="comment__layout">';

        // Avatar
        if (c.authorAvatar) {
          html += '<img class="comment-avatar comment-avatar--img' + (authorIsStaff ? ' comment-avatar--staff' : '') + '" src="' + escapeHtml(c.authorAvatar) + '" alt="' + escapeHtml(c.authorName || 'Member') + '" loading="lazy" />';
        } else {
          html += '<span class="comment-avatar' + (authorIsStaff ? ' comment-avatar--staff' : '') + '">' + escapeHtml(initial) + '</span>';
        }

        html += '<div class="comment__main">';

        // Header
        html += '<div class="comment__header">';
        html += '<span class="comment-author-name">' + escapeHtml(c.authorName || 'Member') + '</span>';
        if (authorIsStaff) {
          html += '<span class="post-role-badge">' + escapeHtml(capitalize(c.authorRole)) + '</span>';
        }
        html += '<span class="post-sep">&middot;</span>';
        html += '<span class="comment-time">' + timeAgo(c.createdAt) + '</span>';
        html += '</div>';

        // Body
        html += '<div class="comment__body">' + linkify(c.content || '') + '</div>';

        // Reactions
        html += '<div class="comment__reactions">';
        for (var e = 0; e < EMOJIS.length; e++) {
          var emoji = EMOJIS[e];
          var count = (c.reactions && c.reactions[emoji]) ? c.reactions[emoji] : 0;
          var mine = (c.myReactions && c.myReactions.indexOf(emoji) !== -1);
          html += '<button class="reaction-btn reaction-btn--sm' + (mine ? ' reaction-btn--active' : '') + (count === 0 && !mine ? ' reaction-btn--empty' : '') + '"';
          html += ' data-target-type="comment" data-target-id="' + escapeHtml(c.id) + '" data-emoji="' + emoji + '" data-post-id="' + escapeHtml(postId) + '">';
          html += '<span class="reaction-emoji">' + emoji + '</span>';
          if (count > 0) html += '<span class="reaction-count">' + count + '</span>';
          html += '</button>';
        }
        html += '</div>';

        // Actions
        html += '<div class="comment__actions">';
        if (!isReply && !c.parentId) {
          html += '<button class="ctrl-btn comment-reply-btn" data-parent-id="' + escapeHtml(c.id) + '" data-post-id="' + escapeHtml(postId) + '">Reply</button>';
        }
        if (canDelete) {
          html += '<button class="ctrl-btn ctrl-btn--danger comment-delete-btn" data-comment-id="' + escapeHtml(c.id) + '" data-post-id="' + escapeHtml(postId) + '">Delete</button>';
        }
        html += '</div>';

        // Reply form (hidden, top-level only)
        if (!isReply && !c.parentId) {
          html += '<div class="comment__reply-form" data-reply-for="' + escapeHtml(c.id) + '" hidden>';
          html += '<textarea class="form-input form-textarea form-textarea--sm" rows="2" maxlength="2000" placeholder="Write a reply..."></textarea>';
          html += '<div class="comment__reply-actions">';
          html += '<button class="btn btn--primary btn--sm reply-submit-btn" data-parent-id="' + escapeHtml(c.id) + '" data-post-id="' + escapeHtml(postId) + '">Reply</button>';
          html += '<button class="btn btn--secondary btn--sm reply-cancel-btn" data-parent-id="' + escapeHtml(c.id) + '">Cancel</button>';
          html += '</div>';
          html += '</div>';
        }

        html += '</div>'; // .comment__main
        html += '</div>'; // .comment__layout
        html += '</div>'; // .comment

        return html;
      }

      // --- Submit comment ---
      function submitComment(postId, textarea, parentId) {
        var content = textarea.value.trim();
        if (!content) return;

        var actionsEl = parentId
          ? textarea.closest('.comment__reply-form').querySelector('.comment__reply-actions')
          : textarea.closest('.comment-compose-inline').querySelector('.comment-compose-inline__actions');
        var submitBtn = actionsEl ? actionsEl.querySelector(parentId ? '.reply-submit-btn' : '.comment-submit-btn') : null;

        if (submitBtn) {
          submitBtn.disabled = true;
          submitBtn.textContent = 'Posting...';
        }

        var payload = { postId: postId, content: content };
        if (parentId) payload.parentId = parentId;

        fetch('/api/community/comments', {
          method: 'POST',
          credentials: 'same-origin',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload)
        })
          .then(function (r) { return r.json(); })
          .then(function (data) {
            if (submitBtn) {
              submitBtn.disabled = false;
              submitBtn.textContent = parentId ? 'Reply' : 'Post';
            }
            if (data.ok && data.comment) {
              textarea.value = '';
              if (!commentsCache[postId]) commentsCache[postId] = [];
              if (parentId) {
                var cached = commentsCache[postId];
                for (var i = 0; i < cached.length; i++) {
                  if (cached[i].id === parentId) {
                    if (!cached[i].replies) cached[i].replies = [];
                    cached[i].replies.push(data.comment);
                    break;
                  }
                }
              } else {
                commentsCache[postId].push(data.comment);
              }
              var card = document.querySelector('[data-post-id="' + postId + '"]');
              var container = card ? card.querySelector('.post-comments') : null;
              if (container) renderCommentsSection(postId, container);
              if (card) updateCommentCount(postId, card);
            }
          })
          .catch(function () {
            if (submitBtn) {
              submitBtn.disabled = false;
              submitBtn.textContent = parentId ? 'Reply' : 'Post';
            }
          });
      }

      // --- Delete comment ---
      function deleteComment(commentId, postId, btn) {
        btn.disabled = true;
        btn.textContent = 'Deleting...';
        fetch('/api/community/comments', {
          method: 'DELETE',
          credentials: 'same-origin',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ commentId: commentId })
        })
          .then(function (r) { return r.json(); })
          .then(function (data) {
            if (data.ok) {
              if (commentsCache[postId]) removeFromComments(commentsCache[postId], commentId);
              var card = document.querySelector('[data-post-id="' + postId + '"]');
              var container = card ? card.querySelector('.post-comments') : null;
              if (container) renderCommentsSection(postId, container);
              if (card) updateCommentCount(postId, card);
            } else {
              btn.disabled = false;
              btn.textContent = 'Delete';
            }
          })
          .catch(function () {
            btn.disabled = false;
            btn.textContent = 'Delete';
          });
      }

      function removeFromComments(comments, id) {
        for (var i = 0; i < comments.length; i++) {
          if (comments[i].id === id) { comments.splice(i, 1); return; }
          if (comments[i].replies) {
            for (var j = 0; j < comments[i].replies.length; j++) {
              if (comments[i].replies[j].id === id) { comments[i].replies.splice(j, 1); return; }
            }
          }
        }
      }

      // --- Comment reaction toggle ---
      function toggleCommentReaction(commentId, emoji, postId, btn) {
        btn.disabled = true;
        fetch('/api/community/reactions', {
          method: 'POST',
          credentials: 'same-origin',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ targetType: 'comment', targetId: commentId, emoji: emoji })
        })
          .then(function (r) { return r.json(); })
          .then(function (data) {
            btn.disabled = false;
            if (!data.ok) return;
            var comment = findInComments(commentsCache[postId] || [], commentId);
            if (comment) {
              if (!comment.reactions) comment.reactions = {};
              if (!comment.myReactions) comment.myReactions = [];
              if (data.action === 'added') {
                comment.reactions[emoji] = (comment.reactions[emoji] || 0) + 1;
                if (comment.myReactions.indexOf(emoji) === -1) comment.myReactions.push(emoji);
              } else {
                comment.reactions[emoji] = Math.max(0, (comment.reactions[emoji] || 0) - 1);
                var idx = comment.myReactions.indexOf(emoji);
                if (idx !== -1) comment.myReactions.splice(idx, 1);
              }
            }
            var card = document.querySelector('[data-post-id="' + postId + '"]');
            var container = card ? card.querySelector('.post-comments') : null;
            if (container) renderCommentsSection(postId, container);
          })
          .catch(function () { btn.disabled = false; });
      }

      function findInComments(comments, id) {
        for (var i = 0; i < comments.length; i++) {
          if (comments[i].id === id) return comments[i];
          if (comments[i].replies) {
            for (var j = 0; j < comments[i].replies.length; j++) {
              if (comments[i].replies[j].id === id) return comments[i].replies[j];
            }
          }
        }
        return null;
      }

      function countComments(postId) {
        var cached = commentsCache[postId] || [];
        var n = 0;
        for (var i = 0; i < cached.length; i++) {
          n++;
          if (cached[i].replies) n += cached[i].replies.length;
        }
        return n;
      }

      function updateCommentCount(postId, card) {
        var btn = card.querySelector('.post-comment-count');
        if (!btn) return;
        var n = countComments(postId);
        btn.textContent = n === 1 ? '1 comment' : n + ' comments';
      }

      // --- Delegated comment interactions ---
      document.addEventListener('click', function (e) {
        // Comment submit
        var submitBtn = e.target.closest('.comment-submit-btn');
        if (submitBtn) {
          var postId = submitBtn.getAttribute('data-post-id');
          var composeWrap = submitBtn.closest('.comment-compose-inline');
          var textarea = composeWrap ? composeWrap.querySelector('.comment-compose-textarea') : null;
          if (textarea) submitComment(postId, textarea, null);
          return;
        }

        // Reply button — show reply form
        var replyBtn = e.target.closest('.comment-reply-btn');
        if (replyBtn) {
          var parentId = replyBtn.getAttribute('data-parent-id');
          var rpPostId = replyBtn.getAttribute('data-post-id');
          var card = document.querySelector('[data-post-id="' + rpPostId + '"]');
          if (card) {
            var allForms = card.querySelectorAll('.comment__reply-form');
            for (var i = 0; i < allForms.length; i++) { allForms[i].hidden = true; }
          }
          var replyForm = document.querySelector('[data-reply-for="' + parentId + '"]');
          if (replyForm) {
            replyForm.hidden = false;
            var ta = replyForm.querySelector('textarea');
            if (ta) ta.focus();
          }
          return;
        }

        // Reply cancel
        var cancelBtn = e.target.closest('.reply-cancel-btn');
        if (cancelBtn) {
          var form = cancelBtn.closest('.comment__reply-form');
          if (form) {
            form.hidden = true;
            var ta2 = form.querySelector('textarea');
            if (ta2) ta2.value = '';
          }
          return;
        }

        // Reply submit
        var replySubmitBtn = e.target.closest('.reply-submit-btn');
        if (replySubmitBtn) {
          var rpId = replySubmitBtn.getAttribute('data-parent-id');
          var rsPostId = replySubmitBtn.getAttribute('data-post-id');
          var replyForm2 = document.querySelector('[data-reply-for="' + rpId + '"]');
          var ta3 = replyForm2 ? replyForm2.querySelector('textarea') : null;
          if (ta3) submitComment(rsPostId, ta3, rpId);
          return;
        }

        // Comment delete
        var deleteBtn = e.target.closest('.comment-delete-btn');
        if (deleteBtn) {
          if (!confirm('Delete this comment?')) return;
          var cId = deleteBtn.getAttribute('data-comment-id');
          var dPostId = deleteBtn.getAttribute('data-post-id');
          deleteComment(cId, dPostId, deleteBtn);
          return;
        }

        // Comment reaction
        var reactionBtn = e.target.closest('.comment__reactions .reaction-btn');
        if (reactionBtn) {
          var targetId = reactionBtn.getAttribute('data-target-id');
          var emoji = reactionBtn.getAttribute('data-emoji');
          var rPostId = reactionBtn.getAttribute('data-post-id');
          toggleCommentReaction(targetId, emoji, rPostId, reactionBtn);
          return;
        }
      });

      // --- Edit modal ---
      function openEditModal(post, card) {
        editingPost = post;
        editingCard = card;
        editModalTitle.value = post.title || '';
        editModalBody.value = post.body || '';
        editModalError.hidden = true;

        if (post.type === 'event') {
          editModalEventFields.hidden = false;
          if (post.eventDate) {
            var ed = new Date(post.eventDate);
            var iso = ed.getFullYear() + '-' +
              pad2(ed.getMonth() + 1) + '-' +
              pad2(ed.getDate()) + 'T' +
              pad2(ed.getHours()) + ':' +
              pad2(ed.getMinutes());
            editModalEventDate.value = iso;
          } else {
            editModalEventDate.value = '';
          }
          editModalEventLink.value = post.eventLink || '';
        } else {
          editModalEventFields.hidden = true;
        }

        if (post.type === 'resource') {
          editModalResourceFields.hidden = false;
          editModalResourceUrl.value = post.resourceUrl || '';
        } else {
          editModalResourceFields.hidden = true;
        }

        editModalEl.hidden = false;
        document.body.style.overflow = 'hidden';
        editModalTitle.focus();
      }

      function closeEditModal() {
        editModalEl.hidden = true;
        document.body.style.overflow = '';
        editingPost = null;
        editingCard = null;
        editModalImageInput.value = '';
        editModalImagePreview.hidden = true;
        editModalImagePreview.innerHTML = '';
      }

      editModalCancel.addEventListener('click', closeEditModal);

      editModalEl.addEventListener('click', function (e) {
        if (e.target === editModalEl || e.target.classList.contains('edit-modal__backdrop')) closeEditModal();
      });

      document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape' && !editModalEl.hidden) closeEditModal();
      });

      editModalForm.addEventListener('submit', function (e) {
        e.preventDefault();
        editModalError.hidden = true;

        var payload = {
          postId: editingPost.id,
          title: editModalTitle.value.trim(),
          body: editModalBody.value.trim()
        };

        if (editingPost.type === 'event') {
          payload.eventDate = editModalEventDate.value || null;
          payload.eventLink = editModalEventLink.value.trim() || null;
        }
        if (editingPost.type === 'resource') {
          payload.resourceUrl = editModalResourceUrl.value.trim() || null;
        }

        if (!payload.title) {
          editModalErrorText.textContent = 'Title is required.';
          editModalError.hidden = false;
          return;
        }

        editModalSave.disabled = true;
        editModalSave.textContent = 'Saving...';

        fetch('/api/community/posts', {
          method: 'PATCH',
          credentials: 'same-origin',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload)
        })
          .then(function (r) { return r.json(); })
          .then(function (data) {
            editModalSave.disabled = false;
            editModalSave.textContent = 'Save Changes';
            if (!data.ok) {
              editModalErrorText.textContent = data.error || 'Update failed.';
              editModalError.hidden = false;
              return;
            }

            // Update local post object
            editingPost.title = payload.title;
            editingPost.body = payload.body;
            if (payload.eventDate !== undefined) editingPost.eventDate = payload.eventDate;
            if (payload.eventLink !== undefined) editingPost.eventLink = payload.eventLink;
            if (payload.resourceUrl !== undefined) editingPost.resourceUrl = payload.resourceUrl;

            // Update card DOM in-place
            if (editingCard) {
              var titleEl = editingCard.querySelector('.post-card__title');
              if (titleEl) titleEl.textContent = payload.title;

              var bodyEl = editingCard.querySelector('.post-card__body');
              var showMoreBtn = editingCard.querySelector('.show-more-btn');
              var isExpanded = editingCard.classList.contains('post-card--expanded');
              var newIsLong = payload.body && payload.body.length > 280;

              if (!payload.body) {
                // Body cleared — remove body element and show-more button
                if (bodyEl) bodyEl.parentNode.removeChild(bodyEl);
                if (showMoreBtn) showMoreBtn.parentNode.removeChild(showMoreBtn);
              } else if (bodyEl) {
                // Body exists — update content
                bodyEl.innerHTML = linkify(payload.body);
                bodyEl.classList.remove('post-card__body--collapsed');
                if (!isExpanded && newIsLong) bodyEl.classList.add('post-card__body--collapsed');
                // Reconcile show-more button
                if (newIsLong && !showMoreBtn) {
                  var toggle = document.createElement('button');
                  toggle.className = 'show-more-btn';
                  toggle.textContent = isExpanded ? 'Show less' : 'Show more';
                  toggle.addEventListener('click', function (ev) {
                    ev.stopPropagation();
                    var collapsed = bodyEl.classList.toggle('post-card__body--collapsed');
                    toggle.textContent = collapsed ? 'Show more' : 'Show less';
                  });
                  bodyEl.parentNode.insertBefore(toggle, bodyEl.nextSibling);
                } else if (!newIsLong && showMoreBtn) {
                  showMoreBtn.parentNode.removeChild(showMoreBtn);
                } else if (showMoreBtn) {
                  showMoreBtn.textContent = isExpanded ? 'Show less' : 'Show more';
                }
              } else {
                // Body didn't exist before — create it
                var mainEl = editingCard.querySelector('.post-card__main');
                var actionsEl = editingCard.querySelector('.post-card__actions');
                if (mainEl && actionsEl) {
                  var newBody = document.createElement('div');
                  newBody.className = 'post-card__body';
                  newBody.innerHTML = linkify(payload.body);
                  if (!isExpanded && newIsLong) newBody.classList.add('post-card__body--collapsed');
                  mainEl.insertBefore(newBody, actionsEl);
                  if (newIsLong) {
                    var toggle2 = document.createElement('button');
                    toggle2.className = 'show-more-btn';
                    toggle2.textContent = isExpanded ? 'Show less' : 'Show more';
                    toggle2.addEventListener('click', function (ev) {
                      ev.stopPropagation();
                      var collapsed = newBody.classList.toggle('post-card__body--collapsed');
                      toggle2.textContent = collapsed ? 'Show more' : 'Show less';
                    });
                    mainEl.insertBefore(toggle2, actionsEl);
                  }
                }
              }
            }

            closeEditModal();
          })
          .catch(function () {
            editModalSave.disabled = false;
            editModalSave.textContent = 'Save Changes';
            editModalErrorText.textContent = 'Network error. Please try again.';
            editModalError.hidden = false;
          });
      });

    })();
  </script>
</BaseLayout>

