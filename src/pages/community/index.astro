---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Community"
  description="Save the Uterus Club community for RRM Academy members."
  canonicalUrl="https://rrmacademy.org/community"
  noindex
>
  <section class="community-page">
    <div class="container">

      <!-- Loading state -->
      <div id="community-loading" class="community-loading">
        <p>Loading...</p>
      </div>

      <!-- Gate: non-members -->
      <div id="community-gate" hidden>
        <div class="gate-hero">
          <h1 class="hero-title">Save the Uterus Club</h1>
          <p class="gate-description">The Save the Uterus Club is a private community for patients, advocates, and medical professionals committed to restorative reproductive medicine. Members get access to exclusive announcements, events, resources, and direct discussions with the RRM Academy team.</p>
          <div class="gate-actions">
            <a href="/save-the-uterus-club/" class="btn btn--primary btn--lg">Join the Save the Uterus Club</a>
          </div>
          <div class="gate-instagram">
            <p>Not ready to join? <a href="https://www.instagram.com/direct/t/7768750249851959/" target="_blank" rel="noopener noreferrer">Join our free Uterus Allies group on Instagram</a></p>
          </div>
        </div>
      </div>

      <!-- Feed: members -->
      <div id="community-feed" hidden>

        <div class="feed-header">
          <h1>Save the Uterus Club</h1>
          <p class="feed-welcome">Welcome, <span id="feed-user-name"></span></p>
        </div>

        <!-- Filter tabs -->
        <div class="feed-tabs" role="tablist">
          <button class="feed-tab active" role="tab" data-type="">All</button>
          <button class="feed-tab" role="tab" data-type="announcement">Announcements</button>
          <button class="feed-tab" role="tab" data-type="event">Events</button>
          <button class="feed-tab" role="tab" data-type="resource">Resources</button>
          <button class="feed-tab" role="tab" data-type="discussion">Discussions</button>
        </div>

        <!-- Compose form -->
        <div class="compose-card">
          <form id="compose-form">
            <div class="form-group">
              <label class="form-label" for="compose-title">Title <span class="form-required">*</span></label>
              <input class="form-input" type="text" id="compose-title" name="title" required maxlength="200" placeholder="What's on your mind?" />
            </div>
            <div class="form-group">
              <label class="form-label" for="compose-body">Body</label>
              <textarea class="form-textarea" id="compose-body" name="body" rows="3" placeholder="Share details, a question, or a thought..."></textarea>
            </div>

            <!-- Staff-only type selector -->
            <div id="compose-type-group" class="form-group" hidden>
              <label class="form-label" for="compose-type">Post type</label>
              <select class="form-input form-select" id="compose-type" name="type">
                <option value="discussion">Discussion</option>
                <option value="announcement">Announcement</option>
                <option value="event">Event</option>
                <option value="resource">Resource</option>
              </select>
            </div>

            <!-- Event fields (shown when type=event) -->
            <div id="compose-event-fields" hidden>
              <div class="form-group">
                <label class="form-label" for="compose-event-date">Event date</label>
                <input class="form-input" type="datetime-local" id="compose-event-date" name="eventDate" />
              </div>
              <div class="form-group">
                <label class="form-label" for="compose-event-link">Event link</label>
                <input class="form-input" type="url" id="compose-event-link" name="eventLink" placeholder="https://..." />
              </div>
            </div>

            <!-- Resource fields (shown when type=resource) -->
            <div id="compose-resource-fields" hidden>
              <div class="form-group">
                <label class="form-label" for="compose-resource-url">Resource URL</label>
                <input class="form-input" type="url" id="compose-resource-url" name="resourceUrl" placeholder="https://..." />
              </div>
            </div>

            <div id="compose-error" class="compose-feedback compose-feedback--error" hidden>
              <p id="compose-error-text"></p>
            </div>

            <div class="compose-actions">
              <button type="submit" class="btn btn--primary btn--sm" id="compose-submit-btn">Post</button>
            </div>
          </form>
        </div>

        <!-- Post list -->
        <div id="post-list" class="post-list"></div>

        <!-- Load more -->
        <div id="load-more-wrap" class="load-more-wrap" hidden>
          <button id="load-more-btn" class="btn btn--secondary">Load more</button>
        </div>

        <!-- Empty state -->
        <div id="posts-empty" class="posts-empty" hidden>
          <p>No posts yet. Be the first to share something with the community.</p>
        </div>

      </div>

    </div>
  </section>

  <script is:inline>
    (function () {
      var STAFF_ROLES = ['superadmin', 'admin', 'mod'];
      var ADMIN_ROLES = ['superadmin', 'admin'];
      var EMOJIS = ['\u2764\uFE0F', '\uD83D\uDC4F', '\uD83D\uDD25', '\uD83D\uDCA1', '\uD83D\uDE4F', '\uD83D\uDE22'];
      var PAGE_SIZE = 20;

      var loadingEl = document.getElementById('community-loading');
      var gateEl = document.getElementById('community-gate');
      var feedEl = document.getElementById('community-feed');
      var userNameEl = document.getElementById('feed-user-name');
      var postListEl = document.getElementById('post-list');
      var loadMoreWrap = document.getElementById('load-more-wrap');
      var loadMoreBtn = document.getElementById('load-more-btn');
      var postsEmpty = document.getElementById('posts-empty');
      var composeForm = document.getElementById('compose-form');
      var composeTitle = document.getElementById('compose-title');
      var composeBody = document.getElementById('compose-body');
      var composeTypeGroup = document.getElementById('compose-type-group');
      var composeType = document.getElementById('compose-type');
      var composeEventFields = document.getElementById('compose-event-fields');
      var composeResourceFields = document.getElementById('compose-resource-fields');
      var composeError = document.getElementById('compose-error');
      var composeErrorText = document.getElementById('compose-error-text');
      var composeSubmitBtn = document.getElementById('compose-submit-btn');
      var tabs = document.querySelectorAll('.feed-tab');

      var currentUser = null;
      var activeType = '';
      var lastCreatedAt = null;
      var allPostsLoaded = false;

      // --- Status check ---
      fetch('/api/community/status', { credentials: 'same-origin' })
        .then(function (r) { return r.json(); })
        .then(function (data) {
          loadingEl.hidden = true;
          if (!data.ok || !data.user) {
            gateEl.hidden = false;
            return;
          }
          if (data.access === 'member') {
            currentUser = data.user;
            userNameEl.textContent = currentUser.name || 'Member';
            setupFeed();
            feedEl.hidden = false;
          } else {
            gateEl.hidden = false;
          }
        })
        .catch(function () {
          loadingEl.hidden = true;
          gateEl.hidden = false;
        });

      // --- Feed setup ---
      function setupFeed() {
        var isStaff = STAFF_ROLES.indexOf(currentUser.role) !== -1;
        if (isStaff) {
          composeTypeGroup.hidden = false;
        }
        loadPosts(false);
      }

      // --- Type selector change ---
      composeType.addEventListener('change', function () {
        var val = composeType.value;
        composeEventFields.hidden = val !== 'event';
        composeResourceFields.hidden = val !== 'resource';
      });

      // --- Tab clicks ---
      for (var i = 0; i < tabs.length; i++) {
        (function (tab) {
          tab.addEventListener('click', function () {
            for (var j = 0; j < tabs.length; j++) {
              tabs[j].classList.remove('active');
            }
            tab.classList.add('active');
            activeType = tab.getAttribute('data-type') || '';
            lastCreatedAt = null;
            allPostsLoaded = false;
            postListEl.innerHTML = '';
            postsEmpty.hidden = true;
            loadPosts(false);
          });
        })(tabs[i]);
      }

      // --- Load posts ---
      function loadPosts(append) {
        var url = '/api/community/posts?limit=' + PAGE_SIZE;
        if (activeType) url += '&type=' + encodeURIComponent(activeType);
        if (append && lastCreatedAt) url += '&before=' + encodeURIComponent(lastCreatedAt);

        loadMoreBtn.disabled = true;
        loadMoreBtn.textContent = 'Loading...';

        fetch(url, { credentials: 'same-origin' })
          .then(function (r) { return r.json(); })
          .then(function (data) {
            loadMoreBtn.disabled = false;
            loadMoreBtn.textContent = 'Load more';
            if (!data.ok || !data.posts) return;

            var posts = data.posts;
            if (posts.length < PAGE_SIZE) {
              allPostsLoaded = true;
              loadMoreWrap.hidden = true;
            } else {
              loadMoreWrap.hidden = false;
            }

            if (posts.length === 0 && !append) {
              postsEmpty.hidden = false;
              return;
            }
            postsEmpty.hidden = true;

            for (var k = 0; k < posts.length; k++) {
              postListEl.appendChild(renderPostCard(posts[k]));
              lastCreatedAt = posts[k].createdAt;
            }
          })
          .catch(function () {
            loadMoreBtn.disabled = false;
            loadMoreBtn.textContent = 'Load more';
          });
      }

      // --- Load more ---
      loadMoreBtn.addEventListener('click', function () {
        if (!allPostsLoaded) loadPosts(true);
      });

      // --- Compose form submit ---
      composeForm.addEventListener('submit', function (e) {
        e.preventDefault();
        composeError.hidden = true;

        var title = composeTitle.value.trim();
        if (!title) {
          composeErrorText.textContent = 'Title is required.';
          composeError.hidden = false;
          return;
        }

        var isStaff = STAFF_ROLES.indexOf(currentUser.role) !== -1;
        var type = isStaff ? composeType.value : 'discussion';
        var payload = {
          type: type,
          title: title,
          body: composeBody.value
        };

        if (type === 'event') {
          var eventDate = document.getElementById('compose-event-date').value;
          var eventLink = document.getElementById('compose-event-link').value.trim();
          if (eventDate) payload.eventDate = eventDate;
          if (eventLink) payload.eventLink = eventLink;
        }
        if (type === 'resource') {
          var resourceUrl = document.getElementById('compose-resource-url').value.trim();
          if (resourceUrl) payload.resourceUrl = resourceUrl;
        }

        composeSubmitBtn.disabled = true;
        composeSubmitBtn.textContent = 'Posting...';

        fetch('/api/community/posts', {
          method: 'POST',
          credentials: 'same-origin',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload)
        })
          .then(function (r) { return r.json(); })
          .then(function (data) {
            composeSubmitBtn.disabled = false;
            composeSubmitBtn.textContent = 'Post';
            if (data.ok && data.post) {
              composeTitle.value = '';
              composeBody.value = '';
              if (isStaff) {
                composeType.value = 'discussion';
                composeEventFields.hidden = true;
                composeResourceFields.hidden = true;
              }
              postListEl.insertBefore(renderPostCard(data.post), postListEl.firstChild);
              postsEmpty.hidden = true;
            } else {
              composeErrorText.textContent = data.error || 'Failed to create post.';
              composeError.hidden = false;
            }
          })
          .catch(function () {
            composeSubmitBtn.disabled = false;
            composeSubmitBtn.textContent = 'Post';
            composeErrorText.textContent = 'Network error. Please try again.';
            composeError.hidden = false;
          });
      });

      // --- Render post card ---
      function renderPostCard(post) {
        var card = document.createElement('article');
        card.className = 'post-card';
        card.setAttribute('data-post-id', post.id);

        var isAdmin = ADMIN_ROLES.indexOf(currentUser.role) !== -1;
        var isMod = STAFF_ROLES.indexOf(currentUser.role) !== -1;
        var authorIsStaff = STAFF_ROLES.indexOf(post.authorRole) !== -1;

        // Header row
        var header = document.createElement('div');
        header.className = 'post-card__header';

        // Left: badge + pin
        var meta = document.createElement('div');
        meta.className = 'post-card__meta';

        var badge = document.createElement('span');
        badge.className = 'post-type-badge post-type-badge--' + post.type;
        badge.textContent = capitalize(post.type);
        meta.appendChild(badge);

        if (post.pinned) {
          var pin = document.createElement('span');
          pin.className = 'post-pin-indicator';
          pin.textContent = 'Pinned';
          meta.appendChild(pin);
        }

        header.appendChild(meta);

        // Right: staff controls
        if (isAdmin || isMod) {
          var controls = document.createElement('div');
          controls.className = 'post-card__controls';

          if (isMod) {
            var pinBtn = document.createElement('button');
            pinBtn.className = 'btn btn--text btn--sm';
            pinBtn.textContent = post.pinned ? 'Unpin' : 'Pin';
            pinBtn.addEventListener('click', function (ev) {
              ev.stopPropagation();
              togglePin(post.id, !post.pinned, pinBtn, card);
            });
            controls.appendChild(pinBtn);
          }

          if (isAdmin) {
            var editBtn = document.createElement('a');
            editBtn.className = 'btn btn--text btn--sm';
            editBtn.textContent = 'Edit';
            editBtn.href = '/community/post/' + post.id;
            editBtn.addEventListener('click', function (ev) { ev.stopPropagation(); });
            controls.appendChild(editBtn);

            var delBtn = document.createElement('button');
            delBtn.className = 'btn btn--text btn--sm post-delete-btn';
            delBtn.textContent = 'Delete';
            delBtn.addEventListener('click', function (ev) {
              ev.stopPropagation();
              deletePost(post.id, card);
            });
            controls.appendChild(delBtn);
          }

          header.appendChild(controls);
        }

        card.appendChild(header);

        // Author line
        var authorLine = document.createElement('div');
        authorLine.className = 'post-card__author';
        var authorName = document.createElement('span');
        authorName.className = 'post-author-name';
        authorName.textContent = post.authorName || 'Member';
        authorLine.appendChild(authorName);

        if (authorIsStaff) {
          var roleBadge = document.createElement('span');
          roleBadge.className = 'post-role-badge';
          roleBadge.textContent = capitalize(post.authorRole);
          authorLine.appendChild(roleBadge);
        }

        var timeEl = document.createElement('span');
        timeEl.className = 'post-time';
        timeEl.textContent = timeAgo(post.createdAt);
        authorLine.appendChild(timeEl);

        card.appendChild(authorLine);

        // Title (clickable link)
        var titleLink = document.createElement('a');
        titleLink.className = 'post-card__title';
        titleLink.href = '/community/post/' + post.id;
        titleLink.textContent = post.title;
        card.appendChild(titleLink);

        // Body preview
        if (post.body) {
          var bodyPreview = document.createElement('p');
          bodyPreview.className = 'post-card__body';
          bodyPreview.textContent = post.body.length > 200 ? post.body.substring(0, 200) + '...' : post.body;
          card.appendChild(bodyPreview);
        }

        // Footer: reactions + comment count
        var footer = document.createElement('div');
        footer.className = 'post-card__footer';

        var reactionBar = document.createElement('div');
        reactionBar.className = 'reaction-bar';
        var reactions = post.reactions || {};
        var userReactions = post.userReactions || [];

        for (var e = 0; e < EMOJIS.length; e++) {
          (function (emoji) {
            var count = reactions[emoji] || 0;
            var isActive = userReactions.indexOf(emoji) !== -1;
            var rBtn = document.createElement('button');
            rBtn.className = 'reaction-btn' + (isActive ? ' reaction-btn--active' : '');
            rBtn.setAttribute('data-emoji', emoji);
            rBtn.innerHTML = '<span class="reaction-emoji">' + emoji + '</span>' + (count > 0 ? '<span class="reaction-count">' + count + '</span>' : '');
            if (count === 0 && !isActive) rBtn.classList.add('reaction-btn--empty');
            rBtn.addEventListener('click', function (ev) {
              ev.stopPropagation();
              toggleReaction(post.id, emoji, rBtn, reactions, userReactions);
            });
            reactionBar.appendChild(rBtn);
          })(EMOJIS[e]);
        }

        footer.appendChild(reactionBar);

        var commentCount = document.createElement('a');
        commentCount.className = 'post-comment-count';
        commentCount.href = '/community/post/' + post.id;
        var cc = post.commentCount || 0;
        commentCount.textContent = cc === 1 ? '1 comment' : cc + ' comments';
        footer.appendChild(commentCount);

        card.appendChild(footer);

        // Make card clickable (navigate to post)
        card.addEventListener('click', function (ev) {
          if (ev.target.tagName === 'A' || ev.target.tagName === 'BUTTON' || ev.target.closest('a') || ev.target.closest('button')) return;
          window.location.href = '/community/post/' + post.id + '/';
        });
        card.style.cursor = 'pointer';

        return card;
      }

      // --- Toggle reaction ---
      function toggleReaction(postId, emoji, btn, reactions, userReactions) {
        btn.disabled = true;
        fetch('/api/community/reactions', {
          method: 'POST',
          credentials: 'same-origin',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ targetType: 'post', targetId: postId, emoji: emoji })
        })
          .then(function (r) { return r.json(); })
          .then(function (data) {
            btn.disabled = false;
            if (!data.ok) return;

            var idx = userReactions.indexOf(emoji);
            if (idx !== -1) {
              userReactions.splice(idx, 1);
              reactions[emoji] = Math.max(0, (reactions[emoji] || 1) - 1);
              btn.classList.remove('reaction-btn--active');
            } else {
              userReactions.push(emoji);
              reactions[emoji] = (reactions[emoji] || 0) + 1;
              btn.classList.add('reaction-btn--active');
            }

            var count = reactions[emoji] || 0;
            btn.innerHTML = '<span class="reaction-emoji">' + emoji + '</span>' + (count > 0 ? '<span class="reaction-count">' + count + '</span>' : '');
            if (count === 0 && userReactions.indexOf(emoji) === -1) {
              btn.classList.add('reaction-btn--empty');
            } else {
              btn.classList.remove('reaction-btn--empty');
            }
          })
          .catch(function () { btn.disabled = false; });
      }

      // --- Pin/unpin ---
      function togglePin(postId, pinned, btn, card) {
        btn.disabled = true;
        btn.textContent = pinned ? 'Pinning...' : 'Unpinning...';
        fetch('/api/community/posts', {
          method: 'PATCH',
          credentials: 'same-origin',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ postId: postId, pinned: pinned })
        })
          .then(function (r) { return r.json(); })
          .then(function (data) {
            btn.disabled = false;
            if (data.ok) {
              btn.textContent = pinned ? 'Unpin' : 'Pin';
              // Update pin indicator
              var existing = card.querySelector('.post-pin-indicator');
              if (pinned && !existing) {
                var pin = document.createElement('span');
                pin.className = 'post-pin-indicator';
                pin.textContent = 'Pinned';
                card.querySelector('.post-card__meta').appendChild(pin);
              } else if (!pinned && existing) {
                existing.parentNode.removeChild(existing);
              }
            } else {
              btn.textContent = pinned ? 'Pin' : 'Unpin';
            }
          })
          .catch(function () {
            btn.disabled = false;
            btn.textContent = pinned ? 'Pin' : 'Unpin';
          });
      }

      // --- Delete post ---
      function deletePost(postId, card) {
        if (!confirm('Delete this post? This cannot be undone.')) return;
        fetch('/api/community/posts', {
          method: 'DELETE',
          credentials: 'same-origin',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ postId: postId })
        })
          .then(function (r) { return r.json(); })
          .then(function (data) {
            if (data.ok) {
              card.parentNode.removeChild(card);
              if (postListEl.children.length === 0) postsEmpty.hidden = false;
            }
          });
      }

      // --- Helpers ---
      function capitalize(s) {
        if (!s) return '';
        return s.charAt(0).toUpperCase() + s.slice(1);
      }

      function timeAgo(dateStr) {
        if (!dateStr) return '';
        var now = Date.now();
        var then = new Date(dateStr).getTime();
        var diff = Math.floor((now - then) / 1000);
        if (diff < 60) return 'just now';
        var mins = Math.floor(diff / 60);
        if (mins < 60) return mins === 1 ? '1 minute ago' : mins + ' minutes ago';
        var hours = Math.floor(mins / 60);
        if (hours < 24) return hours === 1 ? '1 hour ago' : hours + ' hours ago';
        var days = Math.floor(hours / 24);
        if (days < 7) return days === 1 ? '1 day ago' : days + ' days ago';
        var weeks = Math.floor(days / 7);
        if (weeks < 5) return weeks === 1 ? '1 week ago' : weeks + ' weeks ago';
        var months = Math.floor(days / 30);
        if (months < 12) return months === 1 ? '1 month ago' : months + ' months ago';
        var years = Math.floor(days / 365);
        return years === 1 ? '1 year ago' : years + ' years ago';
      }
    })();
  </script>
</BaseLayout>

<style>
  /* Page */
  .community-page {
    padding: var(--space-8) 0 var(--space-16);
    min-height: 60vh;
  }
  .community-loading {
    text-align: center;
    color: var(--text-muted);
    padding: var(--space-16) 0;
  }

  /* Gate */
  .gate-hero {
    max-width: 640px;
    margin: 0 auto;
    text-align: center;
    padding: var(--space-16) 0;
  }
  .gate-hero .hero-title {
    margin-bottom: var(--space-4);
  }
  .gate-description {
    font-size: 0.9375rem;
    line-height: 1.8;
    color: var(--text-secondary);
    margin-bottom: var(--space-8);
  }
  .gate-actions {
    margin-bottom: var(--space-6);
  }
  .gate-instagram {
    font-size: 0.875rem;
    color: var(--text-tertiary);
  }
  .gate-instagram a {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .gate-instagram a:hover {
    color: var(--accent-hover);
  }

  /* Feed header */
  .feed-header {
    margin-bottom: var(--space-6);
  }
  .feed-header h1 {
    font-size: 1.75rem;
    margin-bottom: var(--space-2);
  }
  .feed-welcome {
    font-size: 0.9375rem;
    color: var(--text-secondary);
    margin-bottom: 0;
  }

  /* Tabs */
  .feed-tabs {
    display: flex;
    gap: var(--space-1);
    border-bottom: 1px solid var(--border-color);
    margin-bottom: var(--space-6);
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }
  .feed-tab {
    flex-shrink: 0;
    padding: var(--space-3) var(--space-4);
    font-family: 'Inter', sans-serif;
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--text-tertiary);
    background: transparent;
    border: none;
    border-bottom: 2px solid transparent;
    cursor: pointer;
    transition: color 0.15s, border-color 0.15s;
    white-space: nowrap;
  }
  .feed-tab:hover {
    color: var(--text-primary);
  }
  .feed-tab.active {
    color: var(--purple-700);
    border-bottom-color: var(--purple-700);
    font-weight: 600;
  }

  /* Compose card */
  .compose-card {
    background: var(--bg-surface);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
    margin-bottom: var(--space-6);
  }
  .compose-card .form-group {
    margin-bottom: var(--space-4);
  }
  .compose-card .form-group:last-of-type {
    margin-bottom: var(--space-4);
  }
  .form-select {
    appearance: auto;
    border-radius: var(--radius-md);
  }
  .compose-actions {
    display: flex;
    justify-content: flex-end;
  }
  .compose-feedback--error {
    margin-bottom: var(--space-4);
    padding: var(--space-3) var(--space-4);
    background: rgba(192, 57, 43, 0.05);
    border: 1px solid var(--color-error);
    border-radius: var(--radius-md);
    color: var(--color-error);
    font-size: 0.875rem;
  }

  /* Post list */
  .post-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  /* Post card */
  .post-card {
