      datePublished: '2022',
      isPartOf: { '@type': 'Periodical', name: 'Reproductive Health' },
    },
    {
      '@type': 'ScholarlyArticle',
      name: 'Pregnancy outcomes from a restorative infertility treatment model: a single centre case series',
      author: 'James G, et al.',
      datePublished: '2021',
      isPartOf: { '@type': 'Periodical', name: 'medRxiv' },
    },
    {
      '@type': 'ScholarlyArticle',
      name: 'Restorative reproductive medicine for infertility and recurrent miscarriage in the outpatient gynaecological practice in Ukraine',
      author: 'Horodenchuk Z, et al.',
      datePublished: '2020',
      isPartOf: { '@type': 'Periodical', name: 'Fides et Ratio' },
    },
    {
      '@type': 'ScholarlyArticle',
      name: 'Stratification of fertility potential according to cervical mucus symptoms in couples presenting with subfertility',
      author: 'Marshell M, et al.',
      datePublished: '2019',
      isPartOf: { '@type': 'Periodical', name: 'Human Fertility' },
    },
    {
      '@type': 'ScholarlyArticle',
      name: 'Healthy Singleton Pregnancies From Restorative Reproductive Medicine (RRM) After Failed IVF',
      author: 'de Groot T, et al.',
      datePublished: '2018',
      isPartOf: { '@type': 'Periodical', name: 'Frontiers in Medicine' },
    },
    {
      '@type': 'ScholarlyArticle',
      name: 'Natural conception rates in subfertile couples following fertility awareness training',
      author: 'Frank-Herrmann P, et al.',
      datePublished: '2017',
      isPartOf: { '@type': 'Periodical', name: 'Archives of Gynecology and Obstetrics' },
    },
    {
      '@type': 'ScholarlyArticle',
      name: 'Fertility treatments and adverse perinatal outcomes from a normally-fertile population: a cohort study',
      author: 'Stanford JB, et al.',
      datePublished: '2016',
      isPartOf: { '@type': 'Periodical', name: 'BJOG' },
    },
    {
      '@type': 'ScholarlyArticle',
      name: 'Natural procreative technology for infertility and recurrent miscarriage: outcomes in a Canadian family practice',
