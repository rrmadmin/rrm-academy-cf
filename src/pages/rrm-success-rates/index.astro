---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BackToTop from '../../components/BackToTop.astro';
import PdfDownload from '../../components/PdfDownload.astro';

// Block 1: MedicalWebPage + Article (injected via BaseLayout jsonLd prop)
const pageSchema = {
  '@context': 'https://schema.org',
  '@type': ['Article', 'MedicalWebPage'],
  headline: 'RRM Success Rates: What the Research Shows',
  description: 'Peer-reviewed RRM research reports live birth rates of 32% to 66%. Data from 13 studies across 8 countries. See how RRM compares to IVF.',
  image: 'https://rrmacademy.org/images/og-default.png',
  author: {
    '@type': 'Person',
    '@id': 'https://rrmacademy.org/#naomi-whittaker',
    name: 'Dr. Naomi Whittaker, MD, Board-Certified OBGYN, MIGS, NFPMC, FCI',
    jobTitle: 'Board-Certified OBGYN, NaProTechnology Fellow',
    url: 'https://rrmacademy.org/commentary/rrm-spotlight-naomi-whittaker-md/',
    image: 'https://rrmacademy.org/images/authors/naomi-whittaker.webp',
    sameAs: [
      'https://www.instagram.com/napro_fertility_surgeon/',
      'https://www.linkedin.com/in/naomi-whittaker-md-906b13101/',
    ],
  },
  publisher: {
    '@type': 'EducationalOrganization',
    '@id': 'https://rrmacademy.org/#organization',
    name: 'RRM Academy',
  },
  datePublished: '2026-03-26',
  dateModified: '2026-03-26',
  wordCount: 5000,
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': 'https://rrmacademy.org/rrm-success-rates/',
  },
  about: {
    '@type': 'MedicalTherapy',
    name: 'Restorative Reproductive Medicine',
  },
  articleSection: [
    'Key Takeaways',
    'Does RRM Work for Infertility?',
    'What if I\'ve Already Tried IVF?',
    'Does Age Matter?',
    'What About Male Factor Infertility?',
    'How Long Does It Take?',
    'Study Comparison Table',
    'How RRM Compares to IVF',
    'About the STORRM Registry',
    'Frequently Asked Questions',
    'References',
  ],
  hasPart: [
    { '@type': 'WebPageElement', name: 'Key Takeaways', url: 'https://rrmacademy.org/rrm-success-rates/#key-takeaways' },
    { '@type': 'WebPageElement', name: 'Does RRM Work for Infertility?', url: 'https://rrmacademy.org/rrm-success-rates/#does-rrm-work' },
    { '@type': 'WebPageElement', name: 'What if I\'ve Already Tried IVF?', url: 'https://rrmacademy.org/rrm-success-rates/#after-failed-ivf' },
    { '@type': 'WebPageElement', name: 'Does Age Matter?', url: 'https://rrmacademy.org/rrm-success-rates/#age' },
    { '@type': 'WebPageElement', name: 'What About Male Factor Infertility?', url: 'https://rrmacademy.org/rrm-success-rates/#male-factor' },
    { '@type': 'WebPageElement', name: 'How Long Does It Take?', url: 'https://rrmacademy.org/rrm-success-rates/#time-to-conception' },
    { '@type': 'WebPageElement', name: 'Study Comparison Table', url: 'https://rrmacademy.org/rrm-success-rates/#study-table' },
    { '@type': 'WebPageElement', name: 'How RRM Compares to IVF', url: 'https://rrmacademy.org/rrm-success-rates/#rrm-vs-ivf' },
    { '@type': 'WebPageElement', name: 'About the STORRM Registry', url: 'https://rrmacademy.org/rrm-success-rates/#storrm' },
    { '@type': 'WebPageElement', name: 'Frequently Asked Questions', url: 'https://rrmacademy.org/rrm-success-rates/#faq' },
    { '@type': 'WebPageElement', name: 'References', url: 'https://rrmacademy.org/rrm-success-rates/#references' },
  ],
  citation: [
    {
      '@type': 'ScholarlyArticle',
      name: 'Natural procreative technology (NaProTechnology) for infertility: take-home baby rate and clinical outcomes in a 5-year single-center cohort of 1,310 couples',
      author: 'Sanchez-Mendez JI, et al.',
      datePublished: '2025',
      isPartOf: { '@type': 'Periodical', name: 'Frontiers in Reproductive Health' },
    },
    {
      '@type': 'ScholarlyArticle',
      name: 'Comprehensive diagnostic and therapeutic approach to male factor infertility in couples seeking restorative reproductive medicine',
      author: 'Grande G, et al.',
      datePublished: '2025',
      isPartOf: { '@type': 'Periodical', name: 'Andrology' },
    },
    {
      '@type': 'ScholarlyArticle',
      name: 'Restorative reproductive medicine (RRM) outcomes compared to in-vitro fertilization for the treatment of infertility',
