    },
  ],
};

// Block 2: BreadcrumbList (inline in page body)
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://rrmacademy.org/' },
    { '@type': 'ListItem', position: 2, name: 'Guides', item: 'https://rrmacademy.org/guides/' },
    { '@type': 'ListItem', position: 3, name: 'RRM Success Rates', item: 'https://rrmacademy.org/rrm-success-rates/' },
  ],
};

// Block 3: FAQPage (separate block per spec -- avoids Google validation issues with merged schemas)
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'What are the success rates of RRM treatment?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Published RRM research reports adjusted cumulative live birth rates of 32% to 66% depending on patient population and follow-up duration. The largest cohort of 1,310 couples reported an adjusted cumulative take-home baby rate of 62.1%.',
      },
    },
    {
      '@type': 'Question',
      name: 'Does RRM work after failed IVF?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. In a study of 403 couples where 100% had prior IVF failure, RRM treatment achieved an adjusted cumulative live birth rate of 32.1%, with 92% of babies born at full term.',
      },
    },
    {
      '@type': 'Question',
      name: 'How long does RRM treatment take to achieve pregnancy?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Published data shows 77% of RRM pregnancies are achieved within the first 6 months and 92.5% within the first 12 months. One study reported an average time to conception of 12 months for live birth patients.',
      },
    },
    {
      '@type': 'Question',
      name: 'Is RRM effective for women over 35?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'RRM outcomes vary by age, as expected. Studies report pregnancy rates of approximately 50% for women under 34, approximately 30% for women under 40, and meaningful but lower rates for women over 40.',
      },
    },
    {
      '@type': 'Question',
      name: 'How do RRM success rates compare to IVF?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'RRM reports adjusted cumulative live birth rates of 32% to 66% over 24 months, compared to IVF per-cycle live birth rates of approximately 28%. RRM pregnancies are overwhelmingly singleton and full-term, while IVF carries a 4.24 times higher risk of preterm birth.',
      },
    },
    {
      '@type': 'Question',
      name: 'Does RRM address male factor infertility?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. One multicenter study of 1,014 couples found that comprehensive andrological evaluation identified treatable causes in 87% of male partners, reducing idiopathic infertility from the typical 30-50% to just 8%.',
      },
    },
    {
      '@type': 'Question',
      name: 'Is the evidence for RRM peer-reviewed?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. RRM outcomes have been published in peer-reviewed journals including Human Reproduction Open, Frontiers in Medicine, the Journal of the American Board of Family Medicine, and the Canadian Family Physician, among others.',
      },
    },
  ],
};
---

<BaseLayout
  title="RRM Success Rates: Published Outcomes from 4,500+ Couples | RRM Academy"
  description="Peer-reviewed RRM research reports live birth rates of 32% to 66%. Data from 13 studies across 8 countries. See how RRM compares to IVF."
  canonicalUrl="https://rrmacademy.org/rrm-success-rates/"
  jsonLd={pageSchema}
>
  <!-- Separate JSON-LD blocks (not @graph) per spec -->
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <!-- Content will be added in subsequent tasks -->
</BaseLayout>
