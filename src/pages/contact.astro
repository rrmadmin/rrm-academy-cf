---
import BaseLayout from '../layouts/BaseLayout.astro';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  name: 'Contact RRM Academy',
  description: 'Get in touch with RRM Academy for questions about restorative reproductive medicine education, courses, or our research library.',
  url: 'https://rrmacademy.org/contact',
  mainEntity: {
    '@type': 'EducationalOrganization',
    name: 'RRM Academy',
    url: 'https://rrmacademy.org',
    email: 'contact@rrmacademy.org',
    address: {
      '@type': 'PostalAddress',
      streetAddress: '3401 Hartzdale Dr, Ste 103B PMB 3518',
      addressLocality: 'Camp Hill',
      addressRegion: 'PA',
      postalCode: '17011',
      addressCountry: 'US',
    },
    sameAs: [
      'https://www.instagram.com/rrmacademy',
    ],
  },
};
---
<BaseLayout
  title="Contact Us"
  description="Get in touch with RRM Academy. Questions about restorative reproductive medicine education, courses, or the research library? We would love to hear from you."
  canonicalUrl="https://rrmacademy.org/contact"
  jsonLd={jsonLd}
>
  <!-- Hero -->
  <section class="contact-hero">
    <div class="container container--narrow">
      <h1>Contact Us</h1>
    </div>
  </section>

  <!-- Contact content -->
  <section class="contact-section">
    <div class="container container--narrow">
      <div class="contact-info prose">
          <div class="contact-block">
            <h2>Get in touch</h2>
            <p>
              Have questions about restorative reproductive medicine, our courses, or the research library? We would love to hear from you.
            </p>
          </div>

          <div class="contact-block">
            <h3>Email</h3>
            <p>
              <a href="mailto:contact@rrmacademy.org">contact@rrmacademy.org</a>
            </p>
          </div>

          <div class="contact-block">
            <h3>Mailing address</h3>
            <address class="contact-address">
              RRM Academy<br />
              3401 Hartzdale Dr<br />
              Ste 103B PMB 3518<br />
              Camp Hill, PA 17011
            </address>
          </div>

          <div class="contact-block">
            <h3>Follow us</h3>
            <a href="https://www.instagram.com/rrmacademy" class="contact-social" target="_blank" rel="noopener noreferrer">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
              @rrmacademy
            </a>
          </div>
      </div>

    </div>
  </section>

  <!-- Nonprofit note -->
  <section class="contact-section contact-section--alt">
    <div class="container container--narrow">
      <p class="contact-nonprofit">
        RRM Academy is a project of the Restorative Reproductive Medicine Foundation, a 501(c)(3) nonprofit organization (EIN: 93-4594315).
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  /* Hero */
  .contact-hero {
    padding: var(--space-10) 0 var(--space-8);
    border-bottom: 1px solid var(--border-color);
    text-align: center;
  }
  .contact-hero h1 {
    font-size: 2rem;
    margin-bottom: 0;
  }
  @media (min-width: 769px) {
    .contact-hero {
      padding: var(--space-16) 0 var(--space-12);
    }
    .contact-hero h1 {
      font-size: 2.75rem;
    }
  }

  /* Sections */
  .contact-section {
    padding: var(--space-10) 0;
  }
  .contact-section--alt {
    background: var(--bg-surface);
    border-top: 1px solid var(--border-light);
  }
  @media (min-width: 769px) {
    .contact-section {
      padding: var(--space-16) 0;
    }
  }

  /* Info */
  .contact-block {
    margin-bottom: var(--space-6);
  }
  .contact-block:last-child {
    margin-bottom: 0;
  }
  .contact-block h2 {
    margin-bottom: var(--space-3);
  }
  .contact-block h3 {
    font-size: 1rem;
    margin-bottom: var(--space-2);
  }
  .contact-social {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--accent);
  }
  .contact-social:hover {
    color: var(--accent-hover);
  }

  /* Nonprofit */
  .contact-nonprofit {
    font-size: 0.8125rem;
    color: var(--text-tertiary);
    text-align: center;
    margin-bottom: 0;
  }
</style>
