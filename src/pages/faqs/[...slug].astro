---
import BaseLayout from '../../layouts/BaseLayout.astro';
import MaybeShell from '../../components/MaybeShell.astro';
import { isShellEnabled } from '../../lib/shell-routes';
import { fetchAllFaqs, getRelatedFaqs, PILLAR_CTA_MAP, type FAQ } from '../../lib/faq';
import { buildFAQPage, buildBreadcrumbList } from '../../lib/identity';

const SHELL_ENABLED = isShellEnabled('faqs');

export async function getStaticPaths() {
  const faqs = await fetchAllFaqs();

  return faqs.map(faq => ({
    params: { slug: faq.slug },
    props: { faq, allFaqs: faqs },
  }));
}

interface Props {
  faq: FAQ;
  allFaqs: FAQ[];
}

const { faq, allFaqs } = Astro.props;
const pillar = PILLAR_CTA_MAP[faq.faqId] ?? null;

// D1 emits timestamps as "YYYY-MM-DD HH:MM:SS" (UTC, no Z).
// Normalize to ISO so V8 parses them as UTC, not local.
function toIsoUtc(ts: string | undefined | null): string | null {
  if (!ts) return null;
  if (ts.includes('T')) return ts.endsWith('Z') ? ts : ts + 'Z';
  return ts.replace(' ', 'T') + 'Z';
}

const updatedIso = toIsoUtc(faq.updatedAt);
const createdIso = toIsoUtc(faq.createdAt);

const lastUpdatedLabel = updatedIso
  ? new Intl.DateTimeFormat('en-US', { month: 'long', year: 'numeric' }).format(new Date(updatedIso))
  : null;

const related = getRelatedFaqs(faq, allFaqs, 5);

// Published Answer is already HTML from Airtable (trusted source)
// Airtable content uses h3 for subheadings; promote to h2 so the heading
// hierarchy flows correctly from the page h1 (the question title).
const htmlAnswer = (faq.publishedAnswer || '').replace(/<(\/?)h3/g, '<$1h2');

// Meta
const pageTitle = faq.seoTitle || faq.question;
const metaDescription = faq.seoDescription
  || (faq.basicAnswer ? faq.basicAnswer.slice(0, 155) + (faq.basicAnswer.length > 155 ? '...' : '') : '');

const canonicalUrl = `https://rrmacademy.org/faqs/${faq.slug}`;

// FAQPage JSON-LD (single Q&A — editorially authored, not community Q&A)
// Built via SSOT-aware buildFAQPage + buildBreadcrumbList; dates layered after.
const faqPageRaw = buildFAQPage([
  { question: faq.question, answer: faq.schemaAnswer || faq.basicAnswer || faq.publishedAnswer },
]) as Record<string, unknown>;
const breadcrumbRaw = buildBreadcrumbList([
  { name: 'Home', url: 'https://rrmacademy.org/' },
  { name: 'FAQs', url: 'https://rrmacademy.org/faqs/' },
  { name: faq.question, url: `https://rrmacademy.org/faqs/${faq.slug}/` },
]) as Record<string, unknown>;
const { '@context': _faqCtx, ...faqPageNode } = faqPageRaw;
const { '@context': _bcCtx, ...breadcrumbNode } = breadcrumbRaw;
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      ...faqPageNode,
      dateModified: updatedIso,
      datePublished: createdIso,
    },
    breadcrumbNode,
  ],
};
---
<BaseLayout
  title={pageTitle}
  description={metaDescription}
  canonicalUrl={canonicalUrl}
  jsonLd={jsonLd}
  speakable={['.faq-title', '.prose p']}
  chrome={SHELL_ENABLED ? 'shell' : 'default'}
>
  <MaybeShell enabled={SHELL_ENABLED} context="page" currentPath={Astro.url.pathname}>
  <div class="page-wrapper" data-pagefind-body>
    <span data-pagefind-meta="type:FAQ" style="display:none"></span>
    <span data-pagefind-meta={`title:${faq.question}`} style="display:none"></span>
    <div class="container container--narrow">
      <!-- Breadcrumb -->
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span aria-hidden="true"> &rsaquo; </span>
        <a href="/faqs/">FAQ</a>
        <span aria-hidden="true"> &rsaquo; </span>
        <span>{faq.question.length > 50 ? faq.question.slice(0, 50) + '...' : faq.question}</span>
      </nav>

      <!-- Question -->
      <h1 class="faq-title">{faq.question}</h1>

      <div class="faq-meta-row">
        <span class="faq-category-badge">{faq.category}</span>
        {lastUpdatedLabel && (
          <span class="faq-updated">Last updated {lastUpdatedLabel}</span>
        )}
      </div>

      <!-- Full Answer -->
      <div class="prose" set:html={htmlAnswer} />

      <!-- Research Library References -->
      {faq.libraryRefs.length > 0 && (
        <section class="library-section" aria-label="Research from the RRM Research Library">
          <h2 class="detail-heading">From the RRM Research Library</h2>
          <ul class="library-list">
            {faq.libraryRefs.map(ref => (
              <li>
                <a href={`/library/${ref.slug}/`}>{ref.title}</a>
                <span class="ref-cite">{ref.shortCitation}</span>
              </li>
            ))}
          </ul>
        </section>
      )}

      <!-- External Evidence URLs -->
      {faq.evidence.length > 0 && (
        <section class="evidence-section" aria-label="External resources">
          <h2 class="detail-heading">External Resources</h2>
          <ul class="evidence-list">
            {faq.evidence.map(e => (
              <li>
                {e.url ? (
                  <a href={e.url} target="_blank" rel="noopener noreferrer">{e.title || e.url}</a>
                ) : (
                  <span>{e.title}</span>
                )}
              </li>
            ))}
          </ul>
        </section>
      )}

      <!-- Related FAQs -->
      {related.length > 0 && (
        <section class="related-section" aria-label="Related questions">
          <h2 class="detail-heading">Related Questions</h2>
          <ul class="related-list">
            {related.map(r => (
              <li>
                <a href={`/faqs/${r.slug}/`}>{r.question}</a>
              </li>
            ))}
          </ul>
        </section>
      )}

      <!-- CTA -->
      <section class="faq-cta">
        <h2>Ready to go deeper?</h2>
        <div class="faq-cta__links">
          {pillar ? (
            <>
              <a href={pillar.href} class="btn btn--primary">{pillar.label}</a>
              <a href="/library/" class="btn btn--secondary">Browse the Research Library</a>
            </>
          ) : (
            <>
              <a href="/courses/" class="btn btn--primary">Explore Courses</a>
              <a href="/library/" class="btn btn--secondary">Browse the Research Library</a>
            </>
          )}
        </div>
      </section>

      <!-- Back link -->
      <div class="back-link">
        <a href="/faqs/">&larr; Back to all FAQs</a>
      </div>
    </div>
  </div>
  </MaybeShell>
</BaseLayout>

<style>
  .faq-title {
    font-size: 1.75rem;
    line-height: 1.25;
    letter-spacing: -0.01em;
    margin-bottom: var(--space-3);
  }
  @media (min-width: 769px) {
    .faq-title {
      font-size: 2.25rem;
    }
  }

  .faq-category-badge {
    display: inline-block;
    font-size: 0.6875rem;
    font-family: 'Inter', sans-serif;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-tertiary);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-sm, 4px);
    padding: var(--space-1) var(--space-2);
  }

  .faq-meta-row {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    flex-wrap: wrap;
    margin-bottom: var(--space-6);
  }
  .faq-meta-row .faq-category-badge {
    margin-bottom: 0;
  }
  .faq-updated {
    font-size: 0.8125rem;
    color: var(--text-tertiary);
  }

  /* Prose — answer body typography */
  .prose {
    margin-top: var(--space-8);
    margin-bottom: var(--space-10);
    font-size: 1rem;
    line-height: 1.8;
    color: var(--text-primary);
  }
  .prose :global(h2) {
    font-family: 'Cormorant Garamond', 'Georgia', serif;
    font-size: 1.5rem;
    font-weight: 600;
    margin-top: var(--space-10);
    margin-bottom: var(--space-4);
    line-height: 1.3;
  }
  .prose :global(h3) {
    font-family: 'Cormorant Garamond', 'Georgia', serif;
    font-size: 1.25rem;
    font-weight: 600;
    margin-top: var(--space-8);
    margin-bottom: var(--space-3);
    line-height: 1.3;
  }
  .prose :global(p) {
    margin-bottom: var(--space-5);
  }
  .prose :global(a) {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .prose :global(a:hover) {
    color: var(--purple-900);
  }
  .prose :global(strong) {
    font-weight: 600;
  }
  .prose :global(blockquote) {
    border-left: 3px solid var(--sand-300);
    padding-left: var(--space-5);
    margin: var(--space-6) 0;
    color: var(--text-secondary);
    font-style: italic;
  }
  .prose :global(ul),
  .prose :global(ol) {
    margin-bottom: var(--space-5);
    padding-left: var(--space-6);
  }
  .prose :global(li) {
    margin-bottom: var(--space-2);
  }
  .prose :global(hr) {
    border: none;
    border-top: 1px solid var(--border-color);
    margin: var(--space-8) 0;
  }

  /* Library references — primary */
  .library-section {
    padding-top: var(--space-8);
    border-top: 1px solid var(--border-color);
    margin-bottom: var(--space-8);
  }
  .library-list {
    list-style: none;
    padding: 0;
  }
  .library-list li {
    padding: var(--space-3) 0;
    border-bottom: 1px solid var(--border-color);
  }
  .library-list li:last-child {
    border-bottom: none;
  }
  .library-list a {
    font-size: 0.9375rem;
    color: var(--accent);
    text-decoration: none;
    line-height: 1.5;
    display: block;
  }
  .library-list a:hover {
    text-decoration: underline;
    color: var(--purple-900);
  }
  .ref-cite {
    display: block;
    font-size: 0.8125rem;
    color: var(--text-tertiary);
    margin-top: var(--space-1);
  }

  /* Evidence section — external resources */
  .evidence-section {
    padding-top: var(--space-8);
    border-top: 1px solid var(--border-color);
    margin-bottom: var(--space-8);
  }
  .evidence-list {
    list-style: none;
    padding: 0;
  }
  .evidence-list li {
    padding: var(--space-2) 0;
    font-size: 0.9375rem;
    line-height: 1.6;
    border-bottom: 1px solid var(--border-color);
  }
  .evidence-list li:last-child {
    border-bottom: none;
  }
  .evidence-list a {
    color: var(--accent);
    text-decoration: none;
  }
  .evidence-list a:hover {
    text-decoration: underline;
  }

  /* Related FAQs */
  .related-section {
    padding-top: var(--space-8);
    border-top: 1px solid var(--border-color);
    margin-bottom: var(--space-8);
  }
  .related-list {
    list-style: none;
    padding: 0;
  }
  .related-list li {
    padding: var(--space-2) 0;
  }
  .related-list a {
    font-size: 0.9375rem;
    color: var(--accent);
    text-decoration: none;
    line-height: 1.6;
  }
  .related-list a:hover {
    text-decoration: underline;
    color: var(--purple-900);
  }

  .detail-heading {
    font-family: 'Cormorant Garamond', 'Georgia', serif;
    font-size: 1.125rem;
    font-weight: 600;
    margin-bottom: var(--space-4);
    color: var(--text-primary);
  }

  .back-link {
    padding-top: var(--space-6);
    margin-bottom: var(--space-10);
  }
  .back-link a {
    font-size: 0.9375rem;
    color: var(--accent);
    text-decoration: none;
  }
  .back-link a:hover {
    text-decoration: underline;
  }

  /* CTA */
  .faq-cta {
    text-align: center;
    padding: var(--space-8) 0;
    border-top: 1px solid var(--border-color);
    margin-top: var(--space-8);
  }
  .faq-cta h2 {
    font-size: 1.375rem;
    margin-bottom: var(--space-4);
  }
  .faq-cta__links {
    display: flex;
    gap: var(--space-4);
    justify-content: center;
    flex-wrap: wrap;
  }
</style>
