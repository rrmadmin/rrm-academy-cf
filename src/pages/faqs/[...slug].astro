---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { fetchAllFaqs, getRelatedFaqs, type FAQ } from '../../lib/faq';

export async function getStaticPaths() {
  const faqs = await fetchAllFaqs();

  return faqs.map(faq => ({
    params: { slug: faq.slug },
    props: { faq, allFaqs: faqs },
  }));
}

interface Props {
  faq: FAQ;
  allFaqs: FAQ[];
}

const { faq, allFaqs } = Astro.props;
const related = getRelatedFaqs(faq, allFaqs, 5);

// Published Answer is already HTML from Airtable (trusted source)
const htmlAnswer = faq.publishedAnswer || '';

// Meta
const pageTitle = faq.seoTitle || faq.question;
const metaDescription = faq.seoDescription
  || (faq.basicAnswer ? faq.basicAnswer.slice(0, 155) + (faq.basicAnswer.length > 155 ? '...' : '') : '');

const canonicalUrl = `https://rrmacademy.org/faqs/${faq.slug}`;

// QAPage JSON-LD
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'QAPage',
  mainEntity: {
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: faq.schemaAnswer || faq.basicAnswer || faq.publishedAnswer,
      url: canonicalUrl,
    },
  },
};
---
<BaseLayout
  title={pageTitle}
  description={metaDescription}
  canonicalUrl={canonicalUrl}
  jsonLd={jsonLd}
>
  <div class="page-wrapper" data-pagefind-body>
    <div class="container container--narrow">
      <!-- Breadcrumb -->
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span aria-hidden="true"> &rsaquo; </span>
        <a href="/faqs/">FAQ</a>
        <span aria-hidden="true"> &rsaquo; </span>
        <span>{faq.question.length > 50 ? faq.question.slice(0, 50) + '...' : faq.question}</span>
      </nav>

      <!-- Question -->
      <h1 class="faq-title">{faq.question}</h1>

      <span class="faq-category-badge">{faq.category}</span>

      <!-- Full Answer -->
      <div class="prose" set:html={htmlAnswer} />

      <!-- Research Library References -->
      {faq.libraryRefs.length > 0 && (
        <section class="library-section" aria-label="Research from the RRM Research Library">
          <h2 class="detail-heading">From the RRM Research Library</h2>
          <ul class="library-list">
            {faq.libraryRefs.map(ref => (
              <li>
                <a href={`/library/${ref.slug}/`}>{ref.title}</a>
                <span class="ref-cite">{ref.shortCitation}</span>
              </li>
            ))}
          </ul>
        </section>
      )}

      <!-- External Evidence URLs -->
      {faq.evidence.length > 0 && (
        <section class="evidence-section" aria-label="External resources">
          <h2 class="detail-heading">External Resources</h2>
          <ul class="evidence-list">
            {faq.evidence.map(e => (
              <li>
                {e.url ? (
                  <a href={e.url} target="_blank" rel="noopener noreferrer">{e.title || e.url}</a>
                ) : (
                  <span>{e.title}</span>
                )}
              </li>
            ))}
          </ul>
        </section>
      )}

      <!-- Related FAQs -->
      {related.length > 0 && (
        <section class="related-section" aria-label="Related questions">
          <h2 class="detail-heading">Related Questions</h2>
          <ul class="related-list">
            {related.map(r => (
              <li>
                <a href={`/faqs/${r.slug}/`}>{r.question}</a>
              </li>
            ))}
          </ul>
        </section>
      )}

      <!-- Back link -->
      <div class="back-link">
        <a href="/faqs/">&larr; Back to all FAQs</a>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .faq-title {
    font-size: 1.75rem;
    line-height: 1.25;
    letter-spacing: -0.01em;
    margin-bottom: var(--space-3);
  }
  @media (min-width: 769px) {
    .faq-title {
      font-size: 2.25rem;
    }
  }

  .faq-category-badge {
    display: inline-block;
    font-size: 0.6875rem;
    font-family: 'Inter', sans-serif;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-tertiary);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-sm, 4px);
    padding: var(--space-1) var(--space-2);
    margin-bottom: var(--space-6);
  }

  /* Prose — answer body typography */
  .prose {
    margin-top: var(--space-8);
    margin-bottom: var(--space-10);
    font-size: 1rem;
    line-height: 1.8;
    color: var(--text-primary);
  }
  .prose :global(h2) {
    font-family: 'Cormorant Garamond', 'Georgia', serif;
    font-size: 1.5rem;
    font-weight: 600;
    margin-top: var(--space-10);
    margin-bottom: var(--space-4);
    line-height: 1.3;
  }
  .prose :global(h3) {
    font-family: 'Cormorant Garamond', 'Georgia', serif;
    font-size: 1.25rem;
    font-weight: 600;
    margin-top: var(--space-8);
    margin-bottom: var(--space-3);
    line-height: 1.3;
  }
  .prose :global(p) {
    margin-bottom: var(--space-5);
  }
  .prose :global(a) {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .prose :global(a:hover) {
    color: var(--purple-900);
  }
  .prose :global(strong) {
    font-weight: 600;
  }
  .prose :global(blockquote) {
    border-left: 3px solid var(--sand-300);
    padding-left: var(--space-5);
    margin: var(--space-6) 0;
    color: var(--text-secondary);
    font-style: italic;
  }
  .prose :global(ul),
  .prose :global(ol) {
    margin-bottom: var(--space-5);
    padding-left: var(--space-6);
  }
  .prose :global(li) {
    margin-bottom: var(--space-2);
  }
  .prose :global(hr) {
    border: none;
    border-top: 1px solid var(--border-color);
    margin: var(--space-8) 0;
  }

  /* Library references — primary */
  .library-section {
    padding-top: var(--space-8);
    border-top: 1px solid var(--border-color);
    margin-bottom: var(--space-8);
  }
  .library-list {
    list-style: none;
    padding: 0;
  }
  .library-list li {
    padding: var(--space-3) 0;
    border-bottom: 1px solid var(--border-color);
  }
  .library-list li:last-child {
    border-bottom: none;
  }
  .library-list a {
    font-size: 0.9375rem;
    color: var(--accent);
    text-decoration: none;
    line-height: 1.5;
    display: block;
  }
  .library-list a:hover {
    text-decoration: underline;
    color: var(--purple-900);
  }
  .ref-cite {
    display: block;
    font-size: 0.8125rem;
    color: var(--text-tertiary);
    margin-top: var(--space-1);
  }

  /* Evidence section — external resources */
  .evidence-section {
    padding-top: var(--space-8);
    border-top: 1px solid var(--border-color);
    margin-bottom: var(--space-8);
  }
  .evidence-list {
    list-style: none;
    padding: 0;
  }
  .evidence-list li {
    padding: var(--space-2) 0;
    font-size: 0.9375rem;
    line-height: 1.6;
    border-bottom: 1px solid var(--border-color);
  }
  .evidence-list li:last-child {
    border-bottom: none;
  }
  .evidence-list a {
    color: var(--accent);
    text-decoration: none;
  }
  .evidence-list a:hover {
    text-decoration: underline;
  }

  /* Related FAQs */
  .related-section {
    padding-top: var(--space-8);
    border-top: 1px solid var(--border-color);
    margin-bottom: var(--space-8);
  }
  .related-list {
    list-style: none;
    padding: 0;
  }
  .related-list li {
    padding: var(--space-2) 0;
  }
  .related-list a {
    font-size: 0.9375rem;
    color: var(--accent);
    text-decoration: none;
    line-height: 1.6;
  }
  .related-list a:hover {
    text-decoration: underline;
    color: var(--purple-900);
  }

  .detail-heading {
    font-family: 'Cormorant Garamond', 'Georgia', serif;
    font-size: 1.125rem;
    font-weight: 600;
    margin-bottom: var(--space-4);
    color: var(--text-primary);
  }

  .back-link {
    padding-top: var(--space-6);
    margin-bottom: var(--space-10);
  }
  .back-link a {
    font-size: 0.9375rem;
    color: var(--accent);
    text-decoration: none;
  }
  .back-link a:hover {
    text-decoration: underline;
  }
</style>
