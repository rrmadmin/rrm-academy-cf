---
import BaseLayout from '../../layouts/BaseLayout.astro';
import MaybeShell from '../../components/MaybeShell.astro';
import SectionTocChips from '../../components/SectionTocChips.astro';
import { isShellEnabled } from '../../lib/shell-routes';
import BackToTop from '../../components/BackToTop.astro';
import PdfDownload from '../../components/PdfDownload.astro';
import LastUpdated from '../../components/LastUpdated.astro';
import GlossaryTerm from '../../components/GlossaryTerm.astro';
import glossaryData from '../../data/glossary.json';
import pageDates from '../../data/page-dates.json';
import { safeJsonLd } from '../../lib/jsonld';

const SHELL_ENABLED = isShellEnabled('guides');

const PAGE_PATH = '/glossary/';
const LAST_MODIFIED = pageDates.dates[PAGE_PATH] || '2026-03-15';

// Static part metadata (section IDs + display headings)
const PARTS = [
  { part: 'I',    id: 'core-rrm-principles',    title: 'Part I: Core RRM Principles',                    shortTitle: 'Core RRM Principles' },
  { part: 'II',   id: 'fertility-awareness',    title: 'Part II: Fertility Awareness and Charting Methods', shortTitle: 'Fertility Awareness and Charting Methods' },
  { part: 'III',  id: 'clinical-approaches',    title: 'Part III: Clinical Approaches',                  shortTitle: 'Clinical Approaches' },
  { part: 'IV',   id: 'diagnostic-tools',       title: 'Part IV: Diagnostic Tools and Techniques',       shortTitle: 'Diagnostic Tools and Techniques' },
  { part: 'V',    id: 'surgical-techniques',    title: 'Part V: Surgical Techniques',                    shortTitle: 'Surgical Techniques' },
  { part: 'VI',   id: 'conditions',             title: 'Part VI: Key Conditions Addressed by RRM',       shortTitle: 'Key Conditions Addressed by RRM' },
  { part: 'VII',  id: 'overlapping-disciplines',title: 'Part VII: Overlapping Disciplines',              shortTitle: 'Overlapping Disciplines' },
  { part: 'VIII', id: 'broader-framework',      title: 'Part VIII: The Broader RRM Framework',           shortTitle: 'The Broader RRM Framework' },
];

interface GlossaryTerm {
  id: string;
  slug: string;
  name: string;
  part: string;
  sortOrder: number;
  bodyHtml: string;
  abbreviation: string | null;
  pillarLink: string | null;
  status: string;
}
interface GlossaryReference {
  refNum: number;
  anchorText: string;
  url: string;
  publisher: string | null;
  journal: string | null;
}
interface GlossaryAbbreviation {
  abbreviation: string;
  fullTerm: string;
  termSlug: string | null;
  sortOrder: number;
}
// Only render published terms. Drafts/classified entries in glossary.json
// must not appear in visible H3s, the A-Z index, or the DefinedTermSet
// JSON-LD; the latter would otherwise emit @id values that point at spoke
// pages getStaticPaths refuses to build (status='published' filter), causing
// structured-data references to 404.
const terms: GlossaryTerm[] = (glossaryData.terms ?? []).filter((t: GlossaryTerm) => t.status === 'published');
const references: GlossaryReference[] = glossaryData.references ?? [];
const abbreviations: GlossaryAbbreviation[] = (glossaryData.abbreviations ?? [])
  .slice()
  .sort((a: GlossaryAbbreviation, b: GlossaryAbbreviation) => (a.sortOrder ?? 0) - (b.sortOrder ?? 0));

// Group terms by part (sort_order already preserved by parser)
const termsByPart: Record<string, GlossaryTerm[]> = {};
for (const p of PARTS) termsByPart[p.part] = [];
for (const t of terms) {
  if (termsByPart[t.part]) termsByPart[t.part].push(t);
}
for (const part of Object.keys(termsByPart)) {
  termsByPart[part].sort((a, b) => (a.sortOrder ?? 0) - (b.sortOrder ?? 0));
}

// Build A-Z index from all terms, grouped by first letter of name
function firstLetter(name: string): string {
  const m = name.match(/\p{L}/u);
  return m ? m[0].toUpperCase() : '#';
}
const azMap = new Map<string, GlossaryTerm[]>();
for (const t of terms) {
  const letter = firstLetter(t.name);
  if (!azMap.has(letter)) azMap.set(letter, []);
  azMap.get(letter)!.push(t);
}
for (const arr of azMap.values()) {
  arr.sort((a, b) => a.name.localeCompare(b.name, 'en', { sensitivity: 'base' }));
}
const azLetters = [...azMap.keys()].sort();

// Word count estimate (bodies + overview + key takeaways + refs).
// Strips HTML tags and counts whitespace-delimited tokens.
function wordsIn(html: string | null | undefined): number {
  if (!html) return 0;
  const text = html.replace(/<[^>]*>/g, ' ').replace(/\s+/g, ' ').trim();
  return text ? text.split(' ').length : 0;
}
const bodyWords = terms.reduce((n, t) => n + wordsIn(t.bodyHtml), 0);
const FIXED_WORD_OVERHEAD = 600; // intro, key takeaways, abbr table labels, etc.
const wordCount = bodyWords + FIXED_WORD_OVERHEAD;

// Schema: MedicalWebPage + Article
const pageSchema = {
  '@context': 'https://schema.org',
  '@type': ['Article', 'MedicalWebPage'],
  headline: 'RRM Glossary: A Detailed Reference to Restorative Reproductive Medicine',
  description: 'A detailed, evidence-based glossary of Restorative Reproductive Medicine (RRM) terminology covering core principles, fertility awareness methods, NaProTechnology, diagnostic tools, surgical techniques, key conditions, and abbreviations.',
  // Glossary is a compiled reference work — RRM Academy is the author entity,
  // Dr. Whittaker is the medical reviewer. Pillar guides (/what-is-rrm/, etc.)
  // keep Naomi as author since they're written in her clinical voice.
  author: { '@id': 'https://rrmacademy.org/#organization' },
  reviewedBy: { '@id': 'https://rrmacademy.org/#naomi-whittaker' },
  publisher: {
    '@type': 'EducationalOrganization',
    '@id': 'https://rrmacademy.org/#organization',
    name: 'RRM Academy',
  },
  datePublished: '2026-03-15',
  dateModified: LAST_MODIFIED,
  wordCount,
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': 'https://rrmacademy.org/glossary/',
  },
  about: {
    '@type': 'MedicalTherapy',
    name: 'Restorative Reproductive Medicine',
    alternateName: 'RRM',
  },
  articleSection: [
    ...PARTS.map(p => p.shortTitle),
    'Abbreviations and Quick Reference',
    'References',
  ],
  hasPart: [
    { '@type': 'WebPageElement', name: 'Overview', url: 'https://rrmacademy.org/glossary/#overview' },
    ...PARTS.map(p => ({
      '@type': 'WebPageElement',
      name: p.shortTitle,
      url: `https://rrmacademy.org/glossary/#${p.id}`,
    })),
    { '@type': 'WebPageElement', name: 'Abbreviations and Quick Reference', url: 'https://rrmacademy.org/glossary/#abbreviations' },
    { '@type': 'WebPageElement', name: 'References', url: 'https://rrmacademy.org/glossary/#references' },
  ],
};

// Breadcrumb schema
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://rrmacademy.org/' },
    { '@type': 'ListItem', position: 2, name: 'Guides', item: 'https://rrmacademy.org/guides/' },
    { '@type': 'ListItem', position: 3, name: 'Glossary', item: 'https://rrmacademy.org/glossary/' },
  ],
};

// DefinedTermSet: each term as a citable AEO entity (@id=#slug).
// Prefer the bold lead sentence; if short, also include the next paragraph for AEO citation pickup.
// Target ~600-800 chars (AEO sweet spot per SEO Operator review 2026-04-18).
function extractDescription(bodyHtml: string): string {
  if (!bodyHtml) return '';
  const stripped = bodyHtml.replace(/<sup\b[^>]*>[\s\S]*?<\/sup>/g, '').replace(/<[^>]+>/g, ' ').replace(/\s+/g, ' ').trim();
  const boldMatch = bodyHtml.match(/<strong>([\s\S]+?)<\/strong>/);
  if (boldMatch) {
    const bold = boldMatch[1].replace(/<[^>]+>/g, ' ').replace(/\s+/g, ' ').trim();
    if (bold.length >= 400) return bold.length > 800 ? bold.slice(0, 797) + '...' : bold;
    const idx = stripped.indexOf(bold);
    const start = idx >= 0 ? idx : 0;
    const window = stripped.slice(start, start + 800).trim();
    return window.length > 800 ? window.slice(0, 797) + '...' : window;
  }
  return stripped.length > 800 ? stripped.slice(0, 797) + '...' : stripped;
}
const TERM_SET_ID = 'https://rrmacademy.org/glossary/#defined-term-set';
const definedTermSetSchema = {
  '@context': 'https://schema.org',
  '@type': 'DefinedTermSet',
  '@id': TERM_SET_ID,
  name: 'RRM Glossary',
  description: 'Evidence-based glossary of Restorative Reproductive Medicine terminology, methods, conditions, and procedures.',
  url: 'https://rrmacademy.org/glossary/',
  inLanguage: 'en-US',
  hasDefinedTerm: terms.map(t => {
    const entry: Record<string, unknown> = {
      '@type': 'DefinedTerm',
      '@id': `https://rrmacademy.org/glossary/${t.slug}/#term`,
      name: t.name,
      description: extractDescription(t.bodyHtml),
      inDefinedTermSet: TERM_SET_ID,
      url: `https://rrmacademy.org/glossary/${t.slug}/`,
    };
    if (t.abbreviation) entry.termCode = t.abbreviation;
    return entry;
  }),
};
---

<BaseLayout
  title="RRM Glossary: A Detailed Reference to Restorative Reproductive Medicine"
  description="Evidence-based glossary of RRM terminology: fertility awareness methods, NaProTechnology, diagnostic tools, surgical techniques, and key conditions."
  canonicalUrl="https://rrmacademy.org/glossary/"
  ogType="article"
  publishDate="2026-03-15"
  jsonLd={pageSchema}
  speakable={['.pillar-lead', '.pillar-lead strong']}
  chrome={SHELL_ENABLED ? 'shell' : 'default'}
>
  <!-- Separate JSON-LD block for breadcrumbs -->
  <script type="application/ld+json" set:html={safeJsonLd(breadcrumbSchema)} />

  <!-- DefinedTermSet: per-term citable entities for AEO -->
  <script type="application/ld+json" set:html={safeJsonLd(definedTermSetSchema)} />

  <MaybeShell enabled={SHELL_ENABLED} context="page" currentPath={Astro.url.pathname} hasRail={SHELL_ENABLED}>
  {/* Right rail: A-Z index lives here when the shell is enabled (Brian
      preference 2026-05-07). The legacy <details> at the top of the page
      below is suppressed via the `!SHELL_ENABLED` gate to avoid duplication. */}
  {SHELL_ENABLED && (
    <Fragment slot="rail">
      <section class="app-shell-middle-column__section glossary-rail" aria-label="Alphabetical index of glossary terms">
        <h2 class="app-shell-middle-column__heading">A-Z index ({terms.length})</h2>
        {azLetters.map(letter => (
          <>
            <p class="glossary-rail__letter" aria-hidden="true">{letter}</p>
            <ol class="app-shell-middle-column__list" aria-label={`Terms starting with ${letter}`}>
              {azMap.get(letter).map(t => (
                <li><a href={`#${t.slug}`}>{t.name}</a></li>
              ))}
            </ol>
          </>
        ))}
      </section>
    </Fragment>
  )}

  <div class="page-wrapper" data-pagefind-body>
    <span data-pagefind-meta="type:Guide" style="display:none"></span>
    <span data-pagefind-meta="title:RRM Glossary: A Detailed Reference" style="display:none"></span>
    <div class="container">

      <!-- Breadcrumb -->
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span aria-hidden="true"> &rsaquo; </span>
        <a href="/guides/">Guides</a>
        <span aria-hidden="true"> &rsaquo; </span>
        <span>Glossary</span>
      </nav>

      <h1 class="animate-enter" style="--stagger: 0;">RRM Glossary: A Detailed Reference to Restorative Reproductive Medicine</h1>

      {/* Glossary byline: org-authored + clinically reviewed. Uses the
          canonical .author-avatar-stack + .has-reviewer pattern (see
          /femm/index.astro for the precedent). JSON-LD upstream mirrors
          this with author=#organization + reviewedBy=#naomi-whittaker.
          Pillar guides written in Naomi's clinical voice (/what-is-rrm/,
          /naprotechnology/, etc.) keep her as primary author. */}
      <div class="author-byline">
        <div class="author-avatar-stack">
          <img src="/apple-touch-icon.png" alt="" aria-hidden="true" class="author-byline__photo" width="48" height="48" />
          <img src="/images/authors/naomi-whittaker.webp" alt="" aria-hidden="true" class="author-byline__photo" width="48" height="48" />
        </div>
        <div class="author-byline__text has-reviewer">
          <span class="byline-author">By <strong>RRM Academy</strong></span>
          <span class="byline-reviewer">Reviewed by <strong><a href="/commentary/rrm-spotlight-naomi-whittaker-md/">Dr. Naomi Whittaker, MD, Board-Certified OBGYN, MIGS, NFPMC, FCI</a></strong></span>
          <LastUpdated path="/glossary/" prefix="Updated" class="byline-date" />
          <PdfDownload slug="glossary" />
        </div>
      </div>

      <!-- Mobile TOC -->
      <details class="toc-mobile">
        <summary>On this page</summary>
        <ol>
          <li><a href="#overview">Overview</a></li>
          {PARTS.map(p => (
            <li><a href={`#${p.id}`}>{p.shortTitle}</a></li>
          ))}
          <li><a href="#abbreviations">Abbreviations and Quick Reference</a></li>
          <li><a href="#references">References</a></li>
        </ol>
      </details>

      {/* A-Z alphabetical index (auto-generated from data).
          Letters are visual-only dividers (not headings) to preserve
          h1 -> h2 -> h3 document outline for assistive tech.
          When SHELL_ENABLED, the rail (right column) holds the A-Z index
          instead, so we suppress this top-of-page <details> to avoid
          duplication. */}
      {!SHELL_ENABLED && (
        <details class="az-index">
          <summary>A-Z index of all terms ({terms.length})</summary>
          <nav aria-label="Alphabetical index of glossary terms">
            {azLetters.map(letter => (
              <>
                <p class="az-letter" aria-hidden="true">{letter}</p>
                <ul class="az-list" aria-label={`Terms starting with ${letter}`}>
                  {azMap.get(letter).map(t => (
                    <li><a href={`#${t.slug}`}>{t.name}</a></li>
                  ))}
                </ul>
              </>
            ))}
          </nav>
        </details>
      )}

      {/* On-this-page chip callout — replaces the sticky sidebar TOC when
          the shell is on. With a left site nav + right A-Z rail eating
          horizontal space, an additional sticky internal TOC is too cramped.
          The callout sits between the byline and Overview so readers see
          the full scope at a glance, then scroll. */}
      {SHELL_ENABLED && (
        <SectionTocChips items={[
          { href: '#overview', label: 'Overview' },
          ...PARTS.map(p => ({ href: `#${p.id}`, label: p.shortTitle })),
          { href: '#abbreviations', label: 'Abbreviations' },
          { href: '#references', label: 'References' },
        ]} />
      )}

      {/* Article layout: sidebar TOC + main content. Without the shell, the
          left sticky TOC carries the section nav. With the shell, the
          .section-toc callout above does it and `.article-layout` collapses
          to a single column via the .article-layout--no-toc modifier. */}
      <div class:list={['article-layout', { 'article-layout--no-toc': SHELL_ENABLED }]}>

        {/* Desktop TOC (sticky sidebar, 1024px+) — hidden when SHELL_ENABLED */}
        {!SHELL_ENABLED && (
          <nav class="toc" aria-label="Table of contents">
            <p class="toc-heading">On this page</p>
            <ol>
              <li><a href="#overview">Overview</a></li>
              {PARTS.map(p => (
                <li><a href={`#${p.id}`}>{p.shortTitle}</a></li>
              ))}
              <li><a href="#abbreviations">Abbreviations</a></li>
              <li><a href="#references">References</a></li>
            </ol>
          </nav>
        )}

        <!-- Main content -->
        <article class="prose glossary-content">

          <!-- Overview -->
          <section id="overview">
            <h2>Overview</h2>
            <p class="pillar-lead"><strong>This glossary defines the clinical terms, methods, and conditions used in restorative reproductive medicine (RRM), drawn from peer-reviewed research and active clinical practice, and maintained by RRM Academy for patients and clinicians.</strong></p>
            <p><strong>Restorative Reproductive Medicine (RRM) is a specialized field of medicine that focuses on identifying the underlying health conditions contributing to reproductive dysfunction, then treating them to restore the natural functions of the reproductive system.</strong> Unlike conventional approaches that suppress or bypass normal physiology, RRM seeks to cooperate with the body: diagnosing, understanding, and addressing underlying health concerns to improve overall wellness and restore reproductive abilities. This glossary provides a thorough, well-cited reference for the terminology, methods, conditions, and procedures encountered within the RRM framework.<sup><a href="#ref-1">1</a></sup></p>
          </section>

          <!-- Parts I-VIII: data-driven -->
          {PARTS.map(p => (
            <section id={p.id}>
              <h2>{p.shortTitle}</h2>
              {termsByPart[p.part].map(t => (
                <GlossaryTerm term={t} headingLevel="h3" mode="pillar" />
              ))}
            </section>
          ))}

          <!-- Abbreviations and Quick Reference (data-driven from glossary_abbreviation) -->
          <section id="abbreviations">
            <h2>Abbreviations and Quick Reference</h2>
            <div class="table-wrap">
              <table>
                <thead>
                  <tr>
                    <th>Abbreviation</th>
                    <th>Full Term</th>
                  </tr>
                </thead>
                <tbody>
                  {abbreviations.map(a => (
                    <tr>
                      <td>{a.abbreviation}</td>
                      <td>{a.termSlug
                        ? <a href={`#${a.termSlug}`}>{a.fullTerm}</a>
                        : a.fullTerm}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </section>

          <!-- References: data-driven from glossary_reference -->
          <section class="references" id="references">
            <h2>References</h2>
            <ol>
              {references.map(r => {
                const safeUrl = /^(https?:|mailto:|tel:|\/|#)/i.test((r.url || '').trim()) ? r.url : '#';
                return (
                  <li id={`ref-${r.refNum}`}>
                    <a
                      href={safeUrl}
                      rel={safeUrl.startsWith('https://rrmacademy.org') ? undefined : 'noopener'}
                      target={safeUrl.startsWith('https://rrmacademy.org') ? undefined : '_blank'}
                    >{r.anchorText}</a>.{r.journal ? <em>{r.journal}</em> : r.publisher}.
                  </li>
                );
              })}
            </ol>
          </section>

          <div class="cta-box">
            <h3>Ready to learn more?</h3>
            <p>Explore our other guides on specific RRM approaches and topics.</p>
            <p><a href="/naprotechnology/" class="btn btn--primary">NaProTechnology Guide</a></p>
            <p><a href="/femm/" class="btn btn--secondary">FEMM Guide</a></p>
            <p><a href="/neofertility/" class="btn btn--secondary">NeoFertility Guide</a></p>
            <p><a href="/what-is-rrm/" class="btn btn--secondary">What is RRM?</a></p>
            <p><a href="/library/" class="btn btn--secondary">Browse the Research Library</a></p>
          </div>

          <p class="disclaimer"><em>This content is for educational purposes only and does not constitute medical advice. Consult an RRM clinician or healthcare provider for guidance specific to your situation. Statistics represent published research averages, not guarantees of individual outcomes.</em></p>

        </article>
      </div>
    </div>
  </div>
  <p class="page-updated">Last updated: April 2026 &middot; {terms.length} terms &middot; {references.length} references</p>
  <BackToTop />
  </MaybeShell>
</BaseLayout>

<style is:global>
  /* Rail A-Z index (shell-enabled glossary). Letters are visual-only
     dividers; no <h*> tags so the document outline stays clean. is:global
     so the rules apply inside AppShellChrome's slot (Astro scopes <style>
     to the component by default, which would skip slotted content). */
  .glossary-rail__letter {
    font-family: 'Cormorant Garamond', 'Georgia', serif;
    font-size: 1rem;
    font-weight: 600;
    color: var(--text-primary);
    margin: var(--space-3) 0 var(--space-1);
    padding-bottom: 2px;
    border-bottom: 1px solid var(--border-color);
  }
  .glossary-rail__letter:first-child {
    margin-top: 0;
  }
  .glossary-rail .app-shell-middle-column__list {
    margin-bottom: var(--space-2);
  }
</style>

<style>
  .author-byline {
    font-size: 0.875rem;
    color: var(--text-secondary);
    margin-top: calc(-1 * var(--space-2));
    margin-bottom: var(--space-6);
    line-height: 1.6;
  }

  .table-wrap {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    margin-bottom: var(--space-6);
  }

  table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.875rem;
  }

  th {
    background: var(--bg-surface);
    font-weight: 600;
    padding: var(--space-3) var(--space-4);
    text-align: left;
    border-bottom: 2px solid var(--border-color);
  }

  td {
    padding: var(--space-3) var(--space-4);
    border-bottom: 1px solid var(--border-color);
    vertical-align: top;
    line-height: 1.5;
  }

  tr:last-child td {
    border-bottom: none;
  }

  .references {
    font-size: 0.875rem;
    line-height: 1.7;
    color: var(--text-secondary);
  }

  .references li {
    margin-bottom: var(--space-3);
  }

  .cta-box {
    background: var(--bg-surface);
    border: none;
    border-radius: var(--radius-md);
    padding: var(--space-8);
    text-align: center;
    margin-top: var(--space-10);
    box-shadow: var(--shadow-sm);
  }

  .cta-box h3 {
    font-family: 'Cormorant Garamond', 'Georgia', serif;
    margin-bottom: var(--space-3);
  }

  .cta-box p {
    margin-bottom: var(--space-4);
  }

  .cta-box p:last-child {
    margin-bottom: 0;
  }

  .disclaimer {
    font-size: 0.8125rem;
    color: var(--text-secondary);
    margin-top: var(--space-8);
    line-height: 1.6;
  }

  /* Override container width for article layout */
  @media (min-width: 1024px) {
    .container {
      max-width: calc(var(--max-width-article) + 220px + var(--space-10) + var(--space-8) * 2);
    }
  }

  /* Glossary-specific: tighter term spacing for scannable reference format */
  .prose h3 {
    margin-top: var(--space-8);
    margin-bottom: var(--space-2);
  }

  .prose section h3:first-of-type {
    margin-top: var(--space-4);
  }

  /* A-Z alphabetical index */
  .az-index {
    margin: var(--space-4) 0 var(--space-6);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
    background: var(--bg-surface);
  }

  .az-index summary {
    padding: var(--space-3) var(--space-4);
    cursor: pointer;
    font-weight: 600;
    font-size: 0.9375rem;
  }

  .az-index[open] summary {
    border-bottom: 1px solid var(--border-color);
  }

  .az-index nav {
    padding: var(--space-4);
  }

  .az-letter {
    font-family: 'Cormorant Garamond', 'Georgia', serif;
    font-size: 1.375rem;
    margin: var(--space-4) 0 var(--space-2);
    padding-bottom: var(--space-1);
    border-bottom: 1px solid var(--border-color);
  }

  .az-letter:first-child {
    margin-top: 0;
  }

  .az-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-1) var(--space-4);
    font-size: 0.9375rem;
    line-height: 1.5;
  }

  @media (min-width: 640px) {
    .az-list {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (min-width: 1024px) {
    .az-list {
      grid-template-columns: 1fr 1fr 1fr;
    }
  }

  .az-list li {
    margin: 0;
    padding: var(--space-1) 0;
  }
</style>
