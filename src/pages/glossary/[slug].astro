---
// Per-term glossary spoke page. One static route per published glossary_term row.
// Renders the same body via <GlossaryTerm /> as the pillar at /glossary/, so D1 stays
// SSOT and pillar-vs-spoke drift is structurally impossible.
//
// JSON-LD: 3 blocks. DefinedTerm + MedicalWebPage cross-reference each other via @id
// (subjectOf <-> mainEntity), with the spoke registered as a member of the pillar's
// DefinedTermSet. BreadcrumbList completes the trio.
import BaseLayout from '../../layouts/BaseLayout.astro';
import GlossaryTerm from '../../components/GlossaryTerm.astro';
import LastUpdated from '../../components/LastUpdated.astro';
import glossaryData from '../../data/glossary.json';

interface RelatedTerm {
  slug: string;
  name: string;
  part: string;
}

interface RelatedContentItem {
  slug: string;
  title: string;
}

interface CitedReference {
  refNum: number;
  anchorText: string;
  url: string | null;
  publisher: string | null;
  journal: string | null;
}

interface GlossaryTermRow {
  id: string;
  slug: string;
  name: string;
  part: string;
  sortOrder: number;
  bodyHtml: string;
  abbreviation: string | null;
  pillarLink: string | null;
  status: string;
  createdAt?: string;
  updatedAt?: string;
  relatedTerms?: RelatedTerm[];
  relatedContent?: {
    library?: RelatedContentItem[];
    faqs?: RelatedContentItem[];
    courses?: RelatedContentItem[];
  };
  citedReferences?: CitedReference[];
}

export function getStaticPaths() {
  const terms = (glossaryData.terms ?? []) as GlossaryTermRow[];
  return terms
    .filter((t) => t.status === 'published')
    .map((t) => ({ params: { slug: t.slug }, props: { term: t } }));
}

interface Props {
  term: GlossaryTermRow;
}

const { term } = Astro.props;

const TERM_SET_ID = 'https://rrmacademy.org/glossary/#defined-term-set';
const SPOKE_URL = `https://rrmacademy.org/glossary/${term.slug}/`;
const TERM_ID = `https://rrmacademy.org/glossary/${term.slug}/#term`;
const WEBPAGE_ID = `https://rrmacademy.org/glossary/${term.slug}/#webpage`;

// Description extractor mirrored from the pillar (src/pages/glossary/index.astro).
// Prefer the bold lead sentence; fall back to body window. Target ~600-800 chars
// for the DefinedTerm.description (AEO sweet spot per SEO Operator review 2026-04-18).
function extractDescription(bodyHtml: string): string {
  if (!bodyHtml) return '';
  const stripped = bodyHtml.replace(/<sup>[\s\S]*?<\/sup>/g, '').replace(/<[^>]+>/g, ' ').replace(/\s+/g, ' ').trim();
  const boldMatch = bodyHtml.match(/<strong>([\s\S]+?)<\/strong>/);
  if (boldMatch) {
    const bold = boldMatch[1].replace(/<[^>]+>/g, ' ').replace(/\s+/g, ' ').trim();
    if (bold.length >= 400) return bold.length > 800 ? bold.slice(0, 797) + '...' : bold;
    const idx = stripped.indexOf(bold);
    const start = idx >= 0 ? idx : 0;
    const window = stripped.slice(start, start + 800).trim();
    return window.length > 800 ? window.slice(0, 797) + '...' : window;
  }
  return stripped.length > 800 ? stripped.slice(0, 797) + '...' : stripped;
}

// SEO meta description: 120-160 chars from the body. Tighter window than the
// long-form DefinedTerm.description above.
function extractSeoDescription(bodyHtml: string, name: string): string {
  if (!bodyHtml) return `${name} in restorative reproductive medicine. Glossary entry from RRM Academy.`;
  const stripped = bodyHtml.replace(/<sup>[\s\S]*?<\/sup>/g, '').replace(/<[^>]+>/g, ' ').replace(/\s+/g, ' ').trim();
  if (stripped.length <= 160) return stripped;
  // Trim to a word boundary near 157 chars to leave room for the ellipsis.
  const cut = stripped.slice(0, 157);
  const lastSpace = cut.lastIndexOf(' ');
  const truncated = lastSpace > 120 ? cut.slice(0, lastSpace) : cut;
  return truncated + '...';
}

const longDescription = extractDescription(term.bodyHtml);
const seoDescription = extractSeoDescription(term.bodyHtml, term.name);

// Block 1: DefinedTerm (primary entity)
const definedTermSchema: Record<string, unknown> = {
  '@context': 'https://schema.org',
  '@type': 'DefinedTerm',
  '@id': TERM_ID,
  name: term.name,
  description: longDescription,
  url: SPOKE_URL,
  inDefinedTermSet: TERM_SET_ID,
  subjectOf: { '@id': WEBPAGE_ID },
};
if (term.abbreviation) definedTermSchema.termCode = term.abbreviation;

// Block 2: MedicalWebPage (page wrapper)
const medicalWebPageSchema: Record<string, unknown> = {
  '@context': 'https://schema.org',
  '@type': 'MedicalWebPage',
  '@id': WEBPAGE_ID,
  url: SPOKE_URL,
  name: `${term.name} | RRM Glossary`,
  description: seoDescription,
  mainEntity: { '@id': TERM_ID },
  isPartOf: { '@id': TERM_SET_ID },
  about: { '@type': 'MedicalTherapy', name: 'Restorative Reproductive Medicine', alternateName: 'RRM' },
  author: { '@id': 'https://rrmacademy.org/#naomi-whittaker' },
  publisher: { '@id': 'https://rrmacademy.org/#organization' },
  inLanguage: 'en-US',
  specialty: { '@type': 'MedicalSpecialty', name: 'Reproductive Medicine' },
};
if (term.createdAt) medicalWebPageSchema.datePublished = term.createdAt;
if (term.updatedAt) medicalWebPageSchema.dateModified = term.updatedAt;

// Inline speakable into MedicalWebPage so we keep exactly 3 JSON-LD blocks
// (S4 snapshot gate). BaseLayout's `speakable` prop emits a 4th block and
// is documented as opt-out-via-inline. Term name + first body paragraph.
medicalWebPageSchema.speakable = {
  '@type': 'SpeakableSpecification',
  cssSelector: ['article.prose h1', 'article.prose > p:first-of-type'],
};

// Block 3: BreadcrumbList (Home > Guides > Glossary > term.name)
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://rrmacademy.org/' },
    { '@type': 'ListItem', position: 2, name: 'Guides', item: 'https://rrmacademy.org/guides/' },
    { '@type': 'ListItem', position: 3, name: 'Glossary', item: 'https://rrmacademy.org/glossary/' },
    { '@type': 'ListItem', position: 4, name: term.name, item: SPOKE_URL },
  ],
};
---

<BaseLayout
  title={`${term.name} | RRM Glossary`}
  description={seoDescription}
  canonicalUrl={SPOKE_URL}
  ogType="article"
  publishDate={term.createdAt}
  jsonLd={definedTermSchema}
>
  <!-- Note: speakable is inlined into MedicalWebPage above (not via BaseLayout
       speakable prop) so we ship exactly 3 JSON-LD blocks (snapshot gate S4). -->
  <!-- Additional JSON-LD blocks: MedicalWebPage wrapper + BreadcrumbList. -->
  <script type="application/ld+json" set:html={JSON.stringify(medicalWebPageSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <div class="page-wrapper" data-pagefind-body>
    <span data-pagefind-meta="type:Glossary" style="display:none"></span>
    <span data-pagefind-meta={`title:${term.name}`} style="display:none"></span>
    <div class="container">

      <!-- Breadcrumb (matches pillar pattern) -->
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span aria-hidden="true"> &rsaquo; </span>
        <a href="/guides/">Guides</a>
        <span aria-hidden="true"> &rsaquo; </span>
        <a href="/glossary/">Glossary</a>
        <span aria-hidden="true"> &rsaquo; </span>
        <span>{term.name}</span>
      </nav>

      <article class="prose">
        <GlossaryTerm
          term={term}
          headingLevel="h1"
          mode="spoke"
          keepLocalRefAnchors={!!(term.citedReferences && term.citedReferences.length > 0)}
        >
          <div slot="post-heading" class="author-byline">
            <img src="/images/authors/naomi-whittaker.webp" alt="Dr. Naomi Whittaker, MD" class="author-byline__photo" width="40" height="40" />
            <div class="author-byline__text">
              <span>By <strong><a href="/commentary/rrm-spotlight-naomi-whittaker-md/">Dr. Naomi Whittaker, MD, Board-Certified OBGYN, MIGS, NFPMC, FCI</a></strong></span>
              <LastUpdated date={term.updatedAt || term.createdAt} prefix="Updated" />
            </div>
          </div>
        </GlossaryTerm>

        {term.citedReferences && term.citedReferences.length > 0 && (
          <section class="term-sources" aria-labelledby="term-sources-heading">
            <h2 id="term-sources-heading" class="term-sources__heading">Sources</h2>
            <ol class="term-sources__list">
              {term.citedReferences.map((r) => (
                <li id={`ref-${r.refNum}`} class="term-sources__item">
                  {r.url
                    ? <a href={r.url} target="_blank" rel="noopener">{r.anchorText || r.url}</a>
                    : <span>{r.anchorText}</span>}
                  {r.journal && <span class="term-sources__journal">. <em>{r.journal}</em></span>}
                  {r.publisher && !r.journal && <span class="term-sources__publisher">. {r.publisher}</span>}
                </li>
              ))}
            </ol>
          </section>
        )}

        {term.relatedTerms && term.relatedTerms.length > 0 && (
          <aside class="related-terms" aria-labelledby="related-terms-heading">
            <h2 id="related-terms-heading" class="related-terms__heading">Related terms</h2>
            <ul class="related-terms__list">
              {term.relatedTerms.map((rt) => (
                <li class="related-terms__item">
                  <a href={`/glossary/${rt.slug}/`} class="related-terms__link">{rt.name}</a>
                </li>
              ))}
            </ul>
          </aside>
        )}

        {term.relatedContent && (
          (term.relatedContent.library?.length || term.relatedContent.faqs?.length || term.relatedContent.courses?.length) ? (
            <section class="discussed-in" aria-labelledby="discussed-in-heading">
              <h2 id="discussed-in-heading" class="discussed-in__heading">Discussed in</h2>
              <div class="discussed-in__grid">
                {term.relatedContent.library && term.relatedContent.library.length > 0 && (
                  <div class="discussed-in__group">
                    <h3 class="discussed-in__label">Research library</h3>
                    <ul class="discussed-in__list">
                      {term.relatedContent.library.map((item) => (
                        <li><a href={`/library/${item.slug}/`}>{item.title}</a></li>
                      ))}
                    </ul>
                  </div>
                )}
                {term.relatedContent.faqs && term.relatedContent.faqs.length > 0 && (
                  <div class="discussed-in__group">
                    <h3 class="discussed-in__label">Patient questions</h3>
                    <ul class="discussed-in__list">
                      {term.relatedContent.faqs.map((item) => (
                        <li><a href={`/faqs/${item.slug}/`}>{item.title}</a></li>
                      ))}
                    </ul>
                  </div>
                )}
                {term.relatedContent.courses && term.relatedContent.courses.length > 0 && (
                  <div class="discussed-in__group">
                    <h3 class="discussed-in__label">Courses</h3>
                    <ul class="discussed-in__list">
                      {term.relatedContent.courses.map((item) => (
                        <li><a href={`/courses/${item.slug}/`}>{item.title}</a></li>
                      ))}
                    </ul>
                  </div>
                )}
              </div>
            </section>
          ) : null
        )}

        <div class="cta-box">
          <h3>Back to the full glossary</h3>
          <p>Browse all RRM terminology, methods, conditions, and references.</p>
          <p><a href="/glossary/" class="btn btn--primary">Open the RRM Glossary</a></p>
          <p><a href="/library/" class="btn btn--secondary">Browse the Research Library</a></p>
        </div>

        <p class="disclaimer"><em>This content is for educational purposes only and does not constitute medical advice. Consult an RRM clinician or healthcare provider for guidance specific to your situation.</em></p>
      </article>
    </div>
  </div>
</BaseLayout>

<style>
  /* .gloss-xref styling lives in src/styles/global.css so pillar and spoke
     share one rendering path. */

  .author-byline {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin: var(--space-4) 0 var(--space-8);
    padding-bottom: var(--space-4);
    border-bottom: 1px solid var(--border-color);
  }
  .author-byline__photo {
    flex-shrink: 0;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    object-fit: cover;
  }
  .author-byline__text {
    display: flex;
    flex-direction: column;
    gap: 2px;
    font-size: 0.8125rem;
    color: var(--text-secondary);
    line-height: 1.4;
  }
  .author-byline__text a {
    color: var(--text-secondary);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: color 0.15s ease, border-color 0.15s ease;
  }
  .author-byline__text a:hover {
    color: var(--accent);
    border-bottom-color: var(--accent);
  }

  .term-sources {
    margin-top: var(--space-10);
    padding: var(--space-6);
    background: var(--bg-surface);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
  }
  .term-sources__heading {
    font-family: 'Cormorant Garamond', 'Georgia', serif;
    font-size: 1.375rem;
    font-weight: 600;
    margin: 0 0 var(--space-4) 0;
    color: var(--text-primary);
  }
  .term-sources__list {
    list-style: decimal;
    padding-left: var(--space-5);
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
  .term-sources__item {
    font-size: 0.875rem;
    color: var(--text-secondary);
    line-height: 1.5;
    scroll-margin-top: 5rem;
  }
  .term-sources__item a {
    color: var(--text-primary);
    text-decoration: none;
    border-bottom: 1px solid var(--purple-200);
    transition: color 0.15s ease, border-color 0.15s ease;
  }
  .term-sources__item a:hover {
    color: var(--accent);
    border-bottom-color: var(--accent);
  }
  .term-sources__journal,
  .term-sources__publisher {
    color: var(--text-secondary);
  }

  .related-terms {
    margin-top: var(--space-10);
    padding: var(--space-6);
    background: var(--bg-surface);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
  }
  .related-terms__heading {
    font-family: 'Cormorant Garamond', 'Georgia', serif;
    font-size: 1.375rem;
    font-weight: 600;
    margin: 0 0 var(--space-3) 0;
    color: var(--text-primary);
  }
  .related-terms__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }
  .related-terms__item {
    margin: 0;
  }
  .related-terms__link {
    display: inline-block;
    padding: 6px 12px;
    background: var(--bg-body);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-pill);
    font-size: 0.8125rem;
    color: var(--text-secondary);
    text-decoration: none;
    transition: background 0.15s ease, color 0.15s ease, border-color 0.15s ease;
  }
  .related-terms__link:hover {
    background: var(--purple-50);
    color: var(--accent);
    border-color: var(--purple-200);
    text-decoration: none;
  }

  .discussed-in {
    margin-top: var(--space-8);
    padding: var(--space-6);
    background: var(--bg-surface);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
  }
  .discussed-in__heading {
    font-family: 'Cormorant Garamond', 'Georgia', serif;
    font-size: 1.375rem;
    font-weight: 600;
    margin: 0 0 var(--space-4) 0;
    color: var(--text-primary);
  }
  .discussed-in__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: var(--space-6);
  }
  .discussed-in__group {
    min-width: 0;
  }
  .discussed-in__label {
    font-family: 'Inter', sans-serif;
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-tertiary);
    margin: 0 0 var(--space-3) 0;
  }
  .discussed-in__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  .discussed-in__list li {
    margin: 0;
  }
  .discussed-in__list a {
    font-size: 0.9375rem;
    color: var(--text-primary);
    text-decoration: none;
    line-height: 1.45;
    border-bottom: 1px solid transparent;
    transition: color 0.15s ease, border-color 0.15s ease;
  }
  .discussed-in__list a:hover {
    color: var(--accent);
    border-bottom-color: var(--accent);
  }

  .cta-box {
    background: var(--bg-surface);
    border: none;
    border-radius: var(--radius-md);
    padding: var(--space-8);
    text-align: center;
    margin-top: var(--space-10);
    box-shadow: var(--shadow-sm);
  }

  .cta-box h3 {
    font-family: 'Cormorant Garamond', 'Georgia', serif;
    margin-bottom: var(--space-3);
  }

  .cta-box p {
    margin-bottom: var(--space-4);
  }

  .cta-box p:last-child {
    margin-bottom: 0;
  }

  .disclaimer {
    font-size: 0.8125rem;
    color: var(--text-secondary);
    margin-top: var(--space-8);
    line-height: 1.6;
  }
</style>
