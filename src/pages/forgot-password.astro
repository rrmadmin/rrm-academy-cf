---
import BaseLayout from '../layouts/BaseLayout.astro';
import { TURNSTILE_SITE_KEY } from '../lib/turnstile';
---
<BaseLayout
  title="Forgot Password"
  description="Reset your RRM Academy password."
  canonicalUrl="https://rrmacademy.org/forgot-password"
  noindex
>
  <section class="auth-page">
    <div class="container container--narrow">
      <div class="auth-card">
        <h1>Reset password</h1>
        <p class="auth-intro">Enter your email and we will send you a link to reset your password.</p>

        <form id="forgot-form" class="auth-form" novalidate>
          <div class="form-group">
            <label class="form-label" for="forgot-email">Email</label>
            <input class="form-input" type="email" id="forgot-email" name="email" required autocomplete="email" />
          </div>

          {TURNSTILE_SITE_KEY && (
            <div id="turnstile-container" data-sitekey={TURNSTILE_SITE_KEY}></div>
          )}

          <button type="submit" class="btn btn--primary auth-submit" id="forgot-submit">Send reset link</button>
        </form>

        <div id="auth-success" class="auth-feedback auth-feedback--success" hidden>
          <p>If an account exists with that email, you will receive a reset link shortly. Check your inbox.</p>
        </div>

        <div id="auth-error" class="auth-feedback auth-feedback--error" hidden>
          <p id="auth-error-text"></p>
        </div>

        <div class="auth-links">
          <a href="/login/">Back to log in</a>
        </div>
      </div>
    </div>
  </section>

  {TURNSTILE_SITE_KEY && (
    <script src="https://challenges.cloudflare.com/turnstile/v0/api.js?render=explicit" async defer is:inline></script>
  )}

  <script is:inline>
    (function () {
      var form = document.getElementById('forgot-form');
      var submitBtn = document.getElementById('forgot-submit');
      var errorEl = document.getElementById('auth-error');
      var errorText = document.getElementById('auth-error-text');
      var successEl = document.getElementById('auth-success');
      var turnstileWidgetId = null;
      var pendingSubmit = null;

      function initTurnstile() {
        var el = document.getElementById('turnstile-container');
        if (!el || typeof turnstile === 'undefined') return;
        turnstileWidgetId = turnstile.render(el, {
          sitekey: el.dataset.sitekey, size: 'invisible',
          callback: function (token) {
            if (pendingSubmit) { doSubmit(pendingSubmit.email, token); pendingSubmit = null; }
          },
          'error-callback': function () {
            showError('Spam check failed. Please refresh and try again.');
            submitBtn.disabled = false; submitBtn.textContent = 'Send reset link'; pendingSubmit = null;
          },
        });
      }
      var tsCheck = setInterval(function () { if (typeof turnstile !== 'undefined') { clearInterval(tsCheck); initTurnstile(); } }, 200);
      setTimeout(function () { clearInterval(tsCheck); }, 10000);

      function showError(msg) { errorText.textContent = msg; errorEl.hidden = false; successEl.hidden = true; }

      form.addEventListener('submit', function (e) {
        e.preventDefault(); errorEl.hidden = true;
        var email = form.email.value.trim();
        if (!email) return showError('Please enter your email.');
        submitBtn.disabled = true; submitBtn.textContent = 'Sending...';
        if (typeof turnstile !== 'undefined' && turnstileWidgetId !== null) {
          pendingSubmit = { email: email };
          turnstile.reset(turnstileWidgetId); turnstile.execute(turnstileWidgetId); return;
        }
        doSubmit(email, '');
      });

      function doSubmit(email, token) {
        fetch('/api/auth/forgot-password', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email: email, turnstileToken: token }),
        })
          .then(function (r) { return r.json(); })
          .then(function (data) {
            if (data.ok) { form.hidden = true; successEl.hidden = false; }
            else { showError(data.error || 'Something went wrong.'); submitBtn.disabled = false; submitBtn.textContent = 'Send reset link'; }
          })
          .catch(function () { showError('Network error.'); submitBtn.disabled = false; submitBtn.textContent = 'Send reset link'; });
      }
    })();
  </script>
</BaseLayout>

<style>
  .auth-page { padding: var(--space-16) 0; min-height: 60vh; display: flex; align-items: center; }
  .auth-card {
    max-width: 420px; margin: 0 auto; padding: var(--space-10) var(--space-8);
    background: var(--bg-surface); border: 1px solid var(--border-color); border-radius: var(--radius-lg);
  }
  .auth-card h1 { text-align: center; margin-bottom: var(--space-3); font-size: 1.75rem; }
  .auth-intro { text-align: center; color: var(--text-secondary); margin-bottom: var(--space-8); font-size: 0.9375rem; }
  .auth-form .form-group { margin-bottom: var(--space-5); }
  .auth-form .form-label { display: block; font-family: 'Inter', sans-serif; font-size: 0.8125rem; font-weight: 500; margin-bottom: var(--space-2); }
  .auth-form .form-input {
    width: 100%; padding: var(--space-3) var(--space-5);
    border: 1.5px solid var(--neutral-300); border-radius: var(--radius-pill);
    font-family: 'Inter', sans-serif; font-size: 0.9375rem; color: var(--text-primary); background: var(--bg);
    transition: border-color 0.15s, box-shadow 0.15s;
  }
  .auth-form .form-input:focus { outline: none; border-color: var(--purple-700); box-shadow: 0 0 0 3px var(--focus-ring); }
  .auth-submit { width: 100%; margin-top: var(--space-4); }
  .auth-submit:disabled { opacity: 0.6; cursor: not-allowed; }
  .auth-feedback--success { margin-top: var(--space-4); padding: var(--space-4); background: var(--bg-surface); border: 1px solid var(--border-color); border-radius: var(--radius-md); color: var(--text-secondary); font-size: 0.9375rem; text-align: center; }
  .auth-feedback--error { margin-top: var(--space-4); padding: var(--space-3) var(--space-4); background: rgba(192,57,43,0.05); border: 1px solid var(--color-error); border-radius: var(--radius-md); color: var(--color-error); font-size: 0.875rem; }
  .auth-links { margin-top: var(--space-6); text-align: center; font-size: 0.8125rem; }
  .auth-links a { color: var(--accent); }
  .auth-links a:hover { color: var(--accent-hover); }
</style>
