---
import BaseLayout from '../../layouts/BaseLayout.astro';
import MaybeShell from '../../components/MaybeShell.astro';
import { isShellEnabled } from '../../lib/shell-routes';

const SHELL_ENABLED = isShellEnabled('guides');

// Per-guide brand-anchored accent. RRM-owned guides use the RRM Academy purple
// ramp; entity-specific guides use that entity's primary brand color sourced
// from their canonical site. Hex values are scoped local accents, not new
// global tokens \u2014 do not lift these into the SSOT.
const guides = [
  {
    title: 'RRM Glossary',
    href: '/glossary/',
    description: 'A comprehensive, evidence-based reference for the terminology, methods, conditions, and procedures encountered within the Restorative Reproductive Medicine framework.',
    author: 'Dr. Naomi Whittaker',
    readTime: '35 min read',
    accent: 'var(--purple-700)',
  },
  {
    title: 'NaProTechnology: A Clinician\u2019s Guide',
    href: '/naprotechnology/',
    description: 'NaProTechnology diagnoses and treats the underlying conditions driving infertility, menstrual disorders, and early pregnancy loss. This guide covers how the method works, published outcomes data, how to find a qualified provider, and what to expect on cost and insurance.',
    author: 'Dr. Naomi Whittaker',
    readTime: '18 min read',
    accent: '#f4b223', // Saint Paul VI Institute gold (popepaulvi.com)
  },
  {
    title: 'What is Restorative Reproductive Medicine?',
    href: '/what-is-rrm/',
    description: 'The diagnostic and treatment philosophy behind RRM. How cause-based care differs from suppressive medicine, and what to expect from an RRM-trained clinician.',
    author: 'Dr. Naomi Whittaker',
    readTime: '60 min read',
    accent: 'var(--purple-900)',
  },
  {
    title: 'What is FEMM?',
    href: '/femm/',
    description: 'FEMM (Fertility Education and Medical Management) teaches women to monitor hormonal biomarkers and connects them with trained providers who diagnose and treat the underlying conditions driving their symptoms.',
    author: 'Dr. Naomi Whittaker',
    readTime: '15 min read',
    accent: '#9396C9', // FEMM Health periwinkle (Brian-confirmed brand anchor 2026-05-04)
  },
  {
    title: 'What is NeoFertility?',
    href: '/neofertility/',
    description: 'NeoFertility diagnoses and treats the underlying causes of infertility and recurrent miscarriage using cycle-based evaluation, immunological testing, and targeted treatment to restore natural conception.',
    author: 'Dr. Naomi Whittaker',
    readTime: '22 min read',
    accent: '#00a9e0', // NeoFertility brand blue (neofertility.ie/neo-tokens.css)
  },
  {
    title: 'ART Registries and Codes of Practice',
    href: '/art-registries-and-codes/',
    description: 'A global reference to national IVF registries (HFEA, RTAC, ANZARD, Q-IVF, CDC, DIR, JSOG, CARTR Plus, REDLARA, ESHRE EIM, ICMART) and the codes of practice that govern fertility clinics. What each measures, and what they miss.',
    author: 'RRM Academy',
    readTime: '15 min read',
    accent: 'var(--purple-700)',
  },
  {
    title: 'PCOS Explained: Diagnosis, Phenotypes, and the RRM Approach',
    href: '/pcos/',
    description: 'Polycystic ovary syndrome has four diagnostic phenotypes and distinct metabolic, reproductive, and mental health implications. How RRM-trained clinicians approach diagnosis and treatment differently.',
    author: 'Dr. Naomi Whittaker',
    readTime: '20 min read',
    accent: 'var(--purple-700)',
  },
];

const published = guides.filter(g => !g.comingSoon);
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Guides to Restorative Reproductive Medicine',
  description: 'In-depth guides to NaProTechnology, RRM, and reproductive health topics written by board-certified physicians.',
  url: 'https://rrmacademy.org/guides/',
  mainEntity: {
    '@type': 'ItemList',
    numberOfItems: published.length,
    itemListElement: published.map((g, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      name: g.title,
      url: `https://rrmacademy.org${g.href}`,
    })),
  },
};
---
<BaseLayout
  title="Guides | Restorative Reproductive Medicine"
  description="In-depth guides to NaProTechnology, RRM, and reproductive health topics. Written by board-certified physicians with published outcomes data."
  canonicalUrl="https://rrmacademy.org/guides/"
  jsonLd={jsonLd}
  chrome={SHELL_ENABLED ? 'shell' : 'default'}
>
  <MaybeShell enabled={SHELL_ENABLED} context="page" currentPath={Astro.url.pathname}>
  <div class="page-wrapper">
    <div class="container container--narrow">

      <section class="guides-hero">
        <h1 class="hero-title animate-enter" style="--stagger: 0;">Restorative Reproductive Medicine Guides</h1>
        <p class="guides-intro animate-enter" style="--stagger: 1;">In-depth guides to restorative reproductive medicine, written by board-certified physicians. Each guide covers the evidence, practical next steps, and what to expect.</p>
      </section>

      <div id="guides-pdf-error" style="display:none" class="guides-pdf-notice">
        That download link is invalid or has expired. Find your guide below and request a new link.
      </div>

      <div class="guides-list animate-enter" style="--stagger: 2;">
        {guides.map((guide) => (
          guide.comingSoon ? (
            <div class="guide-card guide-card--soon">
              <div class="guide-card__badge">Coming Soon</div>
              <h2 class="guide-card__title">{guide.title}</h2>
              <p class="guide-card__desc">{guide.description}</p>
              <span class="guide-card__author">{guide.author}</span>
            </div>
          ) : (
            <a href={guide.href} class="guide-card" style={`--card-accent: ${guide.accent};`}>
              <h2 class="guide-card__title">{guide.title}</h2>
              <div class="guide-card__divider"></div>
              <p class="guide-card__desc">{guide.description}</p>
              <div class="guide-card__footer">
                <span class="guide-card__author">{guide.author}</span>
                {guide.readTime && <span class="guide-card__meta">{guide.readTime}</span>}
              </div>
            </a>
          )
        ))}
      </div>

    </div>
  </div>
  </MaybeShell>
</BaseLayout>

<script>
  const notice = document.getElementById('guides-pdf-error');
  if (notice && new URLSearchParams(window.location.search).get('pdf_error') === 'notfound') {
    notice.style.display = '';
  }
</script>

<style>
  .guides-pdf-notice {
    padding: var(--space-3) var(--space-4);
    background: var(--bg-surface);
    border-radius: var(--radius-md);
    font-size: 0.875rem;
    color: var(--text-secondary);
    margin-bottom: var(--space-6);
  }

  @keyframes enter {
    from { opacity: 0; transform: translateY(8px); filter: blur(4px); }
  }
  .animate-enter {
    animation: enter 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94) both;
    animation-delay: calc(100ms * var(--stagger, 0));
  }
  @media (prefers-reduced-motion: reduce) {
    .animate-enter { animation: none; }
  }

  .page-wrapper {
    padding: var(--space-8) 0 var(--space-16);
  }

  .guides-hero {
    margin-bottom: var(--space-10);
  }
  .hero-title {
    /* font-size inherited from global .hero-title (matches default <h1>);
       only the bottom margin is overridden here. */
    margin-bottom: var(--space-3);
  }
  .guides-intro {
    font-size: 0.9375rem;
    color: var(--text-secondary);
    line-height: 1.7;
    max-width: 640px;
  }

  .guides-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    margin-bottom: var(--space-12);
  }

  .guide-card {
    position: relative;
    display: block;
    padding: var(--space-4) var(--space-6);
    background: var(--bg-surface);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
    text-decoration: none;
    overflow: hidden;
    transition: border-color 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
  }
  .guide-card::before {
    content: '';
    position: absolute;
    inset: 0 auto 0 0;
    width: 4px;
    background: var(--card-accent, var(--purple-500));
  }
  .guide-card:hover {
    border-color: var(--card-accent, var(--purple-300));
    transform: translateY(-2px);
    box-shadow: 0 6px 18px -8px color-mix(in srgb, var(--card-accent, var(--purple-500)) 35%, transparent);
    text-decoration: none;
  }
  @media (prefers-reduced-motion: reduce) {
    .guide-card { transition: border-color 0.2s ease; }
    .guide-card:hover { transform: none; }
  }
  .guide-card__title {
    font-family: 'Cormorant Garamond', 'Georgia', serif;
    font-size: 1.75rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: var(--space-2);
    letter-spacing: -0.01em;
  }
  .guide-card__divider {
    width: 180px;
    height: 4px;
    background: linear-gradient(to right, var(--card-accent, var(--purple-700)), transparent);
    border-radius: 1px;
    margin-bottom: var(--space-3);
    opacity: 0.85;
  }
  .guide-card__desc {
    font-size: 0.9375rem;
    color: var(--text-secondary);
    line-height: 1.65;
    margin-bottom: var(--space-3);
  }
  .guide-card__footer {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }
  .guide-card__author {
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--text-secondary);
  }
  .guide-card__meta {
    font-family: 'Inter', sans-serif;
    font-size: 0.6875rem;
    font-weight: 500;
    color: var(--text-secondary);
    letter-spacing: 0.02em;
  }
  .guide-card__meta::before {
    content: '\00b7';
    margin-right: var(--space-3);
  }

  /* Coming soon state */
  .guide-card--soon {
    cursor: default;
    position: relative;
    border: 1px dashed var(--border-color);
    box-shadow: none;
  }
  .guide-card--soon:hover {
    box-shadow: none;
  }
  .guide-card--soon .guide-card__title,
  .guide-card--soon .guide-card__desc,
  .guide-card--soon .guide-card__author {
    color: var(--text-secondary);
  }
  .guide-card__badge {
    display: inline-block;
    font-family: 'Inter', sans-serif;
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-secondary);
    background: var(--bg-body);
    padding: 2px 10px;
    border-radius: var(--radius-pill);
    margin-bottom: var(--space-3);
  }
</style>
