---
import BaseLayout from '../../layouts/BaseLayout.astro';
import MaybeShell from '../../components/MaybeShell.astro';
import { isShellEnabled } from '../../lib/shell-routes';
import pillarRegistry from '../../../ssot/pillars.json';
import { Share2, Check } from '@lucide/astro';

const SHELL_ENABLED = isShellEnabled('guides');

// Per-guide brand-anchored accent lives in ssot/pillars.json. RRM-owned guides
// use the RRM Academy purple ramp; entity-specific guides use that entity's
// primary brand color sourced from their canonical site. Hex values are scoped
// local accents, not new global tokens -- do not lift these into the design
// token SSOT.
// Catalogue rendering filters to in_guides_catalogue=true (common-questions-
// about-rrm is intentionally hidden from the visual catalogue but kept in
// every other surface). Order matches _order in pillars.json.
const guides = pillarRegistry.pillars
  .filter((p) => p.in_guides_catalogue)
  .sort((a, b) => (a._order ?? 999) - (b._order ?? 999))
  .map((p) => ({
    title: p.title,
    href: `/${p.slug}/`,
    description: p.description,
    author: p.author,
    readTime: p.read_time,
    accent: p.accent,
  }));

const published = guides.filter(g => !g.comingSoon);
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Guides to Restorative Reproductive Medicine',
  description: 'In-depth guides to NaProTechnology, RRM, and reproductive health topics written by board-certified physicians.',
  url: 'https://rrmacademy.org/guides/',
  mainEntity: {
    '@type': 'ItemList',
    numberOfItems: published.length,
    itemListElement: published.map((g, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      name: g.title,
      url: `https://rrmacademy.org${g.href}`,
    })),
  },
};
---
<BaseLayout
  title="Guides | Restorative Reproductive Medicine"
  description="In-depth guides to NaProTechnology, RRM, and reproductive health topics. Written by board-certified physicians with published outcomes data."
  canonicalUrl="https://rrmacademy.org/guides/"
  jsonLd={jsonLd}
  chrome={SHELL_ENABLED ? 'shell' : 'default'}
>
  <MaybeShell enabled={SHELL_ENABLED} context="page" currentPath={Astro.url.pathname}>
  <div class="page-wrapper">
    <div class="container container--narrow">

      <section class="guides-hero">
        <h1 class="hero-title animate-enter" style="--stagger: 0;">Restorative Reproductive Medicine Guides</h1>
        <p class="guides-intro animate-enter" style="--stagger: 1;">In-depth guides to restorative reproductive medicine, written by board-certified physicians. Each guide covers the evidence, practical next steps, and what to expect.</p>
      </section>

      <div id="guides-pdf-error" style="display:none" class="guides-pdf-notice">
        That download link is invalid or has expired. Find your guide below and request a new link.
      </div>

      <div class="guides-list animate-enter" style="--stagger: 2;">
        {guides.map((guide) => (
          guide.comingSoon ? (
            <div class="guide-card guide-card--soon">
              <div class="guide-card__badge">Coming Soon</div>
              <h2 class="guide-card__title">{guide.title}</h2>
              <p class="guide-card__desc">{guide.description}</p>
              <span class="guide-card__author">{guide.author}</span>
            </div>
          ) : (
            <article class="guide-card" style={`--card-accent: ${guide.accent};`}>
              <h2 class="guide-card__title">
                <a class="guide-card__link" href={guide.href}>{guide.title}</a>
              </h2>
              <div class="guide-card__divider"></div>
              <p class="guide-card__desc">{guide.description}</p>
              <div class="guide-card__footer">
                <span class="guide-card__author">{guide.author}</span>
                {guide.readTime && <span class="guide-card__meta">{guide.readTime}</span>}
              </div>
              <button
                class="guide-card__share"
                type="button"
                aria-label={`Share "${guide.title}"`}
                data-share-url={`https://rrmacademy.org${guide.href}`}
                data-share-title={guide.title}
                data-share-description={guide.description}
              >
                <Share2 class="guide-card__share-icon" size={14} aria-hidden="true" />
                <Check class="guide-card__share-icon guide-card__share-icon--check" size={14} aria-hidden="true" />
                <span class="guide-card__share-label">Share</span>
              </button>
            </article>
          )
        ))}
      </div>

    </div>
  </div>

  <div class="share-toast" id="share-toast" role="status" aria-live="polite"></div>
  </MaybeShell>
</BaseLayout>

<script>
  const notice = document.getElementById('guides-pdf-error');
  if (notice && new URLSearchParams(window.location.search).get('pdf_error') === 'notfound') {
    notice.style.display = '';
  }

  const shareToast = document.getElementById('share-toast') as HTMLDivElement | null;
  let shareToastTimer: ReturnType<typeof setTimeout> | undefined;
  function showShareToast(message: string) {
    if (!shareToast) return;
    shareToast.textContent = message;
    shareToast.classList.add('share-toast--show');
    if (shareToastTimer) clearTimeout(shareToastTimer);
    shareToastTimer = setTimeout(() => {
      shareToast.classList.remove('share-toast--show');
    }, 2400);
  }

  document.querySelectorAll<HTMLButtonElement>('.guide-card__share').forEach((btn) => {
    btn.addEventListener('click', async (event) => {
      event.preventDefault();
      event.stopPropagation();
      const url = btn.dataset.shareUrl || window.location.href;
      const title = btn.dataset.shareTitle || document.title;
      const text = btn.dataset.shareDescription || '';

      if (typeof navigator.share === 'function') {
        try {
          await navigator.share({ title, text, url });
          return;
        } catch (err) {
          if (err && (err as DOMException).name === 'AbortError') return;
          // fall through to clipboard
        }
      }

      try {
        await navigator.clipboard.writeText(url);
        btn.dataset.state = 'copied';
        showShareToast('Link copied');
        setTimeout(() => {
          if (btn.dataset.state === 'copied') delete btn.dataset.state;
        }, 2400);
      } catch {
        showShareToast('Could not copy link');
      }
    });
  });
</script>

<style>
  .guides-pdf-notice {
    padding: var(--space-3) var(--space-4);
    background: var(--bg-surface);
    border-radius: var(--radius-md);
    font-size: 0.875rem;
    color: var(--text-secondary);
    margin-bottom: var(--space-6);
  }

  @keyframes enter {
    from { opacity: 0; transform: translateY(8px); filter: blur(4px); }
  }
  .animate-enter {
    animation: enter 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94) both;
    animation-delay: calc(100ms * var(--stagger, 0));
  }
  @media (prefers-reduced-motion: reduce) {
    .animate-enter { animation: none; }
  }

  .page-wrapper {
    padding: var(--space-8) 0 var(--space-16);
  }

  .guides-hero {
    margin-bottom: var(--space-10);
  }
  .hero-title {
    /* font-size inherited from global .hero-title (matches default <h1>);
       only the bottom margin is overridden here. */
    margin-bottom: var(--space-3);
  }
  .guides-intro {
    font-size: 0.9375rem;
    color: var(--text-secondary);
    line-height: 1.7;
    max-width: 640px;
  }

  .guides-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    margin-bottom: var(--space-12);
  }

  .guide-card {
    position: relative;
    display: block;
    padding: var(--space-4) var(--space-6);
    background: var(--bg-surface);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
    text-decoration: none;
    overflow: hidden;
    transition: border-color 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
  }
  .guide-card::before {
    content: '';
    position: absolute;
    inset: 0 auto 0 0;
    width: 4px;
    background: var(--card-accent, var(--purple-500));
  }
  .guide-card:hover {
    border-color: var(--card-accent, var(--purple-300));
    transform: translateY(-2px);
    box-shadow: 0 6px 18px -8px color-mix(in srgb, var(--card-accent, var(--purple-500)) 35%, transparent);
    text-decoration: none;
  }
  @media (prefers-reduced-motion: reduce) {
    .guide-card { transition: border-color 0.2s ease; }
    .guide-card:hover { transform: none; }
  }
  .guide-card__title {
    font-family: 'Cormorant Garamond', 'Georgia', serif;
    font-size: 1.75rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: var(--space-2);
    letter-spacing: -0.01em;
    padding-right: 4.5rem; /* room for share button */
  }
  .guide-card__link {
    color: inherit;
    text-decoration: none;
  }
  .guide-card__link:hover,
  .guide-card__link:focus {
    color: inherit;
    text-decoration: none;
  }
  /* Make the whole card click target the title link, without nesting interactive elements. */
  .guide-card__link::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1;
    border-radius: var(--radius-md);
  }
  .guide-card__link:focus-visible::after {
    outline: 2px solid var(--card-accent, var(--purple-500));
    outline-offset: 2px;
  }
  .guide-card__divider {
    width: 180px;
    height: 4px;
    background: linear-gradient(to right, var(--card-accent, var(--purple-700)), transparent);
    border-radius: 1px;
    margin-bottom: var(--space-3);
    opacity: 0.85;
  }
  .guide-card__desc {
    font-size: 0.9375rem;
    color: var(--text-secondary);
    line-height: 1.65;
    margin-bottom: var(--space-3);
  }
  .guide-card__footer {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }
  .guide-card__author {
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--text-secondary);
  }
  .guide-card__meta {
    font-family: 'Inter', sans-serif;
    font-size: 0.6875rem;
    font-weight: 500;
    color: var(--text-secondary);
    letter-spacing: 0.02em;
  }
  .guide-card__meta::before {
    content: '\00b7';
    margin-right: var(--space-3);
  }

  /* Share button: sits above the card-clickable layer with z-index: 2. */
  .guide-card__share {
    position: absolute;
    top: var(--space-3);
    right: var(--space-3);
    z-index: 2;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 12px;
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-pill);
    color: var(--text-secondary);
    font-family: 'Inter', sans-serif;
    font-size: 0.75rem;
    font-weight: 500;
    line-height: 1;
    cursor: pointer;
    transition: background-color 0.18s ease, border-color 0.18s ease, color 0.18s ease, transform 0.18s ease, box-shadow 0.18s ease;
  }
  .guide-card__share:hover,
  .guide-card__share:focus-visible {
    background: var(--card-accent, var(--purple-500));
    border-color: var(--card-accent, var(--purple-500));
    color: #fff;
    transform: translateY(-1px);
    box-shadow: 0 4px 12px -6px color-mix(in srgb, var(--card-accent, var(--purple-500)) 50%, transparent);
    outline: none;
  }
  .guide-card__share:active {
    transform: translateY(0);
  }
  .guide-card__share[data-state="copied"] {
    background: var(--card-accent, var(--purple-500));
    border-color: var(--card-accent, var(--purple-500));
    color: #fff;
  }
  .guide-card__share-icon {
    display: block;
    flex-shrink: 0;
    transition: opacity 0.15s ease, transform 0.15s ease;
  }
  .guide-card__share-icon--check {
    position: absolute;
    left: 12px;
    opacity: 0;
    transform: scale(0.6);
  }
  .guide-card__share[data-state="copied"] .guide-card__share-icon:not(.guide-card__share-icon--check) {
    opacity: 0;
    transform: scale(0.6);
  }
  .guide-card__share[data-state="copied"] .guide-card__share-icon--check {
    opacity: 1;
    transform: scale(1);
  }
  .guide-card__share-label {
    display: inline;
  }
  @media (max-width: 540px) {
    .guide-card__share {
      padding: 8px;
      gap: 0;
    }
    .guide-card__share-label {
      position: absolute;
      width: 1px;
      height: 1px;
      padding: 0;
      margin: -1px;
      overflow: hidden;
      clip: rect(0, 0, 0, 0);
      white-space: nowrap;
      border: 0;
    }
    .guide-card__title {
      padding-right: 3rem;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .guide-card__share { transition: background-color 0.15s, border-color 0.15s, color 0.15s; }
    .guide-card__share:hover,
    .guide-card__share:focus-visible { transform: none; }
    .guide-card__share-icon { transition: opacity 0.15s; }
    .guide-card__share-icon--check { transform: scale(1); }
  }

  /* Toast notification for clipboard-copy fallback. */
  .share-toast {
    position: fixed;
    bottom: calc(env(safe-area-inset-bottom, 0px) + var(--space-6));
    left: 50%;
    transform: translateX(-50%) translateY(16px);
    z-index: 9999;
    background: var(--text-primary);
    color: var(--bg-body);
    padding: 10px 20px;
    border-radius: var(--radius-pill);
    font-family: 'Inter', sans-serif;
    font-size: 0.8125rem;
    font-weight: 500;
    box-shadow: 0 8px 28px -8px color-mix(in srgb, var(--text-primary) 35%, transparent);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.22s ease, transform 0.22s ease;
    max-width: calc(100vw - var(--space-6) * 2);
  }
  .share-toast--show {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }
  @media (prefers-reduced-motion: reduce) {
    .share-toast { transition: opacity 0.15s; }
    .share-toast--show { transform: translateX(-50%); }
  }

  /* Coming soon state */
  .guide-card--soon {
    cursor: default;
    position: relative;
    border: 1px dashed var(--border-color);
    box-shadow: none;
  }
  .guide-card--soon:hover {
    box-shadow: none;
  }
  .guide-card--soon .guide-card__title,
  .guide-card--soon .guide-card__desc,
  .guide-card--soon .guide-card__author {
    color: var(--text-secondary);
  }
  .guide-card__badge {
    display: inline-block;
    font-family: 'Inter', sans-serif;
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-secondary);
    background: var(--bg-body);
    padding: 2px 10px;
    border-radius: var(--radius-pill);
    margin-bottom: var(--space-3);
  }
</style>
