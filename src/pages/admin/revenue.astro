---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout title="Revenue" description="Admin revenue dashboard" noindex={true} bodyClass="admin-page">

  <div class="admin-bar">
    <div class="container admin-bar__inner">
      <span class="admin-bar__title">RRM Admin</span>
      <nav class="admin-bar__nav">
        <a href="/admin/backlinks/" class="admin-bar__link">Backlinks</a>
        <a href="/admin/conversions/" class="admin-bar__link">Conversions</a>
        <a href="/admin/content/" class="admin-bar__link">Content</a>
        <a href="/admin/seo/" class="admin-bar__link">SEO</a>
        <a href="/admin/revenue/" class="admin-bar__link admin-bar__link--active">Revenue</a>
      </nav>
      <div class="admin-bar__actions">
        <a href="/" class="admin-bar__site-link">Return to site</a>
        <button class="admin-bar__logout" id="logout-btn" hidden>Logout</button>
      </div>
    </div>
  </div>

  <section id="login-gate" class="rv-section">
    <div class="container container--narrow rv-login-wrap">
      <h1>Admin Login</h1>
      <div class="form-group">
        <label class="form-label" for="token-input">Admin Token</label>
        <input class="form-input" type="password" id="token-input" placeholder="Enter admin token" autocomplete="off" />
      </div>
      <button class="btn btn--primary" id="login-btn">Login</button>
      <p id="login-error" class="rv-error" hidden></p>
    </div>
  </section>

  <section id="dashboard" class="rv-section" hidden>
    <div class="container">

      <div class="rv-header">
        <h1>Revenue</h1>
        <div class="rv-controls">
          <select class="form-input rv-select" id="period-select">
            <option value="7d">Last 7 days</option>
            <option value="28d" selected>Last 28 days</option>
            <option value="90d">Last 90 days</option>
          </select>
          <button class="btn btn--primary rv-btn" id="refresh-btn">Refresh</button>
        </div>
      </div>

      <!-- Top-level metrics -->
      <div class="rv-metrics rv-metrics--3">
        <div class="rv-card">
          <span class="rv-card__label">MRR</span>
          <span class="rv-card__value rv-card__value--green" id="m-mrr">--</span>
        </div>
        <div class="rv-card">
          <span class="rv-card__label">Period Revenue</span>
          <span class="rv-card__value" id="m-total-rev">--</span>
        </div>
        <div class="rv-card">
          <span class="rv-card__label">Active Subscriptions</span>
          <span class="rv-card__value" id="m-active-subs">--</span>
        </div>
      </div>

      <!-- Breakdown row -->
      <div class="rv-metrics rv-metrics--4">
        <div class="rv-card">
          <span class="rv-card__label">Donations</span>
          <span class="rv-card__value" id="m-donations">--</span>
          <span class="rv-card__sub" id="m-donation-count">-- donations</span>
        </div>
        <div class="rv-card">
          <span class="rv-card__label">Subscription Revenue</span>
          <span class="rv-card__value" id="m-sub-rev">--</span>
          <span class="rv-card__sub" id="m-sub-charges">-- charges</span>
        </div>
        <div class="rv-card">
          <span class="rv-card__label">Cancellations</span>
          <span class="rv-card__value rv-card__value--red" id="m-cancelled">--</span>
          <span class="rv-card__sub">this period</span>
        </div>
        <div class="rv-card">
          <span class="rv-card__label">Churn Rate</span>
          <span class="rv-card__value" id="m-churn">--</span>
          <span class="rv-card__sub">cancelled / active</span>
        </div>
      </div>

      <!-- Tier breakdown -->
      <h2 class="rv-heading">Membership Tiers</h2>
      <div class="rv-metrics rv-metrics--3">
        <div class="rv-card">
          <span class="rv-card__label">Member ($9/mo)</span>
          <span class="rv-card__value" id="t-member-count">--</span>
          <span class="rv-card__sub" id="t-member-mrr">$-- MRR</span>
        </div>
        <div class="rv-card">
          <span class="rv-card__label">Uterus Hero ($19/mo)</span>
          <span class="rv-card__value" id="t-hero-count">--</span>
          <span class="rv-card__sub" id="t-hero-mrr">$-- MRR</span>
        </div>
        <div class="rv-card">
          <span class="rv-card__label">Super Hero ($99/mo)</span>
          <span class="rv-card__value" id="t-superhero-count">--</span>
          <span class="rv-card__sub" id="t-superhero-mrr">$-- MRR</span>
        </div>
      </div>

      <!-- Daily table -->
      <h2 class="rv-heading">Daily Revenue</h2>
      <div class="rv-table-wrap">
        <table class="rv-table">
          <thead>
            <tr>
              <th>Date</th>
              <th>Donations</th>
              <th>Subscriptions</th>
              <th>Total</th>
            </tr>
          </thead>
          <tbody id="rv-tbody">
            <tr><td colspan="4" class="rv-empty">Loading...</td></tr>
          </tbody>
        </table>
      </div>

      <p class="rv-meta" id="rv-meta"></p>
    </div>
  </section>

  <script is:inline>
  (function () {
    var TOKEN_KEY = 'bl_admin_token';
    var EXPIRY_KEY = 'bl_admin_expiry';
    var TTL_MS = 24 * 60 * 60 * 1000;
    function getToken() { var t = localStorage.getItem(TOKEN_KEY), e = localStorage.getItem(EXPIRY_KEY); if (!t||!e) return null; if (Date.now()>Number(e)){clearToken();return null;} return t; }
    function setToken(t) { localStorage.setItem(TOKEN_KEY, t); localStorage.setItem(EXPIRY_KEY, String(Date.now()+TTL_MS)); }
    function clearToken() { localStorage.removeItem(TOKEN_KEY); localStorage.removeItem(EXPIRY_KEY); }

    function money(n) { return '$' + (n||0).toLocaleString(undefined, {minimumFractionDigits:2, maximumFractionDigits:2}); }
    function num(n) { return (n||0).toLocaleString(); }
    function pct(a,b) { return b>0 ? ((a/b)*100).toFixed(1)+'%' : '0%'; }

    async function fetchData(period) {
      var token = getToken();
      if (!token) throw new Error('Not authenticated');
      var resp = await fetch('/api/admin/revenue?period=' + encodeURIComponent(period), {
        headers: { 'Authorization': 'Bearer ' + token },
      });
      if (resp.status === 401) { clearToken(); location.reload(); }
      var data = await resp.json();
      if (!resp.ok) throw new Error(data.error || 'Request failed');
      return data;
    }

    function render(d) {
      document.getElementById('m-mrr').textContent = money(d.mrr);
      document.getElementById('m-total-rev').textContent = money(d.totalRevenue);
      document.getElementById('m-active-subs').textContent = num(d.totalActiveSubs);
      document.getElementById('m-donations').textContent = money(d.donations.total);
      document.getElementById('m-donation-count').textContent = num(d.donations.count) + ' donations';
      document.getElementById('m-sub-rev').textContent = money(d.subscriptionRevenue);
      document.getElementById('m-sub-charges').textContent = num(d.subscriptionCharges) + ' charges';
      document.getElementById('m-cancelled').textContent = num(d.cancelledCount);
      document.getElementById('m-churn').textContent = pct(d.cancelledCount, d.totalActiveSubs + d.cancelledCount);

      document.getElementById('t-member-count').textContent = num(d.tierCounts.member);
      document.getElementById('t-member-mrr').textContent = money(d.tierMrr.member) + ' MRR';
      document.getElementById('t-hero-count').textContent = num(d.tierCounts.hero);
      document.getElementById('t-hero-mrr').textContent = money(d.tierMrr.hero) + ' MRR';
      document.getElementById('t-superhero-count').textContent = num(d.tierCounts.superhero);
      document.getElementById('t-superhero-mrr').textContent = money(d.tierMrr.superhero) + ' MRR';

      var timeline = (d.timeline || []).slice().reverse();
      var tbody = document.getElementById('rv-tbody');
      if (!timeline.length) {
        tbody.innerHTML = '<tr><td colspan="4" class="rv-empty">No data</td></tr>';
      } else {
        tbody.innerHTML = timeline.map(function(r) {
          return '<tr><td>'+r.date+'</td><td>'+money(r.donations)+'</td><td>'+money(r.subscriptions)+'</td><td><strong>'+money(r.total)+'</strong></td></tr>';
        }).join('');
      }

      document.getElementById('rv-meta').textContent = 'Fetched: ' + (d.fetchedAt || 'unknown');
    }

    async function loadData() {
      var period = document.getElementById('period-select').value;
      document.getElementById('rv-tbody').innerHTML = '<tr><td colspan="4" class="rv-empty">Loading...</td></tr>';
      try {
        var resp = await fetchData(period);
        render(resp.data);
        if (resp.cached) document.getElementById('rv-meta').textContent += ' (cached)';
      } catch(e) {
        document.getElementById('rv-tbody').innerHTML = '<tr><td colspan="4" class="rv-empty rv-error">'+e.message+'</td></tr>';
      }
    }

    var token = getToken();
    if (token) { document.getElementById('login-gate').hidden=true; document.getElementById('dashboard').hidden=false; document.getElementById('logout-btn').hidden=false; loadData(); }

    document.getElementById('login-btn').addEventListener('click', async function() {
      var val = document.getElementById('token-input').value.trim(); if(!val) return;
      document.getElementById('login-error').hidden=true;
      try {
        var resp = await fetch('/api/admin/revenue?period=7d', { headers: {'Authorization':'Bearer '+val} });
        if (resp.status===401) throw new Error('Invalid token');
        setToken(val); document.getElementById('login-gate').hidden=true; document.getElementById('dashboard').hidden=false; document.getElementById('logout-btn').hidden=false;
        var data = await resp.json(); if(data.ok) render(data.data);
      } catch(e) { var el=document.getElementById('login-error'); el.textContent=e.message; el.hidden=false; }
    });
    document.getElementById('token-input').addEventListener('keydown', function(e) { if(e.key==='Enter') document.getElementById('login-btn').click(); });
    document.getElementById('logout-btn').addEventListener('click', function() { clearToken(); location.reload(); });
    document.getElementById('period-select').addEventListener('change', loadData);
    document.getElementById('refresh-btn').addEventListener('click', loadData);
  })();
  </script>

</BaseLayout>

<style>
  :root { --admin-sage-700:#7e8772; --admin-sage-300:#bec3b8; --admin-bg:#faf8f5; --admin-surface:#fff; --admin-border:#d9d3cc; --admin-text:#313131; --admin-text-faint:#949392; }
  :global(.admin-page) :global(.site-header){display:none;} :global(.admin-page) :global(footer){display:none;}
  .admin-bar{background:#2d3328;color:#e8ebe5;position:sticky;top:0;z-index:100;} .admin-bar__inner{display:flex;align-items:center;height:48px;gap:var(--space-6);} .admin-bar__title{font-family:'Cormorant Garamond','Georgia',serif;font-weight:600;font-size:1.25rem;color:var(--admin-sage-300);white-space:nowrap;} .admin-bar__nav{display:flex;gap:var(--space-1);} .admin-bar__link{font-size:.8125rem;font-weight:400;color:rgba(255,255,255,.6);text-decoration:none;padding:4px 12px;border-radius:var(--radius-sm);transition:color .15s,background .15s;} .admin-bar__link:hover{color:#fff;text-decoration:none;} .admin-bar__link--active{color:#fff;background:rgba(255,255,255,.1);font-weight:500;} .admin-bar__actions{display:flex;align-items:center;gap:var(--space-3);margin-left:auto;} .admin-bar__site-link{font-size:.8125rem;font-weight:500;color:var(--admin-sage-300);text-decoration:none;padding:5px 16px;border:1px solid var(--admin-sage-300);border-radius:var(--radius-pill);transition:color .15s,border-color .15s;} .admin-bar__site-link:hover{color:#fff;border-color:#fff;text-decoration:none;} .admin-bar__logout{font-size:.8125rem;color:rgba(255,255,255,.5);background:none;border:none;cursor:pointer;padding:4px 8px;} .admin-bar__logout:hover{color:#fff;}

  .rv-section{padding:var(--space-8) 0;background:var(--admin-bg);min-height:80vh;}
  .rv-login-wrap{max-width:400px;margin:var(--space-16) auto;text-align:center;background:var(--admin-surface);border:1px solid var(--admin-border);border-radius:var(--radius-md);padding:var(--space-8) var(--space-6);} .rv-login-wrap h1{margin-bottom:var(--space-6);color:var(--admin-sage-700);} .rv-login-wrap .form-group{margin-bottom:var(--space-4);text-align:left;} .rv-login-wrap .form-input{border-color:var(--admin-border);} .rv-login-wrap .form-input:focus{border-color:var(--admin-sage-700);box-shadow:0 0 0 2px rgba(126,135,114,.15);outline:none;} .rv-login-wrap .btn{width:100%;background:var(--admin-sage-700);border-color:var(--admin-sage-700);color:#fff;} .rv-login-wrap .btn:hover{background:#6b755f;} .rv-error{color:var(--color-error);font-size:.875rem;margin-top:var(--space-3);}

  .rv-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:var(--space-6);flex-wrap:wrap;gap:var(--space-3);} .rv-header h1{margin-bottom:0;color:var(--admin-text);} .rv-controls{display:flex;gap:var(--space-3);align-items:center;} .rv-select{max-width:200px;border-color:var(--admin-border);} .rv-select:focus{border-color:var(--admin-sage-700);box-shadow:0 0 0 2px rgba(126,135,114,.15);outline:none;} .rv-btn{background:var(--admin-sage-700);border-color:var(--admin-sage-700);color:#fff;} .rv-btn:hover{background:#6b755f;}

  .rv-metrics{display:grid;gap:var(--space-4);margin-bottom:var(--space-6);} .rv-metrics--3{grid-template-columns:repeat(3,1fr);} .rv-metrics--4{grid-template-columns:repeat(4,1fr);}
  @media(max-width:768px){.rv-metrics--3{grid-template-columns:repeat(2,1fr);} .rv-metrics--4{grid-template-columns:repeat(2,1fr);}}
  .rv-card{background:var(--admin-surface);border:1px solid var(--admin-border);border-radius:var(--radius-md);padding:var(--space-4) var(--space-5);text-align:center;} .rv-card__label{display:block;font-size:.75rem;font-weight:600;text-transform:uppercase;letter-spacing:.05em;color:var(--admin-text-faint);margin-bottom:var(--space-1);} .rv-card__value{display:block;font-size:1.75rem;font-weight:700;color:var(--admin-text);font-family:'Inter',sans-serif;} .rv-card__value--green{color:#27ae60;} .rv-card__value--red{color:#c0392b;} .rv-card__sub{display:block;font-size:.75rem;color:var(--admin-text-faint);margin-top:2px;}

  .rv-heading{color:var(--admin-text);margin-bottom:var(--space-4);}
  .rv-table-wrap{overflow-x:auto;border:1px solid var(--admin-border);border-radius:var(--radius-md);background:var(--admin-surface);}
  .rv-empty{text-align:center;color:var(--admin-text-faint);padding:var(--space-8) var(--space-4);}
  .rv-meta{font-size:.75rem;color:var(--admin-text-faint);margin-top:var(--space-4);}
</style>

<style is:global>
  .rv-table{width:100%;border-collapse:collapse;font-size:.875rem;} .rv-table th,.rv-table td{padding:var(--space-3) var(--space-4);text-align:right;border-bottom:1px solid #d9d3cc;} .rv-table th:first-child,.rv-table td:first-child{text-align:left;} .rv-table th{background:#eee5dd;font-weight:600;font-size:.75rem;text-transform:uppercase;letter-spacing:.04em;color:#636261;} .rv-table tbody tr:last-child td{border-bottom:none;} .rv-table tbody tr:hover{background:#e8ebe5;}
</style>
