---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout title="Backlinks Dashboard" description="Admin backlinks dashboard" noindex={true} bodyClass="admin-page">

  <!-- Admin Header Bar (replaces site header visually) -->
  <div class="admin-bar">
    <div class="container admin-bar__inner">
      <span class="admin-bar__title">RRM Admin</span>
      <nav class="admin-bar__nav">
        <a href="/admin/backlinks/" class="admin-bar__link admin-bar__link--active">Backlinks</a>
        <a href="/admin/conversions/" class="admin-bar__link">Conversions</a>
        <a href="/admin/content/" class="admin-bar__link">Content</a>
        <a href="/admin/email/" class="admin-bar__link">Email</a>
        <a href="/admin/seo/" class="admin-bar__link">SEO</a>
        <a href="/admin/revenue/" class="admin-bar__link">Revenue</a>
      </nav>
      <div class="admin-bar__actions">
        <a href="/" class="admin-bar__site-link">Return to site</a>
        <button class="admin-bar__logout" id="logout-btn">Logout</button>
      </div>
    </div>
  </div>

  <!-- Dashboard -->
  <section id="dashboard" class="bl-section">
    <div class="container">

      <!-- Page heading -->
      <div class="bl-header">
        <h1>Backlinks</h1>
      </div>

      <!-- Metrics -->
      <div class="bl-metrics">
        <div class="bl-card">
          <span class="bl-card__label">Total</span>
          <span class="bl-card__value" id="m-total">--</span>
        </div>
        <div class="bl-card">
          <span class="bl-card__label">Live</span>
          <span class="bl-card__value bl-card__value--live" id="m-live">--</span>
        </div>
        <div class="bl-card">
          <span class="bl-card__label">Dead</span>
          <span class="bl-card__value bl-card__value--dead" id="m-dead">--</span>
        </div>
        <div class="bl-card">
          <span class="bl-card__label">Dofollow</span>
          <span class="bl-card__value" id="m-dofollow">--</span>
        </div>
      </div>

      <!-- Filters -->
      <div class="bl-filters">
        <div class="form-group" style="margin-bottom:0;">
          <select class="form-input bl-select" id="status-filter">
            <option value="">All</option>
            <option value="live">Live</option>
            <option value="dead">Dead</option>
            <option value="nofollow_changed">Nofollow Changed</option>
            <option value="unchecked">Unchecked</option>
            <option value="timeout">Timeout</option>
          </select>
        </div>
        <button class="btn btn--primary" id="refresh-btn">Refresh</button>
      </div>

      <!-- Table -->
      <div class="bl-table-wrap">
        <table class="bl-table">
          <thead>
            <tr>
              <th style="width:25%" data-sort="referring_url">Referring URL<span class="bl-sort-arrow"></span></th>
              <th style="width:14%" data-sort="referring_domain">Domain<span class="bl-sort-arrow"></span></th>
              <th style="width:15%" data-sort="target_path">Target<span class="bl-sort-arrow"></span></th>
              <th style="width:9%" data-sort="status">Status<span class="bl-sort-arrow"></span></th>
              <th style="width:5%" data-sort="domain_rating">DR<span class="bl-sort-arrow"></span></th>
              <th style="width:8%" data-sort="is_dofollow">Dofollow<span class="bl-sort-arrow"></span></th>
              <th style="width:14%" data-sort="last_checked">Last Checked<span class="bl-sort-arrow"></span></th>
              <th style="width:10%">Actions</th>
            </tr>
          </thead>
          <tbody id="bl-tbody">
            <tr><td colspan="8" class="bl-empty">Loading...</td></tr>
          </tbody>
        </table>
      </div>

    </div>
  </section>

  <script is:inline>
  (function () {
    // API
    async function apiCall(action, params) {
      params = params || {};
      var resp = await fetch('/api/admin/backlinks', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'include',
        body: JSON.stringify({ action: action, params: params }),
      });
      if (resp.status === 401 || resp.status === 403) { window.location.href = '/login/?redirect=/admin/backlinks/'; return; }
      var data = await resp.json();
      if (!resp.ok) throw new Error(data.error || 'Request failed');
      return data;
    }

    // Formatting helpers
    function formatDate(iso) {
      if (!iso) return '--';
      var d = new Date(iso);
      if (isNaN(d.getTime())) return '--';
      var months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
      var h = d.getHours();
      var ampm = h >= 12 ? 'PM' : 'AM';
      h = h % 12 || 12;
      var min = String(d.getMinutes()).padStart(2, '0');
      return months[d.getMonth()] + ' ' + d.getDate() + ', ' + h + ':' + min + ' ' + ampm;
    }

    function truncateUrl(url, max) {
      max = max || 50;
      try {
        var u = new URL(url);
        var display = u.hostname + u.pathname;
        if (display.length > max) return display.substring(0, max) + '...';
        return display;
      } catch (e) {
        if (url && url.length > max) return url.substring(0, max) + '...';
        return url || '--';
      }
    }

    function statusBadge(status) {
      var el = document.createElement('span');
      el.className = 'bl-badge bl-badge--' + (status || 'unchecked');
      el.textContent = status || 'unchecked';
      return el;
    }

    // Sort state
    var currentLinks = [];
    var sortCol = 'domain_rating';
    var sortDir = -1; // -1 = desc, 1 = asc

    // DOM refs
    var mTotal = document.getElementById('m-total');
    var mLive = document.getElementById('m-live');
    var mDead = document.getElementById('m-dead');
    var mDofollow = document.getElementById('m-dofollow');
    var statusFilter = document.getElementById('status-filter');
    var refreshBtn = document.getElementById('refresh-btn');
    var tbody = document.getElementById('bl-tbody');

    // Logout
    document.getElementById('logout-btn').addEventListener('click', async function () {
      await fetch('/api/auth/logout', { method: 'POST', credentials: 'include' });
      window.location.href = '/login/';
    });

    // Load summary
    async function loadSummary() {
      try {
        var data = await apiCall('summary');
        mTotal.textContent = data.total != null ? data.total : '--';
        var bs = data.by_status || {};
        mLive.textContent = bs.live != null ? bs.live : '0';
        mDead.textContent = bs.dead != null ? bs.dead : '0';
        mDofollow.textContent = data.dofollow_count != null ? data.dofollow_count : '--';
      } catch (e) {
        mTotal.textContent = 'err';
      }
    }

    // Sort helpers
    function sortValue(bl, col) {
      switch (col) {
        case 'referring_url': return (bl.referring_url || '').toLowerCase();
        case 'referring_domain': return (bl.referring_domain || '').toLowerCase();
        case 'target_path': return (bl.target_path || '/').toLowerCase();
        case 'status': return bl.status || 'unchecked';
        case 'domain_rating': return Number(bl.domain_rating) || 0;
        case 'is_dofollow': return bl.is_dofollow ? 1 : 0;
        case 'last_checked': return bl.last_checked || '';
        default: return '';
      }
    }

    function sortLinks(links) {
      return links.slice().sort(function (a, b) {
        var va = sortValue(a, sortCol);
        var vb = sortValue(b, sortCol);
        if (va < vb) return -1 * sortDir;
        if (va > vb) return 1 * sortDir;
        return 0;
      });
    }

    function updateSortIndicators() {
      var ths = document.querySelectorAll('.bl-table th[data-sort]');
      for (var i = 0; i < ths.length; i++) {
        var th = ths[i];
        var arrow = th.querySelector('.bl-sort-arrow');
        if (th.dataset.sort === sortCol) {
          arrow.textContent = sortDir === 1 ? ' \u25B2' : ' \u25BC';
        } else {
          arrow.textContent = '';
        }
      }
    }

    // Render rows from currentLinks
    function renderTable() {
      var sorted = sortLinks(currentLinks);
      tbody.innerHTML = '';

      if (sorted.length === 0) {
        var emptyRow = document.createElement('tr');
        var emptyCell = document.createElement('td');
        emptyCell.colSpan = 8;
        emptyCell.className = 'bl-empty';
        emptyCell.textContent = 'No backlinks found';
        emptyRow.appendChild(emptyCell);
        tbody.appendChild(emptyRow);
        return;
      }

      for (var i = 0; i < sorted.length; i++) {
        var bl = sorted[i];
        var tr = document.createElement('tr');

        var tdUrl = document.createElement('td');
        tdUrl.className = 'bl-col-url';
        var a = document.createElement('a');
        a.href = bl.referring_url || '#';
        a.target = '_blank';
        a.rel = 'noopener noreferrer';
        a.textContent = truncateUrl(bl.referring_url);
        a.title = bl.referring_url || '';
        tdUrl.appendChild(a);
        tr.appendChild(tdUrl);

        var tdDomain = document.createElement('td');
        tdDomain.textContent = bl.referring_domain || '--';
        tr.appendChild(tdDomain);

        var tdTarget = document.createElement('td');
        tdTarget.textContent = bl.target_path || '/';
        tr.appendChild(tdTarget);

        var tdStatus = document.createElement('td');
        tdStatus.appendChild(statusBadge(bl.status));
        tr.appendChild(tdStatus);

        var tdDr = document.createElement('td');
        tdDr.textContent = bl.domain_rating != null ? bl.domain_rating : '--';
        tr.appendChild(tdDr);

        var tdDofollow = document.createElement('td');
        if (bl.is_dofollow === 1 || bl.is_dofollow === true) {
          tdDofollow.textContent = 'Yes';
        } else if (bl.is_dofollow === 0 || bl.is_dofollow === false) {
          tdDofollow.textContent = 'No';
        } else {
          tdDofollow.textContent = '--';
        }
        tr.appendChild(tdDofollow);

        var tdChecked = document.createElement('td');
        tdChecked.textContent = formatDate(bl.last_checked);
        tr.appendChild(tdChecked);

        var tdActions = document.createElement('td');
        var checkBtn = document.createElement('button');
        checkBtn.className = 'btn bl-btn-check';
        checkBtn.textContent = 'Check';
        checkBtn.dataset.id = bl.id;
        checkBtn.addEventListener('click', function () { recheck(this); });
        tdActions.appendChild(checkBtn);
        tr.appendChild(tdActions);

        tbody.appendChild(tr);
      }
    }

    // Load backlinks from API then render
    async function loadBacklinks() {
      tbody.innerHTML = '';
      var loadingRow = document.createElement('tr');
      var loadingCell = document.createElement('td');
      loadingCell.colSpan = 8;
      loadingCell.className = 'bl-empty';
      loadingCell.textContent = 'Loading...';
      loadingRow.appendChild(loadingCell);
      tbody.appendChild(loadingRow);

      try {
        var filterVal = statusFilter.value;
        var params = {};
        if (filterVal) params.status = filterVal;
        var data = await apiCall('list', params);
        currentLinks = data.backlinks || [];
        renderTable();
        updateSortIndicators();
      } catch (e) {
        tbody.innerHTML = '';
        var errRow = document.createElement('tr');
        var errCell = document.createElement('td');
        errCell.colSpan = 8;
        errCell.className = 'bl-empty';
        errCell.textContent = 'Error loading backlinks: ' + e.message;
        errRow.appendChild(errCell);
        tbody.appendChild(errRow);
      }
    }

    // Column header click sorting
    document.querySelectorAll('.bl-table th[data-sort]').forEach(function (th) {
      th.addEventListener('click', function () {
        var col = th.dataset.sort;
        if (sortCol === col) {
          sortDir = sortDir * -1;
        } else {
          sortCol = col;
          sortDir = col === 'domain_rating' ? -1 : 1;
        }
        renderTable();
        updateSortIndicators();
      });
    });

    // Re-check single link
    async function recheck(btn) {
      var id = Number(btn.dataset.id);
      btn.disabled = true;
      btn.textContent = 'Checking...';
      try {
        await apiCall('check', { id: id });
        await loadBacklinks();
      } catch (e) {
        btn.textContent = 'Error';
        setTimeout(function () {
          btn.textContent = 'Check';
          btn.disabled = false;
        }, 2000);
      }
    }

    // Filter and refresh
    statusFilter.addEventListener('change', loadBacklinks);
    refreshBtn.addEventListener('click', function () {
      loadSummary();
      loadBacklinks();
    });

    // Init
    loadSummary();
    loadBacklinks();
  })();
  </script>

</BaseLayout>

<style>
  /* Admin palette — dusty rose (on-brand with RRM Academy) */
  :root {
    --admin-rose-700: #8a606e;
    --admin-rose-500: #a8808d;
    --admin-rose-300: #c9a8b2;
    --admin-rose-100: #f0e5e9;
    --admin-cream: #eee5dd;
    --admin-sand: #dbcbbb;
    --admin-bg: #faf8f5;
    --admin-surface: #ffffff;
    --admin-border: #d9d3cc;
    --admin-text: #313131;
    --admin-text-muted: #636261;
    --admin-text-faint: #949392;
  }

  /* Hide site header and footer on admin pages */
  :global(.admin-page) :global(.site-header) { display: none; }
  :global(.admin-page) :global(footer) { display: none; }

  /* Admin header bar */
  .admin-bar {
    background: #3d2a32;
    color: #f0e5e9;
    position: sticky;
    top: 0;
    z-index: 100;
  }
  .admin-bar__inner {
    display: flex;
    align-items: center;
    height: 48px;
    gap: var(--space-6);
  }
  .admin-bar__title {
    font-family: 'Cormorant Garamond', 'Georgia', serif;
    font-weight: 600;
    font-size: 1.25rem;
    color: var(--admin-rose-300);
    white-space: nowrap;
  }
  .admin-bar__nav {
    display: flex;
    gap: var(--space-1);
  }
  .admin-bar__link {
    font-size: 0.8125rem;
    font-weight: 400;
    color: rgba(255,255,255,0.6);
    text-decoration: none;
    padding: 4px 12px;
    border-radius: var(--radius-sm);
    transition: color 0.15s, background 0.15s;
  }
  .admin-bar__link:hover {
    color: #fff;
    text-decoration: none;
  }
  .admin-bar__link--active {
    color: #fff;
    background: rgba(255,255,255,0.1);
    font-weight: 500;
  }
  .admin-bar__actions {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-left: auto;
  }
  .admin-bar__site-link {
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--admin-rose-300);
    text-decoration: none;
    padding: 5px 16px;
    border: 1px solid var(--admin-rose-300);
    border-radius: var(--radius-pill);
    transition: color 0.15s, border-color 0.15s, background 0.15s;
  }
  .admin-bar__site-link:hover {
    color: #fff;
    border-color: #fff;
    text-decoration: none;
  }
  .admin-bar__logout {
    font-size: 0.8125rem;
    font-weight: 400;
    color: rgba(255,255,255,0.5);
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px 8px;
    transition: color 0.15s;
  }
  .admin-bar__logout:hover {
    color: #fff;
  }

  /* Layout */
  .bl-section {
    padding: var(--space-8) 0;
    background: var(--admin-bg);
    min-height: 80vh;
  }

  /* Header */
  .bl-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--space-6);
  }
  .bl-header h1 {
    margin-bottom: 0;
    color: var(--admin-text);
  }

  /* Metrics grid */
  .bl-metrics {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-4);
    margin-bottom: var(--space-6);
  }
  @media (max-width: 600px) {
    .bl-metrics {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  .bl-card {
    background: var(--admin-surface);
    border: 1px solid var(--admin-border);
    border-radius: var(--radius-md);
    padding: var(--space-4) var(--space-5);
    text-align: center;
  }
  .bl-card__label {
    display: block;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--admin-text-faint);
    margin-bottom: var(--space-1);
  }
  .bl-card__value {
    display: block;
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--admin-text);
    font-family: 'Inter', sans-serif;
  }
  .bl-card__value--live {
    color: #27ae60;
  }
  .bl-card__value--dead {
    color: var(--color-error);
  }

  /* Filters */
  .bl-filters {
    display: flex;
    gap: var(--space-3);
    align-items: center;
    margin-bottom: var(--space-4);
  }
  .bl-select {
    max-width: 220px;
    border-color: var(--admin-border);
  }
  .bl-select:focus {
    border-color: var(--admin-rose-700);
    box-shadow: 0 0 0 2px rgba(138, 96, 110, 0.15);
    outline: none;
  }
  .bl-filters .btn--primary {
    background: var(--admin-rose-700);
    border-color: var(--admin-rose-700);
    color: #fff;
  }
  .bl-filters .btn--primary:hover {
    background: #764d5e;
  }

  /* Table wrapper (static, scoped is fine) */
  .bl-table-wrap {
    overflow-x: auto;
    border: 1px solid var(--admin-border);
    border-radius: var(--radius-md);
    background: var(--admin-surface);
  }
</style>

<!-- Global styles for JS-created table elements (scoped styles don't match dynamic DOM) -->
<style is:global>
  .bl-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.875rem;
    white-space: nowrap;
    table-layout: fixed;
  }
  .bl-table th,
  .bl-table td {
    padding: var(--space-3) var(--space-4);
    text-align: left;
    border-bottom: 1px solid #d9d3cc;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    max-width: 0;
  }
  .bl-table th {
    background: #eee5dd;
    font-weight: 600;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: #636261;
    resize: horizontal;
    overflow: auto;
    min-width: 60px;
    max-width: none;
  }
  .bl-table th[data-sort] {
    cursor: pointer;
    user-select: none;
  }
  .bl-table th[data-sort]:hover {
    background: #e4d9ce;
  }
  .bl-sort-arrow {
    font-size: 0.625rem;
    color: #8a606e;
  }
  .bl-table tbody tr:last-child td {
    border-bottom: none;
  }
  .bl-table tbody tr:hover {
    background: #f0e5e9;
  }
  .bl-col-url a {
    color: #8a606e;
    text-decoration: none;
    font-weight: 500;
  }
  .bl-col-url a:hover {
    text-decoration: underline;
    color: #764d5e;
  }
  .bl-empty {
    text-align: center;
    color: #949392;
    padding: var(--space-8) var(--space-4);
  }
  .bl-badge {
    display: inline-block;
    padding: var(--space-1) var(--space-2);
    border-radius: var(--radius-sm);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }
  .bl-badge--live {
    background: #e8f5e9;
    color: #2e7d32;
  }
  .bl-badge--dead {
    background: rgba(192, 57, 43, 0.1);
    color: var(--color-error);
  }
  .bl-badge--nofollow_changed {
    background: #fff3e0;
    color: #e65100;
  }
  .bl-badge--unchecked,
  .bl-badge--timeout {
    background: #f0e5e9;
    color: #636261;
  }
  .bl-btn-check {
    background: none;
    border: 1px solid #d9d3cc;
    color: #8a606e;
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-sm);
    cursor: pointer;
    font-size: 0.75rem;
    font-weight: 500;
  }
  .bl-btn-check:hover {
    border-color: #8a606e;
    background: #f0e5e9;
  }
  .bl-btn-check:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }
</style>
