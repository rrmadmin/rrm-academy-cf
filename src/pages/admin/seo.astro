---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout title="SEO Report" description="Admin SEO dashboard" noindex={true} bodyClass="admin-page">

  <!-- Admin Header Bar -->
  <div class="admin-bar">
    <div class="container admin-bar__inner">
      <span class="admin-bar__title">RRM Admin</span>
      <nav class="admin-bar__nav">
        <a href="/admin/backlinks/" class="admin-bar__link">Backlinks</a>
        <a href="/admin/conversions/" class="admin-bar__link">Conversions</a>
        <a href="/admin/content/" class="admin-bar__link">Content</a>
        <a href="/admin/seo/" class="admin-bar__link admin-bar__link--active">SEO</a>
        <a href="/admin/revenue/" class="admin-bar__link">Revenue</a>
      </nav>
      <div class="admin-bar__actions">
        <a href="/" class="admin-bar__site-link">Return to site</a>
        <button class="admin-bar__logout" id="logout-btn">Logout</button>
      </div>
    </div>
  </div>

  <!-- Dashboard -->
  <section id="dashboard" class="dash-section">
    <div class="container">

      <!-- Header row -->
      <div class="dash-header">
        <div class="dash-header__left">
          <h1 class="dash-header__title">SEO Report</h1>
          <span class="dash-header__updated" id="last-updated">--</span>
        </div>
        <div class="dash-header__right">
          <div class="dash-bell" id="bell-wrap">
            <button class="dash-bell__btn" id="bell-btn" title="Alerts">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
              <span class="dash-bell__dot" id="bell-dot" style="display:none;"></span>
            </button>
            <div class="dash-bell__dropdown" id="bell-dropdown" style="display:none;">
              <div class="dash-bell__header">Alerts</div>
              <div class="dash-bell__list" id="bell-list">No alerts</div>
            </div>
          </div>
          <button class="btn btn--primary dash-refresh-btn" id="refresh-btn">Refresh</button>
        </div>
      </div>

      <!-- KPI strip -->
      <div class="kpi-strip" id="kpi-strip">
        <div class="kpi-card" id="kpi-clicks">
          <span class="kpi-card__label">Clicks</span>
          <div class="kpi-card__row">
            <span class="kpi-card__value" id="kpi-val-clicks">--</span>
            <span class="kpi-card__delta" id="kpi-delta-clicks"></span>
          </div>
          <div class="kpi-card__spark" id="kpi-spark-clicks"></div>
        </div>
        <div class="kpi-card" id="kpi-impressions">
          <span class="kpi-card__label">Impressions</span>
          <div class="kpi-card__row">
            <span class="kpi-card__value" id="kpi-val-impressions">--</span>
            <span class="kpi-card__delta" id="kpi-delta-impressions"></span>
          </div>
          <div class="kpi-card__spark" id="kpi-spark-impressions"></div>
        </div>
        <div class="kpi-card" id="kpi-ctr">
          <span class="kpi-card__label">CTR</span>
          <div class="kpi-card__row">
            <span class="kpi-card__value" id="kpi-val-ctr">--</span>
            <span class="kpi-card__delta" id="kpi-delta-ctr"></span>
          </div>
          <div class="kpi-card__spark" id="kpi-spark-ctr"></div>
        </div>
        <div class="kpi-card" id="kpi-position">
          <span class="kpi-card__label">Position</span>
          <div class="kpi-card__row">
            <span class="kpi-card__value" id="kpi-val-position">--</span>
            <span class="kpi-card__delta" id="kpi-delta-position"></span>
          </div>
          <div class="kpi-card__spark" id="kpi-spark-position"></div>
        </div>
        <div class="kpi-card" id="kpi-visitors">
          <span class="kpi-card__label">Visitors</span>
          <div class="kpi-card__row">
            <span class="kpi-card__value" id="kpi-val-visitors">--</span>
            <span class="kpi-card__delta" id="kpi-delta-visitors"></span>
          </div>
          <div class="kpi-card__spark" id="kpi-spark-visitors"></div>
        </div>
      </div>

      <!-- Keyword Rankings -->
      <div class="dash-card dash-card--full" id="keywords-section">
        <div class="dash-card__header">
          <h2 class="dash-card__title">Keyword Rankings</h2>
          <button class="btn btn--sm dash-edit-kw-btn" id="edit-kw-btn">Edit keywords</button>
        </div>
        <div class="dash-table-wrap">
          <table class="dash-table" id="keywords-table">
            <thead>
              <tr>
                <th style="width:48px;">Tier</th>
                <th>Keyword</th>
                <th style="text-align:right;">Position</th>
                <th style="text-align:right;">Change</th>
                <th>SERP Features</th>
              </tr>
            </thead>
            <tbody id="keywords-body">
              <tr><td colspan="5" class="dash-empty">Loading...</td></tr>
            </tbody>
          </table>
        </div>
      </div>

      <!-- Three-column row -->
      <div class="dash-three-col">
        <!-- Top Pages -->
        <div class="dash-card" id="top-pages-section">
          <div class="dash-card__header">
            <h2 class="dash-card__title">Top Pages</h2>
          </div>
          <table class="dash-table dash-table--compact">
            <thead>
              <tr><th>Path</th><th style="text-align:right;">Clicks</th><th style="text-align:right;">Impr.</th></tr>
            </thead>
            <tbody id="top-pages-body">
              <tr><td colspan="3" class="dash-empty">Loading...</td></tr>
            </tbody>
          </table>
          <button class="dash-view-all" id="view-all-pages" style="display:none;">View all</button>
        </div>

        <!-- Top Queries -->
        <div class="dash-card" id="top-queries-section">
          <div class="dash-card__header">
            <h2 class="dash-card__title">Top Queries</h2>
          </div>
          <table class="dash-table dash-table--compact">
            <thead>
              <tr><th>Query</th><th style="text-align:right;">Clicks</th><th style="text-align:right;">Pos.</th></tr>
            </thead>
            <tbody id="top-queries-body">
              <tr><td colspan="3" class="dash-empty">Loading...</td></tr>
            </tbody>
          </table>
          <button class="dash-view-all" id="view-all-queries" style="display:none;">View all</button>
        </div>

        <!-- Traffic Alerts -->
        <div class="dash-card" id="traffic-alerts-section">
          <div class="dash-card__header">
            <h2 class="dash-card__title">Traffic Alerts</h2>
          </div>
          <div id="traffic-alerts-body" class="dash-alerts-list">
            <p class="dash-empty">Loading...</p>
          </div>
          <button class="dash-view-all" id="view-all-alerts" style="display:none;">View all</button>
        </div>
      </div>

      <!-- Two-column row -->
      <div class="dash-two-col">
        <!-- Site Health -->
        <div class="dash-card" id="health-section">
          <div class="dash-card__header">
            <h2 class="dash-card__title">Site Health</h2>
          </div>
          <div id="health-body" class="dash-health-list">
            <p class="dash-empty">Loading...</p>
          </div>
        </div>

        <!-- Worker Health -->
        <div class="dash-card" id="worker-health-section">
          <div class="dash-card__header">
            <h2 class="dash-card__title">Worker Health</h2>
          </div>
          <div id="worker-health-body" class="dash-worker-list">
            <p class="dash-empty">Loading...</p>
          </div>
        </div>
      </div>

      <!-- Observatory (collapsible) -->
      <div class="obs-section">
        <button class="obs-toggle" id="obs-toggle">
          <span class="obs-toggle__text">Observatory</span>
          <svg class="obs-toggle__icon" width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"><polyline points="4 6 8 10 12 6"/></svg>
        </button>
        <div class="obs-content" id="obs-content" style="display:none;">

          <div class="dash-card__header" style="margin-bottom:var(--space-4);">
            <h2 class="dash-card__title">Worker Activity</h2>
            <button class="btn btn--sm dash-refresh-btn" id="obs-refresh-btn">Refresh</button>
          </div>

          <!-- Worker activity table -->
          <div class="dash-card obs-table-card">
            <table class="dash-table">
              <thead>
                <tr><th>Worker</th><th>Status</th><th style="text-align:right;">Count</th></tr>
              </thead>
              <tbody id="obs-activity-body">
                <tr><td colspan="3" class="dash-empty">Loading...</td></tr>
              </tbody>
            </table>
          </div>

          <!-- Alert conditions -->
          <div class="obs-alerts-row obs-alerts-row--5">
            <div class="dash-card obs-alert-card" id="obs-alert-error-rate">
              <span class="obs-alert-card__label">Error Rate</span>
              <span class="obs-alert-card__icon" id="obs-icon-error-rate">--</span>
              <span class="obs-alert-card__detail" id="obs-detail-error-rate">Not checked</span>
            </div>
            <div class="dash-card obs-alert-card" id="obs-alert-intake">
              <span class="obs-alert-card__label">Library Intake</span>
              <span class="obs-alert-card__icon" id="obs-icon-intake">--</span>
              <span class="obs-alert-card__detail" id="obs-detail-intake">Not checked</span>
            </div>
            <div class="dash-card obs-alert-card" id="obs-alert-missing">
              <span class="obs-alert-card__label">Worker Presence</span>
              <span class="obs-alert-card__icon" id="obs-icon-missing">--</span>
              <span class="obs-alert-card__detail" id="obs-detail-missing">Not checked</span>
            </div>
            <div class="dash-card obs-alert-card" id="obs-alert-n8n">
              <span class="obs-alert-card__label">n8n</span>
              <span class="obs-alert-card__icon" id="obs-icon-n8n">--</span>
              <span class="obs-alert-card__detail" id="obs-detail-n8n">Not checked</span>
            </div>
            <div class="dash-card obs-alert-card" id="obs-alert-ses">
              <span class="obs-alert-card__label">SES</span>
              <span class="obs-alert-card__icon" id="obs-icon-ses">--</span>
              <span class="obs-alert-card__detail" id="obs-detail-ses">Not checked</span>
            </div>
          </div>

          <!-- Latency stats -->
          <div class="dash-card obs-table-card" id="obs-latency-card" style="display:none;">
            <h3 class="obs-sub-heading">Response Times</h3>
            <table class="dash-table">
              <thead>
                <tr><th>Worker</th><th style="text-align:right;">p50</th><th style="text-align:right;">p95</th><th style="text-align:right;">max</th><th style="text-align:right;">n</th></tr>
              </thead>
              <tbody id="obs-latency-body"></tbody>
            </table>
          </div>

          <!-- Recent errors -->
          <div class="dash-card obs-table-card" id="obs-errors-card" style="display:none;">
            <h3 class="obs-sub-heading obs-sub-heading--error">Recent Errors</h3>
            <table class="dash-table">
              <thead>
                <tr><th>Worker</th><th>Action</th><th>Detail</th></tr>
              </thead>
              <tbody id="obs-errors-body"></tbody>
            </table>
          </div>

          <p class="dash-timestamp" id="obs-timestamp">Last refreshed: --</p>
        </div>
      </div>

    </div>
  </section>

  <!-- Keyword Editor Modal -->
  <div class="kw-modal-overlay" id="kw-modal" style="display:none;">
    <div class="kw-modal">
      <div class="kw-modal__header">
        <h2 class="kw-modal__title">Edit Keywords</h2>
        <button class="kw-modal__close" id="kw-modal-close">&times;</button>
      </div>
      <div class="kw-modal__body">
        <div class="kw-modal__list-section">
          <h3 class="kw-modal__list-title">Active <span class="kw-modal__count" id="kw-active-count">0/15</span></h3>
          <div id="kw-active-list" class="kw-modal__list"></div>
          <button class="btn btn--sm kw-modal__add" id="kw-add-active">+ Add keyword</button>
        </div>
        <div class="kw-modal__list-section">
          <h3 class="kw-modal__list-title">Watchlist <span class="kw-modal__count" id="kw-watch-count">0/30</span></h3>
          <div id="kw-watch-list" class="kw-modal__list"></div>
          <button class="btn btn--sm kw-modal__add" id="kw-add-watch">+ Add keyword</button>
        </div>
      </div>
      <div class="kw-modal__footer">
        <button class="btn btn--sm" id="kw-cancel">Cancel</button>
        <button class="btn btn--primary btn--sm" id="kw-save">Save</button>
      </div>
    </div>
  </div>

  <script is:inline>
  (function () {
    // --- Utilities ---
    function esc(s) {
      var el = document.createElement('span');
      el.textContent = s || '';
      return el.innerHTML;
    }

    function fmtNum(n) {
      if (n == null) return '--';
      return Number(n).toLocaleString();
    }

    function fmtPct(n) {
      if (n == null) return '--';
      return (n * 100).toFixed(1) + '%';
    }

    function fmtPos(n) {
      if (n == null) return '--';
      return Number(n).toFixed(1);
    }

    function fmtDelta(n, invert) {
      if (n == null) return '';
      var pct = (n * 100).toFixed(0);
      var sign = n > 0 ? '+' : '';
      var isGood = invert ? n < 0 : n > 0;
      var cls = n === 0 ? 'delta--neutral' : isGood ? 'delta--good' : 'delta--bad';
      return '<span class="kpi-delta ' + cls + '">' + sign + pct + '%</span>';
    }

    function fmtPosDelta(n) {
      if (n == null) return '';
      var val = Number(n).toFixed(1);
      var sign = n > 0 ? '+' : '';
      // For position, negative change = improvement
      var isGood = n < 0;
      var cls = n === 0 ? 'delta--neutral' : isGood ? 'delta--good' : 'delta--bad';
      return '<span class="kpi-delta ' + cls + '">' + sign + val + '</span>';
    }

    function timeAgo(iso) {
      if (!iso) return '--';
      var d = new Date(iso);
      if (isNaN(d.getTime())) return '--';
      var secs = Math.floor((Date.now() - d.getTime()) / 1000);
      if (secs < 60) return 'just now';
      var mins = Math.floor(secs / 60);
      if (mins < 60) return mins + 'm ago';
      var hrs = Math.floor(mins / 60);
      if (hrs < 24) return hrs + 'h ago';
      var days = Math.floor(hrs / 24);
      return days + 'd ago';
    }

    function formatDate(iso) {
      if (!iso) return '--';
      var d = new Date(iso);
      if (isNaN(d.getTime())) return '--';
      var months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
      var h = d.getHours();
      var ampm = h >= 12 ? 'PM' : 'AM';
      h = h % 12 || 12;
      var min = String(d.getMinutes()).padStart(2, '0');
      return months[d.getMonth()] + ' ' + d.getDate() + ' ' + h + ':' + min + ' ' + ampm;
    }

    // --- API ---
    async function apiCall(action, opts) {
      var resp = await fetch('/api/admin/seo?action=' + encodeURIComponent(action), {
        credentials: 'include',
        ...opts,
      });
      if (resp.status === 401 || resp.status === 403) { window.location.href = '/login/?redirect=/admin/seo/'; return; }
      var data = await resp.json();
      if (!resp.ok) throw new Error(data.error || 'Request failed');
      return data;
    }

    // --- State ---
    var reportData = null;
    var allAlerts = [];

    // --- KPI Sparklines ---
    function renderSparkline(container, data) {
      container.innerHTML = '';
      if (!data || data.length < 2) return;
      var w = 120, h = 32;
      var min = Math.min.apply(null, data);
      var max = Math.max.apply(null, data);
      var range = max - min || 1;
      var points = data.map(function (v, i) {
        var x = (i / (data.length - 1)) * w;
        var y = h - ((v - min) / range) * (h - 4) - 2;
        return x.toFixed(1) + ',' + y.toFixed(1);
      }).join(' ');
      var svg = document.createElementNS('http://www.w3.org/2000/svg', 'svg');
      svg.setAttribute('viewBox', '0 0 ' + w + ' ' + h);
      svg.setAttribute('class', 'sparkline-svg');
      var polyline = document.createElementNS('http://www.w3.org/2000/svg', 'polyline');
      polyline.setAttribute('points', points);
      polyline.setAttribute('fill', 'none');
      polyline.setAttribute('stroke', 'var(--admin-rose-700)');
      polyline.setAttribute('stroke-width', '1.5');
      polyline.setAttribute('stroke-linecap', 'round');
      polyline.setAttribute('stroke-linejoin', 'round');
      svg.appendChild(polyline);
      container.appendChild(svg);
    }

    // --- Render functions ---
    function renderKPIs(snapshot, sparklines) {
      var gsc = (snapshot && snapshot.gsc) || {};
      var traffic = (snapshot && snapshot.traffic) || {};

      document.getElementById('kpi-val-clicks').textContent = fmtNum(gsc.clicks);
      document.getElementById('kpi-delta-clicks').innerHTML = fmtDelta(gsc.clicksDelta);
      renderSparkline(document.getElementById('kpi-spark-clicks'), sparklines && sparklines.clicks);

      document.getElementById('kpi-val-impressions').textContent = fmtNum(gsc.impressions);
      document.getElementById('kpi-delta-impressions').innerHTML = fmtDelta(gsc.impressionsDelta);
      renderSparkline(document.getElementById('kpi-spark-impressions'), sparklines && sparklines.impressions);

      document.getElementById('kpi-val-ctr').textContent = fmtPct(gsc.ctr);
      document.getElementById('kpi-delta-ctr').innerHTML = fmtDelta(gsc.ctrDelta);
      renderSparkline(document.getElementById('kpi-spark-ctr'), sparklines && sparklines.ctr);

      document.getElementById('kpi-val-position').textContent = fmtPos(gsc.position);
      document.getElementById('kpi-delta-position').innerHTML = fmtPosDelta(gsc.positionDelta);
      renderSparkline(document.getElementById('kpi-spark-position'), sparklines && sparklines.position);

      document.getElementById('kpi-val-visitors').textContent = fmtNum(traffic.visitors);
      // No visitorsDelta from gsc, check if sparklines has visitors data
      if (sparklines && sparklines.visitors && sparklines.visitors.length >= 2) {
        var curr = sparklines.visitors[0];
        var prev = sparklines.visitors[1];
        var vDelta = prev ? (curr - prev) / prev : null;
        document.getElementById('kpi-delta-visitors').innerHTML = fmtDelta(vDelta);
      }
      renderSparkline(document.getElementById('kpi-spark-visitors'), sparklines && sparklines.visitors);
    }

    function renderKeywords(keywords) {
      var body = document.getElementById('keywords-body');
      if (!keywords || keywords.length === 0) {
        body.innerHTML = '<tr><td colspan="5" class="dash-empty">No keywords tracked yet</td></tr>';
        return;
      }
      body.innerHTML = keywords.map(function (kw) {
        var tierClass = kw.tier === 'active' ? 'tier-badge--active' : 'tier-badge--watch';
        var tierLabel = kw.tier === 'active' ? 'A' : 'W';
        var changeVal = kw.change || 0;
        var changeSign = changeVal > 0 ? '+' : '';
        // For position change: positive = moved up = good
        var changeClass = changeVal === 0 ? 'delta--neutral' : changeVal > 0 ? 'delta--good' : 'delta--bad';
        var features = (kw.features || []).map(function (f) {
          return '<span class="serp-badge">' + esc(f) + '</span>';
        }).join(' ');
        return '<tr>' +
          '<td><span class="tier-badge ' + tierClass + '">' + tierLabel + '</span></td>' +
          '<td>' + esc(kw.keyword) + '</td>' +
          '<td style="text-align:right;font-variant-numeric:tabular-nums;">' + fmtPos(kw.position) + '</td>' +
          '<td style="text-align:right;"><span class="' + changeClass + '">' + changeSign + changeVal + '</span></td>' +
          '<td>' + (features || '--') + '</td>' +
          '</tr>';
      }).join('');
    }

    function renderTopPages(pages) {
      var body = document.getElementById('top-pages-body');
      var viewBtn = document.getElementById('view-all-pages');
      if (!pages || pages.length === 0) {
        body.innerHTML = '<tr><td colspan="3" class="dash-empty">No data yet</td></tr>';
        viewBtn.style.display = 'none';
        return;
      }
      var show = 3;
      var expanded = false;
      function render() {
        var items = expanded ? pages.slice(0, 25) : pages.slice(0, show);
        body.innerHTML = items.map(function (p) {
          var path = p.path || '';
          var short = path.length > 32 ? path.slice(0, 30) + '...' : path;
          return '<tr><td title="' + esc(path) + '">' + esc(short) + '</td>' +
            '<td style="text-align:right;">' + fmtNum(p.clicks) + '</td>' +
            '<td style="text-align:right;">' + fmtNum(p.impressions) + '</td></tr>';
        }).join('');
      }
      render();
      if (pages.length > show) {
        viewBtn.style.display = '';
        viewBtn.onclick = function () {
          expanded = !expanded;
          viewBtn.textContent = expanded ? 'Show less' : 'View all';
          render();
        };
      } else {
        viewBtn.style.display = 'none';
      }
    }

    function renderTopQueries(queries) {
      var body = document.getElementById('top-queries-body');
      var viewBtn = document.getElementById('view-all-queries');
      if (!queries || queries.length === 0) {
        body.innerHTML = '<tr><td colspan="3" class="dash-empty">No data yet</td></tr>';
        viewBtn.style.display = 'none';
        return;
      }
      var show = 3;
      var expanded = false;
      function render() {
        var items = expanded ? queries.slice(0, 25) : queries.slice(0, show);
        body.innerHTML = items.map(function (q) {
          return '<tr><td>' + esc(q.query) + '</td>' +
            '<td style="text-align:right;">' + fmtNum(q.clicks) + '</td>' +
            '<td style="text-align:right;">' + fmtPos(q.position) + '</td></tr>';
        }).join('');
      }
      render();
      if (queries.length > show) {
        viewBtn.style.display = '';
        viewBtn.onclick = function () {
          expanded = !expanded;
          viewBtn.textContent = expanded ? 'Show less' : 'View all';
          render();
        };
      } else {
        viewBtn.style.display = 'none';
      }
    }

    function renderAlerts(alerts) {
      allAlerts = alerts || [];
      var body = document.getElementById('traffic-alerts-body');
      var viewBtn = document.getElementById('view-all-alerts');
      var bellDot = document.getElementById('bell-dot');
      var bellList = document.getElementById('bell-list');

      // Bell dot
      bellDot.style.display = allAlerts.length > 0 ? '' : 'none';

      // Bell dropdown
      if (allAlerts.length === 0) {
        bellList.innerHTML = '<div class="dash-bell__empty">No alerts</div>';
      } else {
        bellList.innerHTML = allAlerts.map(function (a) {
          var d = a.data || {};
          var label = d.path || a.type || 'Alert';
          var detail = d.currentViews ? d.currentViews + ' views' : '';
          if (d.ratio) detail += ' (' + d.ratio.toFixed(1) + 'x)';
          return '<div class="dash-bell__item">' +
            '<div class="dash-bell__item-text"><strong>' + esc(label) + '</strong>' +
            (detail ? '<br><span class="dash-bell__item-detail">' + esc(detail) + '</span>' : '') +
            '</div>' +
            '<button class="dash-bell__dismiss" data-id="' + esc(a.id) + '" title="Dismiss">&times;</button>' +
            '</div>';
        }).join('');
      }

      // Traffic alerts card
      if (allAlerts.length === 0) {
        body.innerHTML = '<p class="dash-empty">No traffic alerts</p>';
        viewBtn.style.display = 'none';
        return;
      }
      var show = 3;
      var expanded = false;
      function render() {
        var items = expanded ? allAlerts.slice(0, 25) : allAlerts.slice(0, show);
        body.innerHTML = items.map(function (a) {
          var d = a.data || {};
          var path = d.path || 'Unknown page';
          var short = path.length > 30 ? path.slice(0, 28) + '...' : path;
          var views = d.currentViews != null ? fmtNum(d.currentViews) : '--';
          var ratio = d.ratio != null ? (d.ratio * 100 - 100).toFixed(0) + '%' : '--';
          return '<div class="dash-alert-item">' +
            '<span class="dash-alert-item__path" title="' + esc(path) + '">' + esc(short) + '</span>' +
            '<span class="dash-alert-item__views">' + views + ' views</span>' +
            '<span class="dash-alert-item__delta delta--bad">+' + ratio + '</span>' +
            '</div>';
        }).join('');
      }
      render();
      if (allAlerts.length > show) {
        viewBtn.style.display = '';
        viewBtn.onclick = function () {
          expanded = !expanded;
          viewBtn.textContent = expanded ? 'Show less' : 'View all';
          render();
        };
      } else {
        viewBtn.style.display = 'none';
      }
    }

    function renderHealth(health) {
      var body = document.getElementById('health-body');
      if (!health || !health.checks || health.checks.length === 0) {
        body.innerHTML = '<p class="dash-empty">No health data</p>';
        return;
      }
      body.innerHTML = health.checks.map(function (c) {
        var dotClass = c.ok ? 'health-dot--ok' : 'health-dot--fail';
        return '<div class="health-row">' +
          '<span class="health-dot ' + dotClass + '"></span>' +
          '<span class="health-row__name">' + esc(c.name) + '</span>' +
          '<span class="health-row__detail">' + esc(c.detail || (c.ok ? 'OK' : 'Failed')) + '</span>' +
          '</div>';
      }).join('');
    }

    function renderWorkerHealth(worker) {
      var body = document.getElementById('worker-health-body');
      if (!worker) {
        body.innerHTML = '<p class="dash-empty">No worker data</p>';
        return;
      }
      var rows = [];
      rows.push({ label: 'Daily cron', value: timeAgo(worker.lastDaily) });
      rows.push({ label: 'Spike detection', value: timeAgo(worker.lastSpike) });
      rows.push({ label: 'Weekly digest', value: timeAgo(worker.lastWeekly) });
      rows.push({ label: 'KV data', value: worker.kvDays != null ? worker.kvDays + ' days stored' : '--' });

      var html = rows.map(function (r) {
        return '<div class="worker-row">' +
          '<span class="worker-row__label">' + esc(r.label) + '</span>' +
          '<span class="worker-row__value">' + esc(r.value) + '</span>' +
          '</div>';
      }).join('');

      // GSC status
      var gscOk = worker.gscConnected;
      html += '<div class="worker-row worker-row--gsc">' +
        '<span class="worker-row__label">GSC</span>' +
        (gscOk
          ? '<span class="worker-row__value worker-row__value--ok">Connected</span>'
          : '<span class="worker-row__value worker-row__value--warn">Disconnected</span>') +
        '</div>';

      body.innerHTML = html;
    }

    // --- Dismiss alert ---
    async function dismissAlert(id) {
      try {
        await apiCall('dismiss', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id: id }),
        });
        allAlerts = allAlerts.filter(function (a) { return a.id !== id; });
        renderAlerts(allAlerts);
      } catch (e) {
        // ignore
      }
    }

    // --- Bell dropdown ---
    var bellBtn = document.getElementById('bell-btn');
    var bellDropdown = document.getElementById('bell-dropdown');
    var bellWrap = document.getElementById('bell-wrap');
    bellBtn.addEventListener('click', function (e) {
      e.stopPropagation();
      bellDropdown.style.display = bellDropdown.style.display === 'none' ? '' : 'none';
    });
    document.addEventListener('click', function (e) {
      if (!bellWrap.contains(e.target)) bellDropdown.style.display = 'none';
    });
    bellDropdown.addEventListener('click', function (e) {
      var btn = e.target.closest('.dash-bell__dismiss');
      if (btn) dismissAlert(btn.dataset.id);
    });

    // --- Fetch report ---
    async function fetchReport() {
      var refreshBtn = document.getElementById('refresh-btn');
      refreshBtn.disabled = true;
      refreshBtn.textContent = 'Loading...';
      try {
        reportData = await apiCall('report');
        if (reportData) {
          var snapshot = reportData.snapshot || {};
          renderKPIs(snapshot, reportData.sparklines);
          renderKeywords(snapshot.keywords);
          renderTopPages(snapshot.traffic && snapshot.traffic.topPages);
          renderTopQueries(snapshot.traffic && snapshot.traffic.topQueries);
          renderAlerts(reportData.alerts);
          renderHealth(snapshot.health);
          renderWorkerHealth(reportData.worker);

          var ts = snapshot.date || (reportData.worker && reportData.worker.lastDaily);
          document.getElementById('last-updated').textContent = 'Updated ' + (ts ? formatDate(ts) : '--');
        }
      } catch (e) {
        document.getElementById('last-updated').textContent = 'Error: ' + e.message;
      }
      refreshBtn.disabled = false;
      refreshBtn.textContent = 'Refresh';
    }

    function refreshReport() {
      fetchReport();
    }

    document.getElementById('refresh-btn').addEventListener('click', refreshReport);

    // --- Keyword Modal ---
    var kwModal = document.getElementById('kw-modal');
    var editKwBtn = document.getElementById('edit-kw-btn');
    var kwModalClose = document.getElementById('kw-modal-close');
    var kwCancel = document.getElementById('kw-cancel');
    var kwSave = document.getElementById('kw-save');
    var kwAddActive = document.getElementById('kw-add-active');
    var kwAddWatch = document.getElementById('kw-add-watch');
    var kwState = { active: [], watch: [] };

    function toggleKeywordModal() {
      var isOpen = kwModal.style.display !== 'none';
      if (isOpen) {
        kwModal.style.display = 'none';
        return;
      }
      // Populate from current data
      var keywords = (reportData && reportData.snapshot && reportData.snapshot.keywords) || [];
      kwState.active = keywords.filter(function (k) { return k.tier === 'active'; }).map(function (k) { return k.keyword; });
      kwState.watch = keywords.filter(function (k) { return k.tier !== 'active'; }).map(function (k) { return k.keyword; });
      renderKwList('active');
      renderKwList('watch');
      kwModal.style.display = '';
    }

    function renderKwList(tier) {
      var listEl = document.getElementById('kw-' + (tier === 'active' ? 'active' : 'watch') + '-list');
      var countEl = document.getElementById('kw-' + (tier === 'active' ? 'active' : 'watch') + '-count');
      var max = tier === 'active' ? 15 : 30;
      var items = kwState[tier === 'active' ? 'active' : 'watch'];
      countEl.textContent = items.length + '/' + max;
      listEl.innerHTML = items.map(function (kw, i) {
        return '<div class="kw-row">' +
          '<input type="text" class="kw-row__input" value="' + esc(kw) + '" data-tier="' + tier + '" data-index="' + i + '">' +
          '<button class="kw-row__toggle" data-tier="' + tier + '" data-index="' + i + '" title="Move to ' + (tier === 'active' ? 'watchlist' : 'active') + '">' + (tier === 'active' ? 'A' : 'W') + '</button>' +
          '<button class="kw-row__delete" data-tier="' + tier + '" data-index="' + i + '" title="Delete">&times;</button>' +
          '</div>';
      }).join('');
    }

    editKwBtn.addEventListener('click', toggleKeywordModal);
    kwModalClose.addEventListener('click', toggleKeywordModal);
    kwCancel.addEventListener('click', toggleKeywordModal);
    kwModal.addEventListener('click', function (e) {
      if (e.target === kwModal) toggleKeywordModal();
    });

    kwAddActive.addEventListener('click', function () {
      if (kwState.active.length >= 15) return;
      kwState.active.push('');
      renderKwList('active');
      var inputs = document.querySelectorAll('#kw-active-list .kw-row__input');
      if (inputs.length) inputs[inputs.length - 1].focus();
    });
    kwAddWatch.addEventListener('click', function () {
      if (kwState.watch.length >= 30) return;
      kwState.watch.push('');
      renderKwList('watch');
      var inputs = document.querySelectorAll('#kw-watch-list .kw-row__input');
      if (inputs.length) inputs[inputs.length - 1].focus();
    });

    // Event delegation for kw list actions
    document.addEventListener('click', function (e) {
      var del = e.target.closest('.kw-row__delete');
      if (del) {
        var tier = del.dataset.tier;
        var idx = parseInt(del.dataset.index, 10);
        var arr = tier === 'active' ? kwState.active : kwState.watch;
        arr.splice(idx, 1);
        renderKwList(tier);
        return;
      }
      var toggle = e.target.closest('.kw-row__toggle');
      if (toggle) {
        var tier2 = toggle.dataset.tier;
        var idx2 = parseInt(toggle.dataset.index, 10);
        var from = tier2 === 'active' ? kwState.active : kwState.watch;
        var to = tier2 === 'active' ? kwState.watch : kwState.active;
        var maxTo = tier2 === 'active' ? 30 : 15;
        if (to.length >= maxTo) return;
        var kw = from.splice(idx2, 1)[0];
        to.push(kw);
        renderKwList('active');
        renderKwList('watch');
      }
    });

    // Sync input values before save
    function syncKwInputs() {
      document.querySelectorAll('.kw-row__input').forEach(function (inp) {
        var tier = inp.dataset.tier;
        var idx = parseInt(inp.dataset.index, 10);
        var arr = tier === 'active' ? kwState.active : kwState.watch;
        arr[idx] = inp.value.trim();
      });
    }

    async function saveKeywords() {
      syncKwInputs();
      var keywords = [];
      kwState.active.forEach(function (kw) {
        if (kw) keywords.push({ keyword: kw, tier: 'active' });
      });
      kwState.watch.forEach(function (kw) {
        if (kw) keywords.push({ keyword: kw, tier: 'watch' });
      });
      kwSave.disabled = true;
      kwSave.textContent = 'Saving...';
      try {
        await apiCall('keywords', {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ keywords: keywords }),
        });
        toggleKeywordModal();
        fetchReport();
      } catch (e) {
        alert('Failed to save: ' + e.message);
      }
      kwSave.disabled = false;
      kwSave.textContent = 'Save';
    }

    kwSave.addEventListener('click', saveKeywords);

    // --- Observatory ---
    var obsToggle = document.getElementById('obs-toggle');
    var obsContent = document.getElementById('obs-content');
    obsToggle.addEventListener('click', function () {
      var open = obsContent.style.display !== 'none';
      obsContent.style.display = open ? 'none' : '';
      obsToggle.classList.toggle('obs-toggle--open', !open);
      if (!open && !obsLoaded) loadObservatory();
    });

    var obsLoaded = false;
    var obsRefreshBtn = document.getElementById('obs-refresh-btn');
    var obsActivityBody = document.getElementById('obs-activity-body');
    var obsTimestamp = document.getElementById('obs-timestamp');
    var obsErrorsCard = document.getElementById('obs-errors-card');
    var obsErrorsBody = document.getElementById('obs-errors-body');

    var ALERT_MAP = {
      high_error_rate: 'error-rate',
      intake_silent: 'intake',
      worker_missing: 'missing',
      n8n_health: 'n8n',
      ses_reputation: 'ses',
    };

    function updateObservatory(data) {
      obsLoaded = true;
      // Activity table
      if (data.summary && data.summary.length > 0) {
        obsActivityBody.innerHTML = data.summary.map(function (r) {
          var statusClass = (r.status === 'error' || r.status === 'fail') ? ' class="obs-row--error"' : '';
          return '<tr' + statusClass + '><td>' + esc(r.worker) + '</td><td>' + esc(r.status) + '</td><td style="text-align:right;">' + r.cnt + '</td></tr>';
        }).join('');
      } else {
        obsActivityBody.innerHTML = '<tr><td colspan="3" class="dash-empty">No events in last 24h</td></tr>';
      }

      // Alert cards
      if (data.alerts && data.alerts.all) {
        for (var i = 0; i < data.alerts.all.length; i++) {
          var a = data.alerts.all[i];
          var cardId = ALERT_MAP[a.name];
          if (!cardId) continue;
          var iconEl = document.getElementById('obs-icon-' + cardId);
          var detailEl = document.getElementById('obs-detail-' + cardId);
          if (!iconEl || !detailEl) continue;

          if (a.alert) {
            iconEl.textContent = '\u2717';
            iconEl.className = 'obs-alert-card__icon obs-alert-card__icon--fail';
          } else if (a.error) {
            iconEl.textContent = '?';
            iconEl.className = 'obs-alert-card__icon';
          } else {
            iconEl.textContent = '\u2713';
            iconEl.className = 'obs-alert-card__icon obs-alert-card__icon--pass';
          }
          detailEl.textContent = a.message || '';
        }
      }

      // Latency table
      var latencyCard = document.getElementById('obs-latency-card');
      var latencyBody = document.getElementById('obs-latency-body');
      if (data.latency && data.latency.length > 0) {
        latencyCard.style.display = '';
        latencyBody.innerHTML = data.latency.map(function (r) {
          var p50 = Math.round(parseFloat(r.p50) || 0);
          var p95 = Math.round(parseFloat(r.p95) || 0);
          var max = Math.round(parseFloat(r.max_ms) || 0);
          var p95Style = p95 > 5000 ? ' style="color:var(--admin-error);text-align:right;"' : p95 > 2000 ? ' style="color:var(--admin-warning);text-align:right;"' : ' style="text-align:right;"';
          return '<tr><td>' + esc(r.worker) + '</td><td style="text-align:right;">' + p50 + 'ms</td><td' + p95Style + '>' + p95 + 'ms</td><td style="text-align:right;">' + max + 'ms</td><td style="text-align:right;">' + r.cnt + '</td></tr>';
        }).join('');
      } else {
        latencyCard.style.display = 'none';
      }

      // Errors table
      if (data.errors && data.errors.length > 0) {
        obsErrorsCard.style.display = '';
        obsErrorsBody.innerHTML = data.errors.slice(0, 15).map(function (e) {
          return '<tr class="obs-row--error"><td>' + esc(e.worker) + '</td><td>' + esc(e.action) + '</td><td>' + esc((e.detail || '').slice(0, 100)) + '</td></tr>';
        }).join('');
      } else {
        obsErrorsCard.style.display = 'none';
      }

      obsTimestamp.textContent = 'Last refreshed: ' + formatDate(new Date().toISOString()) +
        (data.duration_ms ? ' (' + data.duration_ms + 'ms)' : '');
    }

    async function loadObservatory() {
      obsRefreshBtn.disabled = true;
      obsRefreshBtn.textContent = 'Loading...';
      try {
        var data = await apiCall('observatory');
        updateObservatory(data);
      } catch (e) {
        obsTimestamp.textContent = 'Error: ' + e.message;
      }
      obsRefreshBtn.disabled = false;
      obsRefreshBtn.textContent = 'Refresh';
    }

    obsRefreshBtn.addEventListener('click', loadObservatory);

    // --- Logout ---
    document.getElementById('logout-btn').addEventListener('click', async function () {
      await fetch('/api/auth/logout', { method: 'POST', credentials: 'include' });
      window.location.href = '/login/';
    });

    // --- Init ---
    fetchReport();
  })();
  </script>

</BaseLayout>

<style>
  /* Admin palette */
  :root {
    --admin-rose-700: #8a606e;
    --admin-rose-300: #c9a8b2;
    --admin-rose-100: #f0e5e9;
    --admin-bg: #faf8f5;
    --admin-surface: #ffffff;
    --admin-border: #d9d3cc;
    --admin-text: #313131;
    --admin-text-faint: #949392;
    --admin-bar-bg: #3d2a32;
    --admin-success: #2D8A4E;
    --admin-warning: #D4840A;
    --admin-error: #C53030;
  }

  :global(.admin-page) :global(.site-header) { display: none; }
  :global(.admin-page) :global(footer) { display: none; }

  /* Admin bar */
  .admin-bar {
    background: var(--admin-bar-bg);
    color: var(--admin-rose-100);
    position: sticky;
    top: 0;
    z-index: 100;
  }
  .admin-bar__inner {
    display: flex;
    align-items: center;
    height: 48px;
    gap: var(--space-6);
  }
  .admin-bar__title {
    font-family: 'Cormorant Garamond', 'Georgia', serif;
    font-weight: 600;
    font-size: 1.25rem;
    color: var(--admin-rose-300);
    white-space: nowrap;
  }
  .admin-bar__nav {
    display: flex;
    gap: var(--space-1);
  }
  .admin-bar__link {
    font-size: 0.8125rem;
    font-weight: 400;
    color: rgba(255,255,255,0.6);
    text-decoration: none;
    padding: 4px 12px;
    border-radius: var(--radius-sm);
    transition: color 0.15s, background 0.15s;
  }
  .admin-bar__link:hover {
    color: #fff;
    text-decoration: none;
  }
  .admin-bar__link--active {
    color: #fff;
    background: rgba(255,255,255,0.1);
    font-weight: 500;
  }
  .admin-bar__actions {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-left: auto;
  }
  .admin-bar__site-link {
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--admin-rose-300);
    text-decoration: none;
    padding: 5px 16px;
    border: 1px solid var(--admin-rose-300);
    border-radius: var(--radius-pill);
    transition: color 0.15s, border-color 0.15s, background 0.15s;
  }
  .admin-bar__site-link:hover {
    color: #fff;
    border-color: #fff;
    text-decoration: none;
  }
  .admin-bar__logout {
    font-size: 0.8125rem;
    font-weight: 400;
    color: rgba(255,255,255,0.5);
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px 8px;
    transition: color 0.15s;
  }
  .admin-bar__logout:hover {
    color: #fff;
  }

  /* Dashboard section */
  .dash-section {
    padding: var(--space-8) 0;
    background: var(--admin-bg);
    min-height: 80vh;
  }

  /* Header row */
  .dash-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--space-6);
    gap: var(--space-4);
  }
  .dash-header__left {
    display: flex;
    align-items: baseline;
    gap: var(--space-4);
  }
  .dash-header__title {
    margin-bottom: 0;
    color: var(--admin-text);
    font-family: 'Cormorant Garamond', 'Georgia', serif;
  }
  .dash-header__updated {
    font-size: 0.8125rem;
    color: var(--admin-text-faint);
  }
  .dash-header__right {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  /* Refresh button */
  .dash-refresh-btn {
    background: var(--admin-rose-700);
    border-color: var(--admin-rose-700);
    color: #fff;
    font-size: 0.8125rem;
  }
  .dash-refresh-btn:hover {
    background: #764d5e;
  }
  .dash-refresh-btn:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  /* Bell */
  .dash-bell {
    position: relative;
  }
  .dash-bell__btn {
    background: none;
    border: 1px solid var(--admin-border);
    border-radius: var(--radius-sm);
    padding: 6px 8px;
    cursor: pointer;
    color: var(--admin-text-faint);
    display: flex;
    align-items: center;
    position: relative;
    transition: color 0.15s, border-color 0.15s;
  }
  .dash-bell__btn:hover {
    color: var(--admin-text);
    border-color: var(--admin-rose-700);
  }
  .dash-bell__dot {
    position: absolute;
    top: 4px;
    right: 4px;
    width: 8px;
    height: 8px;
    background: var(--admin-error);
    border-radius: 50%;
  }
  .dash-bell__dropdown {
    position: absolute;
    top: 100%;
    right: 0;
    margin-top: var(--space-2);
    background: var(--admin-surface);
    border: 1px solid var(--admin-border);
    border-radius: var(--radius-md);
    box-shadow: 0 4px 16px rgba(0,0,0,0.1);
    width: 320px;
    max-height: 400px;
    overflow-y: auto;
    z-index: 50;
  }
  .dash-bell__header {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--admin-text-faint);
    padding: var(--space-3) var(--space-4);
    border-bottom: 1px solid var(--admin-border);
  }
  .dash-bell__empty {
    padding: var(--space-4);
    text-align: center;
    font-size: 0.8125rem;
    color: var(--admin-text-faint);
  }

  /* KPI strip */
  .kpi-strip {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: var(--space-4);
    margin-bottom: var(--space-6);
  }
  .kpi-card {
    background: var(--admin-surface);
    border: 1px solid var(--admin-border);
    border-radius: var(--radius-md);
    padding: var(--space-4) var(--space-5);
  }
  .kpi-card__label {
    display: block;
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--admin-text-faint);
    margin-bottom: var(--space-1);
  }
  .kpi-card__row {
    display: flex;
    align-items: baseline;
    gap: var(--space-2);
  }
  .kpi-card__value {
    font-family: 'Inter', sans-serif;
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--admin-text);
    font-variant-numeric: tabular-nums;
  }
  .kpi-card__spark {
    margin-top: var(--space-2);
    height: 32px;
  }

  /* Cards */
  .dash-card {
    background: var(--admin-surface);
    border: 1px solid var(--admin-border);
    border-radius: var(--radius-md);
    padding: var(--space-4) var(--space-5);
  }
  .dash-card--full {
    margin-bottom: var(--space-6);
  }
  .dash-card__header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--space-4);
  }
  .dash-card__title {
    font-family: 'Cormorant Garamond', 'Georgia', serif;
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--admin-text);
    margin: 0;
  }

  /* Edit keywords button */
  .dash-edit-kw-btn {
    background: transparent;
    border: 1px solid var(--admin-border);
    color: var(--admin-text-faint);
    font-size: 0.75rem;
  }
  .dash-edit-kw-btn:hover {
    border-color: var(--admin-rose-700);
    color: var(--admin-rose-700);
  }

  /* Tables */
  .dash-table-wrap {
    overflow-x: auto;
  }
  .dash-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.8125rem;
  }
  .dash-table th {
    text-align: left;
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--admin-text-faint);
    padding: var(--space-2) var(--space-3);
    border-bottom: 1px solid var(--admin-border);
  }
  .dash-table td {
    padding: var(--space-2) var(--space-3);
    border-bottom: 1px solid #f0eeeb;
    color: var(--admin-text);
    font-family: 'Inter', sans-serif;
    font-size: 0.8125rem;
  }
  .dash-table--compact td {
    font-size: 0.75rem;
    font-family: 'SF Mono', 'Fira Code', monospace;
  }
