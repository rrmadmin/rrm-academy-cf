---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout title="SEO Health" description="Admin SEO health monitor" noindex={true} bodyClass="admin-page">

  <!-- Admin Header Bar -->
  <div class="admin-bar">
    <div class="container admin-bar__inner">
      <span class="admin-bar__title">RRM Admin</span>
      <nav class="admin-bar__nav">
        <a href="/admin/backlinks/" class="admin-bar__link">Backlinks</a>
        <a href="/admin/conversions/" class="admin-bar__link">Conversions</a>
        <a href="/admin/content/" class="admin-bar__link">Content</a>
        <a href="/admin/seo/" class="admin-bar__link admin-bar__link--active">SEO</a>
        <a href="/admin/revenue/" class="admin-bar__link">Revenue</a>
      </nav>
      <div class="admin-bar__actions">
        <a href="/" class="admin-bar__site-link">Return to site</a>
        <button class="admin-bar__logout" id="logout-btn">Logout</button>
      </div>
    </div>
  </div>

  <!-- Dashboard -->
  <section id="dashboard" class="bl-section">
    <div class="container">

      <!-- Page heading -->
      <div class="bl-header">
        <h1>SEO Health</h1>
        <button class="btn btn--primary seo-run-btn" id="run-check-btn">Run Check</button>
      </div>

      <!-- Status cards -->
      <div class="bl-metrics seo-grid">
        <div class="bl-card seo-card" id="card-pages">
          <span class="bl-card__label">Pages</span>
          <span class="seo-card__icon" id="icon-pages">--</span>
          <span class="seo-card__detail" id="detail-pages">Not checked</span>
        </div>
        <div class="bl-card seo-card" id="card-sitemap">
          <span class="bl-card__label">Sitemap</span>
          <span class="seo-card__icon" id="icon-sitemap">--</span>
          <span class="seo-card__detail" id="detail-sitemap">Not checked</span>
        </div>
        <div class="bl-card seo-card" id="card-robots">
          <span class="bl-card__label">Robots</span>
          <span class="seo-card__icon" id="icon-robots">--</span>
          <span class="seo-card__detail" id="detail-robots">Not checked</span>
        </div>
        <div class="bl-card seo-card" id="card-llms_txt">
          <span class="bl-card__label">llms.txt</span>
          <span class="seo-card__icon" id="icon-llms_txt">--</span>
          <span class="seo-card__detail" id="detail-llms_txt">Not checked</span>
        </div>
        <div class="bl-card seo-card" id="card-schema">
          <span class="bl-card__label">Schema</span>
          <span class="seo-card__icon" id="icon-schema">--</span>
          <span class="seo-card__detail" id="detail-schema">Not checked</span>
        </div>
        <div class="bl-card seo-card" id="card-backlinks">
          <span class="bl-card__label">Backlinks</span>
          <span class="seo-card__icon" id="icon-backlinks">--</span>
          <span class="seo-card__detail" id="detail-backlinks">Not checked</span>
        </div>
        <div class="bl-card seo-card" id="card-headers">
          <span class="bl-card__label">Headers</span>
          <span class="seo-card__icon" id="icon-headers">--</span>
          <span class="seo-card__detail" id="detail-headers">Not checked</span>
        </div>
      </div>

      <!-- Last checked -->
      <p class="seo-timestamp" id="last-checked">Last checked: --</p>

      <!-- Observatory: Worker Health -->
      <div class="obs-section">
        <div class="bl-header">
          <h2>Worker Health</h2>
          <button class="btn btn--primary seo-run-btn" id="obs-refresh-btn">Refresh</button>
        </div>

        <!-- Worker activity table -->
        <div class="bl-card obs-table-card">
          <table class="obs-table" id="obs-activity-table">
            <thead>
              <tr><th>Worker</th><th>Status</th><th>Count</th></tr>
            </thead>
            <tbody id="obs-activity-body">
              <tr><td colspan="3" class="obs-empty">Loading...</td></tr>
            </tbody>
          </table>
        </div>

        <!-- Alert conditions -->
        <div class="obs-alerts-row obs-alerts-row--5">
          <div class="bl-card obs-alert-card" id="obs-alert-error-rate">
            <span class="bl-card__label">Error Rate</span>
            <span class="seo-card__icon" id="obs-icon-error-rate">--</span>
            <span class="seo-card__detail" id="obs-detail-error-rate">Not checked</span>
          </div>
          <div class="bl-card obs-alert-card" id="obs-alert-intake">
            <span class="bl-card__label">Library Intake</span>
            <span class="seo-card__icon" id="obs-icon-intake">--</span>
            <span class="seo-card__detail" id="obs-detail-intake">Not checked</span>
          </div>
          <div class="bl-card obs-alert-card" id="obs-alert-missing">
            <span class="bl-card__label">Worker Presence</span>
            <span class="seo-card__icon" id="obs-icon-missing">--</span>
            <span class="seo-card__detail" id="obs-detail-missing">Not checked</span>
          </div>
          <div class="bl-card obs-alert-card" id="obs-alert-n8n">
            <span class="bl-card__label">n8n</span>
            <span class="seo-card__icon" id="obs-icon-n8n">--</span>
            <span class="seo-card__detail" id="obs-detail-n8n">Not checked</span>
          </div>
          <div class="bl-card obs-alert-card" id="obs-alert-ses">
            <span class="bl-card__label">SES</span>
            <span class="seo-card__icon" id="obs-icon-ses">--</span>
            <span class="seo-card__detail" id="obs-detail-ses">Not checked</span>
          </div>
        </div>

        <!-- Latency stats -->
        <div class="bl-card obs-table-card" id="obs-latency-card" style="display:none;">
          <h3 class="obs-latency-heading">Response Times</h3>
          <table class="obs-table">
            <thead>
              <tr><th>Worker</th><th style="text-align:right;">p50</th><th style="text-align:right;">p95</th><th style="text-align:right;">max</th><th style="text-align:right;">n</th></tr>
            </thead>
            <tbody id="obs-latency-body"></tbody>
          </table>
        </div>

        <!-- Recent errors -->
        <div class="bl-card obs-table-card" id="obs-errors-card" style="display:none;">
          <h3 class="obs-errors-heading">Recent Errors</h3>
          <table class="obs-table">
            <thead>
              <tr><th>Worker</th><th>Action</th><th>Detail</th></tr>
            </thead>
            <tbody id="obs-errors-body"></tbody>
          </table>
        </div>

        <p class="seo-timestamp" id="obs-timestamp">Last refreshed: --</p>
      </div>

    </div>
  </section>

  <script is:inline>
  (function () {
    var CHECK_NAMES = ['pages', 'sitemap', 'robots', 'llms_txt', 'schema', 'backlinks', 'headers'];

    // API
    async function apiCall(action) {
      var resp = await fetch('/api/admin/seo?action=' + encodeURIComponent(action), {
        credentials: 'include',
      });
      if (resp.status === 401 || resp.status === 403) { window.location.href = '/login/?redirect=/admin/seo/'; return; }
      var data = await resp.json();
      if (!resp.ok) throw new Error(data.error || 'Request failed');
      return data;
    }

    // Formatting
    function formatDate(iso) {
      if (!iso) return '--';
      var d = new Date(iso);
      if (isNaN(d.getTime())) return '--';
      var months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
      var h = d.getHours();
      var ampm = h >= 12 ? 'PM' : 'AM';
      h = h % 12 || 12;
      var min = String(d.getMinutes()).padStart(2, '0');
      return months[d.getMonth()] + ' ' + d.getDate() + ', ' + d.getFullYear() + ' ' + h + ':' + min + ' ' + ampm;
    }

    // DOM refs
    var runCheckBtn = document.getElementById('run-check-btn');
    var lastChecked = document.getElementById('last-checked');

    // Update cards from check results
    function updateCards(results) {
      var checks = results.checks || [];
      for (var i = 0; i < checks.length; i++) {
        var c = checks[i];
        var iconEl = document.getElementById('icon-' + c.name);
        var detailEl = document.getElementById('detail-' + c.name);
        if (!iconEl || !detailEl) continue;

        if (c.ok) {
          iconEl.textContent = '\u2713';
          iconEl.className = 'seo-card__icon seo-card__icon--pass';
        } else {
          iconEl.textContent = '\u2717';
          iconEl.className = 'seo-card__icon seo-card__icon--fail';
        }
        detailEl.textContent = c.detail || (c.ok ? 'OK' : 'Failed');
      }

      if (results.timestamp) {
        lastChecked.textContent = 'Last checked: ' + formatDate(results.timestamp);
      }
    }

    // Reset cards to loading state
    function resetCards() {
      for (var i = 0; i < CHECK_NAMES.length; i++) {
        var iconEl = document.getElementById('icon-' + CHECK_NAMES[i]);
        var detailEl = document.getElementById('detail-' + CHECK_NAMES[i]);
        if (iconEl) { iconEl.textContent = '...'; iconEl.className = 'seo-card__icon'; }
        if (detailEl) { detailEl.textContent = 'Checking...'; }
      }
    }

    // Load cached results first
    async function loadCached() {
      try {
        var data = await apiCall('cached');
        updateCards(data);
      } catch (e) {
        // No cached results is fine, cards stay at default
      }
    }

    // Run live check
    async function runCheck() {
      runCheckBtn.disabled = true;
      runCheckBtn.textContent = 'Checking...';
      resetCards();
      try {
        var data = await apiCall('check');
        updateCards(data);
      } catch (e) {
        lastChecked.textContent = 'Error: ' + e.message;
      }
      runCheckBtn.disabled = false;
      runCheckBtn.textContent = 'Run Check';
    }

    // Event listeners
    document.getElementById('logout-btn').addEventListener('click', async function () {
      await fetch('/api/auth/logout', { method: 'POST', credentials: 'include' });
      window.location.href = '/login/';
    });
    runCheckBtn.addEventListener('click', runCheck);

    // Init
    loadCached();

    // --- Observatory ---
    var obsRefreshBtn = document.getElementById('obs-refresh-btn');
    var obsActivityBody = document.getElementById('obs-activity-body');
    var obsTimestamp = document.getElementById('obs-timestamp');
    var obsErrorsCard = document.getElementById('obs-errors-card');
    var obsErrorsBody = document.getElementById('obs-errors-body');

    var ALERT_MAP = {
      high_error_rate: 'error-rate',
      intake_silent: 'intake',
      worker_missing: 'missing',
      n8n_health: 'n8n',
      ses_reputation: 'ses',
    };

    function updateObservatory(data) {
      // Activity table
      if (data.summary && data.summary.length > 0) {
        obsActivityBody.innerHTML = data.summary.map(function (r) {
          var statusClass = (r.status === 'error' || r.status === 'fail') ? ' class="obs-row--error"' : '';
          return '<tr' + statusClass + '><td>' + esc(r.worker) + '</td><td>' + esc(r.status) + '</td><td>' + r.cnt + '</td></tr>';
        }).join('');
      } else {
        obsActivityBody.innerHTML = '<tr><td colspan="3" class="obs-empty">No events in last 24h</td></tr>';
      }

      // Alert cards
      if (data.alerts && data.alerts.all) {
        for (var i = 0; i < data.alerts.all.length; i++) {
          var a = data.alerts.all[i];
          var cardId = ALERT_MAP[a.name];
          if (!cardId) continue;
          var iconEl = document.getElementById('obs-icon-' + cardId);
          var detailEl = document.getElementById('obs-detail-' + cardId);
          if (!iconEl || !detailEl) continue;

          if (a.alert) {
            iconEl.textContent = '\u2717';
            iconEl.className = 'seo-card__icon seo-card__icon--fail';
          } else if (a.error) {
            iconEl.textContent = '?';
            iconEl.className = 'seo-card__icon';
          } else {
            iconEl.textContent = '\u2713';
            iconEl.className = 'seo-card__icon seo-card__icon--pass';
          }
          detailEl.textContent = a.message || '';
        }
      }

      // Latency table
      var latencyCard = document.getElementById('obs-latency-card');
      var latencyBody = document.getElementById('obs-latency-body');
      if (data.latency && data.latency.length > 0) {
        latencyCard.style.display = '';
        latencyBody.innerHTML = data.latency.map(function (r) {
          var p50 = Math.round(parseFloat(r.p50) || 0);
          var p95 = Math.round(parseFloat(r.p95) || 0);
          var max = Math.round(parseFloat(r.max_ms) || 0);
          var p95Style = p95 > 5000 ? ' style="color:#c0392b;text-align:right;"' : p95 > 2000 ? ' style="color:#e67e22;text-align:right;"' : ' style="text-align:right;"';
          return '<tr><td>' + esc(r.worker) + '</td><td style="text-align:right;">' + p50 + 'ms</td><td' + p95Style + '>' + p95 + 'ms</td><td style="text-align:right;">' + max + 'ms</td><td style="text-align:right;">' + r.cnt + '</td></tr>';
        }).join('');
      } else {
        latencyCard.style.display = 'none';
      }

      // Errors table
      if (data.errors && data.errors.length > 0) {
        obsErrorsCard.style.display = '';
        obsErrorsBody.innerHTML = data.errors.slice(0, 15).map(function (e) {
          return '<tr class="obs-row--error"><td>' + esc(e.worker) + '</td><td>' + esc(e.action) + '</td><td>' + esc((e.detail || '').slice(0, 100)) + '</td></tr>';
        }).join('');
      } else {
        obsErrorsCard.style.display = 'none';
      }

      obsTimestamp.textContent = 'Last refreshed: ' + formatDate(new Date().toISOString()) +
        (data.duration_ms ? ' (' + data.duration_ms + 'ms)' : '');
    }

    function esc(s) {
      var el = document.createElement('span');
      el.textContent = s || '';
      return el.innerHTML;
    }

    async function loadObservatory() {
      obsRefreshBtn.disabled = true;
      obsRefreshBtn.textContent = 'Loading...';
      try {
        var data = await apiCall('observatory');
        updateObservatory(data);
      } catch (e) {
        obsTimestamp.textContent = 'Error: ' + e.message;
      }
      obsRefreshBtn.disabled = false;
      obsRefreshBtn.textContent = 'Refresh';
    }

    obsRefreshBtn.addEventListener('click', loadObservatory);
    loadObservatory();
  })();
  </script>

</BaseLayout>

<style>
  /* Reuse admin palette from backlinks */
  :root {
    --admin-rose-700: #8a606e;
    --admin-rose-300: #c9a8b2;
    --admin-bg: #faf8f5;
    --admin-surface: #ffffff;
    --admin-border: #d9d3cc;
    --admin-text: #313131;
    --admin-text-faint: #949392;
  }

  :global(.admin-page) :global(.site-header) { display: none; }
  :global(.admin-page) :global(footer) { display: none; }

  .admin-bar {
    background: #3d2a32;
    color: #f0e5e9;
    position: sticky;
    top: 0;
    z-index: 100;
  }
  .admin-bar__inner {
    display: flex;
    align-items: center;
    height: 48px;
    gap: var(--space-6);
  }
  .admin-bar__title {
    font-family: 'Cormorant Garamond', 'Georgia', serif;
    font-weight: 600;
    font-size: 1.25rem;
    color: var(--admin-rose-300);
    white-space: nowrap;
  }
  .admin-bar__nav {
    display: flex;
    gap: var(--space-1);
  }
  .admin-bar__link {
    font-size: 0.8125rem;
    font-weight: 400;
    color: rgba(255,255,255,0.6);
    text-decoration: none;
    padding: 4px 12px;
    border-radius: var(--radius-sm);
    transition: color 0.15s, background 0.15s;
  }
  .admin-bar__link:hover {
    color: #fff;
    text-decoration: none;
  }
  .admin-bar__link--active {
    color: #fff;
    background: rgba(255,255,255,0.1);
    font-weight: 500;
  }
  .admin-bar__actions {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-left: auto;
  }
  .admin-bar__site-link {
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--admin-rose-300);
    text-decoration: none;
    padding: 5px 16px;
    border: 1px solid var(--admin-rose-300);
    border-radius: var(--radius-pill);
    transition: color 0.15s, border-color 0.15s, background 0.15s;
  }
  .admin-bar__site-link:hover {
    color: #fff;
    border-color: #fff;
    text-decoration: none;
  }
  .admin-bar__logout {
    font-size: 0.8125rem;
    font-weight: 400;
    color: rgba(255,255,255,0.5);
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px 8px;
    transition: color 0.15s;
  }
  .admin-bar__logout:hover {
    color: #fff;
  }

  .bl-section {
    padding: var(--space-8) 0;
    background: var(--admin-bg);
    min-height: 80vh;
  }

  .bl-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--space-6);
  }
  .bl-header h1 {
    margin-bottom: 0;
    color: var(--admin-text);
  }

  /* SEO card grid */
  .seo-grid {
    grid-template-columns: repeat(4, 1fr);
  }
  @media (max-width: 800px) {
    .seo-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  @media (max-width: 500px) {
    .seo-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .bl-metrics {
    display: grid;
    gap: var(--space-4);
    margin-bottom: var(--space-6);
  }

  .bl-card {
    background: var(--admin-surface);
    border: 1px solid var(--admin-border);
    border-radius: var(--radius-md);
    padding: var(--space-4) var(--space-5);
    text-align: center;
  }
  .bl-card__label {
    display: block;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--admin-text-faint);
    margin-bottom: var(--space-2);
  }

  .seo-run-btn {
    background: var(--admin-rose-700);
    border-color: var(--admin-rose-700);
    color: #fff;
  }
  .seo-run-btn:hover {
    background: #764d5e;
  }
  .seo-run-btn:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .seo-timestamp {
    font-size: 0.8125rem;
    color: var(--admin-text-faint);
    text-align: right;
  }

  /* Observatory section */
  .obs-section {
    margin-top: var(--space-10);
    padding-top: var(--space-8);
    border-top: 1px solid var(--admin-border);
  }
  .obs-alerts-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-4);
    margin-bottom: var(--space-6);
  }
  .obs-alerts-row--5 {
    grid-template-columns: repeat(5, 1fr);
  }
  @media (max-width: 800px) {
    .obs-alerts-row--5 { grid-template-columns: repeat(3, 1fr); }
  }
  @media (max-width: 600px) {
    .obs-alerts-row, .obs-alerts-row--5 { grid-template-columns: repeat(2, 1fr); }
  }
  .obs-table-card {
    margin-bottom: var(--space-6);
    padding: var(--space-4) var(--space-5);
  }
  .obs-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.8125rem;
  }
  .obs-table th {
    text-align: left;
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--admin-text-faint);
    padding: var(--space-2) var(--space-3);
    border-bottom: 1px solid var(--admin-border);
  }
  .obs-table td {
    padding: var(--space-2) var(--space-3);
    border-bottom: 1px solid #f0eeeb;
    color: var(--admin-text);
    font-family: 'SF Mono', 'Fira Code', monospace;
    font-size: 0.75rem;
  }
  .obs-row--error td {
    color: #c0392b;
  }
  .obs-empty {
    text-align: center;
    color: var(--admin-text-faint);
    font-style: italic;
    font-family: inherit;
  }
  .obs-errors-heading {
    font-size: 0.875rem;
    color: #c0392b;
    margin: 0 0 var(--space-3);
  }
  .obs-latency-heading {
    font-size: 0.875rem;
    color: var(--admin-text);
    margin: 0 0 var(--space-3);
  }
</style>

<style is:global>
  .seo-card__icon {
    display: block;
    font-size: 2rem;
    font-weight: 700;
    color: #949392;
    margin-bottom: var(--space-1);
    line-height: 1.2;
  }
  .seo-card__icon--pass {
    color: #27ae60;
  }
  .seo-card__icon--fail {
    color: #c0392b;
  }
  .seo-card__detail {
    display: block;
    font-size: 0.75rem;
    color: #636261;
    line-height: 1.4;
    word-break: break-word;
    white-space: normal;
  }
</style>
