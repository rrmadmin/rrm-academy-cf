---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import coursesData from '../../../data/courses.json';

export function getStaticPaths() {
  const paths: any[] = [];
  for (const course of coursesData) {
    for (const section of course.sections) {
      for (const step of section.steps) {
        paths.push({
          params: { slug: course.slug, stepId: step.id },
          props: { course, section, step },
        });
      }
    }
  }
  return paths;
}

const { course, section, step } = Astro.props;

// Build flat step list for prev/next navigation
const allSteps: any[] = [];
for (const s of course.sections) {
  for (const st of s.steps) {
    allSteps.push({ ...st, sectionTitle: s.title, sectionId: s.id });
  }
}
const currentIdx = allSteps.findIndex((s: any) => s.id === step.id);
const prevStep = currentIdx > 0 ? allSteps[currentIdx - 1] : null;
const nextStep = currentIdx < allSteps.length - 1 ? allSteps[currentIdx + 1] : null;
const totalSteps = allSteps.length;
const stepNumber = currentIdx + 1;

function formatDuration(seconds: number) {
  if (!seconds) return '';
  const m = Math.floor(seconds / 60);
  const s = seconds % 60;
  return s > 0 ? `${m}:${String(s).padStart(2, '0')}` : `${m} min`;
}

function stepTypeLabel(type: string) {
  if (type === 'video') return 'Video';
  if (type === 'quiz') return 'Quiz';
  return 'Article';
}
---
<BaseLayout
  title={`${step.title} — ${course.title}`}
  description={`${stepTypeLabel(step.type)}: ${step.title}. Part of ${course.title} on RRM Academy.`}
  canonicalUrl={`https://rrmacademy.org/courses/${course.slug}/${step.id}`}
  noindex
  bodyClass="page-player"
>
  <div class="player-layout">

    <!-- Sidebar -->
    <aside class="player-sidebar" id="player-sidebar">
      <div class="sidebar-header">
        <a href={`/courses/${course.slug}`} class="sidebar-back" title="Back to course">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
        </a>
        <span class="sidebar-course-title">{course.title}</span>
      </div>

      <div class="sidebar-progress" id="sidebar-progress">
        <div class="sidebar-progress__bar" role="progressbar" aria-valuenow={0} aria-valuemin={0} aria-valuemax={100} aria-label="Course progress">
          <div class="sidebar-progress__fill" id="sidebar-progress-fill"></div>
        </div>
        <span class="sidebar-progress__text" id="sidebar-progress-text">0% complete</span>
      </div>

      <nav class="sidebar-nav" aria-label="Course curriculum">
        {course.sections.map((s: any) => {
          const isCurrentSection = s.id === section.id;
          return (
            <details class="sidebar-module" open={isCurrentSection}>
              <summary class="sidebar-module__header">
                <span class="sidebar-module__title">{s.title}</span>
                <svg class="sidebar-module__chevron" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
              </summary>
              <ul class="sidebar-steps">
                {s.steps.map((st: any) => {
                  const isCurrent = st.id === step.id;
                  return (
                    <li>
                      <a
                        href={`/courses/${course.slug}/${st.id}`}
                        class:list={['sidebar-step', { 'sidebar-step--current': isCurrent }]}
                        aria-current={isCurrent ? 'step' : undefined}
                        data-step-id={st.id}
                      >
                        <span class="sidebar-step__check" aria-hidden="true">
                          <svg class="check-empty" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/></svg>
                          <svg class="check-done" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                        </span>
                        <span class="sidebar-step__title">{st.title}</span>
                        {st.duration && <span class="sidebar-step__dur">{formatDuration(st.duration)}</span>}
                      </a>
                    </li>
                  );
                })}
              </ul>
            </details>
          );
        })}
      </nav>
    </aside>

    <!-- Main content area -->
    <div class="player-main">

      <!-- Mobile top bar -->
      <div class="player-topbar">
        <a href={`/courses/${course.slug}`} class="player-topbar__back" title="Back to course">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
        </a>
        <span class="player-topbar__title">{course.title}</span>
        <button class="player-topbar__menu" id="sidebar-toggle" aria-label="Toggle curriculum" aria-expanded="false">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
        </button>
      </div>

      <!-- Video / Article / Quiz content -->
      <div class="player-content">
        {step.type === 'video' && step.vimeoId && (
          <div class="video-wrapper">
            <div class="video-container" id="video-container">
              <iframe
                id="vimeo-player"
                src={`https://player.vimeo.com/video/${step.vimeoId}?title=0&byline=0&portrait=0`}
                width="100%"
                height="100%"
                frameborder="0"
                allow="autoplay; fullscreen; picture-in-picture"
                allowfullscreen
                title={step.title}
              ></iframe>
            </div>
          </div>
        )}

        {step.type === 'article' && (
          <div class="article-content">
            <p class="article-placeholder">Article content for "{step.title}" will be available here.</p>
          </div>
        )}

        {step.type === 'quiz' && (
          <div class="quiz-content" id="quiz-container">
            <div class="quiz-loading" id="quiz-loading">
              <div class="quiz-spinner"></div>
              <p>Loading...</p>
            </div>
            <div class="quiz-form" id="quiz-form" hidden>
              <div class="quiz-header">
                <h2 class="quiz-header__title" id="quiz-title"></h2>
                <p class="quiz-header__desc" id="quiz-desc"></p>
                <div class="quiz-header__meta" id="quiz-meta"></div>
              </div>
              <div class="quiz-questions" id="quiz-questions"></div>
              <div class="quiz-footer">
                <button class="btn btn--primary btn--lg" id="quiz-submit" disabled>Submit Answers</button>
                <p class="quiz-footer__hint" id="quiz-hint"></p>
              </div>
            </div>
            <div class="quiz-results" id="quiz-results" hidden></div>
            <div class="quiz-unavailable" id="quiz-unavailable" hidden>
              <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
              <p class="quiz-unavailable__title">Coming Soon</p>
              <p class="quiz-unavailable__text">Quiz content is being prepared and will be available shortly.</p>
            </div>
          </div>
        )}

        <!-- Lesson header -->
        <div class="lesson-info">
          <div class="lesson-info__header">
            <span class="lesson-info__section">{section.title}</span>
            <span class="lesson-info__counter">Lesson {stepNumber} of {totalSteps}</span>
          </div>
          <h1 class="lesson-info__title">{step.title}</h1>
        </div>

        <!-- Attachments (PDFs, worksheets, etc.) -->
        {step.attachments && step.attachments.length > 0 && (
          <div class="lesson-attachments">
            <h3 class="lesson-attachments__heading">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21.44 11.05l-9.19 9.19a6 6 0 0 1-8.49-8.49l9.19-9.19a4 4 0 0 1 5.66 5.66l-9.2 9.19a2 2 0 0 1-2.83-2.83l8.49-8.48"/></svg>
              Downloads
            </h3>
            <ul class="lesson-attachments__list">
              {step.attachments.map((att: any) => (
                <li>
                  <a href={att.url} class="lesson-attachment" target="_blank" rel="noopener" download={att.name}>
                    <svg class="lesson-attachment__icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="12" y1="18" x2="12" y2="12"/><polyline points="9 15 12 18 15 15"/></svg>
                    <span class="lesson-attachment__info">
                      <span class="lesson-attachment__name">{att.name}</span>
                      <span class="lesson-attachment__size">{att.size > 1048576 ? `${(att.size / 1048576).toFixed(1)} MB` : `${Math.round(att.size / 1024)} KB`}</span>
                    </span>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        )}

        <!-- Mark Complete + Navigation -->
        <div class="lesson-actions" id="lesson-actions">
          <button class="btn btn--primary mark-complete-btn" id="mark-complete-btn" disabled>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            Mark Complete
          </button>
          <div class="lesson-nav">
            {prevStep && (
              <a href={`/courses/${course.slug}/${prevStep.id}`} class="btn btn--secondary btn--sm lesson-nav__prev">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
                Previous
              </a>
            )}
            {nextStep && (
              <a href={`/courses/${course.slug}/${nextStep.id}`} class="btn btn--secondary btn--sm lesson-nav__next" id="next-lesson-btn">
                Next
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
              </a>
            )}
          </div>
        </div>

        <!-- Lesson Comments -->
        <div class="lesson-comments" id="lesson-comments">
          <div class="lesson-comments__header">
            <h3 class="lesson-comments__heading">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
              Discussion
              <span class="lesson-comments__count" id="comments-count"></span>
            </h3>
          </div>

          <div class="lesson-comments__compose" id="comments-compose" hidden>
            <textarea
              class="lesson-comments__input"
              id="comment-input"
              placeholder="Share a thought or question..."
              rows="3"
              maxlength="2000"
            ></textarea>
            <div class="lesson-comments__compose-footer">
              <span class="lesson-comments__char-count" id="comment-chars">0 / 2000</span>
              <button class="btn btn--primary btn--sm" id="comment-submit" disabled>Post</button>
            </div>
          </div>

          <div class="lesson-comments__list" id="comments-list">
            <p class="lesson-comments__empty" id="comments-empty" hidden>No comments yet. Be the first to start a discussion.</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Player logic -->
  <script is:inline define:vars={{
    courseId: course.id,
    courseSlug: course.slug,
    stepId: step.id,
    stepType: step.type,
    vimeoId: step.vimeoId || null,
    nextStepId: nextStep?.id || null,
    nextStepUrl: nextStep ? `/courses/${course.slug}/${nextStep.id}` : '',
    videoDuration: step.duration || 0,
    videoWatchReq: course.settings?.videoWatchRequirement || 0.9,
    fixedOrder: course.settings?.stepOrder === 'fixed',
    autoplayNext: course.settings?.autoplayNextVideo || false,
  }}>
    (function () {
      var markBtn = document.getElementById('mark-complete-btn');
      var isCompleted = false;
      var canComplete = stepType === 'article'; // videos need watch %, quizzes use their own submit flow

      // --- Auth check + load progress ---
      fetch('/api/courses/progress?courseId=' + encodeURIComponent(courseId), { credentials: 'same-origin' })
        .then(function (r) { return r.json(); })
        .then(function (data) {
          if (!data.ok) {
            // Not enrolled — redirect to course detail
            window.location.href = '/courses/' + courseSlug;
            return;
          }

          var steps = data.steps || {};
          var completedCount = 0;
          var totalCount = 0;

          // Update sidebar completion states + step locking
          var hitIncomplete = false;
          document.querySelectorAll('.sidebar-step').forEach(function (el) {
            var sid = el.getAttribute('data-step-id');
            totalCount++;
            if (steps[sid] && steps[sid].completed) {
              completedCount++;
              el.classList.add('sidebar-step--done');
            } else {
              if (fixedOrder && hitIncomplete && sid !== stepId) {
                el.classList.add('sidebar-step--locked');
                el.setAttribute('aria-disabled', 'true');
                el.addEventListener('click', function (e) { e.preventDefault(); });
              }
              hitIncomplete = true;
            }
          });

          // Update progress bar
          updateProgressBar(completedCount, totalCount);

          // Current step already complete
          if (steps[stepId] && steps[stepId].completed) {
            isCompleted = true;
            if (stepType !== 'quiz') {
              markBtn.textContent = 'Completed';
              markBtn.disabled = true;
              markBtn.classList.add('mark-complete-btn--done');
            }
          } else if (canComplete) {
            markBtn.disabled = false;
          }

          // Hide Mark Complete for quiz steps — submission handles it
          if (stepType === 'quiz') {
            markBtn.style.display = 'none';
          }

          // Resume video position
          if (stepType === 'video' && steps[stepId] && steps[stepId].lastPositionSeconds > 0) {
            var iframe = document.getElementById('vimeo-player');
            if (iframe) {
              // Append start time to Vimeo URL
              var src = iframe.getAttribute('src');
              var startTime = '#t=' + steps[stepId].lastPositionSeconds + 's';
              iframe.setAttribute('src', src + startTime);
            }
          }
        })
        .catch(function () {
          // Silently fail — user may not be logged in
        });

      // --- Video progress tracking ---
      if (stepType === 'video' && vimeoId) {
        var lastSaved = 0;
        var maxPercent = 0;

        // Vimeo postMessage API (no SDK needed)
        var iframe = document.getElementById('vimeo-player');
        if (iframe) {
          window.addEventListener('message', function (event) {
            if (!event.origin.includes('vimeo.com')) return;
            var data;
            try { data = JSON.parse(event.data); } catch { return; }

            if (data.event === 'playProgress' || data.event === 'timeupdate') {
              var seconds = Math.floor(data.data?.seconds || 0);
              var percent = data.data?.percent || 0;
              if (percent > maxPercent) maxPercent = percent;

              // Save position every 15 seconds
              if (seconds - lastSaved >= 15) {
                lastSaved = seconds;
                saveProgress(seconds, false);
              }

              // Enable "Mark Complete" once watch requirement met
              if (maxPercent >= videoWatchReq && !isCompleted) {
                canComplete = true;
                markBtn.disabled = false;
              }
            }

            if (data.event === 'finish' || data.event === 'ended') {
              canComplete = true;
              markBtn.disabled = false;

              // Auto-complete + autoplay next
              if (!isCompleted) {
                isCompleted = true;
                saveProgress(null, true).then(function (res) {
                  if (res && res.ok) {
                    markBtn.textContent = 'Completed';
                    markBtn.classList.add('mark-complete-btn--done');
                    markBtn.disabled = true;
                    var el = document.querySelector('.sidebar-step[data-step-id="' + stepId + '"]');
                    if (el) el.classList.add('sidebar-step--done');
                    var done = document.querySelectorAll('.sidebar-step--done').length;
                    var total = document.querySelectorAll('.sidebar-step').length;
                    updateProgressBar(done, total);

                    if (res.courseCompleted) {
                      markBtn.textContent = 'Course Complete!';
                    } else if (autoplayNext && nextStepUrl) {
                      showAutoplayCountdown();
                    }
                  }
                });
              } else if (autoplayNext && nextStepUrl) {
                showAutoplayCountdown();
              }
            }
          });

          // Tell Vimeo to send events
          function postToVimeo(action, value) {
            iframe.contentWindow.postMessage(JSON.stringify({ method: action, value: value }), '*');
          }
          iframe.addEventListener('load', function () {
            postToVimeo('addEventListener', 'playProgress');
            postToVimeo('addEventListener', 'finish');
          });
        }
      }

      // --- Mark complete ---
      markBtn.addEventListener('click', function () {
        if (isCompleted || !canComplete) return;
        markBtn.disabled = true;
        markBtn.textContent = 'Saving...';

        saveProgress(null, true)
          .then(function (data) {
            if (data && data.ok) {
              isCompleted = true;
              markBtn.textContent = 'Completed';
              markBtn.classList.add('mark-complete-btn--done');

              // Update sidebar
              var el = document.querySelector('.sidebar-step[data-step-id="' + stepId + '"]');
              if (el) el.classList.add('sidebar-step--done');

              // Recalculate progress
              var done = document.querySelectorAll('.sidebar-step--done').length;
              var total = document.querySelectorAll('.sidebar-step').length;
              updateProgressBar(done, total);

              if (data.courseCompleted) {
                markBtn.textContent = 'Course Complete!';
              }
            } else {
              markBtn.disabled = false;
              markBtn.textContent = 'Mark Complete';
            }
          })
          .catch(function () {
            markBtn.disabled = false;
            markBtn.textContent = 'Mark Complete';
          });
      });

      // --- Autoplay countdown ---
      function showAutoplayCountdown() {
        var seconds = 5;
        var toast = document.createElement('div');
        toast.className = 'autoplay-toast';
        toast.innerHTML = '<span class="autoplay-toast__text">Next lesson in <strong id="autoplay-sec">' + seconds + '</strong>s</span>' +
          '<button class="autoplay-toast__cancel" id="autoplay-cancel">Cancel</button>';
        document.body.appendChild(toast);

        var secEl = document.getElementById('autoplay-sec');
        var timer = setInterval(function () {
          seconds--;
          if (secEl) secEl.textContent = seconds;
          if (seconds <= 0) {
            clearInterval(timer);
            window.location.href = nextStepUrl;
          }
        }, 1000);

        document.getElementById('autoplay-cancel').addEventListener('click', function () {
          clearInterval(timer);
          toast.remove();
        });
      }

      function saveProgress(posSeconds, completed) {
        var body = { courseId: courseId, stepId: stepId };
        if (completed) body.completed = true;
        if (posSeconds !== null && posSeconds !== undefined) body.lastPositionSeconds = posSeconds;

        return fetch('/api/courses/progress', {
          method: 'PATCH',
          credentials: 'same-origin',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(body),
        })
          .then(function (r) { return r.json(); })
          .catch(function () { return null; });
      }

      function updateProgressBar(done, total) {
        var pct = total > 0 ? Math.round((done / total) * 100) : 0;
        var fill = document.getElementById('sidebar-progress-fill');
        var text = document.getElementById('sidebar-progress-text');
        var bar = document.querySelector('.sidebar-progress__bar');
        if (fill) fill.style.width = pct + '%';
        if (text) text.textContent = pct + '% complete';
        if (bar) bar.setAttribute('aria-valuenow', String(pct));
      }

      // --- Mobile sidebar toggle ---
      var sidebarToggle = document.getElementById('sidebar-toggle');
      var sidebar = document.getElementById('player-sidebar');
      if (sidebarToggle && sidebar) {
        sidebarToggle.addEventListener('click', function () {
          var expanded = sidebar.classList.toggle('sidebar--open');
          sidebarToggle.setAttribute('aria-expanded', String(expanded));
        });
      }
    })();
  </script>

  <!-- Quiz / Questionnaire logic -->
  <script is:inline define:vars={{
    qCourseId: course.id,
    qStepId: step.id,
    qStepType: step.type,
    qCourseSlug: course.slug,
    qCertQuizId: course.certificateQuizId || '',
  }}>
    (function () {
      if (qStepType !== 'quiz') return;

      var loading = document.getElementById('quiz-loading');
      var form = document.getElementById('quiz-form');
      var resultsEl = document.getElementById('quiz-results');
      var unavailable = document.getElementById('quiz-unavailable');
      var titleEl = document.getElementById('quiz-title');
      var descEl = document.getElementById('quiz-desc');
      var metaEl = document.getElementById('quiz-meta');
      var questionsEl = document.getElementById('quiz-questions');
      var submitBtn = document.getElementById('quiz-submit');
      var hintEl = document.getElementById('quiz-hint');

      var quizData = null;
      var answers = {};

      // Fetch quiz content
      fetch('/api/courses/quiz?courseId=' + encodeURIComponent(qCourseId) + '&stepId=' + encodeURIComponent(qStepId), { credentials: 'same-origin' })
        .then(function (r) { return r.json(); })
        .then(function (data) {
          hide(loading);
          if (!data.ok || !data.questions || data.questions.length === 0) {
            show(unavailable);
            return;
          }
          quizData = data;
          renderQuiz(data);
        })
        .catch(function () {
          hide(loading);
          show(unavailable);
        });

      function renderQuiz(data) {
        titleEl.textContent = data.title;
        descEl.textContent = data.description;

        var metaHtml = '<span class="quiz-pill">' + data.questions.length + ' questions</span>';
        if (data.type === 'quiz' && data.passingScore) {
          metaHtml += '<span class="quiz-pill">Passing: ' + data.passingScore + '%</span>';
        }
        metaEl.innerHTML = metaHtml;

        var html = '';
        data.questions.forEach(function (q, i) {
          if (data.type === 'questionnaire' && q.type === 'likert') {
            html += buildLikert(q, i);
          } else {
            html += buildMC(q, i);
          }
        });
        questionsEl.innerHTML = html;

        // Bind radio inputs
        questionsEl.querySelectorAll('input[type="radio"]').forEach(function (input) {
          input.addEventListener('change', function () {
            var name = this.name;
            answers[name] = parseInt(this.value);
            // Highlight selected option
            var group = questionsEl.querySelectorAll('input[name="' + name + '"]');
            group.forEach(function (r) {
              var label = r.closest('.qo') || r.closest('.lk-opt');
              if (label) label.classList.toggle('qo--sel', r.checked);
            });
            checkReady();
          });
        });

        if (data.type === 'quiz' && data.passingScore) {
          hintEl.textContent = 'You need ' + data.passingScore + '% to pass.';
        } else if (data.type === 'questionnaire') {
          hintEl.textContent = 'All responses help improve the course.';
        }

        show(form);
        submitBtn.addEventListener('click', doSubmit);
      }

      function buildMC(q, idx) {
        var h = '<div class="qq">';
        h += '<div class="qq__num">' + (idx + 1) + '</div>';
        h += '<div class="qq__body">';
        h += '<p class="qq__text">' + esc(q.text) + '</p>';
        h += '<div class="qq__opts">';
        q.options.forEach(function (opt, oi) {
          h += '<label class="qo">';
          h += '<input type="radio" name="q-' + q.id + '" value="' + oi + '">';
          h += '<span class="qo__radio"></span>';
          h += '<span class="qo__text">' + esc(opt) + '</span>';
          h += '</label>';
        });
        h += '</div></div></div>';
        return h;
      }

      function buildLikert(q, idx) {
        var sc = q.scale || { min: 1, max: 5, labels: ['1', '2', '3', '4', '5'] };
        var h = '<div class="qq qq--likert">';
        h += '<div class="qq__num">' + (idx + 1) + '</div>';
        h += '<div class="qq__body">';
        h += '<p class="qq__text">' + esc(q.text) + '</p>';
        h += '<div class="lk-row">';
        for (var v = sc.min; v <= sc.max; v++) {
          var lbl = sc.labels ? sc.labels[v - sc.min] : String(v);
          h += '<label class="lk-opt">';
          h += '<input type="radio" name="q-' + q.id + '" value="' + (v - 1) + '">';
          h += '<span class="lk-opt__dot"></span>';
          h += '<span class="lk-opt__lbl">' + esc(lbl) + '</span>';
          h += '</label>';
        }
        h += '</div></div></div>';
        return h;
      }

      function checkReady() {
        if (!quizData) return;
        submitBtn.disabled = Object.keys(answers).length < quizData.questions.length;
      }

      function doSubmit() {
        if (submitBtn.disabled) return;
        submitBtn.disabled = true;
        submitBtn.textContent = 'Submitting...';

        var ansArr = quizData.questions.map(function (q) {
          var key = 'q-' + q.id;
          return answers[key] !== undefined ? answers[key] : -1;
        });

        fetch('/api/courses/quiz', {
          method: 'POST',
          credentials: 'same-origin',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ courseId: qCourseId, stepId: qStepId, answers: ansArr }),
        })
          .then(function (r) { return r.json(); })
          .then(function (data) {
            if (!data.ok) {
              submitBtn.disabled = false;
              submitBtn.textContent = 'Submit Answers';
              alert(data.error || 'Submission failed.');
              return;
            }
            showResults(data);
            markSidebarDone();
          })
          .catch(function () {
            submitBtn.disabled = false;
            submitBtn.textContent = 'Submit Answers';
            alert('Network error. Please try again.');
          });
      }

      function showResults(data) {
        hide(form);
        var h = '';

        if (quizData.type === 'questionnaire') {
          h += '<div class="qr-card qr-card--pass">';
          h += '<svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="var(--green-700)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>';
          h += '<h3>Thank You</h3>';
          h += '<p>Your responses have been recorded.</p>';
          h += '</div>';
        } else {
          var passed = data.passed;
          var cls = passed ? 'qr-card--pass' : 'qr-card--fail';
          var icon = passed
            ? '<svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="var(--green-700)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>'
            : '<svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="var(--rose-600, #e11d48)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>';

          h += '<div class="qr-card ' + cls + '">';
          h += icon;
          h += '<h3>Score: ' + data.score + '%</h3>';
          if (quizData.passingScore) {
            h += '<p>' + (passed ? 'You passed!' : 'You need ' + quizData.passingScore + '% to pass. You can try again.') + '</p>';
          }
          if (passed && qStepId === qCertQuizId) {
            h += '<p class="qr-cert">Your certificate of completion has been issued.</p>';
          }
          h += '</div>';

          // Per-question breakdown
          if (data.results) {
            h += '<div class="qr-breakdown">';
            h += '<h4>Question Breakdown</h4>';
            data.results.forEach(function (r, i) {
              var q = quizData.questions[i];
              var ok = r.correct;
              h += '<div class="qr-item ' + (ok ? 'qr-item--ok' : 'qr-item--wrong') + '">';
              h += '<div class="qr-item__icon">' + (ok ? '&#10003;' : '&#10007;') + '</div>';
              h += '<div class="qr-item__body">';
              h += '<p class="qr-item__q">' + esc(q.text) + '</p>';
              if (!ok && q.options) {
                h += '<p class="qr-item__yours">Your answer: ' + esc(q.options[r.selected] || '—') + '</p>';
                h += '<p class="qr-item__correct">Correct: ' + esc(q.options[r.correctIndex] || '—') + '</p>';
              }
              h += '</div></div>';
            });
            h += '</div>';
          }

          // Retake if failed
          if (!passed) {
            h += '<div class="qr-actions">';
            h += '<button class="btn btn--primary" id="quiz-retake">Try Again</button>';
            h += '</div>';
          }
        }

        // Next lesson link
        var nextBtn = document.getElementById('next-lesson-btn');
        if (nextBtn) {
          h += '<div class="qr-nav">';
          h += '<a href="' + nextBtn.href + '" class="btn btn--secondary">Next Lesson &rarr;</a>';
          h += '</div>';
        }

        resultsEl.innerHTML = h;
        show(resultsEl);
        resultsEl.scrollIntoView({ behavior: 'smooth', block: 'start' });

        // Retake handler
        var retakeBtn = document.getElementById('quiz-retake');
        if (retakeBtn) {
          retakeBtn.addEventListener('click', function () {
            hide(resultsEl);
            answers = {};
            questionsEl.querySelectorAll('input[type="radio"]').forEach(function (input) {
              input.checked = false;
            });
            questionsEl.querySelectorAll('.qo--sel').forEach(function (el) {
              el.classList.remove('qo--sel');
            });
            submitBtn.disabled = true;
            submitBtn.textContent = 'Submit Answers';
            show(form);
            form.scrollIntoView({ behavior: 'smooth', block: 'start' });
          });
        }
      }

      function markSidebarDone() {
        var el = document.querySelector('.sidebar-step[data-step-id="' + qStepId + '"]');
        if (el) el.classList.add('sidebar-step--done');
        var done = document.querySelectorAll('.sidebar-step--done').length;
        var total = document.querySelectorAll('.sidebar-step').length;
        if (total > 0) {
          var pct = Math.round((done / total) * 100);
          var fill = document.getElementById('sidebar-progress-fill');
          var text = document.getElementById('sidebar-progress-text');
          var bar = document.querySelector('.sidebar-progress__bar');
          if (fill) fill.style.width = pct + '%';
          if (text) text.textContent = pct + '% complete';
          if (bar) bar.setAttribute('aria-valuenow', String(pct));
        }
      }

      function esc(s) { var d = document.createElement('div'); d.textContent = s; return d.innerHTML; }
      function hide(el) { if (el) el.hidden = true; }
      function show(el) { if (el) el.hidden = false; }
    })();
  </script>

  <!-- Comments logic -->
  <script is:inline define:vars={{
    cmCourseId: course.id,
    cmStepId: step.id,
  }}>
    (function () {
      var compose = document.getElementById('comments-compose');
      var input = document.getElementById('comment-input');
      var submitBtn = document.getElementById('comment-submit');
      var charCount = document.getElementById('comment-chars');
      var listEl = document.getElementById('comments-list');
      var emptyEl = document.getElementById('comments-empty');
      var countEl = document.getElementById('comments-count');
      var isEnrolled = false;

      // Load comments
      fetch('/api/courses/comments?courseId=' + encodeURIComponent(cmCourseId) + '&stepId=' + encodeURIComponent(cmStepId), { credentials: 'same-origin' })
        .then(function (r) { return r.json(); })
        .then(function (data) {
          if (!data.ok) return;
          isEnrolled = true;
          compose.hidden = false;
          if (data.count > 0) {
            countEl.textContent = data.count;
            renderComments(data.comments);
          } else {
            emptyEl.hidden = false;
          }
        })
        .catch(function () {});

      // Character counter
      input.addEventListener('input', function () {
        var len = input.value.length;
        charCount.textContent = len + ' / 2000';
        submitBtn.disabled = len === 0 || len > 2000;
      });

      // Submit comment
      submitBtn.addEventListener('click', function () {
        var content = input.value.trim();
        if (!content || !isEnrolled) return;
        submitBtn.disabled = true;
        submitBtn.textContent = 'Posting...';

        var parentId = input.dataset.replyTo || null;

        fetch('/api/courses/comments', {
          method: 'POST',
          credentials: 'same-origin',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ courseId: cmCourseId, stepId: cmStepId, content: content, parentId: parentId }),
        })
          .then(function (r) { return r.json(); })
          .then(function (data) {
            submitBtn.disabled = false;
            submitBtn.textContent = 'Post';
            if (!data.ok) return;

            input.value = '';
            charCount.textContent = '0 / 2000';
            cancelReply();
            emptyEl.hidden = true;

            if (parentId) {
              // Append reply to parent's replies container
              var repliesEl = document.getElementById('replies-' + parentId);
              if (repliesEl) {
                repliesEl.insertAdjacentHTML('beforeend', buildCommentHtml(data.comment, true));
              }
            } else {
              // Append to top-level list
              listEl.insertAdjacentHTML('beforeend', buildCommentHtml(data.comment, false));
            }

            // Update count
            var cur = parseInt(countEl.textContent || '0', 10);
            countEl.textContent = cur + 1;
          })
          .catch(function () {
            submitBtn.disabled = false;
            submitBtn.textContent = 'Post';
          });
      });

      // Event delegation for reply buttons (works for dynamically added comments)
      listEl.addEventListener('click', function (e) {
        var btn = e.target.closest('.comment__reply-btn');
        if (btn) startReply(btn.dataset.commentId, btn.dataset.userName);
      });

      function renderComments(comments) {
        var html = '';
        comments.forEach(function (c) {
          html += buildCommentHtml(c, false);
        });
        listEl.innerHTML = html;
      }

      function buildCommentHtml(c, isReply) {
        var cls = isReply ? 'comment comment--reply' : 'comment';
        var h = '<div class="' + cls + '" data-comment-id="' + esc(c.id) + '">';
        h += '<div class="comment__avatar">' + esc(c.userName.charAt(0).toUpperCase()) + '</div>';
        h += '<div class="comment__body">';
        h += '<div class="comment__meta">';
        h += '<span class="comment__name">' + esc(c.userName) + '</span>';
        h += '<span class="comment__time">' + timeAgo(c.createdAt) + '</span>';
        h += '</div>';
        h += '<p class="comment__text">' + escContent(c.content) + '</p>';
        if (!isReply) {
          h += '<button class="comment__reply-btn" data-comment-id="' + esc(c.id) + '" data-user-name="' + esc(c.userName) + '">Reply</button>';
        }
        h += '</div></div>';

        // Render replies if top-level
        if (!isReply && c.replies && c.replies.length > 0) {
          h += '<div class="comment__replies" id="replies-' + esc(c.id) + '">';
          c.replies.forEach(function (r) {
            h += buildCommentHtml(r, true);
          });
          h += '</div>';
        } else if (!isReply) {
          h += '<div class="comment__replies" id="replies-' + esc(c.id) + '"></div>';
        }

        return h;
      }

      function startReply(commentId, userName) {
        input.dataset.replyTo = commentId;
        input.placeholder = 'Replying to ' + userName + '...';
        input.focus();

        // Show cancel reply indicator
        var existing = document.getElementById('reply-indicator');
        if (existing) existing.remove();
        var indicator = document.createElement('div');
        indicator.id = 'reply-indicator';
        indicator.className = 'lesson-comments__reply-indicator';
        indicator.innerHTML = 'Replying to <strong>' + esc(userName) + '</strong> <button class="reply-cancel-btn" id="reply-cancel">Cancel</button>';
        compose.insertBefore(indicator, input);
        document.getElementById('reply-cancel').addEventListener('click', cancelReply);
      }

      function cancelReply() {
        delete input.dataset.replyTo;
        input.placeholder = 'Share a thought or question...';
        var indicator = document.getElementById('reply-indicator');
        if (indicator) indicator.remove();
      }

      function timeAgo(dateStr) {
        if (!dateStr) return '';
        var date = new Date(dateStr.replace(' ', 'T') + 'Z');
        var now = new Date();
        var diff = Math.floor((now - date) / 1000);
        if (diff < 60) return 'just now';
        if (diff < 3600) return Math.floor(diff / 60) + 'm ago';
        if (diff < 86400) return Math.floor(diff / 3600) + 'h ago';
        if (diff < 604800) return Math.floor(diff / 86400) + 'd ago';
        return date.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
      }

      function esc(s) { var d = document.createElement('div'); d.textContent = s; return d.innerHTML; }
      function escContent(s) {
        // Escape HTML but preserve line breaks
        var d = document.createElement('div');
        d.textContent = s;
        return d.innerHTML.replace(/\n/g, '<br>');
      }
    })();
  </script>
</BaseLayout>

<style>
  /* Player uses a custom layout — full viewport, no page-wrapper padding */
  .player-layout {
    display: flex;
    min-height: calc(100vh - 48px); /* minus header height */
  }

  /* ═══════ Sidebar ═══════ */
  .player-sidebar {
    width: 320px;
    flex-shrink: 0;
    background: var(--bg-surface);
    border-right: 1px solid var(--border-color);
    display: flex;
    flex-direction: column;
    overflow-y: auto;
    max-height: calc(100vh - 48px);
    position: sticky;
    top: 48px;
  }

  .sidebar-header {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-4) var(--space-4);
    border-bottom: 1px solid var(--border-light);
    flex-shrink: 0;
  }
  .sidebar-back {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
