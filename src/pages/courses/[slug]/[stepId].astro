  }

  .sidebar-progress {
    padding: var(--space-3) var(--space-4);
    border-bottom: 1px solid var(--border-light);
    flex-shrink: 0;
  }
  .sidebar-progress__bar {
    width: 100%;
    height: 6px;
    background: var(--neutral-200);
    border-radius: 3px;
    overflow: hidden;
  }
  .sidebar-progress__fill {
    height: 100%;
    background: var(--green-700);
    border-radius: 3px;
