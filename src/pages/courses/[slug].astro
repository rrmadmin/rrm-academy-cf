---
import BaseLayout from '../../layouts/BaseLayout.astro';
import coursesData from '../../data/courses.json';

export function getStaticPaths() {
  return coursesData.map((course) => ({
    params: { slug: course.slug },
    props: { course },
  }));
}

const { course } = Astro.props;

const totalSteps = course.sections.reduce((sum: number, s: any) => sum + s.steps.length, 0);
const totalVideos = course.sections.reduce((sum: number, s: any) => sum + s.steps.filter((st: any) => st.type === 'video').length, 0);
const totalDuration = course.sections.reduce((sum: number, s: any) => sum + s.steps.reduce((d: number, st: any) => d + (st.duration || 0), 0), 0);
const hours = Math.floor(totalDuration / 3600);
const minutes = Math.round((totalDuration % 3600) / 60);
const durationLabel = hours > 0 ? `${hours}h ${minutes}m` : `${minutes} min`;
const price = course.isFree ? 'Free' : `$${(course.priceCents / 100).toFixed(0)}`;
const instructor = course.instructors.find((i: any) => i.role === 'Lead Instructor') || course.instructors[0];

// Step type icons mapping
function stepIcon(type: string) {
  if (type === 'video') return '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 3 19 12 5 21 5 3"/></svg>';
  if (type === 'quiz') return '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>';
  return '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>';
}

function formatDuration(seconds: number) {
  if (!seconds) return '';
  const m = Math.floor(seconds / 60);
  const s = seconds % 60;
  return s > 0 ? `${m}:${String(s).padStart(2, '0')}` : `${m} min`;
}

// Find the first step for the "Start Course" CTA
const firstStep = course.isAffiliate ? null : course.sections[0]?.steps[0];

const isAffiliate = !!course.isAffiliate;
let cohortLabel = '';
if (isAffiliate && course.cohortDates) {
  const fmt = (d: string, opts: Intl.DateTimeFormatOptions) => new Intl.DateTimeFormat('en-US', opts).format(new Date(d + 'T00:00:00'));
  cohortLabel = `${fmt(course.cohortDates.start, { month: 'short', day: 'numeric' })} – ${fmt(course.cohortDates.end, { month: 'short', day: 'numeric', year: 'numeric' })}`;
}
const affiliatePrice = isAffiliate && course.affiliatePriceCents ? `$${(course.affiliatePriceCents / 100).toFixed(0)}` : '';

// Schema.org Course
const courseSchema = {
  '@type': 'Course',
  name: course.title,
  description: course.seo?.description || course.shortDescription,
  url: `https://rrmacademy.org/courses/${course.slug}/`,
  ...(course.image ? { image: course.image } : {}),
  provider: isAffiliate
    ? { '@type': 'Organization', name: 'NeoFertility', url: 'https://www.neofertilitytraining.com/' }
    : { '@type': 'Organization', '@id': 'https://rrmacademy.org/#organization', name: 'RRM Academy', url: 'https://rrmacademy.org/' },
  instructor: isAffiliate
    ? { '@type': 'Person', name: 'Dr. Phil Boyle', '@id': 'https://rrmacademy.org/courses/neofertility-medical-training/#phil-boyle' }
    : { '@id': 'https://rrmacademy.org/#naomi-whittaker' },
  educationalLevel: 'Beginner to Advanced',
  ...(course.topics?.length ? { about: course.topics } : {}),
  ...(course.teaches?.length ? { teaches: course.teaches } : {}),
  ...(!isAffiliate ? { numberOfLessons: totalSteps } : {}),
  ...(!isAffiliate ? { timeRequired: hours > 0 ? `PT${hours}H${minutes}M` : `PT${minutes}M` } : {}),
  isAccessibleForFree: course.isFree,
  offers: {
    '@type': 'Offer',
    price: course.isFree ? '0' : (course.priceCents / 100).toFixed(2),
    priceCurrency: 'USD',
    availability: 'https://schema.org/InStock',
    ...(isAffiliate && course.affiliateUrl ? { url: course.affiliateUrl } : {}),
  },
  ...(!isAffiliate ? {
    hasCourseInstance: {
      '@type': 'CourseInstance',
      courseMode: 'online',
      courseWorkload: hours > 0 ? `PT${hours}H${minutes}M` : `PT${minutes}M`,
      instructor: { '@id': 'https://rrmacademy.org/#naomi-whittaker' },
    },
  } : {}),
};

const whittakerPersonNode = {
  '@type': 'Person',
  '@id': 'https://rrmacademy.org/#naomi-whittaker',
  name: 'Dr. Naomi Whittaker',
  honorificPrefix: 'Dr.',
  honorificSuffix: 'MD',
  givenName: 'Naomi',
  familyName: 'Whittaker',
  jobTitle: 'Founder & Medical Director',
  description: "Board-certified obstetrician-gynecologist, Physician Lead at UPMC Divine Mercy Women's Health, and founder of RRM Academy.",
  url: 'https://rrmacademy.org/commentary/rrm-spotlight-naomi-whittaker-md/',
  image: 'https://rrmacademy.org/images/authors/naomi-whittaker.webp',
  sameAs: [
    'https://www.instagram.com/napro_fertility_surgeon/',
    'https://www.linkedin.com/in/naomi-whittaker-md-906b13101/',
  ],
  affiliation: [
    {
      '@type': 'MedicalOrganization',
      name: "UPMC Divine Mercy Women's Health",
    },
    {
      '@type': 'EducationalOrganization',
      '@id': 'https://rrmacademy.org/#organization',
      name: 'RRM Academy',
      url: 'https://rrmacademy.org',
    },
  ],
  hasCredential: [
    {
      '@type': 'EducationalOccupationalCredential',
      credentialCategory: 'Board Certification',
      name: 'Board-Certified Obstetrician-Gynecologist',
    },
    {
      '@type': 'EducationalOccupationalCredential',
      credentialCategory: 'Fellowship',
      name: 'Medical and Surgical NaProTechnology Fellowship',
    },
  ],
  knowsAbout: [
    'Restorative Reproductive Medicine',
    'NaProTechnology',
    'Endometriosis Surgery',
    'PCOS Treatment',
    'Infertility Diagnosis and Treatment',
    'Fertility Awareness-Based Methods',
  ],
};

const breadcrumbSchema = {
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://rrmacademy.org/' },
    { '@type': 'ListItem', position: 2, name: 'Courses', item: 'https://rrmacademy.org/courses/' },
    { '@type': 'ListItem', position: 3, name: course.title, item: `https://rrmacademy.org/courses/${course.slug}/` },
  ],
};

const philBoylePersonNode = {
  '@type': 'Person',
  '@id': 'https://rrmacademy.org/courses/neofertility-medical-training/#phil-boyle',
  name: 'Dr. Phil Boyle',
  honorificPrefix: 'Dr.',
  givenName: 'Phil',
  familyName: 'Boyle',
  jobTitle: 'Founder, NeoFertility',
  description: instructor?.bio || 'Pioneer in Restorative Reproductive Medicine and founder of NeoFertility.',
  url: 'https://www.neofertilitytraining.com/',
  affiliation: {
    '@type': 'Organization',
    name: 'NeoFertility',
    url: 'https://www.neofertilitytraining.com/',
  },
};

const graphNodes: any[] = [courseSchema, isAffiliate ? philBoylePersonNode : whittakerPersonNode, breadcrumbSchema];
if (course.faqs?.length) {
  graphNodes.push({
    '@type': 'FAQPage',
    mainEntity: course.faqs.map((faq: any) => ({
      '@type': 'Question',
      name: faq.question,
      acceptedAnswer: { '@type': 'Answer', text: faq.answer },
    })),
  });
}

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': graphNodes,
};

// Related courses for "included" or "includedIn" relationships
const includedCourse = course.includes
  ? coursesData.find((c: any) => c.slug === course.includes[0])
  : null;
const parentCourse = course.includedIn
  ? coursesData.find((c: any) => c.slug === course.includedIn[0])
  : null;
const relatedCourses = course.relatedCourses
  ? (course.relatedCourses as string[]).map((slug: string) => coursesData.find((c: any) => c.slug === slug)).filter(Boolean)
  : [];
---
<BaseLayout
  title={course.seo?.title || course.title}
  description={course.seo?.description || course.shortDescription}
  canonicalUrl={`https://rrmacademy.org/courses/${course.slug}`}
  ogType="article"
  ogImage={course.image}
  jsonLd={jsonLd}
>
  <div class={`course-page`} {...(course.comingSoon ? {} : { 'data-pagefind-body': '' })}>
    <span data-pagefind-meta="type:Course" style="display:none"></span>
    <span data-pagefind-meta={`title:${course.title}`} style="display:none"></span>
    <span data-pagefind-meta={`description:${course.shortDescription}`} style="display:none"></span>

    <!-- Hero -->
    <section class="course-hero">
      <div class="container">
        <nav class="breadcrumb" aria-label="Breadcrumb">
          <a href="/courses/">Courses</a> <span aria-hidden="true">/</span> {course.title}
        </nav>
        <div class="course-hero__grid">
          <div class="course-hero__content">
            <h1>{course.title}</h1>
            <p class="course-hero__sub">{course.shortDescription}</p>
            <div class="course-hero__meta">
              {isAffiliate ? (
                <>
                  <span class="meta-pill">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c0 1.1 2.7 3 6 3s6-1.9 6-3v-5"/></svg>
                    20+ CME Credits
                  </span>
                  <span class="meta-pill">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                    11-Week Cohort
                  </span>
                  <span class="meta-pill">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                    {cohortLabel}
                  </span>
                  <span class="meta-pill meta-pill--partner">Partner Course</span>
                </>
              ) : (
                <>
                  <span class="meta-pill">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 3 19 12 5 21 5 3"/></svg>
                    {totalVideos} videos
                  </span>
                  <span class="meta-pill">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                    {durationLabel}
                  </span>
                  {course.selfPaced !== false && (
                    <span class="meta-pill">
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c0 1.1 2.7 3 6 3s6-1.9 6-3v-5"/></svg>
                      Self-paced
                    </span>
                  )}
                  {course.hasCertificate && (
                    <span class="meta-pill">
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"/></svg>
                      Certificate
                    </span>
                  )}
                </>
              )}
            </div>
            <p class="course-hero__instructor">{isAffiliate ? `Offered by NeoFertility — Led by ${instructor?.name}` : `Taught by ${instructor?.name}`}</p>
            <div class="course-hero__actions" id="hero-actions" data-pagefind-ignore>
              {isAffiliate ? (
                <div class="hero-cta-static">
                  <span class="course-hero__price">{price}</span>
                  <a href={course.affiliateUrl} class="btn btn--primary btn--lg affiliate-cta-btn" target="_blank" rel="noopener sponsored">
                    Enroll at NeoFertility
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-left: 4px; vertical-align: middle;"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                  </a>
                  <div id="affiliate-login-prompt" class="affiliate-coupon-code">
                    <a href={`/login/?redirect=/courses/${course.slug}/`}>Log in</a> or <a href={`/signup/?redirect=/courses/${course.slug}/`}>create a free account</a> for an exclusive discount code.
                  </div>
                  <div id="affiliate-coupon" class="affiliate-coupon-code" hidden>
                    Use code <strong>{course.couponCode}</strong> at checkout for {course.couponDiscount} off ({affiliatePrice}).
                  </div>
                </div>
              ) : (
                <>
                  <!-- Static: shown before JS hydrates -->
                  <div class="hero-cta-static">
                    {course.isFree ? (
                      <span class="course-hero__price">Free</span>
                    ) : (
                      <span class="course-hero__price">{price}</span>
                    )}
                    <button class="btn btn--primary btn--lg enroll-btn" data-course-id={course.id} data-free={String(course.isFree)}>
                      {course.isFree ? 'Start Learning' : 'Enroll Now'}
                    </button>
                    <a href={`/login/?redirect=/courses/${course.slug}/`} class="course-login-link">Log in</a>
                  </div>
                  <!-- Dynamic: replaced by JS when enrollment status is known -->
                  <div class="hero-cta-enrolled" hidden>
                    <a href={firstStep ? `/courses/${course.slug}/${firstStep.id}/` : '#'} class="btn btn--primary btn--lg" id="continue-btn">
                      Continue Learning
                    </a>
                    <div class="hero-progress" id="hero-progress" hidden>
                      <div class="hero-progress__bar" role="progressbar" aria-valuenow={0} aria-valuemin={0} aria-valuemax={100} aria-label="Course progress">
                        <div class="hero-progress__fill" id="hero-progress-fill"></div>
                      </div>
                      <span class="hero-progress__text" id="hero-progress-text"></span>
                    </div>
                  </div>
                </>
              )}
            </div>
          </div>
          <div class="course-hero__image">
            <img
              src={course.image}
              alt={course.imageAlt || course.title}
              width="560"
              height="315"
            />
          </div>
        </div>
      </div>
    </section>

    <!-- Curriculum -->
    {!isAffiliate && (
    <section class="course-section">
      <div class="container container--narrow">
        <h2>Curriculum</h2>
        <p class="section-sub">{course.sections.length} sections &middot; {totalSteps} lessons &middot; {durationLabel} total</p>

        <div class="curriculum" id="curriculum">
          {course.sections.map((section: any, sIdx: number) => (
            <details class="curriculum__module" open={sIdx === 0}>
              <summary class="curriculum__module-header">
                <span class="curriculum__module-title">{section.title}</span>
                <span class="curriculum__module-meta">{section.steps.length} lessons</span>
                <svg class="curriculum__chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
              </summary>
              <ul class="curriculum__steps">
                {section.steps.map((step: any) => (
                  <li class="curriculum__step" data-step-id={step.id}>
                    <span class="curriculum__step-icon" set:html={stepIcon(step.type)} />
                    <span class="curriculum__step-title">{step.title}</span>
                    {step.duration && (
                      <span class="curriculum__step-duration">{formatDuration(step.duration)}</span>
                    )}
                  </li>
                ))}
              </ul>
            </details>
          ))}
        </div>
      </div>
    </section>
    )}

    <!-- Description -->
    <section class="course-section course-section--alt">
      <div class="container container--narrow">
        <h2>About This Course</h2>
        <div class="course-description prose">
          {course.description.split('\n\n').map((para: string) => {
            if (para.startsWith('•')) {
              const items = para.split('\n').filter((l: string) => l.trim());
              return (
                <ul>
                  {items.map((item: string) => (
                    <li>{item.replace(/^[•]\s*/, '')}</li>
                  ))}
                </ul>
              );
            }
            return <p>{para}</p>;
          })}
        </div>
      </div>
    </section>

    <!-- What's Included (affiliate) -->
    {isAffiliate && course.whatsIncluded?.length > 0 && (
      <section class="course-section">
        <div class="container container--narrow">
          <h2>What's Included</h2>
          <ul class="whats-included">
            {course.whatsIncluded.map((item: string) => (
              <li>{item}</li>
            ))}
          </ul>
        </div>
      </section>
    )}

    <!-- Instructor -->
    <section class="course-section">
      <div class="container container--narrow">
        <h2>Your Instructor</h2>
        <div class="instructor-card">
          <div>
            <h3>{instructor?.name}</h3>
            <p>{instructor?.bio}</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Related / Included -->
    {!isAffiliate && (includedCourse || parentCourse) && (
      <section class="course-section course-section--alt">
        <div class="container container--narrow">
          {includedCourse && (
            <div class="related-course">
              <h2>Included With This Course</h2>
              <p>Your enrollment includes full access to:</p>
              <a href={`/courses/${includedCourse.slug}/`} class="related-course__link">
                <strong>{includedCourse.title}</strong>
                <span>{includedCourse.shortDescription}</span>
              </a>
            </div>
          )}
          {parentCourse && (
            <div class="related-course">
              <h2>Also Available As Part Of</h2>
              <a href={`/courses/${parentCourse.slug}/`} class="related-course__link">
                <strong>{parentCourse.title}</strong>
                <span>Includes this course as a bonus. {parentCourse.isFree ? 'Free' : `$${(parentCourse.priceCents / 100).toFixed(0)}`}</span>
              </a>
            </div>
          )}
        </div>
      </section>
    )}

    <!-- You Might Also Like -->
    {!isAffiliate && relatedCourses.length > 0 && (
      <section class="course-section">
        <div class="container container--narrow">
          <div class="related-course">
            <h2>You Might Also Like</h2>
            {relatedCourses.map((rc: any) => (
              <a href={`/courses/${rc.slug}/`} class="related-course__link">
                <strong>{rc.title}</strong>
                <span>{rc.shortDescription}</span>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- FAQ -->
    {!isAffiliate && course.faqs?.length > 0 && (
      <section class="course-section course-faqs">
        <div class="container container--narrow">
          <h2>Frequently Asked Questions</h2>
          <div class="faq-list">
            {course.faqs.map((faq: any) => (
              <details class="faq-item">
                <summary class="faq-question">
                  <span class="faq-question-text">{faq.question}</span>
                  <span class="faq-chevron" aria-hidden="true">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
                  </span>
                </summary>
                <div class="faq-answer">
                  <p>{faq.answer}</p>
                </div>
              </details>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- Bottom CTA -->
    <section class="course-section course-bottom-cta" data-pagefind-ignore>
      <div class="container container--narrow" style="text-align: center;">
        <h2>Ready to Start?</h2>
        {isAffiliate ? (
          <>
            <p class="section-sub">Enrollment and payment handled by NeoFertility.</p>
            <a href={course.affiliateUrl} class="btn btn--primary btn--lg affiliate-cta-btn" target="_blank" rel="noopener sponsored">
              Enroll at NeoFertility
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-left: 4px; vertical-align: middle;"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
            </a>
          </>
        ) : (
          <>
            <p class="section-sub">{course.isFree ? 'This course is completely free.' : `One-time payment of ${price}. Lifetime access.`}</p>
            <button class="btn btn--primary btn--lg enroll-btn" data-course-id={course.id} data-free={String(course.isFree)}>
              {course.isFree ? 'Start Learning' : 'Enroll Now'}
            </button>
          </>
        )}
      </div>
    </section>

    <p class="page-updated">Last updated: February 2026</p>
  </div>

  {isAffiliate && (
    <script is:inline define:vars={{ affiliateUrl: course.affiliateUrl, courseId: course.id }}>
      (function () {
        // Auth-gated coupon display
        var couponShow = document.getElementById('affiliate-coupon');
        var couponHide = document.getElementById('affiliate-login-prompt');

        fetch('/api/auth/session', { credentials: 'same-origin' })
          .then(function (r) { return r.json(); })
          .then(function (data) {
            if (data.user && data.user.id) {
              if (couponShow) couponShow.hidden = false;
              if (couponHide) couponHide.hidden = true;
            }
          })
          .catch(function () {});

        // Click tracking + redirect
        var btns = document.querySelectorAll('.affiliate-cta-btn');
        for (var i = 0; i < btns.length; i++) {
          btns[i].addEventListener('click', function (e) {
            e.preventDefault();
            window.open(affiliateUrl, '_blank', 'noopener');
            fetch('/api/courses/affiliate-click', {
              method: 'POST',
              credentials: 'same-origin',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ courseId: courseId }),
            }).catch(function () {});
          });
        }
      })();
    </script>
  )}

  <!-- Enrollment + Progress (client-side) -->
  {!isAffiliate && (
  <script is:inline define:vars={{ courseId: course.id, courseSlug: course.slug, firstStepId: firstStep?.id }}>
    (function () {
      var staticCta = document.querySelector('.hero-cta-static');
      var enrolledCta = document.querySelector('.hero-cta-enrolled');
      var heroProgress = document.getElementById('hero-progress');
      var progressFill = document.getElementById('hero-progress-fill');
      var progressText = document.getElementById('hero-progress-text');
      var continueBtn = document.getElementById('continue-btn');
      var enrollBtns = document.querySelectorAll('.enroll-btn');

      // Check enrollment status
      fetch('/api/courses/progress?courseId=' + encodeURIComponent(courseId), { credentials: 'same-origin' })
        .then(function (r) { return r.json(); })
        .then(function (data) {
          if (!data.ok) return; // Not enrolled or not logged in — keep static CTA

          // User is enrolled — switch to enrolled CTA
          staticCta.hidden = true;
          enrolledCta.hidden = false;

          // Find the first incomplete step for "Continue" button
          var steps = data.steps || {};
          var resumeStep = firstStepId;
          var foundIncomplete = false;
          var sections = document.querySelectorAll('.curriculum__module');
          var completedCount = 0;
          var totalCount = 0;

          document.querySelectorAll('.curriculum__step').forEach(function (el) {
            var stepId = el.getAttribute('data-step-id');
            totalCount++;
            if (steps[stepId] && steps[stepId].completed) {
              completedCount++;
              el.classList.add('curriculum__step--completed');
            } else if (!foundIncomplete) {
              resumeStep = stepId;
              foundIncomplete = true;
            }
          });

          if (resumeStep) {
            continueBtn.href = '/courses/' + courseSlug + '/' + resumeStep + '/';
          }

          // Show progress
          if (totalCount > 0) {
            var pct = Math.round((completedCount / totalCount) * 100);
            heroProgress.hidden = false;
            progressFill.style.width = pct + '%';
            progressText.textContent = pct + '% complete (' + completedCount + '/' + totalCount + ' lessons)';
            var bar = heroProgress.querySelector('[role="progressbar"]');
            if (bar) bar.setAttribute('aria-valuenow', String(pct));
          }

          // Hide bottom CTA enroll buttons
          for (var i = 0; i < enrollBtns.length; i++) {
            var btn = enrollBtns[i];
            var wrapper = btn.closest('.course-bottom-cta');
            if (wrapper) wrapper.hidden = true;
          }
        })
        .catch(function () {
          // Network error — leave static CTA visible
        });

      // Enroll button handler
      for (var i = 0; i < enrollBtns.length; i++) {
        enrollBtns[i].addEventListener('click', handleEnroll);
      }

      function handleEnroll(e) {
        var btn = e.currentTarget;
        var cid = btn.getAttribute('data-course-id');
        var isFree = btn.getAttribute('data-free') === 'true';

        btn.disabled = true;
        btn.textContent = 'Processing...';

        fetch('/api/courses/enroll', {
          method: 'POST',
          credentials: 'same-origin',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ courseId: cid }),
        })
          .then(function (r) { return r.json(); })
          .then(function (data) {
            if (!data.ok) {
              if (data.error === 'Not authenticated') {
                window.location.href = '/login/?redirect=' + encodeURIComponent(window.location.pathname);
                return;
              }
              btn.disabled = false;
              btn.textContent = isFree ? 'Start Learning' : 'Enroll Now';
              alert(data.error || 'Enrollment failed. Please try again.');
              return;
            }
            if (data.checkoutUrl) {
              // Paid course — redirect to Stripe Checkout
              window.location.href = data.checkoutUrl;
            } else {
              // Free course — enrolled! Redirect to first lesson
              window.location.href = '/courses/' + courseSlug + '/' + (firstStepId ? firstStepId + '/' : '');
            }
          })
          .catch(function () {
            btn.disabled = false;
            btn.textContent = isFree ? 'Start Learning' : 'Enroll Now';
            alert('Network error. Please try again.');
          });
      }
    })();
  </script>
  )}
</BaseLayout>

