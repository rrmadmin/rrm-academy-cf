---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CourseCard from '../../components/CourseCard.astro';
import coursesData from '../../data/courses.json';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'RRM Academy Courses',
  description: 'Evidence-based courses on endometriosis, fertility, and reproductive medicine from Dr. Naomi Whittaker.',
  url: 'https://rrmacademy.org/courses',
  numberOfItems: coursesData.length,
  itemListElement: coursesData.map((course, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    item: {
      '@type': 'Course',
      name: course.title,
      description: course.shortDescription,
      url: `https://rrmacademy.org/courses/${course.slug}`,
      provider: {
        '@type': 'Organization',
        name: 'RRM Academy',
        url: 'https://rrmacademy.org',
      },
      ...(course.isFree ? {} : {
        offers: {
          '@type': 'Offer',
          price: (course.priceCents / 100).toFixed(2),
          priceCurrency: 'USD',
        },
      }),
    },
  })),
};
---
<BaseLayout
  title="Courses"
  description="Evidence-based courses on endometriosis, fertility, and reproductive medicine. Self-paced video courses taught by Dr. Naomi Whittaker, MD."
  canonicalUrl="https://rrmacademy.org/courses"
  jsonLd={jsonLd}
>
  <div class="page-wrapper">
    <div class="container">

      <section class="courses-hero">
        <h1>Courses</h1>
        <p class="courses-hero__sub">Self-paced video courses on endometriosis, fertility, and reproductive medicine. Taught by Dr. Naomi Whittaker, MD.</p>
      </section>

      <div class="courses-grid">
        {coursesData.map((course) => (
          <CourseCard course={course} />
        ))}
      </div>

      <section class="courses-about">
        <h2>About Your Instructor</h2>
        <div class="instructor-row">
          <div class="instructor-info">
            <h3>Naomi Whittaker, MD</h3>
            <p>Dr. Whittaker is an OBGYN and fertility surgeon who specializes in Restorative Reproductive Medicine (RRM) and NaProTechnology. She is the founder of the RRM Academy and the RRM Foundation, dedicated to making evidence-based reproductive healthcare education accessible to patients and professionals.</p>
            <p>Her courses draw on years of clinical experience treating endometriosis, infertility, and hormonal disorders using a root-cause approach rather than suppressive medications.</p>
          </div>
        </div>
      </section>

    </div>
  </div>
</BaseLayout>

<style>
  .page-wrapper {
    padding: var(--space-10) 0 var(--space-16);
    min-height: 60vh;
  }

  .courses-hero {
    text-align: center;
    margin-bottom: var(--space-10);
  }
  .courses-hero h1 {
    font-size: clamp(2rem, 1.5rem + 2vw, 2.5rem);
    margin-bottom: var(--space-3);
  }
  .courses-hero__sub {
    font-size: 0.9375rem;
    color: var(--text-secondary);
    max-width: 560px;
    margin: 0 auto;
  }

  .courses-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-6);
    max-width: 900px;
    margin: 0 auto var(--space-16);
  }
  @media (max-width: 768px) {
    .courses-grid {
      grid-template-columns: 1fr;
      max-width: 480px;
    }
  }

  /* Instructor section */
  .courses-about {
    max-width: var(--max-width-article);
    margin: 0 auto;
    border-top: 1px solid var(--border-color);
    padding-top: var(--space-10);
  }
  .courses-about h2 {
    text-align: center;
  }
  .instructor-row {
    display: flex;
    gap: var(--space-8);
    align-items: flex-start;
  }
  .instructor-info h3 {
    margin-bottom: var(--space-3);
  }
  .instructor-info p {
    font-size: 0.9375rem;
    color: var(--text-secondary);
    line-height: 1.7;
  }
  @media (max-width: 768px) {
    .instructor-row {
      flex-direction: column;
      text-align: center;
    }
  }
</style>
