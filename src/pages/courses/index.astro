---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CourseCard from '../../components/CourseCard.astro';
import coursesData from '../../data/courses.json';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'RRM Academy Courses',
  description: 'Evidence-based courses on endometriosis, fertility, and reproductive medicine from Dr. Naomi Whittaker.',
  url: 'https://rrmacademy.org/courses/',
  numberOfItems: coursesData.filter((c: any) => !c.comingSoon).length,
  itemListElement: coursesData.filter((c: any) => !c.comingSoon).map((course: any, i: number) => ({
    '@type': 'ListItem',
    position: i + 1,
    item: {
      '@type': 'Course',
      name: course.title,
      description: course.shortDescription,
      url: `https://rrmacademy.org/courses/${course.slug}/`,
      ...(course.image ? { image: course.image } : {}),
      provider: course.isAffiliate
        ? { '@type': 'Organization', name: 'NeoFertility', url: 'https://www.neofertilitytraining.com/' }
        : { '@type': 'Organization', '@id': 'https://rrmacademy.org/#organization', name: 'RRM Academy', url: 'https://rrmacademy.org/' },
      isAccessibleForFree: course.isFree,
      offers: {
        '@type': 'Offer',
        price: course.isFree ? '0' : (course.priceCents / 100).toFixed(2),
        priceCurrency: 'USD',
        availability: 'https://schema.org/InStock',
        ...(course.isAffiliate && course.affiliateUrl ? { url: course.affiliateUrl } : {}),
      },
    },
  })),
};
---
<BaseLayout
  title="Online RRM Courses | Endometriosis & Fertility"
  description="Self-paced video courses on endometriosis, fertility, and reproductive health from leading specialists in restorative reproductive medicine. Start free today."
  canonicalUrl="https://rrmacademy.org/courses"
  jsonLd={jsonLd}
>
  <div class="page-wrapper">
    <div class="container">

      <section class="courses-hero">
        <h1 class="animate-enter" style="--stagger: 0;">Online RRM Courses</h1>
        <p class="courses-hero__sub animate-enter" style="--stagger: 1;">Self-paced online training in Restorative Reproductive Medicine for clinicians and patients. Courses cover endometriosis surgery, NaProTechnology fundamentals, cycle-based diagnostics, and fertility care, taught by board-certified OBGYNs and RRM-trained specialists.</p>
        <p class="courses-hero__audiences animate-enter" style="--stagger: 2;">
          <strong>Clinicians:</strong> expand your training in root-cause reproductive care beyond standard OBGYN, family medicine, and endocrinology curricula.
          <br />
          <strong>Patients:</strong> learn what a real diagnostic workup looks like and how to evaluate surgical and fertility care.
        </p>
      </section>

      <h2 class="sr-only">Available Courses</h2>
      <div class="courses-grid animate-enter" style="--stagger: 3;">
        {coursesData.filter((c: any) => !c.comingSoon).map((course, i) => (
          <CourseCard course={course} eager={i < 2} />
        ))}
      </div>

      <section class="courses-faq">
        <h2>Course FAQ</h2>
        <div class="faq-list">

          <details class="faq-item">
            <summary class="faq-q">What is the format of the courses?</summary>
            <p class="faq-a">Our RRM Academy courses are self-paced and fully online. Each course includes video lectures by expert clinicians, downloadable resources, and quizzes to reinforce your learning. You can start, pause, and return at any time -- there are no deadlines or scheduled sessions. Partner courses may follow a different format (such as live cohorts).</p>
          </details>

          <details class="faq-item">
            <summary class="faq-q">Who are these courses for?</summary>
            <p class="faq-a">Our courses are designed for two audiences: patients navigating reproductive health conditions (endometriosis, infertility, PCOS, hormonal disorders) who want to understand their options beyond standard care; and healthcare professionals seeking education in Restorative Reproductive Medicine and NaProTechnology.</p>
          </details>

          <details class="faq-item">
            <summary class="faq-q">How long will I have access after I enroll?</summary>
            <p class="faq-a">For RRM Academy courses, access is lifetime. Once enrolled, your course remains available in your account with no expiration date -- including any updates or new content added over time. Partner courses have their own access policies set by the partner organization.</p>
          </details>

          <details class="faq-item">
            <summary class="faq-q">What is the difference between the Masterclass in Endometriosis & Surgery and the Long-Term Endometriosis Management course?</summary>
            <p class="faq-a">The Masterclass covers the full journey: understanding endometriosis, evaluating surgical options, choosing a surgeon, and navigating the surgical process. The Long-Term Endometriosis Management course focuses on ongoing and post-surgical care: diet, supplements, lifestyle, and medications. The Long-Term course is included free when you enroll in the Masterclass.</p>
          </details>

          <details class="faq-item">
            <summary class="faq-q">Do the courses offer a certificate of completion?</summary>
            <p class="faq-a">Yes. The Masterclass in Endometriosis & Surgery includes a certificate of completion, issued automatically after you finish all lessons and pass the final assessment with a score of 80% or higher.</p>
          </details>

          <details class="faq-item">
            <summary class="faq-q">Do these courses replace medical advice from my doctor?</summary>
            <p class="faq-a">No. Our courses are educational resources designed to help you understand conditions and treatment options. They do not constitute medical advice and are not a substitute for care from a qualified healthcare provider. Always consult your physician before making medical decisions.</p>
          </details>

          <details class="faq-item">
            <summary class="faq-q">Why do you charge for some courses?</summary>
            <p class="faq-a">Creating high-quality clinical content requires significant time and expertise from our instructors. Paid courses help sustain RRM Academy as a nonprofit. They allow us to keep our free courses free, maintain the Research Library, and continue producing education without ads or outside funding. We charge the minimum needed to support the mission.</p>
          </details>

          <details class="faq-item">
            <summary class="faq-q">Is financial assistance available for paid courses?</summary>
            <p class="faq-a">Yes. If cost is a barrier, please <a href="/contact/">contact us</a>. We offer need-based access on a case-by-case basis and never want cost to prevent someone from getting the education they need.</p>
          </details>

          <details class="faq-item">
            <summary class="faq-q">What is your refund policy?</summary>
            <p class="faq-a">We offer a full refund within 7 days of purchase if you have completed less than 20% of the course. Please <a href="/contact/">contact us</a> with your order details.</p>
          </details>

          <details class="faq-item">
            <summary class="faq-q">What are partner courses?</summary>
            <p class="faq-a">Some courses listed on RRM Academy are offered by trusted training partners in Restorative Reproductive Medicine. These courses are hosted and managed by the partner organization. Enrollment, payment, and course delivery happen on the partner's platform. Partner courses are clearly labeled with a "Partner Course" badge.</p>
          </details>

        </div>
      </section>

      <p class="page-updated">Last updated: February 2026</p>
    </div>
  </div>
</BaseLayout>

<style>
  @keyframes enter {
    from { opacity: 0; transform: translateY(8px); filter: blur(4px); }
  }
  .animate-enter {
    animation: enter 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94) both;
    animation-delay: calc(100ms * var(--stagger, 0));
  }
  @media (prefers-reduced-motion: reduce) {
    .animate-enter { animation: none; }
  }

  .page-wrapper {
    padding: var(--space-8) 0 var(--space-16);
    min-height: 60vh;
  }

  .courses-hero {
    max-width: 900px;
    margin: 0 auto var(--space-10);
  }
  .courses-hero h1 {
    font-size: clamp(2rem, 1.25rem + 2.5vw, 3.25rem);
    margin-bottom: var(--space-3);
  }
  .courses-hero__sub {
    font-size: 0.9375rem;
    color: var(--text-secondary);
    max-width: 680px;
  }
  .courses-hero__audiences {
    font-size: 0.875rem;
    color: var(--text-secondary);
    max-width: 680px;
    margin-top: var(--space-3);
    line-height: 1.65;
  }
  .courses-hero__audiences strong {
    color: var(--text-primary);
  }

  .courses-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-6);
    max-width: 900px;
    margin: 0 auto var(--space-16);
  }
  @media (max-width: 768px) {
    .courses-grid {
      grid-template-columns: 1fr;
      max-width: 480px;
    }
  }

  /* FAQ section */
  .courses-faq {
    max-width: var(--max-width-article);
    margin: 0 auto;
    border-top: 1px solid var(--border-color);
    padding-top: var(--space-10);
  }
  .courses-faq h2 {
    text-align: center;
    margin-bottom: var(--space-8);
  }
  .faq-list {
    margin: 0;
    padding: 0;
  }
  .faq-item {
    border-bottom: 1px solid var(--border-light, var(--border-color));
  }
  .faq-item:first-of-type {
    border-top: 1px solid var(--border-light, var(--border-color));
  }
  .faq-q {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-4);
    padding: var(--space-5) 0;
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--text-primary);
    cursor: pointer;
    list-style: none;
    line-height: 1.4;
  }
  .faq-q::-webkit-details-marker { display: none; }
  .faq-q::after {
    content: '+';
    font-size: 1.25rem;
    font-weight: 300;
    color: var(--text-tertiary);
    flex-shrink: 0;
    transition: transform 0.2s;
  }
  .faq-item[open] .faq-q::after {
    transform: rotate(45deg);
  }
  .faq-a {
    margin: 0;
    padding: 0 0 var(--space-5);
    font-size: 0.9375rem;
    color: var(--text-secondary);
    line-height: 1.7;
  }
  .faq-a a {
    color: var(--accent);
    text-decoration: underline;
  }
</style>
