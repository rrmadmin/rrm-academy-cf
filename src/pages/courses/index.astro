---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CourseCard from '../../components/CourseCard.astro';
import coursesData from '../../data/courses.json';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'RRM Academy Courses',
  description: 'Evidence-based courses on endometriosis, fertility, and reproductive medicine from Dr. Naomi Whittaker.',
  url: 'https://rrmacademy.org/courses',
  numberOfItems: coursesData.length,
  itemListElement: coursesData.map((course, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    item: {
      '@type': 'Course',
      name: course.title,
      description: course.shortDescription,
      url: `https://rrmacademy.org/courses/${course.slug}`,
      provider: {
        '@type': 'Organization',
        name: 'RRM Academy',
        url: 'https://rrmacademy.org',
      },
      ...(course.isFree ? {} : {
        offers: {
          '@type': 'Offer',
          price: (course.priceCents / 100).toFixed(2),
          priceCurrency: 'USD',
        },
      }),
    },
  })),
};
---
<BaseLayout
  title="Courses"
  description="Evidence-based courses on endometriosis, fertility, and reproductive medicine. Self-paced video courses taught by Dr. Naomi Whittaker, MD."
  canonicalUrl="https://rrmacademy.org/courses"
  jsonLd={jsonLd}
>
  <div class="page-wrapper">
    <div class="container">

      <section class="courses-hero">
        <h1>Courses</h1>
        <p class="courses-hero__sub">Self-paced video courses on endometriosis, fertility, and reproductive medicine. Taught by Dr. Naomi Whittaker, MD.</p>
      </section>

      <div class="courses-grid">
        {coursesData.map((course) => (
          <CourseCard course={course} />
        ))}
      </div>

      <section class="courses-faq">
        <h2>Course FAQ</h2>
        <dl class="faq-list">

          <details class="faq-item">
            <summary class="faq-q">What is the format of the courses?</summary>
            <dd class="faq-a">Our courses are self-paced and fully online. Each course includes video lectures by expert clinicians, downloadable resources, and quizzes to reinforce your learning. You can start, pause, and return at any time — there are no deadlines or scheduled sessions.</dd>
          </details>

          <details class="faq-item">
            <summary class="faq-q">Who are these courses for?</summary>
            <dd class="faq-a">Our courses are designed for two audiences: patients navigating reproductive health conditions (endometriosis, infertility, PCOS, hormonal disorders) who want to understand their options beyond standard care; and healthcare professionals seeking education in Restorative Reproductive Medicine and NaProTechnology.</dd>
          </details>

          <details class="faq-item">
            <summary class="faq-q">How long will I have access after I enroll?</summary>
            <dd class="faq-a">Access is lifetime. Once enrolled, your course remains available in your account with no expiration date — including any updates or new content added over time.</dd>
          </details>

          <details class="faq-item">
            <summary class="faq-q">What is the difference between the Masterclass in Endometriosis & Surgery and the Long-Term Endometriosis Management course?</summary>
            <dd class="faq-a">The Masterclass covers the full journey — understanding endometriosis, evaluating surgical options, choosing a surgeon, and navigating the surgical process. The Long-Term Endometriosis Management course focuses on ongoing and post-surgical care: diet, supplements, lifestyle, and medications. The Long-Term course is included free when you enroll in the Masterclass.</dd>
          </details>

          <details class="faq-item">
            <summary class="faq-q">Do the courses offer a certificate of completion?</summary>
            <dd class="faq-a">Yes. The Masterclass in Endometriosis & Surgery includes a certificate of completion, issued automatically after you finish all lessons and pass the final assessment with a score of 80% or higher.</dd>
          </details>

          <details class="faq-item">
            <summary class="faq-q">Do these courses replace medical advice from my doctor?</summary>
            <dd class="faq-a">No. Our courses are educational resources designed to help you understand conditions and treatment options. They do not constitute medical advice and are not a substitute for care from a qualified healthcare provider. Always consult your physician before making medical decisions.</dd>
          </details>

          <details class="faq-item">
            <summary class="faq-q">Why do you charge for some courses?</summary>
            <dd class="faq-a">Creating high-quality clinical content requires significant time and expertise from our instructors. Paid courses help sustain RRM Academy as a nonprofit — they allow us to keep our free courses free, maintain the Research Library, and continue producing education without ads or outside funding. We charge the minimum needed to support the mission.</dd>
          </details>

          <details class="faq-item">
            <summary class="faq-q">Is financial assistance available for paid courses?</summary>
            <dd class="faq-a">Yes. If cost is a barrier, please <a href="/contact/">contact us</a>. We offer need-based access on a case-by-case basis and never want cost to prevent someone from getting the education they need.</dd>
          </details>

          <details class="faq-item">
            <summary class="faq-q">What is your refund policy?</summary>
            <dd class="faq-a">We offer a full refund within 7 days of purchase if you have completed less than 20% of the course. Please <a href="/contact/">contact us</a> with your order details.</dd>
          </details>

        </dl>
      </section>

    </div>
  </div>
</BaseLayout>

<style>
  .page-wrapper {
    padding: var(--space-10) 0 var(--space-16);
    min-height: 60vh;
  }

  .courses-hero {
    text-align: center;
    margin-bottom: var(--space-10);
  }
  .courses-hero h1 {
    font-size: clamp(2rem, 1.5rem + 2vw, 2.5rem);
    margin-bottom: var(--space-3);
  }
  .courses-hero__sub {
    font-size: 0.9375rem;
    color: var(--text-secondary);
    max-width: 560px;
    margin: 0 auto;
  }

  .courses-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-6);
    max-width: 900px;
    margin: 0 auto var(--space-16);
  }
  @media (max-width: 768px) {
    .courses-grid {
      grid-template-columns: 1fr;
      max-width: 480px;
    }
  }

  /* FAQ section */
  .courses-faq {
    max-width: var(--max-width-article);
    margin: 0 auto;
    border-top: 1px solid var(--border-color);
    padding-top: var(--space-10);
  }
  .courses-faq h2 {
    text-align: center;
    margin-bottom: var(--space-8);
  }
  .faq-list {
    margin: 0;
    padding: 0;
  }
  .faq-item {
    border-bottom: 1px solid var(--border-light, var(--border-color));
  }
  .faq-item:first-of-type {
    border-top: 1px solid var(--border-light, var(--border-color));
  }
  .faq-q {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-4);
    padding: var(--space-5) 0;
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--text-primary);
    cursor: pointer;
    list-style: none;
    line-height: 1.4;
  }
  .faq-q::-webkit-details-marker { display: none; }
  .faq-q::after {
    content: '+';
    font-size: 1.25rem;
    font-weight: 300;
    color: var(--text-tertiary);
    flex-shrink: 0;
    transition: transform 0.2s;
  }
  .faq-item[open] .faq-q::after {
    transform: rotate(45deg);
  }
  .faq-a {
    margin: 0;
    padding: 0 0 var(--space-5);
    font-size: 0.9375rem;
    color: var(--text-secondary);
    line-height: 1.7;
  }
  .faq-a a {
    color: var(--accent);
    text-decoration: underline;
  }
</style>
