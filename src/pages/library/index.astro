---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SearchBar from '../../components/SearchBar.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { fetchAllArticles } from '../../lib/airtable';

const articles = await fetchAllArticles();

// Recent additions (first 6, already sorted by date)
const recent = articles.slice(0, 6);

// Rotating ticker (8 most recent, for hero)
const ticker = articles.slice(0, 8).map(a => ({
  title: a.title,
  slug: a.slug,
  shortCitation: a.shortCitation,
}));

// Schema.org for landing page
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'RRM Research Library',
  description: 'The largest free collection of academic references related to restorative reproductive medicine.',
  url: 'https://rrmacademy.org/library',
  numberOfItems: articles.length,
  isPartOf: {
    '@type': 'WebSite',
    name: 'RRM Academy',
    url: 'https://rrmacademy.org',
    potentialAction: {
      '@type': 'SearchAction',
      target: {
        '@type': 'EntryPoint',
        urlTemplate: 'https://rrmacademy.org/library?q={search_term_string}',
      },
      'query-input': 'required name=search_term_string',
    },
  },
  publisher: {
    '@type': 'Organization',
    name: 'RRM Academy',
    url: 'https://rrmacademy.org',
  },
};
---
<BaseLayout
  bodyClass="page-library"
  title="RRM Research Library"
  description={`Browse ${articles.length.toLocaleString()} peer-reviewed articles on restorative reproductive medicine. Free access to abstracts, citations, and full-text links.`}
  canonicalUrl="https://rrmacademy.org/library"
  jsonLd={jsonLd}
>
  <!-- Hero — full-viewport, search-first, Grokipedia-inspired -->
  <section class="hero" data-pagefind-ignore="all">
    <div class="hero__center">
      <h1>Research Library <span class="hero__version">v2.0</span></h1>
      <div class="hero__search">
        <SearchBar />
      </div>
      <div class="hero__ticker" aria-label="Recent additions">
        <div class="hero__ticker-stack" id="ticker-stack">
          {ticker.map((item, i) => (
            <a
              href={`/library/${item.slug}`}
              class:list={['ticker-card', { active: i === 0 }]}
              data-index={i}
            >
              <span class="ticker-card__title">{item.title}</span>
              <span class="ticker-card__meta">{item.shortCitation}</span>
            </a>
          ))}
        </div>
      </div>
    </div>
    <p class="hero__count">
      <span class="hero__count-label">Articles Available</span>
      <span class="hero__count-number">{articles.length.toLocaleString()}</span>
    </p>
  </section>

  <!-- Topic Links -->
  <nav class="topic-links" data-pagefind-ignore="all" aria-label="Browse by topic">
    <a href="/library?topic=Endometriosis">Endometriosis</a>
    <span class="topic-links__dot" aria-hidden="true">&middot;</span>
    <a href="/library?topic=Infertility">Infertility</a>
    <span class="topic-links__dot" aria-hidden="true">&middot;</span>
    <a href="/library?topic=PCOS">PCOS</a>
    <span class="topic-links__dot" aria-hidden="true">&middot;</span>
    <a href="/library?topic=Pregnancy">Pregnancy</a>
    <span class="topic-links__dot" aria-hidden="true">&middot;</span>
    <a href="/library?topic=Surgery">Surgery</a>
    <span class="topic-links__dot" aria-hidden="true">&middot;</span>
    <a href="/library?topic=Hormones%20%26%20Cycle">Hormones &amp; Cycle</a>
    <span class="topic-links__dot" aria-hidden="true">&middot;</span>
    <a href="/library?topic=Contraception">Contraception</a>
    <span class="topic-links__dot" aria-hidden="true">&middot;</span>
    <a href="/library?topic=NaProTECHNOLOGY">NaProTECHNOLOGY</a>
  </nav>

  <!-- Recent Additions -->
  <section class="section" data-pagefind-ignore="all">
    <div class="container">
      <div class="section-header">
        <h2 class="section-label">Recent additions</h2>
        <a href="/library/page/1" class="link-arrow">View all &rarr;</a>
      </div>
      <div class="recent-grid">
        {recent.map(article => (
          <ArticleCard article={article} />
        ))}
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  :global(body.page-library) {
    background-color: #f7f5f3;
  }
  /* Hero — full-viewport, centered, Grokipedia-inspired */
  .hero {
    min-height: calc(100vh - 56px);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    position: relative;
    padding: var(--space-8) var(--space-4);
  }
  .hero__center {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    width: 100%;
    max-width: 600px;
    gap: var(--space-5);
  }
  .hero h1 {
    font-size: 2.5rem;
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin: 0;
  }
  .hero__version {
    font-family: 'Inter', sans-serif;
    font-size: 0.875rem;
    font-weight: 400;
    color: var(--text-muted);
    letter-spacing: 0;
    vertical-align: super;
    margin-left: 2px;
  }
  .hero__search {
    width: 100%;
  }
  .hero__count {
    position: absolute;
    bottom: var(--space-4);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
  }
  .hero__count-label {
    font-size: 0.6875rem;
    font-family: 'Inter', sans-serif;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-tertiary);
    line-height: 1;
  }
  .hero__count-number {
    font-family: 'Cormorant Garamond', 'Georgia', serif;
    font-size: 1.375rem;
    font-weight: 500;
    color: var(--text-tertiary);
    letter-spacing: 0.04em;
    line-height: 1.1;
  }
  /* Stacked card ticker */
  .hero__ticker {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    margin-top: var(--space-6);
    width: 100%;
  }
  .hero__ticker-stack {
    position: relative;
    width: 320px;
    height: 130px;
  }
  .ticker-card {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding: var(--space-4) var(--space-5);
    background: var(--bg-surface);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
    box-shadow: 0 1px 4px rgba(0,0,0,0.05);
    text-decoration: none;
    pointer-events: none;
    opacity: 0;
    transform: scale(0.92) translateY(16px);
    transition: opacity 0.5s ease, transform 0.5s ease, box-shadow 0.15s;
  }
  .ticker-card:hover {
    text-decoration: none;
    box-shadow: 0 4px 16px rgba(0,0,0,0.1);
  }
  /* Active card — front of stack, fully visible */
  .ticker-card.active {
    opacity: 1;
    pointer-events: auto;
    transform: scale(1) translateY(0);
    z-index: 3;
  }
  /* Exiting card — slides up and fades out */
  .ticker-card.exiting {
    opacity: 0;
    pointer-events: none;
    transform: scale(1) translateY(-20px);
    z-index: 4;
  }
  /* Cards behind — scaled down, only bottom edge peeks out */
  .ticker-card.behind-1 {
    opacity: 1;
    transform: scale(0.97) translateY(6px);
    z-index: 2;
  }
  .ticker-card.behind-2 {
    opacity: 1;
    transform: scale(0.94) translateY(12px);
    z-index: 1;
  }
  /* Hide text on behind cards so only the blank card edge shows */
  .ticker-card.behind-1 .ticker-card__title,
  .ticker-card.behind-1 .ticker-card__meta,
  .ticker-card.behind-2 .ticker-card__title,
  .ticker-card.behind-2 .ticker-card__meta {
    visibility: hidden;
  }
  .ticker-card__title {
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--text-primary);
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .ticker-card__meta {
    font-size: 0.6875rem;
    color: var(--text-muted);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  @media (min-width: 769px) {
    .hero__ticker-stack {
      width: 380px;
      height: 130px;
    }
    .ticker-card__title {
      font-size: 0.875rem;
    }
  }
  @media (max-width: 400px) {
    .hero__ticker-stack {
      width: 280px;
    }
  }

  @media (min-width: 769px) {
    .hero h1 {
      font-size: 3.5rem;
    }
    .hero__center {
      max-width: 640px;
    }
    .hero__count-number {
      font-size: 1.5rem;
    }
  }
  @media (max-width: 768px) {
    .hero {
      min-height: calc(100dvh - 56px);
    }
    .hero__count-number {
      font-size: 1.25rem;
      font-weight: 500;
    }
    .hero__count-label {
      font-size: 0.625rem;
    }
    .hero__count {
      bottom: var(--space-2);
    }
  }

  /* Section labels — understated */
  .section-label {
    font-size: 0.6875rem;
    font-family: 'Inter', sans-serif;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-tertiary);
    margin-bottom: var(--space-4);
  }
  @media (min-width: 769px) {
    .section-label {
      font-size: 0.75rem;
      margin-bottom: var(--space-5);
    }
  }

  .link-arrow {
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--accent);
    white-space: nowrap;
  }
  /* Topic links row */
  .topic-links {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: 6px 4px;
    padding: var(--space-8) var(--space-4) var(--space-6);
    max-width: var(--max-width-page);
    margin: 0 auto;
  }
  .topic-links a {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text-secondary);
    text-decoration: none;
    transition: color 0.15s;
  }
  .topic-links a:hover {
    color: var(--accent);
    text-decoration: none;
  }
  .topic-links__dot {
    color: var(--text-muted);
    font-size: 0.875rem;
    line-height: 1;
    user-select: none;
  }
  @media (min-width: 769px) {
    .topic-links {
      gap: 6px 6px;
      padding: var(--space-8) var(--space-4);
    }
    .topic-links a {
      font-size: 0.9375rem;
    }
    .topic-links__dot {
      font-size: 0.9375rem;
    }
  }

  /* Recent grid */
  .recent-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-5);
  }
  @media (min-width: 640px) {
    .recent-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 1024px) {
    .recent-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: var(--space-6);
    }
  }
</style>

<script is:inline>
  // Stacked card ticker
  (function() {
    var stack = document.getElementById('ticker-stack');
    if (!stack) return;
    var cards = stack.querySelectorAll('.ticker-card');
    var n = cards.length;
    if (n < 2) return;
    var current = 0;

    function update() {
      for (var i = 0; i < n; i++) {
        cards[i].classList.remove('active', 'behind-1', 'behind-2', 'exiting');
      }
      cards[current].classList.add('active');
      cards[(current + 1) % n].classList.add('behind-1');
      cards[(current + 2) % n].classList.add('behind-2');
    }

    update();
    setInterval(function() {
      var prev = current;
      current = (current + 1) % n;
      // Clear all state classes first to prevent stale class accumulation
      for (var i = 0; i < n; i++) {
        cards[i].classList.remove('active', 'behind-1', 'behind-2', 'exiting');
      }
      cards[prev].classList.add('exiting');
      cards[current].classList.add('active');
      cards[(current + 1) % n].classList.add('behind-1');
      cards[(current + 2) % n].classList.add('behind-2');
    }, 4000);
  })();
</script>
