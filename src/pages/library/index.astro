---
import BaseLayout from '../../layouts/BaseLayout.astro';
import MaybeShell from '../../components/MaybeShell.astro';
import SearchBar from '../../components/SearchBar.astro';
import { isShellEnabled } from '../../lib/shell-routes';
import { fetchAllArticles, type Article } from '../../lib/airtable';

const SHELL_ENABLED = isShellEnabled('library');

const articles = await fetchAllArticles();

// Compact homepage card data — derive once at build time so the JSX stays trivial.
const recent = articles.slice(0, 6).map((a: Article) => {
  const authorsRaw = String(a.authors || '');
  const firstAuthor = authorsRaw.split(';')[0]?.split(',')[0]?.trim() || '';
  // Multi-author detection: semicolons are the canonical separator, but some
  // historical imports comma-separated co-authors. Treat 2+ commas as multi too.
  const hasSemi = authorsRaw.includes(';');
  const commaCount = (authorsRaw.match(/,/g) || []).length;
  const isMulti = hasSemi || commaCount >= 2;
  let authorYear: string;
  if (a.shortCitation) {
    authorYear = a.shortCitation;
  } else if (firstAuthor) {
    authorYear = `${firstAuthor}${isMulti ? ' et al.' : ''}${a.year ? `, ${a.year}` : ''}`;
  } else {
    authorYear = a.year ? String(a.year) : '';
  }
  return {
    slug: a.slug,
    title: a.title,
    authorYear: authorYear.trim(),
    journal: a.journalAbbv || a.journal || '',
    isOpenAccess: Boolean(a.isOpenAccess) || a.accessLevel === 'open',
  };
});

// Build-time topic counts. articles.json topics are hierarchical
// ("Endometriosis > Disease Classification > ..."); match on top segment.
// `match` aliases let display labels stay patient-friendly while counting
// against the canonical data labels (e.g. "Contraception" → "Contraception/Comparison").
function countTopic(matchTargets: string[]): number {
  const targets = new Set(matchTargets.map(s => s.toLowerCase()));
  let n = 0;
  for (const a of articles) {
    for (const t of (a.topics ?? [])) {
      if (targets.has(String(t).split(' > ')[0].trim().toLowerCase())) { n++; break; }
    }
  }
  return n;
}

const TOPICS = [
  { name: 'Endometriosis',       accent: 'p',
    match: ['Endometriosis'],
    desc: 'Excision, AMH, recurrence, biomarkers.' },
  { name: 'Infertility',         accent: 'r',
    match: ['Infertility'],
    desc: 'RRM work-up, IVF outcomes, recurrent loss.' },
  { name: 'PCOS',                accent: 'g',
    match: ['PCOS'],
    desc: 'Phenotype, insulin resistance, progesterone.' },
  { name: 'Pregnancy',           accent: 'r',
    match: ['Pregnancy'],
    desc: 'Progesterone support, miscarriage, neonatal outcomes.' },
  { name: 'Hormones & Cycle',    accent: 'p',
    match: ['Menstrual Cycle'],
    desc: 'Cycle physiology, mucus biomarkers, ovulation.' },
  { name: 'Contraception',       accent: 's',
    match: ['Contraception/Comparison'],
    desc: 'Side effects, long-term outcomes, comparison studies.' },
  { name: 'NaProTECHNOLOGY',     accent: 'p',
    match: ['NaProTECHNOLOGY', 'RRM Methods'],
    desc: 'Cumulative pregnancy rates, protocols, vs IVF.' },
  { name: 'Fertility Awareness', accent: 'g',
    match: ['Fertility Awareness'],
    desc: 'Method efficacy, Creighton, Marquette, Billings, FEMM.' },
  { name: 'Surgery',             accent: 's',
    match: ['Surgery'],
    desc: 'Excision, laparoscopy, fertility-sparing approaches.' },
];

function topicSlug(topic: string): string {
  return topic
    .toLowerCase()
    .replace(/\//g, '-')
    .replace(/\s+&\s+/g, '-and-')
    .replace(/\s+/g, '-')
    .replace(/[^a-z0-9-]/g, '')
    .replace(/-+/g, '-')
    .replace(/^-|-$/g, '');
}

const topicTiles = TOPICS.map(t => ({
  ...t,
  count: countTopic(t.match),
  href: `/library/topics/${topicSlug(t.match[0])}/`,
}));

const suggestions = [
  'endometriosis excision outcomes',
  'progesterone in PCOS',
  'NaProTECHNOLOGY infertility',
  'low-dose naltrexone',
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'CollectionPage',
      '@id': 'https://rrmacademy.org/library/#collection',
      name: 'RRM Research Library',
      description: 'The largest free collection of academic references related to restorative reproductive medicine.',
      url: 'https://rrmacademy.org/library/',
      numberOfItems: articles.length,
      inLanguage: 'en',
      isPartOf: { '@id': 'https://rrmacademy.org/#website' },
      about: { '@id': 'https://rrmacademy.org/#organization' },
      publisher: { '@id': 'https://rrmacademy.org/#organization' },
      breadcrumb: { '@id': 'https://rrmacademy.org/library/#breadcrumb' },
      potentialAction: {
        '@type': 'SearchAction',
        target: { '@type': 'EntryPoint', urlTemplate: 'https://rrmacademy.org/library/?q={search_term_string}' },
        'query-input': 'required name=search_term_string',
      },
    },
    {
      '@type': 'WebSite',
      '@id': 'https://rrmacademy.org/#website',
      url: 'https://rrmacademy.org/',
      name: 'RRM Academy',
      publisher: { '@id': 'https://rrmacademy.org/#organization' },
      potentialAction: {
        '@type': 'SearchAction',
        target: { '@type': 'EntryPoint', urlTemplate: 'https://rrmacademy.org/library/?q={search_term_string}' },
        'query-input': 'required name=search_term_string',
      },
    },
    {
      '@type': 'Organization',
      '@id': 'https://rrmacademy.org/#organization',
      name: 'RRM Academy',
      url: 'https://rrmacademy.org/',
    },
    {
      '@type': 'BreadcrumbList',
      '@id': 'https://rrmacademy.org/library/#breadcrumb',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://rrmacademy.org/' },
        { '@type': 'ListItem', position: 2, name: 'Research Library', item: 'https://rrmacademy.org/library/' },
      ],
    },
  ],
};
---
<BaseLayout
  bodyClass="page-library"
  title={`RRM Research Library | ${articles.length.toLocaleString()} Academic Scholarly Works`}
  description={`The largest free collection of RRM research. Browse ${articles.length.toLocaleString()} academic scholarly works on endometriosis, PCOS, infertility, and reproductive health.`}
  canonicalUrl="https://rrmacademy.org/library"
  jsonLd={jsonLd}
  chrome={SHELL_ENABLED ? 'shell' : 'default'}
>
  <MaybeShell enabled={SHELL_ENABLED} context="index" currentPath={Astro.url.pathname}>

    <section class="atlas-hero" data-pagefind-ignore="all">
      <div class="container atlas-hero__inner">
        <h1 class="animate-enter" style="--stagger: 0;">Find your topic in the evidence</h1>
        <p class="atlas-hero__dek animate-enter" style="--stagger: 1;">
          Browse {articles.length.toLocaleString()} academic scholarly works on restorative
          reproductive medicine &mdash; organized by topic, condition, and method.
        </p>
        <div class="atlas-hero__search animate-enter" style="--stagger: 2;">
          <SearchBar />
        </div>
        <div class="atlas-hero__suggestions animate-enter" style="--stagger: 3;" aria-label="Suggested searches">
          <span class="atlas-hero__suggestions-label">Try</span>
          {suggestions.map(q => (
            <a href={`/library/?q=${encodeURIComponent(q)}`} class="atlas-hero__suggestion">{q}</a>
          ))}
        </div>
      </div>
    </section>

    <section class="atlas animate-enter" style="--stagger: 5;" data-pagefind-ignore="all" aria-labelledby="atlas-heading">
      <div class="container">
        <header class="atlas__head">
          <h2 id="atlas-heading">Browse by topic</h2>
          <span class="atlas__head-aside">Tap a topic to filter the library</span>
        </header>

        <ul class="atlas-grid" role="list">
          {topicTiles.map(t => (
            <li>
              <a href={t.href} class={`topic-tile topic-tile--${t.accent}`} aria-label={`${t.name} — ${t.count} articles`}>
                <h3 class="topic-tile__name">
                  <span class="topic-tile__initial">{t.name.slice(0, 2)}</span>{t.name.slice(2)}
                </h3>
                <p class="topic-tile__desc">{t.desc}</p>
                <div class="topic-tile__foot">
                  <span class="topic-tile__count tabular">{t.count.toLocaleString()} articles</span>
                  <span class="topic-tile__cta" aria-hidden="true">View &rarr;</span>
                </div>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </section>

    {recent.length > 0 && (
    <section class="section" data-pagefind-ignore="all" aria-labelledby="recent-heading">
      <div class="container">
        <div class="section-header">
          <h2 id="recent-heading" class="section-label">Recently published</h2>
          <a href="/library/page/1/" class="link-arrow">View all &rarr;</a>
        </div>
        <ul class="recent-grid" role="list">
          {recent.map(a => (
            <li>
              <a
                href={`/library/${a.slug}/`}
                class="recent-card"
                data-article-card
                data-slug={a.slug}
                data-title={a.title}
              >
                {a.isOpenAccess && (
                  <span class="recent-card__oa" aria-label="Open access">
                    <svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 9.9-1"/></svg>
                    Open
                  </span>
                )}
                <h3 class="recent-card__title">{a.title}</h3>
                <div class="recent-card__meta">
                  <span class="recent-card__author">{a.authorYear}</span>
                  {a.journal && <span class="recent-card__journal">{a.journal}</span>}
                </div>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </section>
    )}

  </MaybeShell>
</BaseLayout>

<script is:inline>
  // Hide the topic atlas + recent-additions while the search dropdown is open,
  // so the user sees one affordance at a time. SearchBar.astro toggles
  // aria-expanded on the input as the dropdown opens/closes.
  (function () {
    var input = document.getElementById('search-input');
    if (!input) return;
    function apply() {
      var open = input.getAttribute('aria-expanded') === 'true';
      document.body.classList.toggle('library-searching', open);
    }
    apply();
    new MutationObserver(apply).observe(input, { attributes: true, attributeFilter: ['aria-expanded'] });
  })();
</script>

<style is:global>
  /* Smooth hide of competing affordances while search dropdown is open.
     .page-library is the body class, not a descendant -- use compound
     selectors so the rule actually matches. */
  body.page-library .atlas,
  body.page-library .section {
    transition:
      opacity 420ms cubic-bezier(0.22, 1, 0.36, 1),
      visibility 0s linear 0s;
    will-change: opacity;
  }
  body.page-library.library-searching .atlas,
  body.page-library.library-searching .section {
    opacity: 0;
    pointer-events: none;
    visibility: hidden;
    transition:
      opacity 360ms cubic-bezier(0.4, 0, 0.2, 1),
      visibility 0s linear 360ms;
  }

  /* Try pills stay visible during search -- they sit in their own row below
     the hero, so the dropdown overlays page content above them and the user
     can still see suggested queries underneath. */

  /* Search dropdown slide-in. Preserve the existing translateX(-50%) centering.
     Duration matches the atlas fade-out so the two animations feel paired. */
  body.page-library .search-results:not(:empty) {
    animation: rrm-dropdown-in 360ms cubic-bezier(0.22, 1, 0.36, 1) both;
  }
  @keyframes rrm-dropdown-in {
    from { opacity: 0; transform: translate(-50%, -8px); }
    to   { opacity: 1; transform: translate(-50%, 0); }
  }
  @media (prefers-reduced-motion: reduce) {
    body.page-library .atlas,
    body.page-library .section,
    body.page-library .search-results:not(:empty) {
      animation: none;
      transition: none;
    }
  }
</style>

<style>
  @keyframes enter {
    from {
      opacity: 0;
      transform: translateY(8px);
      filter: blur(4px);
    }
  }
  .animate-enter {
    animation: enter 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94) both;
    animation-delay: calc(100ms * var(--stagger, 0));
  }
  @media (prefers-reduced-motion: reduce) {
    .animate-enter { animation: none; }
  }

  .atlas-hero {
    padding: var(--space-12) 0 var(--space-8);
    background: radial-gradient(ellipse 80% 60% at 50% 0%, rgba(245, 240, 248, 0.6), transparent 70%);
  }
  :global([data-theme="dark"]) .atlas-hero {
    background: radial-gradient(ellipse 80% 60% at 50% 0%, rgba(46, 38, 54, 0.4), transparent 70%);
  }
  .atlas-hero__inner {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
  }
  .atlas-hero h1 {
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin: 0;
  }
  .atlas-hero__dek {
    max-width: 540px;
    margin: 0;
    color: var(--text-secondary);
    font-size: 1rem;
    line-height: 1.55;
  }
  @media (min-width: 769px) {
    .atlas-hero__dek { font-size: 1.0625rem; }
  }
  .atlas-hero__search {
    width: 100%;
    max-width: 620px;
    margin-top: var(--space-2);
    /* Stacking: pills sit LATER in DOM order than .atlas-hero__search and
       paint above by default. Give this flex item an explicit z-index so
       the dropdown inside .search-wrapper (z:10) wins over the pills row. */
    position: relative;
    z-index: 1;
  }
  .atlas-hero__suggestions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: var(--space-2);
    font-size: 0.8125rem;
    color: var(--text-tertiary);
    margin-top: var(--space-1);
  }
  .atlas-hero__suggestions-label {
    color: var(--text-secondary);
    font-weight: 600;
    margin-right: var(--space-1);
    flex-shrink: 0;
  }
  .atlas-hero__suggestion {
    padding: 4px 12px;
    border-radius: var(--radius-pill);
    border: 1px solid var(--border-color);
    background: var(--bg-surface);
    color: var(--text-secondary);
    text-decoration: none;
    font-size: 0.8125rem;
    flex-shrink: 0;
    transition: border-color 0.15s, color 0.15s, background-color 0.15s;
  }
  .atlas-hero__suggestion:hover {
    border-color: var(--accent);
    color: var(--text-primary);
    background: var(--purple-50);
    text-decoration: none;
  }
  /* Mobile: single scrolling row instead of vertical stack — keeps the strip
     under ~40px tall regardless of how many suggestions we ship. */
  @media (max-width: 639px) {
    .atlas-hero__suggestions {
      flex-wrap: nowrap;
      overflow-x: auto;
      justify-content: flex-start;
      margin-inline: calc(var(--space-4) * -1);
      padding-inline: var(--space-4);
      padding-block: var(--space-1);
      scrollbar-width: none;
      -webkit-mask-image: linear-gradient(90deg, transparent 0, #000 16px, #000 calc(100% - 24px), transparent 100%);
              mask-image: linear-gradient(90deg, transparent 0, #000 16px, #000 calc(100% - 24px), transparent 100%);
    }
    .atlas-hero__suggestions::-webkit-scrollbar { display: none; }
    .atlas-hero__suggestion { white-space: nowrap; }
  }

  .atlas {
    padding: var(--space-10) 0 var(--space-8);
  }
  .atlas__head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-bottom: var(--space-5);
  }
  .atlas__head h2 {
    font-size: 0.6875rem;
    font-family: 'Inter', sans-serif;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-secondary);
    margin: 0;
  }
  @media (min-width: 769px) {
    .atlas__head h2 { font-size: 0.75rem; }
  }
  .atlas__head-aside {
    font-size: 0.75rem;
    color: var(--text-tertiary);
  }

  .atlas-grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-3);
  }
  @media (min-width: 640px) {
    .atlas-grid { grid-template-columns: repeat(2, 1fr); gap: var(--space-4); }
  }
  @media (min-width: 1024px) {
    .atlas-grid { grid-template-columns: repeat(3, 1fr); }
  }

  .topic-tile {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    background: var(--bg-surface);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
    padding: var(--space-5);
    text-decoration: none;
    color: inherit;
    min-height: 140px;
    transition: border-color 0.15s, transform 0.15s, box-shadow 0.2s;
  }
  .topic-tile:hover {
    border-color: var(--accent);
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
    text-decoration: none;
  }
  .topic-tile:focus-visible {
    outline: 0;
    border-color: var(--purple-700);
    box-shadow: 0 0 0 3px var(--focus-ring);
  }

  .topic-tile__name {
    font-family: 'Cormorant Garamond', 'Georgia', serif;
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--text-primary);
    line-height: 1.15;
    letter-spacing: -0.01em;
    margin: 0;
  }
  /* Breaking-Bad-style inline element box: solid rounded square containing
     the first 2 letters of the topic name, sitting inside the H3 as if it
     were the literal "En" of "Endometriosis". Background tints + letter
     color follow the tile's accent variant. */
  .topic-tile__initial {
    display: inline-block;
    background: var(--purple-100);
    color: var(--accent);
    border-radius: 4px;
    padding: 0 0.12em;
    line-height: 0.95;
    vertical-align: baseline;
    margin-right: 0.04em;
  }
  .topic-tile--p .topic-tile__initial { background: var(--purple-100); color: var(--accent); }
  .topic-tile--r .topic-tile__initial { background: var(--rose-100);   color: var(--rose-700); }
  .topic-tile--g .topic-tile__initial { background: var(--sage-100);   color: var(--sage-700); }
  .topic-tile--s .topic-tile__initial { background: var(--sand-300);   color: var(--sand-700); }
  :global([data-theme="dark"]) .topic-tile--s .topic-tile__initial { color: var(--text-primary); }

  .topic-tile__desc {
    margin: 0;
    font-size: 0.875rem;
    line-height: 1.5;
    color: var(--text-secondary);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .topic-tile__foot {
    margin-top: auto;
    padding-top: var(--space-3);
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--space-3);
    border-top: 1px solid var(--border-light);
  }
  .topic-tile__count {
    font-size: 0.75rem;
    color: var(--text-tertiary);
    font-variant-numeric: tabular-nums;
  }
  .topic-tile__cta {
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--accent);
    opacity: 0;
    transform: translateX(-4px);
    transition: opacity 0.15s, transform 0.15s;
  }
  .topic-tile:hover .topic-tile__cta,
  .topic-tile:focus-visible .topic-tile__cta {
    opacity: 1;
    transform: translateX(0);
  }
  /* Mobile: don't hover-lock the CTA, and use a single tighter row */
  @media (max-width: 639px) {
    .topic-tile { padding: var(--space-4); min-height: 0; }
    .topic-tile__name { font-size: 1.25rem; }
    .topic-tile__desc { font-size: 0.8125rem; -webkit-line-clamp: 2; }
    .topic-tile__cta { opacity: 1; transform: none; }
  }

  .section-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: var(--space-4);
  }
  .section-label {
    font-size: 0.6875rem;
    font-family: 'Inter', sans-serif;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-secondary);
    margin: 0;
  }
  @media (min-width: 769px) {
    .section-label { font-size: 0.75rem; }
  }
  .link-arrow {
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--accent);
    white-space: nowrap;
  }
  .recent-grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
  }
  @media (min-width: 640px) {
    .recent-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 1024px) {
    .recent-grid { grid-template-columns: repeat(3, 1fr); }
  }

  .recent-card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    min-height: 170px;
    padding: var(--space-5);
    background: var(--bg-surface);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s, transform 0.15s, box-shadow 0.2s;
  }
  .recent-card:hover {
    border-color: var(--accent);
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
    text-decoration: none;
  }
  .recent-card:focus-visible {
    outline: 0;
    border-color: var(--purple-700);
    box-shadow: 0 0 0 3px var(--focus-ring);
  }
  .recent-card__title {
    font-family: 'Cormorant Garamond', 'Georgia', serif;
    font-size: 1.0625rem;
    font-weight: 600;
    line-height: 1.3;
    color: var(--text-primary);
    margin: 0;
    padding-right: var(--space-12); /* leave room for the OA pill */
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    transition: color 0.15s;
  }
  .recent-card:hover .recent-card__title { color: var(--accent); }
  .recent-card__meta {
    display: flex;
    flex-direction: column;
    gap: 2px;
    font-size: 0.75rem;
    line-height: 1.4;
    color: var(--text-tertiary);
    min-width: 0;
  }
  .recent-card__author {
    color: var(--text-secondary);
    font-weight: 500;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    font-variant-numeric: tabular-nums;
  }
  .recent-card__journal {
    font-style: italic;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .recent-card__oa {
    position: absolute;
    top: var(--space-3);
    right: var(--space-3);
    display: inline-flex;
