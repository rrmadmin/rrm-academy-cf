---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SearchBar from '../../components/SearchBar.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { fetchAllArticles, getTopicCounts } from '../../lib/airtable';

const articles = await fetchAllArticles();
const topicCounts = getTopicCounts(articles);

// Sort topics by count (descending), take top 30
const topTopics = [...topicCounts.entries()]
  .sort((a, b) => b[1] - a[1])
  .slice(0, 30);

// Split: top 6 featured, next 12 visible, rest hidden
const featuredTopics = topTopics.slice(0, 6);
const visiblePills = topTopics.slice(6, 18);
const hiddenPills = topTopics.slice(18);

// Recent additions (first 6, already sorted by date)
const recent = articles.slice(0, 6);

// Pagination for full browse
const PER_PAGE = 50;
const totalPages = Math.ceil(articles.length / PER_PAGE);

// Schema.org for landing page
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'RRM Research Library',
  description: 'The largest free collection of academic references related to restorative reproductive medicine.',
  url: 'https://rrmacademy.org/library',
  numberOfItems: articles.length,
  isPartOf: {
    '@type': 'WebSite',
    name: 'RRM Academy',
    url: 'https://rrmacademy.org',
    potentialAction: {
      '@type': 'SearchAction',
      target: {
        '@type': 'EntryPoint',
        urlTemplate: 'https://rrmacademy.org/library?q={search_term_string}',
      },
      'query-input': 'required name=search_term_string',
    },
  },
  publisher: {
    '@type': 'Organization',
    name: 'RRM Academy',
    url: 'https://rrmacademy.org',
  },
};
---
<BaseLayout
  title="RRM Research Library"
  description={`Browse ${articles.length.toLocaleString()} peer-reviewed articles on restorative reproductive medicine. Free access to abstracts, citations, and full-text links.`}
  canonicalUrl="https://rrmacademy.org/library"
  jsonLd={jsonLd}
>
  <!-- Hero — full-viewport, search-first, Grokipedia-inspired -->
  <section class="hero" data-pagefind-ignore="all">
    <div class="hero__center">
      <h1>Research Library</h1>
      <div class="hero__search">
        <SearchBar />
      </div>
      <p class="hero__count">
        <span class="hero__count-label">Articles Available</span>
        <span class="hero__count-number">{articles.length.toLocaleString()}</span>
      </p>
    </div>
    <div class="hero__scroll" aria-hidden="true">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
    </div>
  </section>

  <!-- Browse by Topic -->
  <section class="section" data-pagefind-ignore="all">
    <div class="container">
      <h2 class="section-label">Browse by topic</h2>
      <div class="featured-topics">
        {featuredTopics.map(([topic, count]) => (
          <a href={`/library?topic=${encodeURIComponent(topic)}`} class="featured-topic">
            <span class="featured-topic__name">{topic}</span>
            <span class="featured-topic__count">{count}</span>
          </a>
        ))}
      </div>
      <div class="topic-grid" id="topic-grid">
        {visiblePills.map(([topic, count]) => (
          <a
            href={`/library?topic=${encodeURIComponent(topic)}`}
            class="topic-pill"
          >
            {topic} <span class="topic-count">({count})</span>
          </a>
        ))}
        {hiddenPills.map(([topic, count]) => (
          <a
            href={`/library?topic=${encodeURIComponent(topic)}`}
            class="topic-pill topic-pill--hidden"
          >
            {topic} <span class="topic-count">({count})</span>
          </a>
        ))}
      </div>
      {hiddenPills.length > 0 && (
        <button class="show-more-btn" id="show-more-topics">
          + {hiddenPills.length} more
        </button>
      )}
    </div>
  </section>

  <hr class="divider" />

  <!-- Recent Additions -->
  <section class="section" data-pagefind-ignore="all">
    <div class="container">
      <div class="section-header">
        <h2 class="section-label">Recent additions</h2>
        <a href="/library/page/1" class="link-arrow">View all &rarr;</a>
      </div>
      <div class="recent-grid">
        {recent.map(article => (
          <ArticleCard article={article} />
        ))}
      </div>
    </div>
  </section>

  <hr class="divider" />

  <!-- Browse All -->
  <section class="section" id="browse" data-pagefind-ignore="all">
    <div class="container">
      <div class="section-header">
        <h2 class="section-label">All articles</h2>
        <span class="meta-count">{articles.length.toLocaleString()} articles</span>
      </div>
      <div class="article-grid" id="article-list">
        {articles.slice(0, PER_PAGE).map(article => (
          <ArticleCard article={article} compact />
        ))}
      </div>

      {totalPages > 1 && (
        <nav class="pagination" aria-label="Pagination">
          <span class="current">1</span>
          {totalPages >= 2 && <a href="/library/page/2">2</a>}
          {totalPages >= 3 && <a href="/library/page/3">3</a>}
          {totalPages > 3 && <span class="ellipsis">&hellip;</span>}
          {totalPages > 3 && <a href={`/library/page/${totalPages}`}>{totalPages}</a>}
          <a href="/library/page/2">Next &raquo;</a>
        </nav>
      )}
    </div>
  </section>
</BaseLayout>

<style>
  /* Hero — full-viewport, centered, Grokipedia-inspired */
  .hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    position: relative;
    padding: var(--space-8) var(--space-4);
  }
  .hero__center {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    width: 100%;
    max-width: 600px;
    gap: var(--space-5);
  }
  .hero h1 {
    font-size: 2.5rem;
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin: 0;
  }
  .hero__search {
    width: 100%;
  }
  .hero__count {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-1);
    margin-top: var(--space-4);
  }
  .hero__count-label {
    font-size: 0.6875rem;
    font-family: 'Inter', sans-serif;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-tertiary);
  }
  .hero__count-number {
    font-family: 'Cormorant Garamond', 'Georgia', serif;
    font-size: 1.75rem;
    font-weight: 600;
    color: var(--text-secondary);
    letter-spacing: 0.04em;
  }
  .hero__scroll {
    position: absolute;
    bottom: var(--space-8);
    color: var(--text-muted);
    animation: gentle-bounce 2.5s ease-in-out infinite;
  }
  @keyframes gentle-bounce {
    0%, 100% { transform: translateY(0); opacity: 0.4; }
    50% { transform: translateY(6px); opacity: 0.8; }
  }

  @media (min-width: 769px) {
    .hero h1 {
      font-size: 3.5rem;
    }
    .hero__center {
      max-width: 640px;
    }
    .hero__count-number {
      font-size: 2.25rem;
    }
  }
  @media (max-width: 768px) {
    .hero {
      min-height: 85vh;
    }
  }

  /* Section labels — understated */
  .section-label {
    font-size: 0.6875rem;
    font-family: 'Inter', sans-serif;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-tertiary);
    margin-bottom: var(--space-4);
  }
  @media (min-width: 769px) {
    .section-label {
      font-size: 0.75rem;
      margin-bottom: var(--space-5);
    }
  }

  /* Section header row */
  .section-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-3);
  }
  .section-header .section-label {
    margin-bottom: var(--space-4);
  }
  .link-arrow {
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--accent);
    white-space: nowrap;
  }
  .meta-count {
    font-size: 0.75rem;
    color: var(--text-tertiary);
    white-space: nowrap;
  }

  /* Divider between sections */
  .divider {
    border: none;
    border-top: 1px solid var(--border-color);
    margin: 0 auto;
    max-width: var(--max-width-page);
    padding: 0 var(--space-6);
  }

  /* Featured topics — clean list, not cards */
  .featured-topics {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
    margin-bottom: var(--space-4);
  }
  .featured-topic {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    padding: var(--space-3) 0;
    border-bottom: 1px solid var(--border-light);
    text-decoration: none;
    transition: color 0.15s;
  }
  .featured-topic:first-child {
    padding-top: 0;
  }
  .featured-topic:last-child {
    border-bottom: none;
  }
  .featured-topic:hover {
    text-decoration: none;
  }
  .featured-topic:hover .featured-topic__name {
    color: var(--accent);
  }
  .featured-topic__name {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text-primary);
    line-height: 1.4;
    transition: color 0.15s;
  }
  .featured-topic__count {
    font-size: 0.6875rem;
    color: var(--text-muted);
    font-variant-numeric: tabular-nums;
    flex-shrink: 0;
    margin-left: var(--space-3);
  }

  @media (min-width: 769px) {
    .featured-topics {
      grid-template-columns: repeat(2, 1fr);
      column-gap: var(--space-12);
    }
    .featured-topic {
      padding: var(--space-3) 0;
    }
    .featured-topic:first-child,
    .featured-topic:nth-child(2) {
      padding-top: 0;
    }
    /* Remove border from last items in each column */
    .featured-topic:nth-child(3):last-child,
    .featured-topic:last-child {
      border-bottom: none;
    }
    .featured-topic__name {
      font-size: 0.9375rem;
    }
  }

  /* Topic pills — smaller, tighter */
  .topic-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .topic-pill--hidden {
    display: none;
  }
  .topic-grid.expanded .topic-pill--hidden {
    display: inline-block;
  }
  .topic-count {
    font-size: 0.625rem;
    color: var(--text-muted);
  }

  .show-more-btn {
    display: inline-block;
    margin-top: var(--space-3);
    font-size: 0.6875rem;
    font-weight: 500;
    color: var(--text-tertiary);
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
  }
  .show-more-btn:hover {
    color: var(--accent);
  }
  .show-more-btn.expanded {
    display: none;
  }

  /* Recent grid */
  .recent-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-5);
  }
  @media (min-width: 640px) {
    .recent-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 1024px) {
    .recent-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: var(--space-6);
    }
  }
</style>

<script is:inline>
  var btn = document.getElementById('show-more-topics');
  var grid = document.getElementById('topic-grid');
  if (btn && grid) {
    btn.addEventListener('click', function() {
      grid.classList.add('expanded');
      btn.classList.add('expanded');
    });
  }
</script>
