---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Citation from '../../components/Citation.astro';
import TopicTag from '../../components/TopicTag.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import LibraryFundingCallout from '../../components/LibraryFundingCallout.astro';
import { fetchAllArticles, getRelatedArticles, type Article } from '../../lib/airtable';
import { parseStructuredAbstract } from '../../lib/abstract-parser';

export async function getStaticPaths() {
  const articles = await fetchAllArticles();

  return articles.map(article => ({
    params: { slug: article.slug },
    props: { article, allArticles: articles },
  }));
}

interface Props {
  article: Article;
  allArticles: Article[];
}

const { article, allArticles } = Astro.props;
const related = getRelatedArticles(article, allArticles, 4);
const abstractSections = parseStructuredAbstract(article.abstract);

// Build journal citation line
const journalParts: string[] = [];
if (article.journal) journalParts.push(article.journal);
if (article.volume) {
  let vol = article.volume;
  if (article.issue) vol += `(${article.issue})`;
  journalParts.push(vol);
}
if (article.pages) journalParts.push(article.pages);
const journalLine = journalParts.join(', ');

// Build description for meta
const metaDescription = article.abstract
  ? article.abstract.slice(0, 155) + (article.abstract.length > 155 ? '...' : '')
  : `${article.title} - RRM Research Library`;

// Build DOI URL
const doiUrl = article.doi ? `https://doi.org/${article.doi}` : '';
const pubmedUrl = article.pmid ? `https://pubmed.ncbi.nlm.nih.gov/${article.pmid}/` : '';

// Parse pages for schema
const pageMatch = article.pages?.match(/^(\d+)\s*[-–]\s*(\d+)$/);
const pageStart = pageMatch ? pageMatch[1] : article.pages || undefined;
const pageEnd = pageMatch ? pageMatch[2] : undefined;

// Schema.org JSON-LD
const jsonLd: any = {
  '@context': 'https://schema.org',
  '@type': 'MedicalScholarlyArticle',
  name: article.title,
  url: `https://rrmacademy.org/library/${article.slug}/`,
  publisher: {
    '@type': 'Organization',
    name: 'RRM Academy',
    url: 'https://rrmacademy.org',
  },
};

// Build Person JSON-LD per author. Prefer structured authorRecords (D1-backed:
// includes ORCID sameAs and affiliation with ROR) when available; fall back to
// the legacy comma-separated authors string for any article without enrichment.
//
// Dedup: the authors table still has pre-enrichment rows alongside the newly
// enriched ones for some articles (2,515 open dedup_flags as of 2026-04-18).
// Collapse duplicates here so JSON-LD doesn't emit the same person twice.
const authorRecordsRaw = Array.isArray(article.authorRecords) ? article.authorRecords : [];

function orcidUrl(orcid: string | null | undefined): string | null {
  if (!orcid) return null;
  const clean = String(orcid).trim();
  if (!/^\d{4}-\d{4}-\d{4}-\d{3}[\dX]$/i.test(clean)) return null;
  return `https://orcid.org/${clean.toUpperCase()}`;
}

// Dedup key: lastname + first-initial. Tolerates middle-initial variations
// ("Lauren Wise" vs "Lauren A Wise" both produce "wise l"), which is the
// dominant legacy-vs-enriched collision shape. Collisions on this key are
// only acted on when one side has an ORCID, so false positives are safe.
function nameKey(fullName: string | null | undefined): string {
  if (!fullName) return '';
  const n = String(fullName)
    .toLowerCase()
    .normalize('NFKD').replace(/[\u0300-\u036f]/g, '')
    .replace(/[.,]/g, '')
    .replace(/\s+/g, ' ')
    .trim();
  const parts = n.split(' ').filter(Boolean);
  if (parts.length === 0) return '';
  if (parts.length === 1) return parts[0];
  const last = parts[parts.length - 1];
  const firstInitial = parts[0][0] || '';
  return `${last} ${firstInitial}`;
}

type AuthorRec = typeof authorRecordsRaw[number];

function dedupeAuthorRecords(records: AuthorRec[]): AuthorRec[] {
  // Pass 1: collapse by ORCID. When multiple records share an ORCID, keep the
  // one with the richest affiliation data.
  const byOrcid = new Map<string, AuthorRec>();
  const noOrcid: AuthorRec[] = [];
  for (const r of records) {
    if (r.orcid) {
      const prev = byOrcid.get(r.orcid);
      if (!prev) { byOrcid.set(r.orcid, r); continue; }
      const prevScore = (prev.primary_ror_id ? 2 : 0) + (prev.primary_institution_name ? 1 : 0);
      const nextScore = (r.primary_ror_id ? 2 : 0) + (r.primary_institution_name ? 1 : 0);
      if (nextScore > prevScore) byOrcid.set(r.orcid, r);
    } else {
      noOrcid.push(r);
    }
  }
  // Pass 2: among no-ORCID entries, drop any whose nameKey is already covered
  // by an ORCID-bearing record (legacy duplicate of an enriched author).
  const orcidNameKeys = new Set([...byOrcid.values()].map(r => nameKey(r.full_name || r.name)));
  const seenNoOrcidKey = new Set<string>();
  const keptNoOrcid: AuthorRec[] = [];
  for (const r of noOrcid) {
    const key = nameKey(r.full_name || r.name);
    if (key && orcidNameKeys.has(key)) continue;
    if (key && seenNoOrcidKey.has(key)) continue;
    if (key) seenNoOrcidKey.add(key);
    keptNoOrcid.push(r);
  }
  return [...byOrcid.values(), ...keptNoOrcid];
}

// Cap affiliation name length: raw PubMed affiliations can include the entire
// authors-affiliations block ("Authors' Affiliations: 1Slone ...") which is
// hundreds of chars and not a valid organization name.
function cleanAffiliationName(raw: string | null | undefined): string | null {
  if (!raw) return null;
  const s = String(raw).trim();
  if (!s) return null;
  if (s.length <= 200) return s;
  return s.slice(0, 197) + '...';
}

function personFromRecord(rec: AuthorRec) {
  const person: any = {
    '@type': 'Person',
    name: rec.full_name || rec.name,
  };
  const orcid = orcidUrl(rec.orcid);
  if (orcid) person.sameAs = orcid;
  const institutionName = cleanAffiliationName(rec.primary_institution_name);
  const fallbackAff = cleanAffiliationName(rec.affiliation);
  if (institutionName) {
    const org: any = { '@type': 'Organization', name: institutionName };
    if (rec.primary_ror_id) org.sameAs = rec.primary_ror_id;
    person.affiliation = org;
  } else if (fallbackAff) {
    person.affiliation = { '@type': 'Organization', name: fallbackAff };
  }
  return person;
}

const authorRecords = dedupeAuthorRecords(authorRecordsRaw);
const AUTHOR_CAP = 20;

if (authorRecords.length > AUTHOR_CAP) {
  // Consortium / mega-paper: emit single Organization using the legacy authors
  // string (which for these papers is the consortium name, e.g. "GBD 2023 ...
  // Collaborators"). Emitting thousands of Person entries bloats HTML and
  // Google's JSON-LD parser caps usefulness well below that anyway.
  jsonLd.author = article.authors
    ? [{ '@type': 'Organization', name: article.authors.trim() }]
    : [{ '@type': 'Organization', name: 'Consortium Authors' }];
} else if (authorRecords.length > 0) {
  jsonLd.author = authorRecords.map(personFromRecord);
} else if (article.authors) {
  jsonLd.author = article.authors.split(',').map(name => ({
    '@type': 'Person',
    name: name.trim(),
  }));
}

if (article.datePublished) {
  jsonLd.datePublished = article.datePublished;
}

if (article.abstract) {
  jsonLd.abstract = article.abstract;
}

if (article.journal) {
  const isPartOf: any = {
    '@type': 'Periodical',
    name: article.journal,
  };

  if (article.volume) {
    jsonLd.isPartOf = {
      '@type': 'PublicationVolume',
      volumeNumber: article.volume,
      isPartOf: article.issue
        ? { '@type': 'PublicationIssue', issueNumber: article.issue, isPartOf: isPartOf }
        : isPartOf,
    };
  } else {
    jsonLd.isPartOf = isPartOf;
  }
}

if (pageStart) jsonLd.pageStart = pageStart;
if (pageEnd) jsonLd.pageEnd = pageEnd;

const identifiers: any[] = [];
if (article.doi) {
  identifiers.push({ '@type': 'PropertyValue', propertyID: 'doi', value: article.doi });
  jsonLd.sameAs = doiUrl;
}
if (article.pmid) {
  identifiers.push({ '@type': 'PropertyValue', propertyID: 'PMID', value: article.pmid });
}
if (identifiers.length) jsonLd.identifier = identifiers;

// OA metadata
if (article.accessLevel === 'open' || article.accessLevel === 'free') {
  jsonLd.isAccessibleForFree = true;
} else {
  jsonLd.isAccessibleForFree = false;
}

// License URL
const LICENSE_URLS: Record<string, string> = {
  'CC-BY': 'https://creativecommons.org/licenses/by/4.0/',
  'CC-BY-SA': 'https://creativecommons.org/licenses/by-sa/4.0/',
  'CC-BY-NC': 'https://creativecommons.org/licenses/by-nc/4.0/',
  'CC-BY-NC-SA': 'https://creativecommons.org/licenses/by-nc-sa/4.0/',
  'CC-BY-ND': 'https://creativecommons.org/licenses/by-nd/4.0/',
  'CC-BY-NC-ND': 'https://creativecommons.org/licenses/by-nc-nd/4.0/',
  'CC0': 'https://creativecommons.org/publicdomain/zero/1.0/',
};
if (article.license && LICENSE_URLS[article.license]) {
  jsonLd.license = LICENSE_URLS[article.license];
}

// Source link when there's no DOI, or when sourceUrl differs from the DOI link (dead DOI fallback)
const showSourceLink = article.sourceUrl && (!article.doi || article.sourceUrl !== `https://doi.org/${article.doi}`);
// Free full text only when oaUrl differs from both sourceUrl and DOI
const showFreeFullText = article.oaUrl
  && article.oaUrl !== article.sourceUrl
  && article.oaUrl !== (article.doi ? `https://doi.org/${article.doi}` : '');

const canonicalUrl = `https://rrmacademy.org/library/${article.slug}/`;

// Highwire Press citation meta for Zotero Connector
const citationAuthors = article.authors?.split(';').map(a => a.trim()).filter(Boolean) || [];
const citationDate = article.datePublished?.split('T')[0]?.replace(/-/g, '/') || (article.year ? String(article.year) : undefined);
// Parse pages broadly for Highwire (handles S42-S48, e123-e130, etc.)
const hwPages = article.pages?.split(/[-–]/).map(p => p.trim()) || [];
const citationMeta = {
  title: article.title,
  authors: citationAuthors,
  date: citationDate,
  journal: article.journal || undefined,
  journalAbbrev: article.journalAbbv || undefined,
  volume: article.volume || undefined,
  issue: article.issue || undefined,
  firstPage: hwPages[0] || undefined,
  lastPage: hwPages[1] || undefined,
  doi: article.doi || undefined,
  pmid: article.pmid || undefined,
  abstract: article.abstract || undefined,
  keywords: article.topics.length > 0 ? article.topics.join('; ') : undefined,
};
---
<BaseLayout
  bodyClass="page-library page-library-article page-synopsis"
  title={article.title}
  description={metaDescription}
  canonicalUrl={canonicalUrl}
  ogType="article"
  jsonLd={jsonLd}
  citationMeta={citationMeta}
>
  <div class="page-wrapper" data-pagefind-body>
    <span data-pagefind-meta="type:Research" style="display:none"></span>
    {article.rrmRelevance && <span data-pagefind-meta={`rrmRelevance:${article.rrmRelevance}`} style="display:none"></span>}
    {article.sentiment && <span data-pagefind-meta={`sentiment:${article.sentiment}`} style="display:none"></span>}
    <div class="container container--narrow">
      <!-- Breadcrumb + Save -->
      <div class="article-topbar" data-pagefind-ignore>
        <nav class="breadcrumb" aria-label="Breadcrumb">
          <a href="/library/">Research Library</a>
          <span aria-hidden="true"> &rsaquo; </span>
          <span>Synopsis</span>
        </nav>
        <div class="topbar-actions">
          <button
            class="action-btn"
            id="share-btn"
            aria-label="Copy link"
            title="Copy link"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 17 5-5-5-5"/><path d="M4 18v-2a4 4 0 0 1 4-4h12"/></svg>
            <span class="action-label" id="share-label"></span>
          </button>
          <button
            class="action-btn"
            id="cite-btn"
            aria-label="Download citation"
            title="Download citation (.RIS)"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            <span class="action-label" id="cite-label"></span>
          </button>
          <button
            class="action-btn"
            id="save-btn"
            aria-label="Save article"
            data-slug={article.slug}
            data-title={article.title}
            data-authors={article.shortCitation || ''}
            data-journal={article.journal || article.journalAbbv || ''}
            data-journal-abbv={article.journalAbbv || ''}
            data-year={article.year || ''}
            data-doi={article.doi || ''}
            data-pmid={article.pmid || ''}
            data-volume={article.volume || ''}
            data-issue={article.issue || ''}
            data-pages={article.pages || ''}
            data-date-published={article.datePublished || ''}
            data-abstract={article.abstract || ''}
            data-topics={article.topics.join(';')}
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/></svg>
            <span class="action-label" id="save-label"></span>
          </button>
        </div>
      </div>

      <!-- Title -->
      <h1 class="article-title" data-pagefind-weight="10" data-pagefind-meta="title">{article.title}</h1>

      <!-- Authors + access icon -->
      <div class="article-meta-row">
        {article.shortCitation ? (
          <p class="short-citation" data-pagefind-weight="5" data-pagefind-meta="authors">{article.shortCitation}</p>
        ) : article.authors ? (
          <p class="short-citation" data-pagefind-weight="5" data-pagefind-meta="authors">{article.authors}</p>
        ) : null}
        {article.accessLevel === 'open' && (
          <span class="access-badge access-badge--open" title={article.oaType ? `${article.oaType} Open Access` : 'Open Access'}>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 9.9-1"/></svg>
            Open Access
          </span>
        )}
        {article.accessLevel === 'free' && (
          <span class="access-badge access-badge--free" title="Free to Read (Bronze OA)">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 9.9-1"/></svg>
            Free to Read
          </span>
        )}
        {article.accessLevel === 'restricted' && article.isCopyrighted && (
          <span class="access-badge access-badge--restricted" title="Restricted">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
          </span>
        )}
        {(article.sentiment === 'hostile' || article.sentiment === 'critical') && (
          <span class={`access-badge access-badge--${article.sentiment === 'hostile' ? 'hostile' : 'critical'}`}
            title={article.sentiment === 'hostile'
              ? 'This article is hostile or in bad faith toward restorative reproductive medicine'
              : 'This article is critical or opposed to restorative reproductive medicine'}>
            {article.sentiment === 'hostile' ? 'Hostile' : 'Critical'}
          </span>
        )}
      </div>
      {article.year && (
        <span data-pagefind-meta={`year:${article.year}`} style="display:none"></span>
      )}

      <!-- Journal citation line -->
      {journalLine && (
        <p class="journal-line" data-pagefind-weight="2">{journalLine}</p>
      )}

      <!-- Identifiers & links -->
      <div class="article-ids" data-pagefind-ignore>
        {article.doi && (
          <span class="article-id">
            <span class="article-id__label">DOI</span>
            <a href={doiUrl} class="article-id__value" target="_blank" rel="noopener">{article.doi}</a>
          </span>
        )}
        {article.pmid && (
          <span class="article-id">
            <span class="article-id__label">PMID</span>
            <a href={pubmedUrl} class="article-id__value" target="_blank" rel="noopener">{article.pmid}</a>
          </span>
        )}
        {article.license && (
          <span class="article-id">
            <span class="article-id__label">License</span>
            <span class="article-id__license">{article.license}</span>
          </span>
        )}
        {showSourceLink && (
          <a href={article.sourceUrl} class="external-link" target="_blank" rel="noopener">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
            Source
          </a>
        )}
        {showFreeFullText && (
          <a href={article.oaUrl} class="external-link" target="_blank" rel="noopener">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
            Free full text
          </a>
        )}
      </div>

      <!-- Synopsis (above abstract for SEO/AEO -- structured, citable content first) -->
      {article.insights && (
        <section class="article-insights" aria-label="Synopsis">
          <h2 class="detail-heading">Synopsis</h2>
          <div class="insights-tldr">
            <p>{article.insights.tldr}</p>
          </div>
          {article.insights.key_findings && article.insights.key_findings.length > 0 && (
            <div class="insights-findings">
              <h3 class="insights-subheading">Key Findings</h3>
              <ul>
                {article.insights.key_findings.map(finding => (
                  <li>{finding}</li>
                ))}
              </ul>
            </div>
          )}
          {article.insights.clinical_implications && (
            <div class="insights-relevance">
              <h3 class="insights-subheading">Clinical Implications</h3>
              <p>{article.insights.clinical_implications}</p>
            </div>
          )}
          {article.insights.rrm_context && (
            <div class="insights-context">
              <h3 class="insights-subheading">RRM Context</h3>
              <p>{article.insights.rrm_context}</p>
            </div>
          )}
        </section>
      )}

      <!-- Abstract -->
      <section class="abstract" aria-label="Abstract">
        <h2 class="detail-heading">Abstract</h2>
        {abstractSections.length === 0 ? (
          <p class="abstract-empty">No abstract available for this article.</p>
        ) : (
          abstractSections.map(section => (
            <div class="abstract-section">
              {section.heading && (
                <span class="abstract-heading">{section.heading}</span>
              )}
              {section.text.split(/\n/).filter(p => p.trim()).map(para => (
                <p>{para.trim()}</p>
              ))}
            </div>
          ))
        )}
      </section>

      <!-- Topics -->
      {article.topics.length > 0 && (
        <section class="article-topics" aria-label="Topics">
          <h2 class="detail-heading">Topics</h2>
          <div class="topic-grid" data-pagefind-weight="3">
            {article.topics.map(topic => (
              <TopicTag topic={topic} />
            ))}
          </div>
        </section>
      )}

      {article.searchTerms.length > 0 && (
        <div data-pagefind-weight="4" style="position:absolute;width:1px;height:1px;overflow:hidden;clip:rect(0,0,0,0)">
          {article.searchTerms.join(', ')}
        </div>
      )}

      {(article.pmid || article.doi) && (
        <div data-pagefind-weight="10" style="position:absolute;width:1px;height:1px;overflow:hidden;clip:rect(0,0,0,0)">
          {article.pmid && `PMID ${article.pmid} ${article.pmid}`}
          {article.doi && `DOI ${article.doi} ${article.doi}`}
        </div>
      )}

      <!-- Citations -->
      {(article.apaCitation || article.vancouverCitation || article.mlaCitation) && (
        <section class="article-citations" aria-label="Citations" data-pagefind-ignore="all">
          <h2 class="detail-heading">Cite this article</h2>
          <Citation
            apa={article.apaCitation}
            vancouver={article.vancouverCitation}
            mla={article.mlaCitation}
          />
        </section>
      )}

      <!-- Keywords -->
      {article.keywords && (
        <section class="article-keywords" aria-label="Keywords">
          <h2 class="detail-heading">Keywords</h2>
          <p class="keywords-text">{article.keywords}</p>
        </section>
      )}

      <!-- Funding callout -->
      <LibraryFundingCallout />

      <!-- Related articles -->
      {related.length > 0 && (
        <section class="article-related" aria-label="Related articles" data-pagefind-ignore="all">
          <h2 class="detail-heading">Related articles</h2>
          <div class="related-grid">
            {related.map(rel => (
              <ArticleCard article={rel} />
            ))}
          </div>
        </section>
      )}
    </div>
  </div>
</BaseLayout>

<style>
  .article-title {
    font-size: 1.875rem;
    margin-bottom: var(--space-4);
    line-height: 1.25;
    letter-spacing: -0.015em;
  }
  .article-meta-row {
    display: flex;
    align-items: baseline;
    gap: var(--space-2);
    margin-bottom: var(--space-3);
  }
  .article-meta-row .access-badge {
    align-self: center;
    position: relative;
    top: -1px;
  }
  .short-citation {
    font-size: 0.875rem;
    color: var(--neutral-600);
    font-weight: 500;
    margin: 0;
  }
  .article-authors {
    font-size: 0.875rem;
    color: var(--neutral-700);
    line-height: 1.6;
    margin-bottom: var(--space-2);
  }
  .journal-line {
    font-family: 'Cormorant Garamond', 'Georgia', serif;
    font-size: 0.9375rem;
    color: var(--neutral-600);
    font-style: italic;
    margin-bottom: var(--space-5);
  }
  .article-ids {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: var(--space-2) var(--space-5);
    margin-bottom: var(--space-6);
    font-size: 0.8125rem;
  }
  .article-id {
    display: inline-flex;
    align-items: baseline;
    gap: var(--space-1);
  }
  .article-id__label {
    font-size: 0.6875rem;
    font-weight: 600;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }
  .article-id__value {
    color: var(--text-secondary);
    text-decoration: none;
    transition: color 0.15s;
  }
  .article-id__value:hover {
    color: var(--accent);
    text-decoration: underline;
  }
  .article-id__license {
    color: var(--neutral-600);
    font-size: 0.8125rem;
  }
  .external-link {
    font-size: 0.8125rem;
  }

  .abstract {
    background: transparent;
    border: none;
    border-top: 1px solid var(--border-light, var(--border-color));
    border-radius: 0;
