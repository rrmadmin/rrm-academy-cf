---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Citation from '../../components/Citation.astro';
import TopicTag from '../../components/TopicTag.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import ArticleHero from '../../components/ArticleHero.astro';
import LibraryFundingCallout from '../../components/LibraryFundingCallout.astro';
import AppShellChrome from '../../components/AppShellChrome.astro';
import AppShellSheet from '../../components/AppShellSheet.astro';
import { isShellEnabled } from '../../lib/shell-routes';
import { fetchAllArticles, getRelatedArticles, getArticlesByAuthor, type Article } from '../../lib/airtable';
import { parseStructuredAbstract } from '../../lib/abstract-parser';
import { parseMarkdown, looksLikeMarkdown } from '../../lib/markdown-sanitize';
import { buildMedicalScholarlyArticle, buildBreadcrumbList } from '../../lib/identity';

const SHELL_ENABLED = isShellEnabled('library');

export async function getStaticPaths() {
  const articles = await fetchAllArticles();

  return articles.map(article => ({
    params: { slug: article.slug },
    props: { article, allArticles: articles },
  }));
}

interface Props {
  article: Article;
  allArticles: Article[];
}

const { article, allArticles } = Astro.props;
const related = getRelatedArticles(article, allArticles, 4);

// Server-rendered related-content sections for the right rail (app shell).
// Topics → filter URLs; By this author → matched articles; Related research →
// the same multi-signal scoring used in the article body. Only sections with
// items render — prevents empty headings.
const byAuthor = getArticlesByAuthor(article, allArticles, 4);
const byAuthorIds = new Set(byAuthor.map((a) => a.id));
const relatedDeduped = related.filter((a) => !byAuthorIds.has(a.id));
// Defensive normalisation: strip CR/LF/TAB + collapse whitespace
// before URL-encoding the topic. Mirrors TopicTag.astro's cleanTopic
// pattern -- Bucket G of the 2026-05-20 GSC coverage plan tracked a
// `?topic=...%3E \nFecundability` URL whose source was untraceable in
// the current data; the strip closes the regression class.
const sanitizeTopic = (s: string) =>
  s.replace(/[\r\n\t]+/g, ' ').replace(/\s+/g, ' ').trim();
const relatedSections = [
  {
    heading: 'Topics',
    items: (article.topics || []).slice(0, 6).map((t) => ({
      href: `/library/?topic=${encodeURIComponent(sanitizeTopic(t))}`,
      label: t,
    })),
  },
  {
    heading: 'By this author',
    items: byAuthor.map((a) => ({
      href: `/library/${a.slug}/`,
      label: a.title,
    })),
  },
  {
    heading: 'Related research',
    items: relatedDeduped.map((a) => ({
      href: `/library/${a.slug}/`,
      label: a.title,
    })),
  },
].filter((s) => s.items.length > 0);
const abstractSections = parseStructuredAbstract(article.abstract);
const renderedAbstractSections = await Promise.all(
  abstractSections.map(async (section) => ({
    heading: section.heading,
    html: looksLikeMarkdown(section.text)
      ? await parseMarkdown(section.text)
      : section.text
          .split(/\n\s*\n/)
          .map((p) => p.replace(/\s+/g, ' ').trim())
          .filter(Boolean)
          .map((p) => `<p>${p.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')}</p>`)
          .join(''),
  }))
);

// Build journal citation line
const journalParts: string[] = [];
if (article.journal) journalParts.push(article.journal);
if (article.volume) {
  let vol = article.volume;
  if (article.issue) vol += `(${article.issue})`;
  journalParts.push(vol);
}
if (article.pages) journalParts.push(article.pages);
if (article.year) journalParts.push(String(article.year));
const journalLine = journalParts.join(', ');

// Build description for meta
const metaDescription = article.abstract
  ? article.abstract.slice(0, 155) + (article.abstract.length > 155 ? '...' : '')
  : `${article.title} - RRM Research Library`;

// Build DOI URL
const doiUrl = article.doi ? `https://doi.org/${article.doi}` : '';
const pubmedUrl = article.pmid ? `https://pubmed.ncbi.nlm.nih.gov/${article.pmid}/` : '';

// Schema.org JSON-LD — delegated to buildMedicalScholarlyArticle (Phase 7).
// Helpers below (orcidUrl, nameKey, dedupeAuthorRecords, cleanAffiliationName,
// uniqueAffiliations) remain because the visible markup still depends on them.
const articleSchemaRaw = buildMedicalScholarlyArticle(article) as Record<string, unknown>;
const breadcrumbRaw = buildBreadcrumbList([
  { name: 'Home', url: 'https://rrmacademy.org/' },
  { name: 'Research Library', url: 'https://rrmacademy.org/library/' },
  { name: article.title, url: `https://rrmacademy.org/library/${article.slug}/` },
]) as Record<string, unknown>;
const { '@context': _articleCtx, ...articleNode } = articleSchemaRaw;
const { '@context': _bcCtx, ...breadcrumbNode } = breadcrumbRaw;
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [articleNode, breadcrumbNode],
};

// Build Person JSON-LD per author. Prefer structured authorRecords (D1-backed:
// includes ORCID sameAs and affiliation with ROR) when available; fall back to
// the legacy comma-separated authors string for any article without enrichment.
//
// Dedup: the authors table still has pre-enrichment rows alongside the newly
// enriched ones for some articles (2,515 open dedup_flags as of 2026-04-18).
// Collapse duplicates here so JSON-LD doesn't emit the same person twice.
const authorRecordsRaw = Array.isArray(article.authorRecords) ? article.authorRecords : [];

function orcidUrl(orcid: string | null | undefined): string | null {
  if (!orcid) return null;
  const clean = String(orcid).trim();
  if (!/^\d{4}-\d{4}-\d{4}-\d{3}[\dX]$/i.test(clean)) return null;
  return `https://orcid.org/${clean.toUpperCase()}`;
}

// Dedup key: lastname + first-initial. Tolerates middle-initial variations
// ("Lauren Wise" vs "Lauren A Wise" both produce "wise l"), which is the
// dominant legacy-vs-enriched collision shape. Collisions on this key are
// only acted on when one side has an ORCID, so false positives are safe.
function nameKey(fullName: string | null | undefined): string {
  if (!fullName) return '';
  const n = String(fullName)
    .toLowerCase()
    .normalize('NFKD').replace(/[\u0300-\u036f]/g, '')
    .replace(/[.,]/g, '')
    .replace(/\s+/g, ' ')
    .trim();
  const parts = n.split(' ').filter(Boolean);
  if (parts.length === 0) return '';
  if (parts.length === 1) return parts[0];
  const last = parts[parts.length - 1];
  const firstInitial = parts[0][0] || '';
  return `${last} ${firstInitial}`;
}

type AuthorRec = typeof authorRecordsRaw[number];

function dedupeAuthorRecords(records: AuthorRec[]): AuthorRec[] {
  // Pass 1: collapse by ORCID. When multiple records share an ORCID, keep the
  // one with the richest affiliation data.
  const byOrcid = new Map<string, AuthorRec>();
  const noOrcid: AuthorRec[] = [];
  for (const r of records) {
    if (r.orcid) {
      const prev = byOrcid.get(r.orcid);
      if (!prev) { byOrcid.set(r.orcid, r); continue; }
      const prevScore = (prev.primary_ror_id ? 2 : 0) + (prev.primary_institution_name ? 1 : 0);
      const nextScore = (r.primary_ror_id ? 2 : 0) + (r.primary_institution_name ? 1 : 0);
      if (nextScore > prevScore) byOrcid.set(r.orcid, r);
    } else {
      noOrcid.push(r);
    }
  }
  // Pass 2: among no-ORCID entries, drop any whose nameKey is already covered
  // by an ORCID-bearing record (legacy duplicate of an enriched author).
  const orcidNameKeys = new Set([...byOrcid.values()].map(r => nameKey(r.full_name || r.name)));
  const seenNoOrcidKey = new Set<string>();
  const keptNoOrcid: AuthorRec[] = [];
  for (const r of noOrcid) {
    const key = nameKey(r.full_name || r.name);
    if (key && orcidNameKeys.has(key)) continue;
    if (key && seenNoOrcidKey.has(key)) continue;
    if (key) seenNoOrcidKey.add(key);
    keptNoOrcid.push(r);
  }
  return [...byOrcid.values(), ...keptNoOrcid];
}

// Cap affiliation name length: raw PubMed affiliations can include the entire
// authors-affiliations block ("Authors' Affiliations: 1Slone ...") which is
// hundreds of chars and not a valid organization name.
function cleanAffiliationName(raw: string | null | undefined): string | null {
  if (!raw) return null;
  let s = String(raw).trim();
  if (!s) return null;
  // Strip PubMed-style "Authors' Affiliations:" prefix (smart or straight quote)
  s = s.replace(/^Authors['’]?\s*Affiliations?\s*:?\s*/i, '');
  // Strip leading superscript-like number prefix ("1Slone", "2 Lombardi")
  s = s.replace(/^\d+\s*/, '');
  s = s.trim();
  if (!s) return null;
  if (s.length <= 200) return s;
  return s.slice(0, 197) + '...';
}

const authorRecords = dedupeAuthorRecords(authorRecordsRaw);
const AUTHOR_CAP = 20;

// Unique institutions for the visible affiliations block. Dedup by ROR id when
// present (canonical); fall back to normalized name so two authors at the same
// unrorred institution collapse. Only emit when authors are shown inline (not
// consortium fallback) and at least one record has institution data.
type Affiliation = { name: string; ror: string | null };
function uniqueAffiliations(records: AuthorRec[]): Affiliation[] {
  const seen = new Set<string>();
  const out: Affiliation[] = [];
  for (const r of records) {
    const name = cleanAffiliationName(r.primary_institution_name);
    if (!name) continue;
    const ror = r.primary_ror_id || null;
    const key = ror || name.toLowerCase().replace(/\s+/g, ' ').trim();
    if (seen.has(key)) continue;
    seen.add(key);
    out.push({ name, ror });
  }
  return out;
}
const affiliations =
  authorRecords.length > 0 && authorRecords.length <= AUTHOR_CAP
    ? uniqueAffiliations(authorRecords)
    : [];

// Source link when there's no DOI, or when sourceUrl differs from the DOI link (dead DOI fallback)
const showSourceLink = article.sourceUrl && (!article.doi || article.sourceUrl !== `https://doi.org/${article.doi}`);
// Free full text only when oaUrl differs from both sourceUrl and DOI
const showFreeFullText = article.oaUrl
  && article.oaUrl !== article.sourceUrl
  && article.oaUrl !== (article.doi ? `https://doi.org/${article.doi}` : '');

const canonicalUrl = `https://rrmacademy.org/library/${article.slug}/`;

// Highwire Press citation meta for Zotero Connector
const citationAuthors = article.authors?.split(';').map(a => a.trim()).filter(Boolean) || [];
const citationDate = article.datePublished?.split('T')[0]?.replace(/-/g, '/') || (article.year ? String(article.year) : undefined);
// Parse pages broadly for Highwire (handles S42-S48, e123-e130, etc.)
const hwPages = article.pages?.split(/[-–]/).map(p => p.trim()) || [];
const citationMeta = {
  title: article.title,
  authors: citationAuthors,
  date: citationDate,
  journal: article.journal || undefined,
  journalAbbrev: article.journalAbbv || undefined,
  volume: article.volume || undefined,
  issue: article.issue || undefined,
  firstPage: hwPages[0] || undefined,
  lastPage: hwPages[1] || undefined,
  doi: article.doi || undefined,
  pmid: article.pmid || undefined,
  abstract: article.abstract || undefined,
  keywords: article.topics.length > 0 ? article.topics.join('; ') : undefined,
};
---
<BaseLayout
  bodyClass="page-library page-library-article page-synopsis"
  title={article.title}
  description={metaDescription}
  canonicalUrl={canonicalUrl}
  ogType="article"
  jsonLd={jsonLd}
  citationMeta={citationMeta}
  speakable={['.article-title', '.article-meta-row', '.abstract']}
  chrome={SHELL_ENABLED ? 'shell' : 'default'}
  noindex={typeof article.word_count === 'number' ? article.word_count < 30 : (!article.abstract || article.abstract.trim().length < 30)}
  trackScroll
>
  {SHELL_ENABLED ? (
    <AppShellChrome context="article" currentPath={Astro.url.pathname} relatedSections={relatedSections}>
  <div class="page-wrapper" data-pagefind-body>
    <span data-pagefind-meta="type:Research" style="display:none"></span>
    {article.rrmRelevance && <span data-pagefind-meta={`rrmRelevance:${article.rrmRelevance}`} style="display:none"></span>}
    {article.sentiment && <span data-pagefind-meta={`sentiment:${article.sentiment}`} style="display:none"></span>}
    <div class="container container--narrow">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/library/">Research Library</a>
        <span aria-hidden="true"> &rsaquo; </span>
        <span>Synopsis</span>
      </nav>

      <ArticleHero
        article={article}
        authorRecords={authorRecords}
        affiliations={affiliations}
        authorCap={AUTHOR_CAP}
        journalLine={journalLine}
        doiUrl={doiUrl}
        pubmedUrl={pubmedUrl}
        showSourceLink={showSourceLink}
        showFreeFullText={showFreeFullText}
      />

      <!-- Synopsis (above abstract for SEO/AEO -- structured, citable content first) -->
      {article.insights && (
        <section class="article-insights" aria-label="Synopsis">
          <h2 class="detail-heading">Synopsis</h2>
          <div class="insights-tldr">
            <p>{article.insights.tldr}</p>
          </div>
          {article.insights.key_findings && article.insights.key_findings.length > 0 && (
            <div class="insights-findings">
              <h3 class="insights-subheading">Key Findings</h3>
              <ul>
                {article.insights.key_findings.map(finding => (
                  <li>{finding}</li>
                ))}
              </ul>
            </div>
          )}
          {article.insights.clinical_implications && (
            <div class="insights-relevance">
              <h3 class="insights-subheading">Clinical Implications</h3>
              <p>{article.insights.clinical_implications}</p>
            </div>
          )}
          {article.insights.rrm_context && (
            <div class="insights-context">
              <h3 class="insights-subheading">RRM Context</h3>
              <p>{article.insights.rrm_context}</p>
            </div>
          )}
        </section>
      )}

      <!-- Abstract -->
      <section class="abstract" aria-label="Abstract">
        <h2 class="detail-heading">Abstract</h2>
        {renderedAbstractSections.length === 0 ? (
          <p class="abstract-empty">No abstract available for this article.</p>
        ) : (
          renderedAbstractSections.map(section => (
            <div class="abstract-section">
              {section.heading && (
                <span class="abstract-heading">{section.heading}</span>
              )}
              <Fragment set:html={section.html} />
            </div>
          ))
        )}
      </section>

      <!-- Topics -->
      {article.topics.length > 0 && (
        <section class="article-topics" aria-label="Topics">
          <h2 class="detail-heading">Topics</h2>
          <div class="topic-grid" data-pagefind-weight="3">
            {article.topics.map(topic => (
              <TopicTag topic={topic} />
            ))}
          </div>
        </section>
      )}

      {article.searchTerms.length > 0 && (
        <div data-pagefind-weight="4" style="position:absolute;width:1px;height:1px;overflow:hidden;clip:rect(0,0,0,0)">
          {article.searchTerms.join(', ')}
        </div>
      )}

      {(article.pmid || article.doi) && (
        <div data-pagefind-weight="10" style="position:absolute;width:1px;height:1px;overflow:hidden;clip:rect(0,0,0,0)">
          {article.pmid && `PMID ${article.pmid} ${article.pmid}`}
          {article.doi && `DOI ${article.doi} ${article.doi}`}
        </div>
      )}

      <!-- Citations -->
      {(article.apaCitation || article.vancouverCitation || article.mlaCitation) && (
        <section class="article-citations" aria-label="Citations" data-pagefind-ignore="all">
          <h2 class="detail-heading">Cite this article</h2>
          <Citation
            apa={article.apaCitation}
            vancouver={article.vancouverCitation}
            mla={article.mlaCitation}
          />
        </section>
      )}

      <!-- Keywords -->
      {article.keywords && (
        <section class="article-keywords" aria-label="Keywords">
          <h2 class="detail-heading">Keywords</h2>
          <p class="keywords-text">{article.keywords}</p>
        </section>
      )}

      <!-- Funding callout -->
      <LibraryFundingCallout />

      <!-- Related articles -->
      {related.length > 0 && (
        <section class="article-related" aria-label="Related articles" data-pagefind-ignore="all">
          <h2 class="detail-heading">Related articles</h2>
          <div class="related-grid">
            {related.map(rel => (
              <ArticleCard article={rel} />
            ))}
          </div>
        </section>
      )}
    </div>
  </div>
    </AppShellChrome>
  ) : (
    <Fragment>
  <div class="page-wrapper" data-pagefind-body>
    <span data-pagefind-meta="type:Research" style="display:none"></span>
    {article.rrmRelevance && <span data-pagefind-meta={`rrmRelevance:${article.rrmRelevance}`} style="display:none"></span>}
    {article.sentiment && <span data-pagefind-meta={`sentiment:${article.sentiment}`} style="display:none"></span>}
    <div class="container container--narrow">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/library/">Research Library</a>
        <span aria-hidden="true"> &rsaquo; </span>
        <span>Synopsis</span>
      </nav>

      <ArticleHero
        article={article}
        authorRecords={authorRecords}
        affiliations={affiliations}
        authorCap={AUTHOR_CAP}
        journalLine={journalLine}
        doiUrl={doiUrl}
        pubmedUrl={pubmedUrl}
        showSourceLink={showSourceLink}
        showFreeFullText={showFreeFullText}
      />

      <!-- Synopsis (above abstract for SEO/AEO -- structured, citable content first) -->
      {article.insights && (
        <section class="article-insights" aria-label="Synopsis">
          <h2 class="detail-heading">Synopsis</h2>
          <div class="insights-tldr">
            <p>{article.insights.tldr}</p>
          </div>
          {article.insights.key_findings && article.insights.key_findings.length > 0 && (
            <div class="insights-findings">
              <h3 class="insights-subheading">Key Findings</h3>
              <ul>
                {article.insights.key_findings.map(finding => (
                  <li>{finding}</li>
                ))}
              </ul>
            </div>
          )}
          {article.insights.clinical_implications && (
            <div class="insights-relevance">
              <h3 class="insights-subheading">Clinical Implications</h3>
              <p>{article.insights.clinical_implications}</p>
            </div>
          )}
          {article.insights.rrm_context && (
            <div class="insights-context">
              <h3 class="insights-subheading">RRM Context</h3>
              <p>{article.insights.rrm_context}</p>
            </div>
          )}
        </section>
      )}

      <!-- Abstract -->
      <section class="abstract" aria-label="Abstract">
        <h2 class="detail-heading">Abstract</h2>
        {renderedAbstractSections.length === 0 ? (
          <p class="abstract-empty">No abstract available for this article.</p>
        ) : (
          renderedAbstractSections.map(section => (
            <div class="abstract-section">
              {section.heading && (
                <span class="abstract-heading">{section.heading}</span>
              )}
              <Fragment set:html={section.html} />
            </div>
          ))
        )}
      </section>

      <!-- Topics -->
      {article.topics.length > 0 && (
        <section class="article-topics" aria-label="Topics">
          <h2 class="detail-heading">Topics</h2>
          <div class="topic-grid" data-pagefind-weight="3">
            {article.topics.map(topic => (
              <TopicTag topic={topic} />
            ))}
          </div>
        </section>
      )}

      {article.searchTerms.length > 0 && (
        <div data-pagefind-weight="4" style="position:absolute;width:1px;height:1px;overflow:hidden;clip:rect(0,0,0,0)">
          {article.searchTerms.join(', ')}
        </div>
      )}

      {(article.pmid || article.doi) && (
        <div data-pagefind-weight="10" style="position:absolute;width:1px;height:1px;overflow:hidden;clip:rect(0,0,0,0)">
          {article.pmid && `PMID ${article.pmid} ${article.pmid}`}
          {article.doi && `DOI ${article.doi} ${article.doi}`}
        </div>
      )}

      <!-- Citations -->
      {(article.apaCitation || article.vancouverCitation || article.mlaCitation) && (
        <section class="article-citations" aria-label="Citations" data-pagefind-ignore="all">
          <h2 class="detail-heading">Cite this article</h2>
          <Citation
            apa={article.apaCitation}
            vancouver={article.vancouverCitation}
            mla={article.mlaCitation}
          />
        </section>
      )}

      <!-- Keywords -->
      {article.keywords && (
        <section class="article-keywords" aria-label="Keywords">
          <h2 class="detail-heading">Keywords</h2>
          <p class="keywords-text">{article.keywords}</p>
        </section>
      )}

      <!-- Funding callout -->
      <LibraryFundingCallout />

      <!-- Related articles -->
      {related.length > 0 && (
        <section class="article-related" aria-label="Related articles" data-pagefind-ignore="all">
          <h2 class="detail-heading">Related articles</h2>
          <div class="related-grid">
            {related.map(rel => (
              <ArticleCard article={rel} />
            ))}
          </div>
        </section>
      )}
    </div>
  </div>
    </Fragment>
  )}
  {SHELL_ENABLED && <AppShellSheet />}
</BaseLayout>

<style>
  .article-title {
    /* font-size inherited from global <h1> clamp() — H1 harmony 2026-05-08. */
    margin-bottom: var(--space-4);
    line-height: 1.25;
    letter-spacing: -0.015em;
  }
  .article-meta-row {
    display: flex;
    align-items: baseline;
    gap: var(--space-2);
    margin-bottom: var(--space-3);
  }
  .article-meta-row .access-badge {
    align-self: center;
    position: relative;
    top: -1px;
  }
  .short-citation {
    font-size: 0.875rem;
    color: var(--neutral-600);
    font-weight: 500;
    margin: 0;
    line-height: 1.55;
  }
  .orcid-link {
    display: inline-flex;
    align-items: center;
    margin-left: 0.25em;
    vertical-align: -2px;
    text-decoration: none;
    opacity: 0.9;
    transition: opacity 120ms ease;
  }
  .orcid-link:hover,
  .orcid-link:focus {
    opacity: 1;
  }
  .orcid-link svg {
    display: block;
  }
  .article-authors {
    font-size: 0.875rem;
    color: var(--neutral-700);
    line-height: 1.6;
    margin-bottom: var(--space-2);
  }
  .article-affiliations-wrap {
    margin: var(--space-2) 0 var(--space-3);
  }
  .article-affiliations-summary {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.75rem;
    color: var(--neutral-600);
    cursor: pointer;
    list-style: none;
    user-select: none;
    padding: 2px 0;
  }
  .article-affiliations-summary::-webkit-details-marker { display: none; }
  .article-affiliations-summary:hover { color: var(--neutral-900); }
  .article-affiliations-chevron {
    transition: transform 150ms ease;
  }
  .article-affiliations-wrap[open] .article-affiliations-chevron {
    transform: rotate(180deg);
  }
  .article-affiliations {
    list-style: none;
    padding: 0;
    margin: var(--space-2) 0 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    font-size: 0.8125rem;
    color: var(--neutral-600);
    line-height: 1.5;
  }
  .affiliation {
    display: flex;
    align-items: baseline;
    gap: 0.5em;
    flex-wrap: wrap;
  }
  .affiliation__name {
    font-style: italic;
  }
  .affiliation__ror {
    display: inline-flex;
    align-items: center;
    gap: 0.25em;
    padding: 0.125em 0.5em;
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-decoration: none;
    color: var(--neutral-700);
    background: var(--neutral-100);
    border: 1px solid var(--neutral-200);
    border-radius: 3px;
    transition: background 120ms ease, border-color 120ms ease;
  }
