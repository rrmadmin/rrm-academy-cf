---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Citation from '../../components/Citation.astro';
import TopicTag from '../../components/TopicTag.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { fetchAllArticles, getRelatedArticles, type Article } from '../../lib/airtable';
import { parseStructuredAbstract } from '../../lib/abstract-parser';

export async function getStaticPaths() {
  const articles = await fetchAllArticles();

  return articles.map(article => ({
    params: { slug: article.slug },
    props: { article, allArticles: articles },
  }));
}

interface Props {
  article: Article;
  allArticles: Article[];
}

const { article, allArticles } = Astro.props;
const related = getRelatedArticles(article, allArticles, 5);
const abstractSections = parseStructuredAbstract(article.abstract);

// Build journal citation line
const journalParts: string[] = [];
if (article.journal) journalParts.push(article.journal);
if (article.volume) {
  let vol = article.volume;
  if (article.issue) vol += `(${article.issue})`;
  journalParts.push(vol);
}
if (article.pages) journalParts.push(article.pages);
const journalLine = journalParts.join(', ');

// Build description for meta
const metaDescription = article.abstract
  ? article.abstract.slice(0, 155) + (article.abstract.length > 155 ? '...' : '')
  : `${article.title} - RRM Research Library`;

// Build DOI URL
const doiUrl = article.doi ? `https://doi.org/${article.doi}` : '';
const pubmedUrl = article.pmid ? `https://pubmed.ncbi.nlm.nih.gov/${article.pmid}/` : '';

// Parse pages for schema
const pageMatch = article.pages?.match(/^(\d+)\s*[-–]\s*(\d+)$/);
const pageStart = pageMatch ? pageMatch[1] : article.pages || undefined;
const pageEnd = pageMatch ? pageMatch[2] : undefined;

// Schema.org JSON-LD
const jsonLd: any = {
  '@context': 'https://schema.org',
  '@type': 'MedicalScholarlyArticle',
  name: article.title,
  url: `https://rrmacademy.org/library/${article.slug}`,
  publisher: {
    '@type': 'Organization',
    name: 'RRM Academy',
    url: 'https://rrmacademy.org',
  },
};

if (article.authors) {
  jsonLd.author = article.authors.split(',').map(name => ({
    '@type': 'Person',
    name: name.trim(),
  }));
}

if (article.datePublished) {
  jsonLd.datePublished = article.datePublished;
}

if (article.abstract) {
  jsonLd.abstract = article.abstract;
}

if (article.journal) {
  const isPartOf: any = {
    '@type': 'Periodical',
    name: article.journal,
  };

  if (article.volume) {
    jsonLd.isPartOf = {
      '@type': 'PublicationVolume',
      volumeNumber: article.volume,
      isPartOf: article.issue
        ? { '@type': 'PublicationIssue', issueNumber: article.issue, isPartOf: isPartOf }
        : isPartOf,
    };
  } else {
    jsonLd.isPartOf = isPartOf;
  }
}

if (pageStart) jsonLd.pageStart = pageStart;
if (pageEnd) jsonLd.pageEnd = pageEnd;

const identifiers: any[] = [];
if (article.doi) {
  identifiers.push({ '@type': 'PropertyValue', propertyID: 'doi', value: article.doi });
  jsonLd.sameAs = doiUrl;
}
if (article.pmid) {
  identifiers.push({ '@type': 'PropertyValue', propertyID: 'PMID', value: article.pmid });
}
if (identifiers.length) jsonLd.identifier = identifiers;

const canonicalUrl = `https://rrmacademy.org/library/${article.slug}`;
---
<BaseLayout
  bodyClass="page-library page-synopsis"
  title={article.title}
  description={metaDescription}
  canonicalUrl={canonicalUrl}
  ogType="article"
  jsonLd={jsonLd}
>
  <div class="page-wrapper" data-pagefind-body>
    <div class="container container--narrow">
      <!-- Breadcrumb + Save -->
      <div class="article-topbar" data-pagefind-ignore>
        <nav class="breadcrumb" aria-label="Breadcrumb">
          <a href="/library">Research Library</a>
          <span aria-hidden="true"> &rsaquo; </span>
          <span>Synopsis</span>
        </nav>
        <div class="topbar-actions">
          <button
            class="action-btn"
            id="share-btn"
            aria-label="Copy link"
            title="Copy link"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
            <span class="action-label" id="share-label"></span>
          </button>
          <button
            class="action-btn"
            id="save-btn"
            aria-label="Save article"
            data-slug={article.slug}
            data-title={article.title}
            data-authors={article.shortCitation || ''}
            data-journal={article.journal || article.journalAbbv || ''}
            data-year={article.year || ''}
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/></svg>
            <span class="action-label" id="save-label"></span>
          </button>
        </div>
      </div>

      <!-- Title -->
      <h1 class="article-title" data-pagefind-weight="10" data-pagefind-meta="title">{article.title}</h1>

      <!-- Authors + OA badge -->
      <div class="article-meta-row">
        {article.shortCitation ? (
          <p class="short-citation" data-pagefind-weight="5" data-pagefind-meta="authors">{article.shortCitation}</p>
        ) : article.authors ? (
          <p class="short-citation" data-pagefind-weight="5" data-pagefind-meta="authors">{article.authors}</p>
        ) : null}
        {article.isOpenAccess && <span class="badge badge--oa">Open Access</span>}
      </div>
      {article.year && (
        <span data-pagefind-meta={`year:${article.year}`} style="display:none"></span>
      )}

      <!-- Journal citation line -->
      {journalLine && (
        <p class="journal-line" data-pagefind-weight="2">{journalLine}</p>
      )}

      <!-- Identifiers & links -->
      <div class="article-ids" data-pagefind-ignore>
        {article.doi && (
          <span class="article-id">
            <span class="article-id__label">DOI</span>
            <a href={doiUrl} class="article-id__value" target="_blank" rel="noopener">{article.doi}</a>
          </span>
        )}
        {article.pmid && (
          <span class="article-id">
            <span class="article-id__label">PMID</span>
            <a href={pubmedUrl} class="article-id__value" target="_blank" rel="noopener">{article.pmid}</a>
          </span>
        )}
        {article.sourceUrl && (
          <a href={article.sourceUrl} class="external-link" target="_blank" rel="noopener">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
            Source
          </a>
        )}
      </div>

      <!-- Abstract -->
      <section class="abstract" aria-label="Abstract">
        <h2 class="detail-heading">Abstract</h2>
        {abstractSections.length === 0 ? (
          <p class="abstract-empty">No abstract available for this article.</p>
        ) : (
          abstractSections.map(section => (
            <div class="abstract-section">
              {section.heading && (
                <span class="abstract-heading">{section.heading}</span>
              )}
              <p>{section.text}</p>
            </div>
          ))
        )}
      </section>
      <!-- Topics -->
      {article.topics.length > 0 && (
        <section class="article-topics" aria-label="Topics">
          <h2 class="detail-heading">Topics</h2>
          <div class="topic-grid" data-pagefind-weight="3">
            {article.topics.map(topic => (
              <TopicTag topic={topic} />
            ))}
          </div>
        </section>
      )}

      {article.searchTerms.length > 0 && (
        <div data-pagefind-weight="4" style="position:absolute;width:1px;height:1px;overflow:hidden;clip:rect(0,0,0,0)">
          {article.searchTerms.join(', ')}
        </div>
      )}

      <!-- Citations -->
      {(article.apaCitation || article.vancouverCitation || article.mlaCitation) && (
        <section class="article-citations" aria-label="Citations" data-pagefind-ignore="all">
          <h2 class="detail-heading">Cite this article</h2>
          <Citation
            apa={article.apaCitation}
            vancouver={article.vancouverCitation}
            mla={article.mlaCitation}
          />
        </section>
      )}

      <!-- Keywords -->
      {article.keywords && (
        <section class="article-keywords" aria-label="Keywords">
          <h2 class="detail-heading">Keywords</h2>
          <p class="keywords-text">{article.keywords}</p>
        </section>
      )}

      <!-- Related articles -->
      {related.length > 0 && (
        <section class="article-related" aria-label="Related articles" data-pagefind-ignore="all">
          <h2 class="detail-heading">Related articles</h2>
          <div class="related-grid">
            {related.map(rel => (
              <ArticleCard article={rel} compact />
            ))}
          </div>
        </section>
      )}
    </div>
  </div>
</BaseLayout>

<style>
  .article-title {
    font-size: 1.875rem;
    margin-bottom: var(--space-4);
    line-height: 1.25;
    letter-spacing: -0.015em;
  }
  .article-meta-row {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-3);
  }
  .short-citation {
    font-size: 0.875rem;
    color: var(--neutral-600);
    font-weight: 500;
  }
  .article-authors {
    font-size: 0.875rem;
    color: var(--neutral-700);
    line-height: 1.6;
    margin-bottom: var(--space-2);
  }
  .journal-line {
    font-family: 'Cormorant Garamond', 'Georgia', serif;
    font-size: 0.9375rem;
    color: var(--neutral-600);
    font-style: italic;
    margin-bottom: var(--space-5);
  }
  .article-ids {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: var(--space-2) var(--space-5);
    margin-bottom: var(--space-6);
    font-size: 0.8125rem;
  }
  .article-id {
    display: inline-flex;
    align-items: baseline;
    gap: var(--space-1);
  }
  .article-id__label {
    font-size: 0.6875rem;
    font-weight: 600;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }
  .article-id__value {
    color: var(--text-secondary);
    text-decoration: none;
    transition: color 0.15s;
  }
  .article-id__value:hover {
    color: var(--accent);
    text-decoration: underline;
  }
  .external-link {
    font-size: 0.8125rem;
  }

  .abstract {
    background: transparent;
    border: none;
    border-top: 1px solid var(--border-light, var(--border-color));
    border-radius: 0;
    padding: var(--space-6) 0 0 0;
    margin-bottom: var(--space-8);
  }
  .abstract-empty {
    color: var(--neutral-500);
    font-style: italic;
    font-size: 0.875rem;
  }
  .detail-heading {
    font-family: 'Cormorant Garamond', 'Georgia', serif;
    font-size: 1.125rem;
    font-weight: 600;
    margin-bottom: var(--space-4);
    color: var(--neutral-900);
  }
  .article-topics {
    margin-bottom: var(--space-8);
  }
  .article-citations {
    margin-bottom: var(--space-8);
  }
  .article-keywords {
    margin-bottom: var(--space-8);
  }
  .keywords-text {
    font-size: 0.875rem;
    color: var(--neutral-600);
    line-height: 1.7;
  }
  .article-related {
    margin-top: var(--space-12);
    padding-top: var(--space-8);
    border-top: 1px solid var(--border-color);
  }

  /* Topbar: breadcrumb + save button */
  .article-topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
  }

  .topbar-actions {
    display: flex;
    align-items: center;
    gap: 6px;
    flex-shrink: 0;
  }
  .action-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 4px;
    padding: 4px;
    font-size: 0.6875rem;
    font-weight: 500;
    font-family: 'Inter', sans-serif;
    color: var(--text-muted);
    background: none;
    border: none;
    cursor: pointer;
    transition: color 0.15s;
    white-space: nowrap;
  }
  .action-label:empty {
    display: none;
  }
  .action-btn:hover {
    color: var(--accent);
  }
  .action-btn.copied {
    color: var(--accent);
  }
  .action-btn.saved {
    color: var(--accent);
  }

  @media (max-width: 768px) {
    .article-title {
      font-size: 1.5rem;
    }
  }
</style>

<script is:inline>
  // Share / copy link button
  (function() {
    var shareBtn = document.getElementById('share-btn');
    var shareLabel = document.getElementById('share-label');
    if (!shareBtn) return;
    shareBtn.addEventListener('click', function() {
      var url = window.location.href;
      if (navigator.clipboard && navigator.clipboard.writeText) {
        navigator.clipboard.writeText(url).then(function() {
          shareBtn.classList.add('copied');
          shareLabel.textContent = 'Copied!';
          setTimeout(function() {
            shareBtn.classList.remove('copied');
            shareLabel.textContent = '';
          }, 2000);
        });
      } else {
        // Fallback
        var input = document.createElement('input');
        input.value = url;
        document.body.appendChild(input);
        input.select();
        document.execCommand('copy');
        document.body.removeChild(input);
        shareBtn.classList.add('copied');
        shareLabel.textContent = 'Copied!';
        setTimeout(function() {
          shareBtn.classList.remove('copied');
          shareLabel.textContent = '';
        }, 2000);
      }
    });
  })();

  // Save article button
  (function() {
    var KEY = 'rrm_saved';
    var btn = document.getElementById('save-btn');
    var saveLabel = document.getElementById('save-label');
    if (!btn) return;

    function getSaved() {
      try { return JSON.parse(localStorage.getItem(KEY) || '[]'); }
      catch(e) { return []; }
    }

    function setSaved(items) {
      localStorage.setItem(KEY, JSON.stringify(items));
    }

    var slug = btn.dataset.slug;
    var saved = getSaved();
    var isSaved = saved.some(function(s) { return s.slug === slug; });

    // Color the icon if already saved
    if (isSaved) btn.classList.add('saved');

    // Update header badge
    function updateBadge() {
      var badge = document.getElementById('saved-count');
      var link = document.getElementById('saved-link');
      var mobileLink = document.getElementById('mobile-saved-link');
      if (badge) badge.textContent = saved.length;
      if (saved.length > 0) {
        if (link) link.classList.add('has-items');
        if (mobileLink) mobileLink.classList.add('has-items');
      } else {
        if (link) link.classList.remove('has-items');
        if (mobileLink) mobileLink.classList.remove('has-items');
      }
    }

    btn.addEventListener('click', function() {
      saved = getSaved();
      if (isSaved) {
        saved = saved.filter(function(s) { return s.slug !== slug; });
        isSaved = false;
        btn.classList.remove('saved');
        saveLabel.textContent = '';
      } else {
        saved.unshift({
          slug: slug,
          title: btn.dataset.title,
          authors: btn.dataset.authors,
          journal: btn.dataset.journal,
          year: btn.dataset.year,
          savedAt: new Date().toISOString()
        });
        isSaved = true;
        btn.classList.add('saved');
        saveLabel.textContent = 'Saved!';
        btn.classList.add('copied');
        setTimeout(function() {
          saveLabel.textContent = '';
          btn.classList.remove('copied');
        }, 2000);
      }
      setSaved(saved);
      updateBadge();
    });
  })();
</script>
