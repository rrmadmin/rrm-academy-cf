  /* Mobile .article-title font-size now handled by global <h1> clamp(). */
</style>

<script is:inline>
  // Share / copy link button
  (function() {
    var shareBtn = document.getElementById('share-btn');
    var shareLabel = document.getElementById('share-label');
    if (!shareBtn) return;
    shareBtn.addEventListener('click', function() {
      var url = window.location.href;
      // GA4 share_click via the global bridge (track-auto.ts). network='copy-link'
      // since this surface is the copy-URL action (no social share API today).
      try {
        if (window.__rrmTrack__) window.__rrmTrack__('share_click', {
          surface: 'library-article',
          network: 'copy-link',
        });
      } catch (e) {}
      if (navigator.clipboard && navigator.clipboard.writeText) {
        navigator.clipboard.writeText(url).then(function() {
          shareBtn.classList.add('copied');
          shareLabel.textContent = 'Copied!';
          setTimeout(function() {
            shareBtn.classList.remove('copied');
            shareLabel.textContent = '';
          }, 2000);
        });
      } else {
        // Fallback
        var input = document.createElement('input');
        input.value = url;
        document.body.appendChild(input);
        input.select();
        document.execCommand('copy');
        document.body.removeChild(input);
        shareBtn.classList.add('copied');
        shareLabel.textContent = 'Copied!';
        setTimeout(function() {
          shareBtn.classList.remove('copied');
          shareLabel.textContent = '';
        }, 2000);
      }
    });
  })();

  // RIS citation generation (shared by download button + batch export)
  function generateRIS(d) {
    var lines = ['TY  - JOUR'];
    var authors = (d.authors || '').split(/[,;]/);
    for (var i = 0; i < authors.length; i++) {
      var a = authors[i].trim();
      if (a) lines.push('AU  - ' + a);
    }
    if (d.title) lines.push('TI  - ' + d.title);
    if (d.journal) lines.push('T2  - ' + d.journal);
    if (d.journalAbbv) lines.push('JO  - ' + d.journalAbbv);
    if (d.abstract) lines.push('AB  - ' + d.abstract);
    if (d.datePublished) lines.push('DA  - ' + d.datePublished.replace(/-/g, '/'));
    if (d.year) lines.push('PY  - ' + d.year);
    if (d.volume) lines.push('VL  - ' + d.volume);
    if (d.issue) lines.push('IS  - ' + d.issue);
    if (d.pages) {
      var parts = d.pages.split(/[-\u2013]/);
      if (parts[0]) lines.push('SP  - ' + parts[0].trim());
      if (parts[1]) lines.push('EP  - ' + parts[1].trim());
    }
    if (d.doi) {
      lines.push('DO  - ' + d.doi);
      lines.push('UR  - https://doi.org/' + d.doi);
    }
    if (d.pmid) lines.push('N1  - PMID: ' + d.pmid);
    if (d.topics) {
      var topics = d.topics.split(';');
      for (var j = 0; j < topics.length; j++) {
        var t = topics[j].trim();
        if (t) lines.push('KW  - ' + t);
      }
    }
    if (d.slug) lines.push('UR  - https://rrmacademy.org/library/' + d.slug + '/');
    lines.push('ER  - ');
    return lines.join('\n') + '\n';
  }

  function downloadRIS(content, filename) {
    var blob = new Blob([content], { type: 'application/x-research-info-systems' });
    var url = URL.createObjectURL(blob);
    var a = document.createElement('a');
    a.href = url;
    a.download = filename;
    a.click();
    URL.revokeObjectURL(url);
  }

  // Download citation button
  (function() {
    var citeBtn = document.getElementById('cite-btn');
    var citeLabel = document.getElementById('cite-label');
    var saveBtn = document.getElementById('save-btn');
    if (!citeBtn || !saveBtn) return;
    citeBtn.addEventListener('click', function() {
      var d = saveBtn.dataset;
      // GA4 copy_citation via the global bridge (track-auto.ts). format='ris'
      // since this button downloads a .ris file (Research Information Systems
      // format consumed by Zotero, Mendeley, EndNote).
      try {
        if (window.__rrmTrack__) window.__rrmTrack__('copy_citation', {
          surface: 'library-article',
          format: 'ris',
          slug: d.slug || '',
        });
      } catch (e) {}
      var ris = generateRIS(d);
      var fname = (d.doi || d.pmid || d.slug || 'citation').replace(/[\/\\]/g, '_') + '.ris';
      downloadRIS(ris, fname);
      citeBtn.classList.add('copied');
      citeLabel.textContent = 'Downloaded!';
      setTimeout(function() {
        citeBtn.classList.remove('copied');
        citeLabel.textContent = '';
      }, 2000);
    });
  })();

  // Save article button
  (function() {
    var KEY = 'rrm_saved';
    var btn = document.getElementById('save-btn');
    var saveLabel = document.getElementById('save-label');
    if (!btn) return;

    function getSaved() {
      try { return JSON.parse(localStorage.getItem(KEY) || '[]'); }
      catch(e) { return []; }
    }

    function setSaved(items) {
      localStorage.setItem(KEY, JSON.stringify(items));
    }

    var slug = btn.dataset.slug;
    var saved = getSaved();
    var isSaved = saved.some(function(s) { return s.slug === slug; });

    // Color the icon if already saved
    if (isSaved) btn.classList.add('saved');

    // Update header badge
    function updateBadge() {
      var badge = document.getElementById('saved-count');
      var mobileBadge = document.getElementById('mobile-saved-count');
      var link = document.getElementById('saved-link');
      var mobileLink = document.getElementById('mobile-saved-link');
      if (badge) badge.textContent = saved.length;
      if (mobileBadge) mobileBadge.textContent = saved.length;
      if (saved.length > 0) {
        if (link) link.classList.add('has-items');
        if (mobileLink) mobileLink.classList.add('has-items');
      } else {
        if (link) link.classList.remove('has-items');
        if (mobileLink) mobileLink.classList.remove('has-items');
      }
    }

    // Server-side save/unsave (fire-and-forget for logged-in users)
    function serverSave(article) {
      fetch('/api/saved', {
        method: 'POST',
        credentials: 'same-origin',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ article: article })
      }).catch(function() {});
    }
    function serverUnsave(articleSlug) {
      fetch('/api/saved', {
        method: 'DELETE',
        credentials: 'same-origin',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ slug: articleSlug })
      }).catch(function() {});
    }

    btn.addEventListener('click', function() {
      saved = getSaved();
      var d = btn.dataset;
      if (isSaved) {
        saved = saved.filter(function(s) { return s.slug !== slug; });
        isSaved = false;
        btn.classList.remove('saved');
        saveLabel.textContent = '';
        serverUnsave(slug);
      } else {
        var article = {
          slug: d.slug,
          title: d.title,
          authors: d.authors,
          journal: d.journal,
          journalAbbv: d.journalAbbv,
          year: d.year,
          doi: d.doi,
          pmid: d.pmid,
          volume: d.volume,
          issue: d.issue,
          pages: d.pages,
          datePublished: d.datePublished,
          abstract: d.abstract,
          topics: d.topics,
          savedAt: new Date().toISOString()
        };
        saved.unshift(article);
        isSaved = true;
        btn.classList.add('saved');
        saveLabel.textContent = 'Saved!';
        btn.classList.add('copied');
        setTimeout(function() {
          saveLabel.textContent = '';
          btn.classList.remove('copied');
        }, 2000);
        serverSave(article);
      }
      setSaved(saved);
      updateBadge();
    });
  })();
</script>
