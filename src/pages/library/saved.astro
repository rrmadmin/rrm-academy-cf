---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AppShellChrome from '../../components/AppShellChrome.astro';
import { isShellEnabled } from '../../lib/shell-routes';

const SHELL_ENABLED = isShellEnabled('library');
---
<BaseLayout
  bodyClass="page-library"
  title="Saved Articles"
  description="Your saved articles from the RRM Research Library."
  canonicalUrl="https://rrmacademy.org/library/saved"
  noindex
  chrome={SHELL_ENABLED ? 'shell' : 'default'}
>
  {SHELL_ENABLED ? (
    <AppShellChrome context="saved" currentPath={Astro.url.pathname}>
  <div class="page-wrapper" data-pagefind-ignore="all">
    <div class="container container--narrow">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/library/">Research Library</a>
        <span aria-hidden="true"> &rsaquo; </span>
        <span>Saved</span>
      </nav>

      <div class="saved-header">
        <h1 class="saved-title">Saved Articles</h1>
        <div class="saved-actions">
          <button id="export-all" class="export-btn">Export all (.RIS)</button>
          <button id="clear-all" class="clear-all-btn">Clear all</button>
        </div>
      </div>

      <div id="saved-empty" class="saved-empty">
        <p>No saved articles yet.</p>
        <p class="saved-hint">
          Tap the <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align: -2px;"><path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/></svg> Save button on any article to add it here.
        </p>
        <a href="/library/" class="back-link">&larr; Browse the library</a>
        <p id="guest-signin-hint" class="guest-signin-hint" hidden>Have an account? <a href="/login/">Log in</a> to see your saved articles.</p>
      </div>

      <div id="saved-list" class="saved-list"></div>

      <!-- Guest sync nudge — shown only for guests with saved articles -->
      <aside id="guest-sync-nudge" class="sync-nudge" hidden>
        <div class="sync-nudge__icon" aria-hidden="true">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/></svg>
        </div>
        <div class="sync-nudge__text">
          <strong>These articles are saved in this browser only.</strong>
          <span>Create a free account to keep them across all your devices.</span>
        </div>
        <div class="sync-nudge__actions">
          <a href="/signup/" class="sync-nudge__signup">Create free account</a>
          <span class="sync-nudge__or">or <a href="/login/" class="sync-nudge__login">Log in</a></span>
        </div>
      </aside>
    </div>
  </div>
    </AppShellChrome>
  ) : (
    <Fragment>
  <div class="page-wrapper" data-pagefind-ignore="all">
    <div class="container container--narrow">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/library/">Research Library</a>
        <span aria-hidden="true"> &rsaquo; </span>
        <span>Saved</span>
      </nav>

      <div class="saved-header">
        <h1 class="saved-title">Saved Articles</h1>
        <div class="saved-actions">
          <button id="export-all" class="export-btn">Export all (.RIS)</button>
          <button id="clear-all" class="clear-all-btn">Clear all</button>
        </div>
      </div>

      <div id="saved-empty" class="saved-empty">
        <p>No saved articles yet.</p>
        <p class="saved-hint">
          Tap the <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align: -2px;"><path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/></svg> Save button on any article to add it here.
        </p>
        <a href="/library/" class="back-link">&larr; Browse the library</a>
        <p id="guest-signin-hint" class="guest-signin-hint" hidden>Have an account? <a href="/login/">Log in</a> to see your saved articles.</p>
      </div>

      <div id="saved-list" class="saved-list"></div>

      <!-- Guest sync nudge — shown only for guests with saved articles -->
      <aside id="guest-sync-nudge" class="sync-nudge" hidden>
        <div class="sync-nudge__icon" aria-hidden="true">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/></svg>
        </div>
        <div class="sync-nudge__text">
          <strong>These articles are saved in this browser only.</strong>
          <span>Create a free account to keep them across all your devices.</span>
        </div>
        <div class="sync-nudge__actions">
          <a href="/signup/" class="sync-nudge__signup">Create free account</a>
          <span class="sync-nudge__or">or <a href="/login/" class="sync-nudge__login">Log in</a></span>
        </div>
      </aside>
    </div>
  </div>
    </Fragment>
  )}
</BaseLayout>

<style>
  .saved-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-4);
    margin-bottom: var(--space-6);
  }
  .saved-title {
    font-size: 1.5rem;
    margin-bottom: 0;
  }

  .saved-empty {
    text-align: center;
    padding: var(--space-12) 0;
    color: var(--neutral-500);
    font-size: 0.875rem;
    display: none;
  }
  .saved-empty.visible {
    display: block;
  }
  .saved-hint {
    font-size: 0.8125rem;
    color: var(--neutral-400);
    margin-top: var(--space-2);
  }
  .back-link {
    display: inline-block;
    margin-top: var(--space-4);
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--purple-700);
  }

  .saved-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  /* Individual saved item — rendered by JS */
  .saved-list :global(.saved-item) {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--space-4);
    padding: var(--space-4) 0;
    border-bottom: 1px solid var(--neutral-200);
  }
  .saved-list :global(.saved-item:first-child) {
    padding-top: 0;
  }
  .saved-list :global(.saved-item__info) {
    flex: 1;
    min-width: 0;
  }
  .saved-list :global(.saved-item__title) {
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--neutral-900);
    text-decoration: none;
    line-height: 1.4;
    display: block;
  }
  .saved-list :global(.saved-item__title:hover) {
    color: var(--purple-700);
  }
  .saved-list :global(.saved-item__meta) {
    font-size: 0.6875rem;
    color: var(--neutral-500);
    margin-top: 2px;
  }
  .saved-list :global(.saved-item__remove) {
    flex-shrink: 0;
    background: none;
    border: none;
    cursor: pointer;
    color: var(--neutral-400);
    padding: 4px;
    transition: color 0.15s;
    margin-top: 2px;
  }
  .saved-list :global(.saved-item__remove:hover) {
    color: var(--neutral-900);
  }

  .saved-actions {
    display: none;
    align-items: center;
    gap: var(--space-4);
  }
  .saved-actions.visible {
    display: flex;
  }
  .export-btn {
    font-size: 0.75rem;
    font-weight: 500;
    font-family: 'Inter', sans-serif;
    color: var(--purple-700);
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    transition: color 0.15s;
  }
  .export-btn:hover {
    color: var(--purple-900);
  }
  .clear-all-btn {
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--neutral-400);
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
  }
  .clear-all-btn:hover {
    color: var(--neutral-900);
  }

  /* Guest sign-in hint (empty state) */
  .guest-signin-hint {
    font-size: 0.8125rem;
    color: var(--neutral-400);
    margin-top: var(--space-4);
  }
  .guest-signin-hint a {
    color: var(--purple-700);
    font-weight: 500;
  }

  /* Guest sync nudge (has articles, not logged in) */
  .sync-nudge[hidden] {
    display: none;
  }
  .sync-nudge {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    background: var(--bg-surface);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
    padding: var(--space-4) var(--space-5);
    margin-top: var(--space-6);
  }
  .sync-nudge__icon {
    color: var(--accent);
    flex-shrink: 0;
    opacity: 0.7;
  }
  .sync-nudge__text {
    flex: 1;
    font-size: 0.875rem;
    line-height: 1.6;
    color: var(--text-secondary);
    min-width: 0;
  }
  .sync-nudge__text strong {
    display: block;
    color: var(--text-primary);
    font-weight: 600;
    margin-bottom: 2px;
  }
  .sync-nudge__actions {
    display: flex;
    flex-direction: row;
    gap: var(--space-3);
    flex-shrink: 0;
    align-items: center;
  }
  .sync-nudge__or {
    font-size: 0.75rem;
    color: var(--text-secondary);
    white-space: nowrap;
  }
  .sync-nudge__signup {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--white);
    background: var(--accent);
    padding: 6px 16px;
    border-radius: var(--radius-pill);
    text-decoration: none;
    white-space: nowrap;
    transition: background 0.15s;
  }
  .sync-nudge__signup:hover {
    background: var(--accent-hover, var(--purple-900));
  }
  .sync-nudge__login {
    font-size: 0.75rem;
    color: var(--accent);
    text-decoration: none;
  }
  .sync-nudge__login:hover {
    text-decoration: underline;
  }
  @media (max-width: 600px) {
    .sync-nudge {
      flex-wrap: wrap;
      gap: var(--space-3);
    }
    .sync-nudge__icon {
      display: none;
    }
    .sync-nudge__actions {
      width: 100%;
    }
  }
</style>

<script is:inline>
  (function() {
    var KEY = 'rrm_saved';
    var list = document.getElementById('saved-list');
    var empty = document.getElementById('saved-empty');
    var clearBtn = document.getElementById('clear-all');
    var exportBtn = document.getElementById('export-all');
    var actionsRow = document.querySelector('.saved-actions');
    var isLoggedIn = false;

    function getSaved() {
      try { return JSON.parse(localStorage.getItem(KEY) || '[]'); }
      catch(e) { return []; }
    }

    function setSaved(items) {
      localStorage.setItem(KEY, JSON.stringify(items));
    }

    function renderItems(saved) {
      list.innerHTML = '';

      if (saved.length === 0) {
        empty.classList.add('visible');
        if (actionsRow) actionsRow.classList.remove('visible');
        return;
      }

      empty.classList.remove('visible');
      if (actionsRow) actionsRow.classList.add('visible');

      saved.forEach(function(item) {
        var div = document.createElement('div');
        div.className = 'saved-item';

        var meta = [item.authors, item.journal, item.year].filter(Boolean).join(' \u00b7 ');

        div.innerHTML =
          '<div class="saved-item__info">' +
            '<a href="/library/' + item.slug + '/" class="saved-item__title">' + escapeHtml(item.title) + '</a>' +
            (meta ? '<div class="saved-item__meta">' + escapeHtml(meta) + '</div>' : '') +
          '</div>' +
          '<button class="saved-item__remove" data-slug="' + item.slug + '" aria-label="Remove" title="Remove">' +
            '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>' +
          '</button>';

        list.appendChild(div);
      });

      // Remove buttons
      list.querySelectorAll('.saved-item__remove').forEach(function(btn) {
        btn.addEventListener('click', function() {
          var slug = btn.dataset.slug;
          var items = getSaved().filter(function(s) { return s.slug !== slug; });
          setSaved(items);
          renderItems(items);
          updateHeaderBadge(items.length);
          // Also remove server-side if logged in
          if (isLoggedIn) {
            fetch('/api/saved', {
              method: 'DELETE',
              credentials: 'same-origin',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ slug: slug })
            }).catch(function() {});
          }
        });
      });
    }

    function render() {
      renderItems(getSaved());
    }

    function updateHeaderBadge(count) {
      var badge = document.getElementById('saved-count');
      var mobileBadge = document.getElementById('mobile-saved-count');
      var link = document.getElementById('saved-link');
      var mobileLink = document.getElementById('mobile-saved-link');
      if (badge) badge.textContent = count;
      if (mobileBadge) mobileBadge.textContent = count;
      if (link) {
        if (count > 0) link.classList.add('has-items');
        else link.classList.remove('has-items');
      }
      if (mobileLink) {
        if (count > 0) mobileLink.classList.add('has-items');
        else mobileLink.classList.remove('has-items');
      }
    }

    // Clear all
    if (clearBtn) {
      clearBtn.addEventListener('click', function() {
        if (confirm('Remove all saved articles?')) {
          // Clear localStorage
          setSaved([]);
          render();
          updateHeaderBadge(0);
          // Clear server-side too if logged in
          if (isLoggedIn) {
            fetch('/api/saved', { credentials: 'same-origin' })
              .then(function(r) { return r.json(); })
              .then(function(data) {
                if (data.ok && data.articles) {
                  data.articles.forEach(function(a) {
                    fetch('/api/saved', {
                      method: 'DELETE',
                      credentials: 'same-origin',
                      headers: { 'Content-Type': 'application/json' },
                      body: JSON.stringify({ slug: a.slug })
                    }).catch(function() {});
                  });
                }
              }).catch(function() {});
          }
        }
      });
    }

    // Export all saved articles as RIS
    if (exportBtn) {
      exportBtn.addEventListener('click', function() {
        var saved = getSaved();
        if (saved.length === 0) return;
        var ris = '';
        saved.forEach(function(d) {
          var lines = ['TY  - JOUR'];
          var authors = (d.authors || '').split(/[,;]/);
          for (var i = 0; i < authors.length; i++) {
            var a = authors[i].trim();
            if (a) lines.push('AU  - ' + a);
          }
          if (d.title) lines.push('TI  - ' + d.title);
          if (d.journal) lines.push('T2  - ' + d.journal);
          if (d.journalAbbv) lines.push('JO  - ' + d.journalAbbv);
          if (d.abstract) lines.push('AB  - ' + d.abstract);
          if (d.datePublished) lines.push('DA  - ' + d.datePublished.replace(/-/g, '/'));
          if (d.year) lines.push('PY  - ' + d.year);
          if (d.volume) lines.push('VL  - ' + d.volume);
          if (d.issue) lines.push('IS  - ' + d.issue);
          if (d.pages) {
            var parts = d.pages.split(/[-\u2013]/);
            if (parts[0]) lines.push('SP  - ' + parts[0].trim());
            if (parts[1]) lines.push('EP  - ' + parts[1].trim());
          }
          if (d.doi) {
            lines.push('DO  - ' + d.doi);
            lines.push('UR  - https://doi.org/' + d.doi);
          }
          if (d.pmid) lines.push('N1  - PMID: ' + d.pmid);
          if (d.topics) {
            var topics = d.topics.split(';');
            for (var j = 0; j < topics.length; j++) {
              var t = topics[j].trim();
              if (t) lines.push('KW  - ' + t);
            }
          }
          if (d.slug) lines.push('UR  - https://rrmacademy.org/library/' + d.slug + '/');
          lines.push('ER  - ');
          ris += lines.join('\n') + '\n';
        });
        var blob = new Blob([ris], { type: 'application/x-research-info-systems' });
        var url = URL.createObjectURL(blob);
        var a = document.createElement('a');
        a.href = url;
        a.download = 'rrm-library-' + saved.length + '-articles.ris';
        a.click();
        URL.revokeObjectURL(url);
      });
    }

    function escapeHtml(str) {
      var div = document.createElement('div');
      div.textContent = str;
      return div.innerHTML;
    }

    // Merge server articles into localStorage (union by slug, server wins on duplicates)
    function mergeArticles(local, server) {
      var slugMap = {};
      local.forEach(function(a) { slugMap[a.slug] = a; });
      server.forEach(function(a) { slugMap[a.slug] = a; });
      var merged = Object.values(slugMap);
      merged.sort(function(a, b) {
        return (b.savedAt || '').localeCompare(a.savedAt || '');
      });
      return merged;
    }

    // Render localStorage immediately, then sync with server if logged in
    render();

    var syncNudge = document.getElementById('guest-sync-nudge');
    var signinHint = document.getElementById('guest-signin-hint');

    fetch('/api/auth/session', { credentials: 'same-origin' })
      .then(function(r) { return r.json(); })
      .then(function(data) {
        if (!data.ok || !data.user) {
          // Guest — show appropriate nudge based on article count
          var saved = getSaved();
          if (saved.length > 0 && syncNudge) {
            syncNudge.hidden = false;
          } else if (saved.length === 0 && signinHint) {
            signinHint.hidden = false;
          }
          return;
        }

        isLoggedIn = true;

        var local = getSaved();

        // Sync localStorage → server (merge), then render the merged result
        fetch('/api/saved', {
          method: 'POST',
          credentials: 'same-origin',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ articles: local })
        })
          .then(function(r) { return r.json(); })
          .then(function(result) {
            if (result.ok && result.articles) {
              var merged = mergeArticles(local, result.articles);
              setSaved(merged);
              renderItems(merged);
              updateHeaderBadge(merged.length);
            }
          })
          .catch(function() {});
      })
      .catch(function() {
        // Network error — treat as guest with articles
        var saved = getSaved();
        if (saved.length > 0 && syncNudge) syncNudge.hidden = false;
      });
  })();
</script>
