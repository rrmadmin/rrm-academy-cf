---
import AppShell from '../../../../layouts/AppShell.astro';
import ArticleCard from '../../../components/ArticleCard.astro';
import { fetchAllArticles } from '../../../lib/airtable';

export async function getStaticPaths() {
  const perPage = 50;
  const articles = await fetchAllArticles();
  const totalPages = Math.ceil(articles.length / perPage);

  return Array.from({ length: totalPages }, (_, i) => ({
    params: { page: String(i + 1) },
    props: { articles, currentPage: i + 1, totalPages, perPage },
  }));
}

interface Props {
  articles: any[];
  currentPage: number;
  totalPages: number;
  perPage: number;
}

const { articles, currentPage, totalPages, perPage } = Astro.props;
const start = (currentPage - 1) * perPage;
const pageArticles = articles.slice(start, start + perPage);

// Pagination range
const range: (number | '...')[] = [];
const delta = 2;
for (let i = 1; i <= totalPages; i++) {
  if (i === 1 || i === totalPages || (i >= currentPage - delta && i <= currentPage + delta)) {
    range.push(i);
  } else if (range[range.length - 1] !== '...') {
    range.push('...');
  }
}
---
<AppShell
  bodyClass="page-library"
  title={`Browse Articles - Page ${currentPage}`}
  description={`Page ${currentPage} of ${totalPages} - Browse all articles in the RRM Research Library.`}
  canonicalUrl={`https://rrmacademy.org/library/page/${currentPage}`}
>
  <section class="browse-page" data-pagefind-ignore="all">
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/app/library/">Research Library</a>
        <span aria-hidden="true"> &rsaquo; </span>
        <span>Page {currentPage}</span>
      </nav>

      <div class="browse-header">
        <div>
          <h1>Browse all articles</h1>
          <p class="browse-meta">
            Showing {start + 1}&ndash;{Math.min(start + perPage, articles.length)} of {articles.length.toLocaleString()}
          </p>
        </div>
        <a href="/app/library/#search" class="btn btn--secondary btn--sm">Search</a>
      </div>

      <div class="article-list">
        {pageArticles.map(article => (
          <ArticleCard article={article} basePath="/app/library/" />
        ))}
      </div>

      <nav class="pagination" aria-label="Pagination">
        {currentPage > 1 && (
          <a href={`/app/library/page/${currentPage - 1}/`}>&laquo; Prev</a>
        )}
        {range.map(item => (
          item === '...' ? (
            <span class="ellipsis">&hellip;</span>
          ) : item === currentPage ? (
            <span class="current">{item}</span>
          ) : (
            <a href={`/app/library/page/${item}/`}>{item}</a>
          )
        ))}
        {currentPage < totalPages && (
          <a href={`/app/library/page/${currentPage + 1}/`}>Next &raquo;</a>
        )}
      </nav>
    </div>
  </section>
</AppShell>

<style>
  h1 {
    margin-bottom: var(--space-1);
  }

  /* Browse list — two-column card grid replacing the old compact flat list */
  .article-list {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-5);
  }

  @media (min-width: 768px) {
    .article-list {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-6);
    }
  }
</style>
