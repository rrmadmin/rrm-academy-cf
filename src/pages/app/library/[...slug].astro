---
import AppShell from '../../../layouts/AppShell.astro';
import Citation from '../../../components/Citation.astro';
import TopicTag from '../../../components/TopicTag.astro';
import ArticleCard from '../../../components/ArticleCard.astro';
import LibraryFundingCallout from '../../../components/LibraryFundingCallout.astro';
import { fetchAllArticles, getRelatedArticles, type Article } from '../../../lib/airtable';
import { parseStructuredAbstract } from '../../../lib/abstract-parser';

export async function getStaticPaths() {
  const articles = await fetchAllArticles();

  return articles.map(article => ({
    params: { slug: article.slug },
    props: { article, allArticles: articles },
  }));
}

interface Props {
  article: Article;
  allArticles: Article[];
}

const { article, allArticles } = Astro.props;
const related = getRelatedArticles(article, allArticles, 4);
const abstractSections = parseStructuredAbstract(article.abstract);

// Build journal citation line
const journalParts: string[] = [];
if (article.journal) journalParts.push(article.journal);
if (article.volume) {
  let vol = article.volume;
  if (article.issue) vol += `(${article.issue})`;
  journalParts.push(vol);
}
if (article.pages) journalParts.push(article.pages);
const journalLine = journalParts.join(', ');

// Build description for meta
const metaDescription = article.abstract
  ? article.abstract.slice(0, 155) + (article.abstract.length > 155 ? '...' : '')
  : `${article.title} - RRM Research Library`;

// Build DOI URL
const doiUrl = article.doi ? `https://doi.org/${article.doi}` : '';
const pubmedUrl = article.pmid ? `https://pubmed.ncbi.nlm.nih.gov/${article.pmid}/` : '';

// Parse pages for schema
const pageMatch = article.pages?.match(/^(\d+)\s*[-–]\s*(\d+)$/);
const pageStart = pageMatch ? pageMatch[1] : article.pages || undefined;
const pageEnd = pageMatch ? pageMatch[2] : undefined;

// Schema.org JSON-LD
const jsonLd: any = {
  '@context': 'https://schema.org',
  '@type': 'MedicalScholarlyArticle',
  name: article.title,
  url: `https://rrmacademy.org/library/${article.slug}/`,
  publisher: {
    '@type': 'Organization',
    name: 'RRM Academy',
    url: 'https://rrmacademy.org',
  },
};

if (article.authors) {
  jsonLd.author = article.authors.split(',').map(name => ({
    '@type': 'Person',
    name: name.trim(),
  }));
}

if (article.datePublished) {
  jsonLd.datePublished = article.datePublished;
}

if (article.abstract) {
  jsonLd.abstract = article.abstract;
}

if (article.journal) {
  const isPartOf: any = {
    '@type': 'Periodical',
    name: article.journal,
  };

  if (article.volume) {
    jsonLd.isPartOf = {
      '@type': 'PublicationVolume',
      volumeNumber: article.volume,
      isPartOf: article.issue
        ? { '@type': 'PublicationIssue', issueNumber: article.issue, isPartOf: isPartOf }
        : isPartOf,
    };
  } else {
    jsonLd.isPartOf = isPartOf;
  }
}

if (pageStart) jsonLd.pageStart = pageStart;
if (pageEnd) jsonLd.pageEnd = pageEnd;

const identifiers: any[] = [];
if (article.doi) {
  identifiers.push({ '@type': 'PropertyValue', propertyID: 'doi', value: article.doi });
  jsonLd.sameAs = doiUrl;
}
if (article.pmid) {
  identifiers.push({ '@type': 'PropertyValue', propertyID: 'PMID', value: article.pmid });
}
if (identifiers.length) jsonLd.identifier = identifiers;

// OA metadata
if (article.accessLevel === 'open' || article.accessLevel === 'free') {
  jsonLd.isAccessibleForFree = true;
} else {
  jsonLd.isAccessibleForFree = false;
}

// License URL
const LICENSE_URLS: Record<string, string> = {
  'CC-BY': 'https://creativecommons.org/licenses/by/4.0/',
  'CC-BY-SA': 'https://creativecommons.org/licenses/by-sa/4.0/',
  'CC-BY-NC': 'https://creativecommons.org/licenses/by-nc/4.0/',
  'CC-BY-NC-SA': 'https://creativecommons.org/licenses/by-nc-sa/4.0/',
  'CC-BY-ND': 'https://creativecommons.org/licenses/by-nd/4.0/',
  'CC-BY-NC-ND': 'https://creativecommons.org/licenses/by-nc-nd/4.0/',
  'CC0': 'https://creativecommons.org/publicdomain/zero/1.0/',
};
if (article.license && LICENSE_URLS[article.license]) {
  jsonLd.license = LICENSE_URLS[article.license];
}

// Source link only when there's no DOI (non-journal sources need it; DOI covers journal articles)
const showSourceLink = article.sourceUrl && !article.doi;
// Free full text only when oaUrl differs from both sourceUrl and DOI
const showFreeFullText = article.oaUrl
  && article.oaUrl !== article.sourceUrl
  && article.oaUrl !== (article.doi ? `https://doi.org/${article.doi}` : '');

const canonicalUrl = `https://rrmacademy.org/library/${article.slug}/`;

// Format published date for display
function formatPublishDate(dateStr?: string, year?: number): string | null {
  if (dateStr) {
    try {
      const d = new Date(dateStr);
      return d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
    } catch { /* fall through */ }
  }
  if (year) return String(year);
  return null;
}
const publishedDisplay = formatPublishDate(article.datePublished, article.year);

// Highwire Press citation meta for Zotero Connector
const citationAuthors = article.authors?.split(';').map(a => a.trim()).filter(Boolean) || [];
const citationDate = article.datePublished?.split('T')[0]?.replace(/-/g, '/') || (article.year ? String(article.year) : undefined);
// Parse pages broadly for Highwire (handles S42-S48, e123-e130, etc.)
const hwPages = article.pages?.split(/[-–]/).map(p => p.trim()) || [];
const citationMeta = {
  title: article.title,
  authors: citationAuthors,
  date: citationDate,
  journal: article.journal || undefined,
  journalAbbrev: article.journalAbbv || undefined,
  volume: article.volume || undefined,
  issue: article.issue || undefined,
  firstPage: hwPages[0] || undefined,
  lastPage: hwPages[1] || undefined,
  doi: article.doi || undefined,
  pmid: article.pmid || undefined,
  abstract: article.abstract || undefined,
  keywords: article.topics.length > 0 ? article.topics.join('; ') : undefined,
};
---
<AppShell
  bodyClass="page-library page-library-article page-synopsis"
  title={article.title}
  description={metaDescription}
  canonicalUrl={canonicalUrl}
  ogType="article"
  jsonLd={jsonLd}
  citationMeta={citationMeta}
>
  <div class="page-wrapper" data-pagefind-body>
    <span data-pagefind-meta="type:Research" style="display:none"></span>
    {article.rrmRelevance && <span data-pagefind-meta={`rrmRelevance:${article.rrmRelevance}`} style="display:none"></span>}
    {article.sentiment && <span data-pagefind-meta={`sentiment:${article.sentiment}`} style="display:none"></span>}
    <div class="container">
      <!-- Breadcrumb + Save -->
      <div class="article-topbar" data-pagefind-ignore>
        <nav class="breadcrumb" aria-label="Breadcrumb">
          <a href="/app/library/">Research Library</a>
          <span aria-hidden="true"> &rsaquo; </span>
          <span>Synopsis</span>
        </nav>
        <div class="topbar-actions">
          <button
            class="action-btn"
            id="share-btn"
            aria-label="Copy link"
            title="Copy link"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 17 5-5-5-5"/><path d="M4 18v-2a4 4 0 0 1 4-4h12"/></svg>
            <span class="action-label" id="share-label"></span>
          </button>
          <button
            class="action-btn"
            id="cite-btn"
            aria-label="Download citation"
            title="Download citation (.RIS)"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            <span class="action-label" id="cite-label"></span>
          </button>
          <button
            class="action-btn"
            id="save-btn"
            aria-label="Save article"
            data-slug={article.slug}
            data-title={article.title}
            data-authors={article.shortCitation || ''}
            data-journal={article.journal || article.journalAbbv || ''}
            data-journal-abbv={article.journalAbbv || ''}
            data-year={article.year || ''}
            data-doi={article.doi || ''}
            data-pmid={article.pmid || ''}
            data-volume={article.volume || ''}
            data-issue={article.issue || ''}
            data-pages={article.pages || ''}
            data-date-published={article.datePublished || ''}
            data-abstract={article.abstract || ''}
            data-topics={article.topics.join(';')}
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/></svg>
            <span class="action-label" id="save-label"></span>
          </button>
        </div>
      </div>

      <!-- Journal badge + published date -->
      <div class="article-header-meta">
        <div class="article-header-meta__left">
          {article.journal && (
            <span class="journal-badge">{article.journal}</span>
          )}
          {publishedDisplay && (
            <span class="publish-date">Published: {publishedDisplay}</span>
          )}
          {article.accessLevel === 'open' && (
            <span class="access-badge access-badge--open" title={article.oaType ? `${article.oaType} Open Access` : 'Open Access'}>
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 9.9-1"/></svg>
              Open Access
            </span>
          )}
          {article.accessLevel === 'free' && (
            <span class="access-badge access-badge--free" title="Free to Read (Bronze OA)">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 9.9-1"/></svg>
              Free to Read
            </span>
          )}
          {(article.sentiment === 'hostile' || article.sentiment === 'critical') && (
            <span class={`access-badge access-badge--${article.sentiment === 'hostile' ? 'hostile' : 'critical'}`}
              title={article.sentiment === 'hostile'
                ? 'This article is hostile or in bad faith toward restorative reproductive medicine'
                : 'This article is critical or opposed to restorative reproductive medicine'}>
              {article.sentiment === 'hostile' ? 'Hostile' : 'Critical'}
            </span>
          )}
        </div>
      </div>

      <!-- Title -->
      <h1 class="article-title" data-pagefind-weight="10" data-pagefind-meta="title">{article.title}</h1>

      {article.year && (
        <span data-pagefind-meta={`year:${article.year}`} style="display:none"></span>
      )}

      <!-- Authors + Identifiers row -->
      <div class="article-details-row" data-pagefind-ignore>
        <div class="article-details-col">
          <span class="article-details-label">Authors</span>
          {article.authors ? (
            <p class="article-details-value" data-pagefind-weight="5" data-pagefind-meta="authors">{article.authors}</p>
          ) : (
            <p class="article-details-value article-details-value--empty">—</p>
          )}
        </div>
        <div class="article-details-col">
          <span class="article-details-label">Identifiers</span>
          <div class="article-ids">
            {article.doi && (
              <span class="article-id">
                <span class="article-id__label">DOI:</span>
                <a href={doiUrl} class="article-id__value" target="_blank" rel="noopener">{article.doi}</a>
              </span>
            )}
            {article.pmid && (
              <span class="article-id">
                <span class="article-id__label">PMID:</span>
                <a href={pubmedUrl} class="article-id__value" target="_blank" rel="noopener">{article.pmid}</a>
              </span>
            )}
            {article.license && (
              <span class="article-id">
                <span class="article-id__label">License:</span>
                <span class="article-id__license">{article.license}</span>
              </span>
            )}
            {showSourceLink && (
              <a href={article.sourceUrl} class="external-link" target="_blank" rel="noopener">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                Source
              </a>
            )}
            {showFreeFullText && (
              <a href={article.oaUrl} class="external-link" target="_blank" rel="noopener">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                Free full text
              </a>
            )}
          </div>
        </div>
      </div>

      <div class="article-layout">
        <main class="article-main">

      <!-- Synopsis (above abstract for SEO/AEO -- structured, citable content first) -->
      {article.insights && (
        <section class="article-insights" aria-label="Synopsis">
          <h2 class="detail-heading">Synopsis</h2>
          <div class="insights-tldr">
            <p>{article.insights.tldr}</p>
          </div>
          {article.insights.key_findings && article.insights.key_findings.length > 0 && (
            <div class="insights-findings">
              <h3 class="insights-subheading">Key Findings</h3>
              <ul>
                {article.insights.key_findings.map(finding => (
                  <li>{finding}</li>
                ))}
              </ul>
            </div>
          )}
          {article.insights.clinical_implications && (
            <div class="insights-relevance">
              <h3 class="insights-subheading">Clinical Implications</h3>
              <p>{article.insights.clinical_implications}</p>
            </div>
          )}
          {article.insights.rrm_context && (
            <div class="insights-context">
              <h3 class="insights-subheading">RRM Context</h3>
              <p>{article.insights.rrm_context}</p>
            </div>
          )}
        </section>
      )}

      <!-- Abstract -->
      <section class="abstract" aria-label="Abstract">
        <h2 class="detail-heading">Abstract</h2>
        {abstractSections.length === 0 ? (
          <p class="abstract-empty">No abstract available for this article.</p>
        ) : (
          abstractSections.map(section => (
            <div class="abstract-section">
              {section.heading && (
                <span class="abstract-heading">{section.heading}</span>
              )}
              {section.text.split(/\n/).filter(p => p.trim()).map(para => (
                <p>{para.trim()}</p>
              ))}
            </div>
          ))
        )}
      </section>

      <!-- Topics -->
      {article.topics.length > 0 && (
        <section class="article-topics" aria-label="Topics">
          <h2 class="detail-heading">Topics</h2>
          <div class="topic-grid" data-pagefind-weight="3">
            {article.topics.map(topic => (
              <TopicTag topic={topic} />
            ))}
          </div>
        </section>
      )}

      {article.searchTerms.length > 0 && (
        <div data-pagefind-weight="4" style="position:absolute;width:1px;height:1px;overflow:hidden;clip:rect(0,0,0,0)">
          {article.searchTerms.join(', ')}
        </div>
      )}
        </main>

        <aside class="article-sidebar">
          <!-- Citations -->
      {(article.apaCitation || article.vancouverCitation || article.mlaCitation) && (
        <section class="article-citations" aria-label="Citations" data-pagefind-ignore="all">
          <h2 class="detail-heading">Cite this article</h2>
          <Citation
            apa={article.apaCitation}
            vancouver={article.vancouverCitation}
            mla={article.mlaCitation}
          />
        </section>
      )}

      <!-- Keywords -->
      {article.keywords && (
        <section class="article-keywords" aria-label="Keywords">
          <h2 class="detail-heading">Keywords</h2>
          <p class="keywords-text">{article.keywords}</p>
        </section>
      )}

      <!-- Funding callout -->
      <LibraryFundingCallout />

      <!-- Related articles -->
      {related.length > 0 && (
        <section class="article-related" aria-label="Related articles" data-pagefind-ignore="all">
          <h2 class="detail-heading">Related articles</h2>
          <div class="related-grid">
            {related.map(rel => (
              <ArticleCard article={rel} basePath="/app/library/" />
            ))}
          </div>
        </section>
      )}
        </aside>
      </div>
    </div>
  </div>
</AppShell>

<style>
  .article-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
  }
  @media (min-width: 1024px) {
    .article-layout {
      grid-template-columns: minmax(0, 1fr) 340px;
      gap: var(--space-12);
      align-items: start;
    }
  }
  .article-sidebar {
    position: sticky;
    top: var(--space-8);
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }
  .article-sidebar > section {
    margin: 0;
    padding: 0;
    border: none;
  }
  
  /* Article header meta: journal badge + date */
  .article-header-meta {
    margin-bottom: var(--space-5);
  }
  .article-header-meta__left {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-3);
  }
  .journal-badge {
    display: inline-block;
    font-family: 'Inter', sans-serif;
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--purple-700);
    background: var(--purple-50);
    padding: 3px 10px;
    border-radius: var(--radius-sm);
    line-height: 1.4;
  }
  .publish-date {
    font-family: 'Inter', sans-serif;
    font-size: 0.8125rem;
    color: var(--text-tertiary);
    font-weight: 400;
  }

  /* Display title */
  .article-title {
    font-family: 'Cormorant Garamond', 'Georgia', serif;
    font-size: clamp(2.5rem, 2rem + 3vw, 4rem);
    font-weight: 700;
    line-height: 1.08;
    letter-spacing: -0.025em;
    color: var(--text-primary);
    margin-bottom: var(--space-10, 3rem);
    max-width: 52ch;
  }

  /* Authors + Identifiers two-column row */
  .article-details-row {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-5);
    border-top: 1px solid var(--border-color);
    padding-top: var(--space-5);
    margin-bottom: var(--space-8);
  }
  @media (min-width: 640px) {
    .article-details-row {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-8);
    }
  }
  .article-details-label {
    display: block;
    font-family: 'Inter', sans-serif;
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-tertiary);
    margin-bottom: var(--space-2);
  }
  .article-details-value {
    font-family: 'Cormorant Garamond', 'Georgia', serif;
    font-size: 1rem;
    font-style: italic;
    line-height: 1.5;
    color: var(--text-secondary);
    margin: 0;
  }
  .article-details-value--empty {
    color: var(--text-muted);
  }
  .article-ids {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    font-size: 0.8125rem;
  }
  .article-id {
    display: inline-flex;
    align-items: baseline;
    gap: 4px;
  }
  .article-id__label {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--text-tertiary);
  }
  .article-id__value {
    color: var(--text-secondary);
    text-decoration: none;
    transition: color 0.15s;
  }
  .article-id__value:hover {
    color: var(--accent);
    text-decoration: underline;
  }
  .article-id__license {
    color: var(--neutral-600);
    font-size: 0.8125rem;
  }
  .external-link {
    font-size: 0.8125rem;
  }

  .abstract {
    background: transparent;
    border: none;
    border-top: 1px solid var(--border-light, var(--border-color));
    border-radius: 0;
    padding: var(--space-6) 0 0 0;
    margin-bottom: var(--space-8);
  }
  .abstract-empty {
    color: var(--neutral-500);
    font-style: italic;
    font-size: 0.875rem;
  }
  .detail-heading {
    font-family: 'Cormorant Garamond', 'Georgia', serif;
    font-size: 1.375rem;
    font-weight: 600;
    margin-bottom: var(--space-4);
    color: var(--neutral-900);
  }
  .article-insights {
    background: var(--bg-surface);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md, 8px);
    padding: var(--space-8);
    margin-bottom: var(--space-8);
  }
  .article-insights .detail-heading {
    font-size: 1.375rem;
    margin-top: 0;
    margin-bottom: var(--space-4);
  }
  .insights-tldr {
    font-size: 1rem;
    font-weight: 500;
    line-height: 1.6;
    color: var(--text-primary);
    margin-bottom: var(--space-6);
  }
  .insights-subheading {
    font-family: 'Cormorant Garamond', 'Georgia', serif;
    font-size: 1.0625rem;
    font-weight: 600;
    text-transform: none;
    letter-spacing: normal;
    color: var(--text-primary);
    margin-bottom: var(--space-3);
  }
  .insights-findings {
    margin-bottom: var(--space-5);
  }
  .insights-findings ul {
    list-style: disc;
    padding-left: var(--space-5);
    font-size: 0.9375rem;
    line-height: 1.7;
    color: var(--text-secondary);
  }
  .insights-findings li {
    margin-bottom: var(--space-2);
  }
  .insights-relevance,
  .insights-context {
    margin-bottom: var(--space-4);
  }
  .insights-relevance p,
  .insights-context p {
    font-size: 0.9375rem;
    line-height: 1.7;
    color: var(--text-secondary);
  }
  .article-topics {
    margin-bottom: var(--space-8);
  }
  .article-citations {
    margin-bottom: var(--space-8);
  }
  .article-keywords {
    margin-bottom: var(--space-8);
  }
  .keywords-text {
    font-size: 0.875rem;
    color: var(--neutral-600);
    line-height: 1.7;
  }
  .related-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-5);
  }
  @media (min-width: 640px) and (max-width: 1023px) {
    .related-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  /* Topbar: breadcrumb + save button */
  .article-topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    margin-bottom: var(--space-6);
  }
  @media (min-width: 1024px) {
    .article-topbar {
      display: grid;
      grid-template-columns: minmax(0, 1fr) 340px;
      gap: var(--space-12);
      align-items: center;
    }
  }

  .article-topbar .breadcrumb {
    margin-bottom: 0;
  }

  .topbar-actions {
    display: flex;
    align-items: center;
    gap: 6px;
    justify-self: end;
  }
  .action-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 4px;
    padding: 4px;
    font-size: 0.6875rem;
    font-weight: 500;
    font-family: 'Inter', sans-serif;
    color: var(--text-muted);
    background: none;
    border: none;
    cursor: pointer;
    transition: color 0.15s;
    white-space: nowrap;
  }
  .action-label:empty {
    display: none;
  }
  .action-btn:hover {
    color: var(--accent);
  }
  .action-btn.copied {
    color: var(--accent);
  }
  .action-btn.saved {
    color: var(--accent);
  }
  .action-btn.saved svg {
    fill: var(--accent);
  }

  @media (max-width: 768px) {
    .article-title {
      font-size: 2.25rem;
    }
    .journal-badge {
      font-size: 0.625rem;
    }
  }
</style>

<script is:inline>
  // Share / copy link button
  (function() {
    var shareBtn = document.getElementById('share-btn');
    var shareLabel = document.getElementById('share-label');
    if (!shareBtn) return;
    shareBtn.addEventListener('click', function() {
      var url = window.location.href;
      if (navigator.clipboard && navigator.clipboard.writeText) {
        navigator.clipboard.writeText(url).then(function() {
          shareBtn.classList.add('copied');
          shareLabel.textContent = 'Copied!';
          setTimeout(function() {
            shareBtn.classList.remove('copied');
            shareLabel.textContent = '';
          }, 2000);
        });
      } else {
        // Fallback
        var input = document.createElement('input');
        input.value = url;
        document.body.appendChild(input);
        input.select();
        document.execCommand('copy');
        document.body.removeChild(input);
        shareBtn.classList.add('copied');
        shareLabel.textContent = 'Copied!';
        setTimeout(function() {
          shareBtn.classList.remove('copied');
          shareLabel.textContent = '';
        }, 2000);
      }
    });
  })();

  // RIS citation generation (shared by download button + batch export)
  function generateRIS(d) {
    var lines = ['TY  - JOUR'];
    var authors = (d.authors || '').split(/[,;]/);
    for (var i = 0; i < authors.length; i++) {
      var a = authors[i].trim();
      if (a) lines.push('AU  - ' + a);
    }
    if (d.title) lines.push('TI  - ' + d.title);
    if (d.journal) lines.push('T2  - ' + d.journal);
    if (d.journalAbbv) lines.push('JO  - ' + d.journalAbbv);
    if (d.abstract) lines.push('AB  - ' + d.abstract);
    if (d.datePublished) lines.push('DA  - ' + d.datePublished.replace(/-/g, '/'));
    if (d.year) lines.push('PY  - ' + d.year);
    if (d.volume) lines.push('VL  - ' + d.volume);
    if (d.issue) lines.push('IS  - ' + d.issue);
    if (d.pages) {
      var parts = d.pages.split(/[-\u2013]/);
      if (parts[0]) lines.push('SP  - ' + parts[0].trim());
      if (parts[1]) lines.push('EP  - ' + parts[1].trim());
    }
    if (d.doi) {
      lines.push('DO  - ' + d.doi);
      lines.push('UR  - https://doi.org/' + d.doi);
    }
    if (d.pmid) lines.push('N1  - PMID: ' + d.pmid);
    if (d.topics) {
      var topics = d.topics.split(';');
      for (var j = 0; j < topics.length; j++) {
        var t = topics[j].trim();
        if (t) lines.push('KW  - ' + t);
      }
    }
    if (d.slug) lines.push('UR  - https://rrmacademy.org/library/' + d.slug + '/');
    lines.push('ER  - ');
    return lines.join('\n') + '\n';
  }

  function downloadRIS(content, filename) {
    var blob = new Blob([content], { type: 'application/x-research-info-systems' });
    var url = URL.createObjectURL(blob);
    var a = document.createElement('a');
    a.href = url;
    a.download = filename;
    a.click();
    URL.revokeObjectURL(url);
  }

  // Download citation button
  (function() {
    var citeBtn = document.getElementById('cite-btn');
    var citeLabel = document.getElementById('cite-label');
    var saveBtn = document.getElementById('save-btn');
    if (!citeBtn || !saveBtn) return;
    citeBtn.addEventListener('click', function() {
      var d = saveBtn.dataset;
      var ris = generateRIS(d);
      var fname = (d.doi || d.pmid || d.slug || 'citation').replace(/[\/\\]/g, '_') + '.ris';
      downloadRIS(ris, fname);
      citeBtn.classList.add('copied');
      citeLabel.textContent = 'Downloaded!';
      setTimeout(function() {
        citeBtn.classList.remove('copied');
        citeLabel.textContent = '';
      }, 2000);
    });
  })();

  // Save article button
  (function() {
    var KEY = 'rrm_saved';
    var btn = document.getElementById('save-btn');
    var saveLabel = document.getElementById('save-label');
    if (!btn) return;

    function getSaved() {
      try { return JSON.parse(localStorage.getItem(KEY) || '[]'); }
      catch(e) { return []; }
    }

    function setSaved(items) {
      localStorage.setItem(KEY, JSON.stringify(items));
    }

    var slug = btn.dataset.slug;
    var saved = getSaved();
    var isSaved = saved.some(function(s) { return s.slug === slug; });

    // Color the icon if already saved
    if (isSaved) btn.classList.add('saved');

    // Update header badge
    function updateBadge() {
      var badge = document.getElementById('saved-count');
      var mobileBadge = document.getElementById('mobile-saved-count');
      var link = document.getElementById('saved-link');
      var mobileLink = document.getElementById('mobile-saved-link');
      if (badge) badge.textContent = saved.length;
      if (mobileBadge) mobileBadge.textContent = saved.length;
      if (saved.length > 0) {
        if (link) link.classList.add('has-items');
        if (mobileLink) mobileLink.classList.add('has-items');
      } else {
        if (link) link.classList.remove('has-items');
        if (mobileLink) mobileLink.classList.remove('has-items');
      }
    }

    // Server-side save/unsave (fire-and-forget for logged-in users)
    function serverSave(article) {
      fetch('/api/saved', {
        method: 'POST',
        credentials: 'same-origin',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ article: article })
      }).catch(function() {});
    }
    function serverUnsave(articleSlug) {
      fetch('/api/saved', {
        method: 'DELETE',
        credentials: 'same-origin',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ slug: articleSlug })
      }).catch(function() {});
    }

    btn.addEventListener('click', function() {
      saved = getSaved();
      var d = btn.dataset;
      if (isSaved) {
        saved = saved.filter(function(s) { return s.slug !== slug; });
        isSaved = false;
        btn.classList.remove('saved');
        saveLabel.textContent = '';
        serverUnsave(slug);
      } else {
        var article = {
          slug: d.slug,
          title: d.title,
          authors: d.authors,
          journal: d.journal,
          journalAbbv: d.journalAbbv,
          year: d.year,
          doi: d.doi,
          pmid: d.pmid,
          volume: d.volume,
          issue: d.issue,
          pages: d.pages,
          datePublished: d.datePublished,
          abstract: d.abstract,
          topics: d.topics,
          savedAt: new Date().toISOString()
        };
        saved.unshift(article);
        isSaved = true;
        btn.classList.add('saved');
        saveLabel.textContent = 'Saved!';
        btn.classList.add('copied');
        setTimeout(function() {
          saveLabel.textContent = '';
          btn.classList.remove('copied');
        }, 2000);
        serverSave(article);
      }
      setSaved(saved);
      updateBadge();
    });
  })();
</script>
