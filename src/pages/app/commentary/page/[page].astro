---
import AppShell from '../../../../layouts/AppShell.astro';
import BlogCard from '../../../components/BlogCard.astro';
import { fetchAllPosts } from '../../../lib/blog';

export async function getStaticPaths() {
  const PER_PAGE = 6;
  const posts = await fetchAllPosts();
  const totalPages = Math.max(1, Math.ceil(posts.length / PER_PAGE));

  // Page 1 is /commentary/ (index.astro) — skip it here to avoid duplicate content
  return Array.from({ length: totalPages - 1 }, (_, i) => ({
    params: { page: String(i + 2) },
    props: { currentPage: i + 2, totalPages },
  }));
}

interface Props {
  currentPage: number;
  totalPages: number;
}

const PER_PAGE = 6;
const { currentPage, totalPages } = Astro.props;
const posts = await fetchAllPosts();
const start = (currentPage - 1) * PER_PAGE;
const pagePosts = posts.slice(start, start + PER_PAGE);

// Pagination range
const range: (number | '...')[] = [];
const delta = 2;
for (let i = 1; i <= totalPages; i++) {
  if (i === 1 || i === totalPages || (i >= currentPage - delta && i <= currentPage + delta)) {
    range.push(i);
  } else if (range[range.length - 1] !== '...') {
    range.push('...');
  }
}
---
<AppShell
  title={`RRM Articles & Commentary - Page ${currentPage}`}
  description={`Page ${currentPage} of ${totalPages} - Clinical perspectives on endometriosis, fertility, and restorative reproductive medicine from Dr. Naomi Whittaker.`}
  canonicalUrl={`https://rrmacademy.org/commentary/page/${currentPage}`}
>
  <section class="browse-page" data-pagefind-ignore="all">
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/commentary/">Commentary</a>
        <span aria-hidden="true"> &rsaquo; </span>
        <span>Page {currentPage}</span>
      </nav>

      <div class="browse-header">
        <div>
          <h1>RRM Articles &amp; Commentary</h1>
          <p class="browse-subtitle">Clinical perspectives on endometriosis, fertility awareness, NaProTechnology, and restorative reproductive medicine from <a href="/about/">Dr. Naomi Whittaker</a>.</p>
          {pagePosts.length > 0 && (
            <p class="browse-meta">
              Showing {start + 1}&ndash;{Math.min(start + PER_PAGE, posts.length)} of {posts.length}
            </p>
          )}
        </div>
      </div>

      {pagePosts.length > 0 ? (
        <div class="blog-grid">
          {pagePosts.map((post, i) => (
            <BlogCard post={post} eager={i < 3} basePath="/app/commentary/" />
          ))}
        </div>
      ) : (
        <p class="empty-state">No commentary posts yet.</p>
      )}

      <nav class="pagination" aria-label="Pagination">
        {currentPage > 1 && (
          <a href={currentPage === 2 ? '/app/commentary/' : `/app/commentary/page/${currentPage - 1}/`}>&laquo; Prev</a>
        )}
        {range.map(item => (
          item === '...' ? (
            <span class="ellipsis">&hellip;</span>
          ) : item === currentPage ? (
            <span class="current">{item}</span>
          ) : (
            <a href={item === 1 ? '/app/commentary/' : `/app/commentary/page/${item}/`}>{item}</a>
          )
        ))}
        {currentPage < totalPages && (
          <a href={`/app/commentary/page/${currentPage + 1}/`}>Next &raquo;</a>
        )}
      </nav>
    </div>
  </section>
</AppShell>

<style>
  h1 {
    margin-bottom: var(--space-2);
  }
  .browse-subtitle {
    font-family: 'Inter', sans-serif;
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--text-secondary);
    max-width: 600px;
    margin-bottom: var(--space-4);
  }
  .browse-subtitle a {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .browse-subtitle a:hover {
    color: var(--accent-hover);
  }
</style>
