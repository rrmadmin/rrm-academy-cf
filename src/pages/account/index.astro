---
import BaseLayout from '../../layouts/BaseLayout.astro';
import coursesData from '../../data/courses.json';

const courseMetaMap: Record<string, { title: string; slug: string; image: string }> = {};
for (const c of coursesData) {
  courseMetaMap[c.id] = { title: c.title, slug: c.slug, image: c.image };
}
---
<BaseLayout
  title="My Account"
  description="Manage your RRM Academy account, courses, and membership."
  canonicalUrl="https://rrmacademy.org/account"
  noindex
>
  <section class="auth-page">
    <div class="container container--narrow">

      <!-- Loading state -->
      <div id="account-loading" class="account-loading">
        <p>Loading your account...</p>
      </div>

      <!-- Not logged in -->
      <div id="account-guest" class="auth-card" hidden>
        <h1>My Account</h1>
        <p class="auth-intro">Please log in to access your account.</p>
        <a href="/login/" class="btn btn--primary auth-submit">Log in</a>
        <div class="auth-links">
          <span>Don't have an account?</span>
          <a href="/signup/">Create one</a>
        </div>
      </div>

      <!-- Logged in -->
      <div id="account-dashboard" hidden>
        <div class="account-header">
          <h1>Welcome, <span id="account-name"></span></h1>
          <button id="logout-btn" class="btn btn--secondary btn--sm">Log out</button>
        </div>

        <!-- Email verification banner -->
        <div id="verify-banner" class="account-banner account-banner--warning" hidden>
          <p>Your email is not verified. <button id="send-verify-btn" class="btn btn--text btn--sm">Send verification code</button></p>
        </div>

        <div class="account-sections">

          <!-- 1a. STUC member courses (gated, shown only to active members) -->
          <div class="account-section" id="member-courses-section" hidden>
            <div class="member-courses-header">
              <h2>Save the Uterus Club Courses</h2>
              <span id="member-courses-tier" class="member-courses-tier"></span>
            </div>
            <div id="member-courses-banner" class="member-courses-banner" hidden></div>
            <div id="member-courses-list" class="course-card-grid"></div>
          </div>

          <!-- 1b. Courses (highest engagement) -->
          <div class="account-section" id="courses-section">
            <h2>Courses</h2>
            <div id="courses-loading" class="account-placeholder">Loading courses...</div>
            <div id="courses-none" hidden>
              <p class="account-placeholder">You haven't enrolled in any courses yet.</p>
              <a href="/courses/" class="btn btn--secondary btn--sm" style="margin-top: var(--space-4); display: inline-flex;">Browse Courses</a>
            </div>
            <div id="courses-list" class="course-card-grid" hidden></div>
          </div>

          <!-- 2. Membership / billing -->
          <div class="account-section" id="billing-section">
            <h2>Membership</h2>
            <div id="billing-loading" class="account-placeholder">Loading billing info...</div>
            <div id="billing-none" hidden>
              <p class="account-placeholder">You don't have an active membership.</p>
              <a href="/save-the-uterus-club/" class="btn btn--secondary btn--sm" style="margin-top: var(--space-4); display: inline-flex;">Join the Save the Uterus Club</a>
            </div>
            <div id="billing-active" hidden>
              <dl class="account-details">
                <dt>Membership</dt>
                <dd id="billing-tier"></dd>
                <dt>Status</dt>
                <dd id="billing-status"></dd>
                <dt>Next donation</dt>
                <dd id="billing-date"></dd>
              </dl>
              <p id="billing-cancel-notice" class="billing-cancel-notice" hidden>Your membership will end at the next donation date.</p>
              <button id="manage-billing-btn" class="btn btn--secondary btn--sm" style="margin-top: var(--space-4);">Manage Billing</button>
              <div id="manage-billing-wix-note" hidden class="billing-wix-note">
                <p>Your recurring donation is processed through our legacy platform. To update your card, change your amount, or cancel, email <a href="mailto:support@rrmacademy.org">support@rrmacademy.org</a> — we'll respond within 1 business day.</p>
              </div>
              <div id="billing-payments" hidden>
                <h3 class="billing-history-heading">Payment History</h3>
                <div id="payments-list" class="donations-list"></div>
                <button id="payments-show-all" class="btn btn--text btn--sm history-toggle" hidden>Show all</button>
              </div>
            </div>
            <div id="billing-donations" hidden>
              <h3 class="billing-history-heading">Donation History</h3>
              <div id="donations-list" class="donations-list"></div>
              <button id="donations-show-all" class="btn btn--text btn--sm history-toggle" hidden>Show all</button>
            </div>
          </div>

          <!-- 3. Saved articles (placeholder slot) -->
          <div class="account-section" id="saved-section">
            <h2>Saved Articles</h2>
            <p class="account-placeholder">Articles you've bookmarked from the Research Library.</p>
            <a href="/library/saved/" class="btn btn--secondary btn--sm" style="margin-top: var(--space-4); display: inline-flex;">View saved articles</a>
          </div>

          <!-- 4. Profile + Password -->
          <div class="account-section">
            <div class="profile-password-grid">
              <!-- Profile column -->
              <div class="profile-col">
                <div class="section-header">
                  <h2>Profile</h2>
                  <button id="edit-profile-btn" class="btn btn--text btn--sm" hidden>Edit</button>
                </div>

                <!-- Read-only display -->
                <dl id="profile-display" class="account-details">
                  <dt>First name</dt>
                  <dd id="profile-first-name"></dd>
                  <dt>Last name</dt>
                  <dd id="profile-last-name"></dd>
                  <dt>Email</dt>
                  <dd id="profile-email"></dd>
                  <dt>Member since</dt>
                  <dd id="profile-since">--</dd>
                </dl>

                <!-- Edit form -->
                <form id="profile-form" class="profile-edit-form" hidden>
                  <div class="form-row">
                    <div class="form-group">
                      <label class="form-label" for="edit-first-name">First name</label>
                      <input class="form-input" type="text" id="edit-first-name" name="firstName" required maxlength="100" autocomplete="given-name" />
                    </div>
                    <div class="form-group">
                      <label class="form-label" for="edit-last-name">Last name</label>
                      <input class="form-input" type="text" id="edit-last-name" name="lastName" required maxlength="100" autocomplete="family-name" />
                    </div>
                  </div>
                  <div class="form-group">
                    <label class="form-label">Email</label>
                    <input class="form-input" type="email" id="edit-email" disabled />
                  </div>
                  <div id="profile-error" class="profile-feedback profile-feedback--error" hidden>
                    <p id="profile-error-text"></p>
                  </div>
                  <div class="profile-actions">
                    <button type="submit" class="btn btn--primary btn--sm" id="save-profile-btn">Save</button>
                    <button type="button" class="btn btn--secondary btn--sm" id="cancel-profile-btn">Cancel</button>
                  </div>
                </form>
              </div>

              <!-- Password column -->
              <div class="password-col">
                <div class="section-header">
                  <h2>Password</h2>
                  <button id="change-pw-btn" class="btn btn--text btn--sm" hidden>Change</button>
                </div>
                <p id="pw-display" class="account-placeholder">••••••••</p>
                <form id="pw-form" class="profile-edit-form" hidden>
                  <div class="form-group">
                    <label class="form-label" for="pw-current">Current password</label>
                    <input class="form-input" type="password" id="pw-current" required autocomplete="current-password" />
                  </div>
                  <div class="form-group">
                    <label class="form-label" for="pw-new">New password</label>
                    <input class="form-input" type="password" id="pw-new" required minlength="8" autocomplete="new-password" />
                  </div>
                  <div class="form-group">
                    <label class="form-label" for="pw-confirm">Confirm new password</label>
                    <input class="form-input" type="password" id="pw-confirm" required minlength="8" autocomplete="new-password" />
                  </div>
                  <div id="pw-error" class="profile-feedback profile-feedback--error" hidden>
                    <p id="pw-error-text"></p>
                  </div>
                  <div id="pw-success" class="profile-feedback profile-feedback--success" hidden>
                    <p>Password updated successfully.</p>
                  </div>
                  <div class="profile-actions">
                    <button type="submit" class="btn btn--primary btn--sm" id="save-pw-btn">Update Password</button>
                    <button type="button" class="btn btn--secondary btn--sm" id="cancel-pw-btn">Cancel</button>
                  </div>
                </form>
              </div>
            </div>
          </div>

          <!-- 5. MCP API keys (power-user) -->
          <div class="account-section" id="mcp-section">
            <h2>MCP API Keys</h2>
            <p class="account-placeholder">Connect Claude, ChatGPT, or Perplexity to the RRM Academy research library.</p>
            <a href="/account/mcp-keys/" class="btn btn--secondary btn--sm" style="margin-top: var(--space-4); display: inline-flex;">Manage keys</a>
          </div>

        </div>

        <!-- Course metadata for client-side rendering (cover images, titles, slugs from courses.json) -->
        <script type="application/json" id="course-meta-data" set:html={JSON.stringify(courseMetaMap)}></script>
      </div>

    </div>
  </section>

  <script is:inline>
    (function () {
      var loadingEl = document.getElementById('account-loading');
      var guestEl = document.getElementById('account-guest');
      var dashEl = document.getElementById('account-dashboard');
      var nameEl = document.getElementById('account-name');
      var profileFirstName = document.getElementById('profile-first-name');
      var profileLastName = document.getElementById('profile-last-name');
      var profileEmail = document.getElementById('profile-email');
      var verifyBanner = document.getElementById('verify-banner');
      var sendVerifyBtn = document.getElementById('send-verify-btn');
      var logoutBtn = document.getElementById('logout-btn');
      var editBtn = document.getElementById('edit-profile-btn');
      var profileDisplay = document.getElementById('profile-display');
      var profileForm = document.getElementById('profile-form');
      var editFirstName = document.getElementById('edit-first-name');
      var editLastName = document.getElementById('edit-last-name');
      var editEmail = document.getElementById('edit-email');
      var saveBtn = document.getElementById('save-profile-btn');
      var cancelBtn = document.getElementById('cancel-profile-btn');
      var profileError = document.getElementById('profile-error');
      var profileErrorText = document.getElementById('profile-error-text');
      var currentUser = null;

      fetch('/api/auth/session', { credentials: 'same-origin' })
        .then(function (r) { return r.json(); })
        .then(function (data) {
          loadingEl.hidden = true;
          if (!data.ok || !data.user) {
            guestEl.hidden = false;
            return;
          }
          currentUser = data.user;
          renderProfile(currentUser);
          if (!currentUser.emailVerified) verifyBanner.hidden = false;
          dashEl.hidden = false;
          showPwButton();
          loadBilling();
          loadCourses();
        })
        .catch(function () {
          loadingEl.hidden = true;
          guestEl.hidden = false;
        });

      function renderProfile(user) {
        nameEl.textContent = user.firstName || user.name || 'Member';
        profileFirstName.textContent = user.firstName || '--';
        profileLastName.textContent = user.lastName || '--';
        profileEmail.textContent = user.email;
        if (user.createdAt) {
          var d = new Date(user.createdAt.replace(' ', 'T') + 'Z');
          document.getElementById('profile-since').textContent = d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
        }
        editBtn.hidden = false;
      }

      editBtn.addEventListener('click', function () {
        editFirstName.value = currentUser.firstName || '';
        editLastName.value = currentUser.lastName || '';
        editEmail.value = currentUser.email;
        profileDisplay.hidden = true;
        editBtn.hidden = true;
        profileError.hidden = true;
        profileForm.hidden = false;
        editFirstName.focus();
      });

      cancelBtn.addEventListener('click', function () {
        profileForm.hidden = true;
        profileDisplay.hidden = false;
        editBtn.hidden = false;
        profileError.hidden = true;
      });

      profileForm.addEventListener('submit', function (e) {
        e.preventDefault();
        profileError.hidden = true;
        var fn = editFirstName.value.trim();
        var ln = editLastName.value.trim();
        if (!fn) { profileErrorText.textContent = 'First name is required.'; profileError.hidden = false; return; }
        if (!ln) { profileErrorText.textContent = 'Last name is required.'; profileError.hidden = false; return; }
        saveBtn.disabled = true; saveBtn.textContent = 'Saving...';
        fetch('/api/auth/profile', {
          method: 'PATCH', credentials: 'same-origin',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ firstName: fn, lastName: ln }),
        })
          .then(function (r) { return r.json(); })
          .then(function (data) {
            saveBtn.disabled = false; saveBtn.textContent = 'Save';
            if (data.ok) {
              currentUser.firstName = data.user.firstName;
              currentUser.lastName = data.user.lastName;
              currentUser.name = data.user.name;
              renderProfile(currentUser);
              profileForm.hidden = true;
              profileDisplay.hidden = false;
              editBtn.hidden = false;
            } else {
              profileErrorText.textContent = data.error || 'Update failed.';
              profileError.hidden = false;
            }
          })
          .catch(function () {
            saveBtn.disabled = false; saveBtn.textContent = 'Save';
            profileErrorText.textContent = 'Network error. Please try again.';
            profileError.hidden = false;
          });
      });

      logoutBtn.addEventListener('click', function () {
        fetch('/api/auth/logout', { method: 'POST', credentials: 'same-origin' })
          .then(function () { window.location.href = '/login/'; });
      });

      sendVerifyBtn.addEventListener('click', function () {
        sendVerifyBtn.disabled = true; sendVerifyBtn.textContent = 'Sending...';
        fetch('/api/auth/resend-verification', { method: 'POST', credentials: 'same-origin' })
          .then(function () { sendVerifyBtn.textContent = 'Sent! Check your email.'; });
      });

      // --- Password ---
      var changePwBtn = document.getElementById('change-pw-btn');
      var pwDisplay = document.getElementById('pw-display');
      var pwForm = document.getElementById('pw-form');
      var pwCurrent = document.getElementById('pw-current');
      var pwNew = document.getElementById('pw-new');
      var pwConfirm = document.getElementById('pw-confirm');
      var savePwBtn = document.getElementById('save-pw-btn');
      var cancelPwBtn = document.getElementById('cancel-pw-btn');
      var pwError = document.getElementById('pw-error');
      var pwErrorText = document.getElementById('pw-error-text');
      var pwSuccess = document.getElementById('pw-success');

      function showPwButton() { changePwBtn.hidden = false; }

      changePwBtn.addEventListener('click', function () {
        pwDisplay.hidden = true;
        changePwBtn.hidden = true;
        pwError.hidden = true;
        pwSuccess.hidden = true;
        pwForm.hidden = false;
        pwCurrent.value = '';
        pwNew.value = '';
        pwConfirm.value = '';
        pwCurrent.focus();
      });

      cancelPwBtn.addEventListener('click', function () {
        pwForm.hidden = true;
        pwDisplay.hidden = false;
        changePwBtn.hidden = false;
        pwError.hidden = true;
        pwSuccess.hidden = true;
      });

      pwForm.addEventListener('submit', function (e) {
        e.preventDefault();
        pwError.hidden = true;
        pwSuccess.hidden = true;
        if (pwNew.value !== pwConfirm.value) {
          pwErrorText.textContent = 'New passwords do not match.';
          pwError.hidden = false;
          return;
        }
        if (pwNew.value.length < 8) {
          pwErrorText.textContent = 'New password must be at least 8 characters.';
          pwError.hidden = false;
          return;
        }
        savePwBtn.disabled = true;
        savePwBtn.textContent = 'Updating...';
        fetch('/api/auth/change-password', {
          method: 'POST', credentials: 'same-origin',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ currentPassword: pwCurrent.value, newPassword: pwNew.value }),
        })
          .then(function (r) { return r.json(); })
          .then(function (data) {
            savePwBtn.disabled = false;
            savePwBtn.textContent = 'Update Password';
            if (data.ok) {
              pwForm.hidden = true;
              pwDisplay.hidden = false;
              changePwBtn.hidden = false;
              pwSuccess.hidden = false;
              setTimeout(function () { pwSuccess.hidden = true; }, 5000);
            } else {
              pwErrorText.textContent = data.error || 'Failed to update password.';
              pwError.hidden = false;
            }
          })
          .catch(function () {
            savePwBtn.disabled = false;
            savePwBtn.textContent = 'Update Password';
            pwErrorText.textContent = 'Network error. Please try again.';
            pwError.hidden = false;
          });
      });

      // --- Courses ---
      var courseMeta = {};
      try {
        var metaScript = document.getElementById('course-meta-data');
        if (metaScript) courseMeta = JSON.parse(metaScript.textContent || '{}');
      } catch (_e) {
        courseMeta = {};
      }

      var TIER_DISPLAY = { member: '🐻 Member', hero: '💖 Hero', superhero: '🦸‍♀️ Superhero', staff: 'Staff' };

      function renderCourseMini(c) {
        var meta = courseMeta[c.courseId] || { title: c.courseId, slug: c.courseId, image: '' };
        var pct = c.totalSteps > 0 ? Math.round((c.completedSteps / c.totalSteps) * 100) : 0;
        var completed = !!c.completedAt;
        var statusText = completed ? 'Completed' : (pct > 0 ? pct + '% complete' : 'Not started');
        var lessonText = c.completedSteps + ' / ' + c.totalSteps + ' lessons';
        var statusClass = completed ? 'course-mini__status--done' : (pct > 0 ? 'course-mini__status--progress' : 'course-mini__status--new');
        var imgHtml = meta.image
          ? '<img src="' + escapeHtml(meta.image) + '" alt="' + escapeHtml(meta.title) + '" loading="lazy" width="400" height="225">'
          : '<div class="course-mini__image-placeholder" aria-hidden="true"></div>';
        return '<a href="/courses/' + escapeHtml(meta.slug) + '/" class="course-mini">' +
          '<div class="course-mini__image">' + imgHtml + '</div>' +
          '<div class="course-mini__body">' +
            '<div class="course-mini__title">' + escapeHtml(meta.title) + '</div>' +
            '<div class="course-mini__bar" role="progressbar" aria-valuenow="' + pct + '" aria-valuemin="0" aria-valuemax="100">' +
              '<div class="course-mini__fill" style="width:' + pct + '%"></div>' +
            '</div>' +
            '<div class="course-mini__meta">' +
              '<span class="course-mini__status ' + statusClass + '">' + statusText + '</span>' +
              '<span class="course-mini__lessons">' + lessonText + '</span>' +
            '</div>' +
          '</div>' +
        '</a>';
      }

      function renderMemberSection(memberCourses) {
        var section = document.getElementById('member-courses-section');
        var listEl = document.getElementById('member-courses-list');
        var tierEl = document.getElementById('member-courses-tier');
        var bannerEl = document.getElementById('member-courses-banner');
        if (!section || !listEl) return;

        var html = '';
        for (var i = 0; i < memberCourses.length; i++) html += renderCourseMini(memberCourses[i]);
        listEl.innerHTML = html;
        section.hidden = false;

        // Decorate with membership status fetched from /api/community/status
        fetch('/api/community/status', { credentials: 'same-origin' })
          .then(function (r) { return r.json(); })
          .then(function (statusData) {
            if (!statusData || !statusData.ok) return;
            if (statusData.access === 'member' && statusData.user && statusData.user.tier) {
              if (tierEl) tierEl.textContent = 'Included with your ' + (TIER_DISPLAY[statusData.user.tier] || statusData.user.tier) + ' tier';
            } else {
              // Enrolled rows exist but membership is not active — show resume banner.
              if (bannerEl) {
                bannerEl.innerHTML = 'Your Save the Uterus Club membership has lapsed. Your progress is saved. <a href="/save-the-uterus-club/">Resume membership</a> to continue these courses.';
                bannerEl.hidden = false;
              }
            }
          })
          .catch(function () { /* leave decorations off on network error */ });
      }

      function loadCourses() {
        var coursesLoading = document.getElementById('courses-loading');
        var coursesNone = document.getElementById('courses-none');
        var coursesList = document.getElementById('courses-list');

        fetch('/api/courses/progress', { credentials: 'same-origin' })
          .then(function (r) { return r.json(); })
          .then(function (data) {
            coursesLoading.hidden = true;
            if (!data.ok || !data.courses || data.courses.length === 0) {
              coursesNone.hidden = false;
              return;
            }
            // Split by accessType so STUC-gated courses get their own subsection,
            // and render both sections via the shared course-mini card style.
            var memberCourses = [];
            var otherCourses = [];
            for (var i = 0; i < data.courses.length; i++) {
              if (data.courses[i].accessType === 'members') memberCourses.push(data.courses[i]);
              else otherCourses.push(data.courses[i]);
            }
            if (memberCourses.length > 0) renderMemberSection(memberCourses);
            if (otherCourses.length > 0) {
              var html = '';
              for (var j = 0; j < otherCourses.length; j++) html += renderCourseMini(otherCourses[j]);
              coursesList.innerHTML = html;
              coursesList.hidden = false;
            } else if (memberCourses.length === 0) {
              coursesNone.hidden = false;
            }
          })
          .catch(function () {
            coursesLoading.hidden = true;
            coursesNone.hidden = false;
          });
      }

      // --- Billing ---
      function escapeHtml(str) {
        return String(str).replace(/[&<>"']/g, function (c) {
          return { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c];
        });
      }

      function renderHistoryList(items, listEl, toggleBtn, containerEl) {
        if (!items.length) return;
        var html = '';
        items.forEach(function (d, i) {
          var dateStr = new Date(d.date * 1000).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
          var amountStr = '$' + (d.amount / 100).toFixed(2);
          var hiddenAttr = i >= 1 ? ' hidden' : '';
          var receiptHtml;
          if (d.receiptNumber) {
            receiptHtml = '<span class="donation-receipt history-receipt">Save the Uterus Club Donation Receipt #' + escapeHtml(String(d.receiptNumber)) + '</span>';
          } else if (d.receiptUrl) {
            receiptHtml = '<a href="' + d.receiptUrl + '" target="_blank" rel="noopener noreferrer" class="donation-receipt">Receipt</a>';
          } else {
            receiptHtml = '<span class="donation-receipt"></span>';
          }
          html += '<div class="donation-row"' + hiddenAttr + ' data-history-row>' +
            '<span class="donation-date">' + dateStr + '</span>' +
            '<span class="donation-amount">' + amountStr + '</span>' +
            receiptHtml +
          '</div>';
        });
        listEl.innerHTML = html;
        containerEl.hidden = false;
        if (items.length > 1) {
          toggleBtn.textContent = 'Show all';
          toggleBtn.hidden = false;
          toggleBtn.addEventListener('click', function () {
            var rows = listEl.querySelectorAll('[data-history-row]');
            var expanding = rows[1] && rows[1].hidden;
            for (var i = 1; i < rows.length; i++) {
              rows[i].hidden = !expanding;
            }
            toggleBtn.textContent = expanding ? 'Show less' : 'Show all';
          });
        }
      }

      // Brand-canonical tier labels — must match copy used on /save-the-uterus-club/
      // and /donate/. Lookup falls back to the raw slug if a new tier ships before
      // this map is updated, so the page never renders empty.
      var tierNames = {
        member: 'STUC Member',
        hero: 'Uterus Hero',
        superhero: 'Uterus Super Hero',
      };

      function loadBilling() {
        var billingLoading = document.getElementById('billing-loading');
        var billingNone = document.getElementById('billing-none');
        var billingActive = document.getElementById('billing-active');
        var billingTier = document.getElementById('billing-tier');
        var billingStatus = document.getElementById('billing-status');
        var billingDate = document.getElementById('billing-date');
        var cancelNotice = document.getElementById('billing-cancel-notice');

        fetch('/api/billing/status', { credentials: 'same-origin' })
          .then(function (r) { return r.json(); })
          .then(function (data) {
            billingLoading.hidden = true;
            if (!data.ok) { billingNone.hidden = false; return; }

            var hasSub = !!data.subscription;
            var donations = data.donations || [];
            var payments = data.payments || [];
            var hasDonations = donations.length > 0;
            var hasPayments = payments.length > 0;

            if (!hasSub && !hasDonations) {
              billingNone.hidden = false;
              return;
            }

            if (hasSub) {
              var sub = data.subscription;
              billingTier.textContent = tierNames[sub.tier] || sub.tier;
              billingStatus.textContent = sub.status.charAt(0).toUpperCase() + sub.status.slice(1);
              if (sub.currentPeriodEnd) {
                billingDate.textContent = new Date(sub.currentPeriodEnd * 1000).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
              } else {
                billingDate.textContent = '--';
              }
              if (sub.cancelAtPeriodEnd) cancelNotice.hidden = false;

              // Wix-source subs route "Manage Billing" to a mailto helper, not Stripe portal.
              // Use inline style.display, not the [hidden] attribute -- global `.btn { display: inline-flex }`
              // wins the cascade against the UA `[hidden] { display: none }` rule, so the attribute alone
              // would leave both the Stripe button AND the Wix mailto note visible at once.
              var manageBtn = document.getElementById('manage-billing-btn');
              var manageNote = document.getElementById('manage-billing-wix-note');
              if (sub.source === 'wix') {
                if (manageBtn) manageBtn.style.display = 'none';
                if (manageNote) manageNote.hidden = false;
              } else {
                if (manageBtn) manageBtn.style.display = '';
                if (manageNote) manageNote.hidden = true;
              }

              billingActive.hidden = false;
            }

            if (hasPayments) {
              renderHistoryList(payments,
                document.getElementById('payments-list'),
                document.getElementById('payments-show-all'),
                document.getElementById('billing-payments'));
            }

            if (hasDonations) {
              renderHistoryList(donations,
                document.getElementById('donations-list'),
                document.getElementById('donations-show-all'),
                document.getElementById('billing-donations'));
            }
          })
          .catch(function () {
            billingLoading.hidden = true;
            billingNone.hidden = false;
          });
      }

      document.getElementById('manage-billing-btn').addEventListener('click', function () {
        var btn = this;
        btn.disabled = true;
        btn.textContent = 'Opening...';
        fetch('/api/billing/portal', { method: 'POST', credentials: 'same-origin' })
          .then(function (r) { return r.json(); })
          .then(function (data) {
            if (data.ok && data.url) {
              window.location.href = data.url;
            } else {
              btn.disabled = false;
              btn.textContent = 'Manage Billing';
              alert(data.error || 'Unable to open billing portal.');
            }
          })
          .catch(function () {
            btn.disabled = false;
            btn.textContent = 'Manage Billing';
          });
      });
    })();
  </script>
</BaseLayout>

