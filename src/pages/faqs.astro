---
import BaseLayout from '../layouts/BaseLayout.astro';
import MaybeShell from '../components/MaybeShell.astro';
import { isShellEnabled } from '../lib/shell-routes';
import { fetchAllFaqs, groupByCategory } from '../lib/faq';
import { buildFAQPage, buildBreadcrumbList } from '../lib/identity';

const SHELL_ENABLED = isShellEnabled('faqs');

const allFaqs = await fetchAllFaqs();
const groups = groupByCategory(allFaqs);

// D1 emits timestamps as "YYYY-MM-DD HH:MM:SS" (UTC, no Z).
// Normalize to ISO before parsing so V8 doesn't treat them as local time.
function toIsoUtc(ts: string | undefined | null): string | null {
  if (!ts) return null;
  if (ts.includes('T')) return ts.endsWith('Z') ? ts : ts + 'Z';
  return ts.replace(' ', 'T') + 'Z';
}

const updatedTimestamps = allFaqs
  .map(f => toIsoUtc(f.updatedAt))
  .filter((s): s is string => s !== null)
  .map(s => Date.parse(s))
  .filter(n => Number.isFinite(n));
const createdTimestamps = allFaqs
  .map(f => toIsoUtc(f.createdAt))
  .filter((s): s is string => s !== null)
  .map(s => Date.parse(s))
  .filter(n => Number.isFinite(n));

const latestUpdated = updatedTimestamps.length
  ? new Date(Math.max(...updatedTimestamps))
  : new Date();
const earliestCreated = createdTimestamps.length
  ? new Date(Math.min(...createdTimestamps))
  : latestUpdated;

const lastUpdatedLabel = new Intl.DateTimeFormat('en-US', {
  month: 'long',
  year: 'numeric',
}).format(latestUpdated);

// JSON-LD: FAQPage + BreadcrumbList in a single @graph.
// FAQPage built via buildFAQPage; name/description/dates layered on top.
const faqPageRaw = buildFAQPage(
  allFaqs.map(faq => ({
    question: faq.question,
    answer: faq.schemaAnswer || faq.basicAnswer || faq.publishedAnswer,
  }))
) as Record<string, unknown>;
const breadcrumbRaw = buildBreadcrumbList([
  { name: 'Home', url: 'https://rrmacademy.org/' },
  { name: 'FAQs', url: 'https://rrmacademy.org/faqs/' },
]) as Record<string, unknown>;
const { '@context': _faqCtx, ...faqPageNode } = faqPageRaw;
const { '@context': _bcCtx, ...breadcrumbNode } = breadcrumbRaw;
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      ...faqPageNode,
      name: 'Frequently Asked Questions about Restorative Reproductive Medicine',
      description: 'Answers to common questions about RRM, NaProTechnology, fertility charting, treatment approaches, success rates, and costs.',
      dateModified: latestUpdated.toISOString(),
      datePublished: earliestCreated.toISOString(),
    },
    breadcrumbNode,
  ],
};
---
<BaseLayout
  title="RRM FAQs | Restorative Reproductive Medicine Questions"
  description="Answers to common questions about Restorative Reproductive Medicine (RRM), NaProTechnology, fertility charting, treatment, and costs."
  canonicalUrl="https://rrmacademy.org/faqs"
  jsonLd={jsonLd}
  speakable={['.hero-title', '.faqs-intro']}
  chrome={SHELL_ENABLED ? 'shell' : 'default'}
>
  <MaybeShell enabled={SHELL_ENABLED} context="page" currentPath={Astro.url.pathname}>
  <div class="page-wrapper">
    <div class="container container--narrow">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span aria-hidden="true"> &rsaquo; </span>
        <span aria-current="page">FAQs</span>
      </nav>

      <section class="faqs-hero">
        <h1 class="hero-title animate-enter" style="--stagger: 0;">Restorative Reproductive Medicine FAQs</h1>
        <p class="faqs-intro animate-enter" style="--stagger: 1;">Common questions about Restorative Reproductive Medicine, NaProTechnology, treatment approaches, and getting started with an RRM clinician.</p>
      </section>

      {groups.map((group) => (
        <section class="faq-group">
          <h2 class="faq-group-title">{group.category}</h2>
          <div class="faq-list">
            {group.faqs.map((faq) => (
              <details class="faq-item">
                <summary class="faq-question">
                  <span class="faq-question-text">{faq.question}</span>
                  <span class="faq-chevron" aria-hidden="true">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <polyline points="6 9 12 15 18 9"></polyline>
                    </svg>
                  </span>
                </summary>
                <div class="faq-answer">
                  <p>{faq.basicAnswer || faq.publishedAnswer}</p>
                  <a href={`/faqs/${faq.slug}/`} class="faq-read-more">Read more &rarr;</a>
                </div>
              </details>
            ))}
          </div>
        </section>
      ))}

      <section class="faqs-contact">
        <h2>Still have questions?</h2>
        <p>We are here to help. Reach out and we will get back to you as soon as we can.</p>
        <div class="faqs-contact__links">
          <a href="/contact/" class="btn btn--primary">Contact Us</a>
          <a href="/courses/" class="btn btn--secondary">Explore Courses</a>
          <a href="/endo-survey/" class="btn btn--secondary">Take the Endo Self-Survey</a>
        </div>
      </section>

    <p class="page-updated">Last updated: {lastUpdatedLabel}</p>
    </div>
  </div>
  </MaybeShell>
</BaseLayout>

<style>
  @keyframes enter {
    from { transform: translateY(8px); filter: blur(4px); }
  }
  .animate-enter {
    animation: enter 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94) both;
    animation-delay: calc(100ms * var(--stagger, 0));
  }
  @media (prefers-reduced-motion: reduce) {
    .animate-enter { animation: none; }
  }

  /* Hero */
  .faqs-hero {
    margin-bottom: var(--space-10);
  }
  .faqs-hero h1 {
    margin-bottom: var(--space-3);
  }
  .faqs-intro {
    font-size: 0.9375rem;
    line-height: 1.8;
    color: var(--text-secondary);
    max-width: 600px;
  }

  /* Group */
  .faq-group {
    margin-bottom: var(--space-10);
  }
  .faq-group-title {
    font-size: 0.6875rem;
    font-family: 'Inter', sans-serif;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-secondary);
    margin-bottom: var(--space-4);
    padding-bottom: var(--space-2);
    border-bottom: 1px solid var(--border-color);
  }

  /* Read more link */
  .faq-read-more {
    display: inline-block;
    margin-top: var(--space-2);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--accent);
    text-decoration: none;
  }
  .faq-read-more:hover {
    color: var(--purple-900);
    text-decoration: underline;
  }

  /* Contact CTA */
  .faqs-contact {
    text-align: center;
    padding: var(--space-10) 0 0;
    border-top: 1px solid var(--border-color);
    margin-top: var(--space-4);
  }
  .faqs-contact h2 {
    font-size: 1.5rem;
    margin-bottom: var(--space-3);
  }
  .faqs-contact p {
    font-size: 0.9375rem;
    color: var(--text-secondary);
    margin-bottom: var(--space-5);
  }
  .faqs-contact__links {
    display: flex;
    gap: var(--space-4);
    justify-content: center;
    flex-wrap: wrap;
  }

  .breadcrumb {
    font-size: 0.875rem;
    color: var(--text-tertiary);
    margin-bottom: var(--space-6);
  }
  .breadcrumb a {
    color: var(--text-tertiary);
    text-decoration: none;
  }
  .breadcrumb a:hover {
    color: var(--accent);
    text-decoration: underline;
  }
  .breadcrumb [aria-current="page"] {
    color: var(--text-secondary);
  }
</style>
