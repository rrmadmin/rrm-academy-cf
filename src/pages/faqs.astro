---
import BaseLayout from '../layouts/BaseLayout.astro';
import { fetchAllFaqs, groupByCategory } from '../lib/faq';

const allFaqs = await fetchAllFaqs();
const groups = groupByCategory(allFaqs);

// FAQPage JSON-LD from all published FAQs
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  name: 'Frequently Asked Questions about Restorative Reproductive Medicine',
  description: 'Answers to common questions about RRM, NaProTechnology, fertility charting, treatment approaches, success rates, and costs.',
  mainEntity: allFaqs.map(faq => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: faq.schemaAnswer || faq.basicAnswer || faq.publishedAnswer,
    },
  })),
};
---
<BaseLayout
  title="RRM FAQs | Restorative Reproductive Medicine Questions"
  description="Answers to common questions about Restorative Reproductive Medicine (RRM), NaProTechnology, fertility charting, treatment approaches, success rates, and costs."
  canonicalUrl="https://rrmacademy.org/faqs"
  jsonLd={jsonLd}
>
  <div class="page-wrapper">
    <div class="container container--narrow">

      <section class="faqs-hero">
        <h1 class="hero-title">Frequently Asked Questions</h1>
        <p class="faqs-intro">Common questions about Restorative Reproductive Medicine, NaProTechnology, treatment approaches, and getting started with an RRM clinician.</p>
      </section>

      {groups.map((group) => (
        <section class="faq-group">
          <h2 class="faq-group-title">{group.category}</h2>
          <div class="faq-list">
            {group.faqs.map((faq) => (
              <details class="faq-item">
                <summary class="faq-question">
                  <span class="faq-question-text">{faq.question}</span>
                  <span class="faq-chevron" aria-hidden="true">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <polyline points="6 9 12 15 18 9"></polyline>
                    </svg>
                  </span>
                </summary>
                <div class="faq-answer">
                  <p>{faq.basicAnswer || faq.publishedAnswer}</p>
                  <a href={`/faqs/${faq.slug}/`} class="faq-read-more">Read more &rarr;</a>
                </div>
              </details>
            ))}
          </div>
        </section>
      ))}

      <section class="faqs-contact">
        <h2>Still have questions?</h2>
        <p>We are here to help. Reach out and we will get back to you as soon as we can.</p>
        <div class="faqs-contact__links">
          <a href="/contact/" class="btn btn--primary">Contact Us</a>
          <a href="/courses/" class="btn btn--secondary">Explore Courses</a>
          <a href="/endo-survey/" class="btn btn--secondary">Take the Endo Self-Survey</a>
        </div>
      </section>

    <p class="page-updated">Last updated: February 2026</p>
    </div>
  </div>
</BaseLayout>

<style>
  /* Hero */
  .faqs-hero {
    margin-bottom: var(--space-10);
  }
  .faqs-hero h1 {
    margin-bottom: var(--space-3);
  }
  .faqs-intro {
    font-size: 0.9375rem;
    line-height: 1.8;
    color: var(--text-secondary);
    max-width: 600px;
  }

  /* Group */
  .faq-group {
    margin-bottom: var(--space-10);
  }
  .faq-group-title {
    font-size: 0.6875rem;
    font-family: 'Inter', sans-serif;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-tertiary);
    margin-bottom: var(--space-4);
    padding-bottom: var(--space-2);
    border-bottom: 1px solid var(--border-color);
  }

  /* Read more link */
  .faq-read-more {
    display: inline-block;
    margin-top: var(--space-2);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--accent);
    text-decoration: none;
  }
  .faq-read-more:hover {
    color: var(--purple-900);
    text-decoration: underline;
  }

  /* Contact CTA */
  .faqs-contact {
    text-align: center;
    padding: var(--space-10) 0 0;
    border-top: 1px solid var(--border-color);
    margin-top: var(--space-4);
  }
  .faqs-contact h2 {
    font-size: 1.5rem;
    margin-bottom: var(--space-3);
  }
  .faqs-contact p {
    font-size: 0.9375rem;
    color: var(--text-secondary);
    margin-bottom: var(--space-5);
  }
  .faqs-contact__links {
    display: flex;
    gap: var(--space-4);
    justify-content: center;
    flex-wrap: wrap;
  }

</style>
