---
// Pagefind search widget wrapper
---
<div class="search-wrapper" id="search">
  <div id="pagefind-search"></div>
</div>

<style>
  .search-wrapper {
    position: relative;
  }
  /* Override Pagefind default styles */
  .search-wrapper :global(.pagefind-ui) {
    --pagefind-ui-scale: 0.9;
    --pagefind-ui-primary: var(--purple-700);
    --pagefind-ui-text: var(--neutral-900);
    --pagefind-ui-background: var(--white);
    --pagefind-ui-border: var(--neutral-300);
    --pagefind-ui-border-width: 1.5px;
    --pagefind-ui-border-radius: var(--radius-lg);
    --pagefind-ui-font: 'Inter', sans-serif;
  }
  .search-wrapper :global(.pagefind-ui__search-input) {
    width: 100%;
    padding: 14px 16px 14px 44px;
    font-size: 1rem;
    font-family: 'Inter', sans-serif;
    border: 1.5px solid var(--neutral-300);
    border-radius: var(--radius-lg);
    outline: none;
    transition: all 0.2s;
    background: var(--white);
  }
  .search-wrapper :global(.pagefind-ui__search-input:focus) {
    border-color: var(--purple-700);
    box-shadow: 0 0 0 3px rgba(114, 94, 126, 0.1);
  }
  .search-wrapper :global(.pagefind-ui__search-input::placeholder) {
    color: var(--neutral-500);
  }
  .search-wrapper :global(.pagefind-ui__search-clear) {
    right: 12px;
    color: var(--neutral-500);
  }
  .search-wrapper :global(.pagefind-ui__result-link) {
    color: var(--purple-700);
    font-weight: 500;
  }
  .search-wrapper :global(.pagefind-ui__result-link:hover) {
    color: var(--purple-900);
  }
  .search-wrapper :global(.pagefind-ui__result-excerpt) {
    color: var(--neutral-600);
    font-size: 0.875rem;
  }
  .search-wrapper :global(.pagefind-ui__message) {
    font-size: 0.875rem;
    color: var(--neutral-600);
    padding: var(--space-4) 0;
  }
</style>

<link href="/pagefind/pagefind-ui.css" rel="stylesheet" />
<script is:inline>
  async function initSearch() {
    const { PagefindUI } = await import('/pagefind/pagefind-ui.js');
    new PagefindUI({
      element: '#pagefind-search',
      showSubResults: false,
      showImages: false,
      excerptLength: 20,
      resetStyles: false,
    });

    // Apply placeholder after Pagefind creates the input
    requestAnimationFrame(function() {
      var input = document.querySelector('.pagefind-ui__search-input');
      if (input) {
        input.placeholder = 'Search by topic, title, author, or keyword...';
        // Check URL for search param
        var params = new URLSearchParams(window.location.search);
        var q = params.get('q') || params.get('search');
        if (q) {
          input.value = q;
          input.dispatchEvent(new Event('input', { bubbles: true }));
        }
      }
    });
  }
  initSearch();
</script>
