---
// Pagefind search widget wrapper
// Shows a native input immediately; Pagefind replaces it once JS loads
---
<div class="search-wrapper" id="search">
  <div class="search-fallback" id="search-fallback">
    <svg class="search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
    <input
      type="search"
      class="search-fallback__input"
      placeholder="Search articles..."
      id="search-fallback-input"
      autocomplete="off"
    />
  </div>
  <div id="pagefind-search"></div>
</div>

<style>
  .search-wrapper {
    position: relative;
  }

  /* Native fallback — visible immediately in HTML */
  .search-fallback {
    position: relative;
    display: flex;
    align-items: center;
  }
  .search-fallback.hidden {
    display: none;
  }
  .search-icon {
    position: absolute;
    left: 14px;
    color: var(--text-muted);
    pointer-events: none;
  }
  .search-fallback__input {
    width: 100%;
    padding: 12px 16px 12px 42px;
    font-size: 16px; /* Prevents iOS zoom */
    font-family: 'Inter', sans-serif;
    border: 1.5px solid var(--border-color);
    border-radius: var(--radius-pill);
    outline: none;
    background: var(--bg-surface);
    color: var(--text-primary);
    transition: border-color 0.15s;
  }
  .search-fallback__input:focus {
    border-color: var(--accent);
    box-shadow: 0 0 0 3px var(--focus-ring);
  }
  .search-fallback__input::placeholder {
    color: var(--text-muted);
  }

  /* Pagefind overrides */
  .search-wrapper :global(.pagefind-ui) {
    --pagefind-ui-scale: 0.9;
    --pagefind-ui-primary: var(--accent);
    --pagefind-ui-text: var(--text-primary);
    --pagefind-ui-background: var(--bg-surface);
    --pagefind-ui-border: var(--border-color);
    --pagefind-ui-border-width: 1.5px;
    --pagefind-ui-border-radius: var(--radius-pill);
    --pagefind-ui-font: 'Inter', sans-serif;
  }
  .search-wrapper :global(.pagefind-ui__search-input) {
    width: 100%;
    padding: 12px 16px 12px 44px;
    font-size: 16px;
    font-family: 'Inter', sans-serif;
    border: 1.5px solid var(--border-color);
    border-radius: var(--radius-pill);
    outline: none;
    transition: all 0.2s;
    background: var(--bg-surface);
    color: var(--text-primary);
  }
  .search-wrapper :global(.pagefind-ui__search-input:focus) {
    border-color: var(--accent);
    box-shadow: 0 0 0 3px var(--focus-ring);
  }
  .search-wrapper :global(.pagefind-ui__search-input::placeholder) {
    color: var(--text-muted);
  }
  .search-wrapper :global(.pagefind-ui__search-clear) {
    right: 12px;
    color: var(--text-tertiary);
    font-size: 0;
    border-radius: 50%;
    width: 24px;
    height: 24px;
    padding: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    border: none;
    background: none;
  }
  .search-wrapper :global(.pagefind-ui__search-clear::after) {
    content: '✕';
    font-size: 14px;
  }
  /* Results container — left-aligned, constrained width */
  .search-wrapper :global(.pagefind-ui__drawer) {
    text-align: left;
    max-width: 720px;
    margin: 0 auto;
    padding-top: var(--space-4);
  }
  .search-wrapper :global(.pagefind-ui__message) {
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    padding: var(--space-3) 0 var(--space-2);
    text-align: left;
    border: none;
  }
  .search-wrapper :global(.pagefind-ui__results) {
    text-align: left;
  }

  /* Individual result — card-like row */
  .search-wrapper :global(.pagefind-ui__result) {
    padding: var(--space-5) 0;
    border-bottom: 1px solid var(--border-light, var(--border-color));
    list-style: none;
  }
  .search-wrapper :global(.pagefind-ui__result:first-child) {
    border-top: 1px solid var(--border-light, var(--border-color));
  }
  .search-wrapper :global(.pagefind-ui__result-inner) {
    text-align: left;
  }

  /* Result title */
  .search-wrapper :global(.pagefind-ui__result-title) {
    margin: 0 0 var(--space-2);
    text-align: left;
  }
  .search-wrapper :global(.pagefind-ui__result-link) {
    font-family: 'Cormorant Garamond', 'Georgia', serif;
    font-size: 1.125rem;
    font-weight: 600;
    line-height: 1.3;
    color: var(--text-primary);
    text-decoration: none;
    transition: color 0.15s;
  }
  .search-wrapper :global(.pagefind-ui__result-link:hover) {
    color: var(--accent);
  }

  /* Result excerpt */
  .search-wrapper :global(.pagefind-ui__result-excerpt) {
    font-size: 0.8125rem;
    line-height: 1.6;
    color: var(--text-secondary);
    text-align: left;
    margin: 0 0 var(--space-2);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .search-wrapper :global(.pagefind-ui__result-excerpt mark) {
    background: var(--yellow-100, #fef9c3);
    color: inherit;
    padding: 0 1px;
    border-radius: 2px;
  }

  /* Metadata tags (Authors, Year) */
  .search-wrapper :global(.pagefind-ui__result-tags) {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .search-wrapper :global(.pagefind-ui__result-tag) {
    font-size: 0.6875rem;
    font-weight: 500;
    color: var(--text-tertiary);
  }

  /* Hide the thumbnail/image placeholder area */
  .search-wrapper :global(.pagefind-ui__result-thumb) {
    display: none;
  }

  /* Loading indicator */
  .search-wrapper :global(.pagefind-ui__loading) {
    color: var(--text-muted);
    font-size: 0.8125rem;
    text-align: left;
    padding: var(--space-4) 0;
  }

  /* "Load more" button */
  .search-wrapper :global(.pagefind-ui__button) {
    display: block;
    width: 100%;
    margin-top: var(--space-5);
    padding: var(--space-3) var(--space-5);
    font-size: 0.8125rem;
    font-weight: 500;
    font-family: 'Inter', sans-serif;
    color: var(--text-secondary);
    background: var(--bg-surface);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-pill);
    cursor: pointer;
    transition: border-color 0.15s, color 0.15s;
  }
  .search-wrapper :global(.pagefind-ui__button:hover) {
    border-color: var(--accent);
    color: var(--accent);
  }

</style>

<link href="/pagefind/pagefind-ui.css" rel="stylesheet" />
<script is:inline>
  async function initSearch() {
    var fallback = document.getElementById('search-fallback');
    var fallbackInput = document.getElementById('search-fallback-input');
    var savedQuery = fallbackInput ? fallbackInput.value : '';

    await import('/pagefind/pagefind-ui.js');
    new window.PagefindUI({
      element: '#pagefind-search',
      showSubResults: false,
      showImages: false,
      excerptLength: 20,
      resetStyles: false,
    });

    // Hide fallback once Pagefind is ready
    requestAnimationFrame(function() {
      if (fallback) fallback.classList.add('hidden');
      var input = document.querySelector('.pagefind-ui__search-input');
      if (input) {
        input.placeholder = 'Search articles...';
        // Transfer any query typed into fallback
        var q = savedQuery || new URLSearchParams(window.location.search).get('q') || '';
        if (q) {
          input.value = q;
          input.dispatchEvent(new Event('input', { bubbles: true }));
        }

        // Smooth fade-out when clearing results
        var clearBtn = document.querySelector('.pagefind-ui__search-clear');
        var drawer = document.querySelector('.pagefind-ui__drawer');
        if (clearBtn && drawer) {
          clearBtn.addEventListener('click', function() {
            drawer.style.transition = 'opacity 0.3s ease';
            drawer.style.opacity = '0';
            setTimeout(function() { drawer.style.opacity = ''; }, 350);
          });
        }
      }
    });
  }
  initSearch();
</script>
