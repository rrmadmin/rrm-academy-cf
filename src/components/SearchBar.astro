---
// Custom Pagefind search — uses the JS API directly for full control over result rendering.
// No pagefind-ui.js or pagefind-ui.css loaded.
---
<div class="search-wrapper" id="search">
  <div class="search-box">
    <svg class="search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
    <input
      type="search"
      class="search-input"
      placeholder="Search..."
      id="search-input"
      autocomplete="off"
    />
    <button class="search-clear hidden" id="search-clear" aria-label="Clear search">✕</button>
    <div class="search-results" id="search-results"></div>
  </div>
</div>

<style>
  .search-wrapper {
    position: relative;
    width: 100%;
    z-index: 10;
  }

  /* Search input — position: relative so .search-results is anchored to the input width */
  .search-box {
    position: relative;
    display: flex;
    align-items: center;
    width: 100%;
  }
  .search-icon {
    position: absolute;
    left: 14px;
    color: var(--text-muted);
    pointer-events: none;
  }
  .search-input {
    width: 100%;
    padding: 12px 40px 12px 42px;
    font-size: 16px;
    font-family: 'Inter', sans-serif;
    border: 1px solid var(--border-light);
    border-radius: var(--radius-pill);
    outline: none;
    background: var(--bg-surface);
    color: var(--text-primary);
    box-shadow: 0 4px 16px rgba(0,0,0,0.08), 0 1px 4px rgba(0,0,0,0.04);
    transition: border-color 0.15s, box-shadow 0.15s;
  }
  .search-input:focus {
    border-color: var(--sand-500);
    box-shadow: 0 4px 20px rgba(184,163,143,0.25), 0 0 0 3px rgba(184,163,143,0.12);
  }
  :global([data-theme="dark"]) .search-input {
    border-color: rgba(255,255,255,0.15);
    box-shadow: 0 4px 16px rgba(255,255,255,0.04), 0 1px 4px rgba(255,255,255,0.02);
  }
  :global([data-theme="dark"]) .search-input:focus {
    box-shadow: 0 4px 20px rgba(255,255,255,0.06), 0 0 0 3px var(--focus-ring);
  }
  .search-input::placeholder {
    color: var(--text-muted);
  }
  .search-input::-webkit-search-cancel-button {
    -webkit-appearance: none;
    display: none;
  }
  .search-clear {
    position: absolute;
    right: 12px;
    width: 24px;
    height: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: none;
    background: none;
    color: var(--text-tertiary);
    font-size: 14px;
    cursor: pointer;
    border-radius: 50%;
    padding: 0;
    transition: color 0.15s;
  }
  .search-clear:hover {
    color: var(--text-primary);
  }
  .search-clear.hidden {
    display: none;
  }

  /* Results area — overlay so it doesn't shift the hero layout */
  .search-results {
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    width: min(560px, 100%);
    text-align: left;
    padding: 0 var(--space-5) var(--space-6);
    background: var(--bg-body);
    max-height: 60vh;
    overflow-y: auto;
    box-shadow: 0 8px 24px rgba(0,0,0,0.1);
    z-index: 100;
  }
  .search-results:empty {
    display: none;
  }

  /* Result count */
  .search-results :global(.sr-count) {
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    padding: var(--space-4) 0 var(--space-2);
  }

  /* Individual result card */
  .search-results :global(.sr-item) {
    display: block;
    padding: var(--space-5) 0;
    border-bottom: 1px solid var(--border-light, var(--border-color));
    text-decoration: none;
    transition: background 0.1s;
  }
  .search-results :global(.sr-item:first-of-type) {
    border-top: 1px solid var(--border-light, var(--border-color));
  }
  .search-results :global(.sr-item:hover) {
    text-decoration: none;
  }
  .search-results :global(.sr-item:hover .sr-title) {
    color: var(--accent);
  }

  /* Title */
  .search-results :global(.sr-title) {
    font-family: 'Cormorant Garamond', 'Georgia', serif;
    font-size: 1.125rem;
    font-weight: 600;
    line-height: 1.3;
    color: var(--text-primary);
    margin: 0 0 6px;
    transition: color 0.15s;
  }

  /* Meta line: authors · journal · year */
  .search-results :global(.sr-meta) {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 2px 0;
    font-size: 0.75rem;
    line-height: 1.5;
    margin-bottom: 8px;
  }
  .search-results :global(.sr-authors) {
    color: var(--text-secondary);
    font-weight: 500;
  }

  /* Excerpt */
  .search-results :global(.sr-excerpt) {
    font-size: 0.8125rem;
    line-height: 1.6;
    color: var(--text-secondary);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* Load more */
  .search-results :global(.sr-more) {
    display: block;
    width: 100%;
    margin-top: var(--space-5);
    padding: var(--space-3) var(--space-5);
    font-size: 0.8125rem;
    font-weight: 500;
    font-family: 'Inter', sans-serif;
    color: var(--text-secondary);
    background: var(--bg-surface);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-pill);
    cursor: pointer;
    transition: border-color 0.15s, color 0.15s;
  }
  .search-results :global(.sr-more:hover) {
    border-color: var(--accent);
    color: var(--accent);
  }

  /* Loading */
  .search-results :global(.sr-loading) {
    font-size: 0.8125rem;
    color: var(--text-muted);
    padding: var(--space-5) 0;
  }

  /* No results */
  .search-results :global(.sr-empty) {
    font-size: 0.875rem;
    color: var(--text-tertiary);
    padding: var(--space-6) 0;
  }

  /* Type badge in title row */
  .search-results :global(.sr-title-row) {
    display: flex;
    align-items: baseline;
    gap: var(--space-2);
  }
  .search-results :global(.sr-type) {
    flex-shrink: 0;
    font-size: 0.5625rem;
    font-weight: 600;
    font-family: 'Inter', sans-serif;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 2px 6px;
    border-radius: 3px;
    white-space: nowrap;
  }
  .search-results :global(.sr-type--research) {
    color: var(--green-700);
    background: var(--green-100);
  }
  .search-results :global(.sr-type--course) {
    color: var(--purple-700);
    background: var(--purple-100);
  }
  .search-results :global(.sr-type--faq) {
    color: var(--amber-700);
    background: var(--amber-100);
  }
  .search-results :global(.sr-type--article) {
    color: var(--sage-700);
    background: var(--sage-100);
  }
  .search-results :global(.sr-type--guide) {
    color: var(--rose-700);
    background: var(--rose-100);
  }
</style>

<script is:inline>
(function() {
  var input = document.getElementById('search-input');
  var clearBtn = document.getElementById('search-clear');
  var resultsEl = document.getElementById('search-results');
  if (!input || !resultsEl) return;

  var pagefindReady = null;
  var debounceTimer = null;
  var currentResults = [];
  var shown = 0;
  var INITIAL_PAGE = 3;
  var PER_PAGE = 8;
  var totalCount = 0;
  var currentQuery = '';
  var PRELOAD_CAP = 50;
  var preloadedData = [];
  var isFirstPage = true;

  // Load Pagefind on first interaction — single shared promise prevents race conditions
  function ensurePagefind() {
    if (!pagefindReady) {
      pagefindReady = import('/pagefind/pagefind.js').then(function(pf) {
        return pf.init().then(function() { return pf; });
      });
    }
    return pagefindReady;
  }

  // Debounced search
  function onInput() {
    var q = input.value.trim();
    clearBtn.classList.toggle('hidden', !q);
    clearTimeout(debounceTimer);
    if (!q) {
      resultsEl.innerHTML = '';
      currentResults = [];
      preloadedData = [];
      currentQuery = '';
      return;
    }
    currentQuery = q;
    debounceTimer = setTimeout(function() { doSearch(q); }, 150);
  }

  function positionResultsPanel() {
    // CSS handles positioning via left: 50% + transform: translateX(-50%)
  }

  // Detect non-English titles to de-prioritize in results.
  // Two signals: (1) 3+ non-ASCII chars after stripping English loanwords,
  // or (2) title has 5+ words but almost none are common English function words.
  var _engWordRe = /^(the|of|in|and|for|with|a|an|to|from|by|on|at|or|is|are|was|were|after|before|between|during|through|about|into|over|its|their|this|that|these|those|which|who|has|have|had|not|but|can|may|should|will|be|been|do|each|all|both|more|most|some|such|no|only|other|same|so|also|new|based|using|associated|among|without|within|upon|including|following|versus|compared|effect|role|impact|review|study|analysis|treatment|outcomes|risk|women|patients|clinical|use|health)$/i;
  function isNonEnglish(title) {
    if (!title) return false;
    // Signal 1: non-ASCII density (catches French, German with accents/umlauts)
    var t = title.replace(/m\u00fcller\w*/gi, '').replace(/caf\u00e9/gi, '').replace(/na\u00efve/gi, '');
    var nonAscii = (t.match(/[^\x00-\x7F]/g) || []).length;
    if (nonAscii >= 3) return true;
    // Signal 2: lacks English function words (catches Polish, some Spanish with ASCII chars)
    var words = title.split(/[\s\-\u2013\u2014:,;.()]+/).filter(function(w) { return w.length > 0; });
    if (words.length < 5) return false;
    var engCount = 0;
    for (var i = 0; i < words.length; i++) {
      if (_engWordRe.test(words[i])) engCount++;
    }
    return (engCount / words.length) < 0.15;
  }

  function extractSlug(url) {
    var parts = url.replace(/\/$/, '').split('/');
    return parts[parts.length - 1];
  }

  async function doSearch(query) {
    resultsEl.innerHTML = '<p class="sr-loading">Searching\u2026</p>';
    positionResultsPanel();
    try {
      // Fire both searches in parallel
      var semanticPromise = fetch('/api/search/semantic?q=' + encodeURIComponent(query))
        .then(function(r) { return r.json(); })
        .catch(function() { return { results: [] }; });

      var pf = await ensurePagefind();
      var search = await pf.search(query);
      if (query !== currentQuery) return;
      currentResults = search.results;

      // Pre-load top Pagefind results for metadata access
      var toPreload = search.results.slice(0, PRELOAD_CAP);
      var pfLoaded = await Promise.all(
        toPreload.map(function(r, i) {
          return r.data().then(function(d) {
            d._pfRank = i;
            // Non-English penalty: push far down the Pagefind ranking
            if (isNonEnglish(d.meta && d.meta.title)) d._pfRank += 1000;
            return d;
          });
        })
      );
      if (query !== currentQuery) return;

      // Wait for semantic with 300ms timeout (Pagefind is already done)
      var semanticData = await Promise.race([
        semanticPromise,
        new Promise(function(resolve) { setTimeout(function() { resolve(null); }, 300); })
      ]);
      if (query !== currentQuery) return;

      var semanticResults = (semanticData && semanticData.results || []).filter(function(sr) { return sr.score >= 0.5; });

      // --- Reciprocal Rank Fusion ---
      // RRF score = sum(1 / (K + rank)) across both systems
      // Items appearing in both lists get boosted; single-source items still included
      var RRF_K = 60;
      var fusedMap = {}; // url -> { score, data }

      // Normalize URLs to relative paths (Pagefind may return absolute pages.dev URLs)
      function toRelative(url) {
        try { return new URL(url).pathname; } catch(e) { return url; }
      }

      // Extract Airtable record ID from slug (e.g. "...-recXYZ123/" -> "recxyz123")
      // Used for dedup when slugs change but record ID stays the same
      function extractRecId(url) {
        var m = url.match(/-(rec[a-zA-Z0-9]+)\/?$/);
        return m ? m[1].toLowerCase() : null;
      }

      var recIdToKey = {}; // recId -> fusedMap key (for cross-slug dedup)

      // Score Pagefind results (dedup by record ID within Pagefind too)
      for (var pi = 0; pi < pfLoaded.length; pi++) {
        var pItem = pfLoaded[pi];
        var pUrl = toRelative(pItem.url);
        pItem.url = pUrl;
        var pRecId = extractRecId(pUrl);
        var existingKey = pRecId && recIdToKey[pRecId];
        if (existingKey) {
          // Same article, different URL -- boost and keep higher-ranked
          fusedMap[existingKey].score += 1 / (RRF_K + pItem._pfRank);
        } else {
          fusedMap[pUrl] = {
            score: 1 / (RRF_K + pItem._pfRank),
            data: pItem
          };
          if (pRecId) recIdToKey[pRecId] = pUrl;
        }
      }

      // Score and merge semantic results
      for (var si = 0; si < semanticResults.length; si++) {
        var sItem = semanticResults[si];
        var sUrl = toRelative(sItem.url);
        var sRank = si;
        if (isNonEnglish(sItem.title)) sRank += 1000;

        // Match by URL first, then by record ID (handles slug renames)
        var sRecId = extractRecId(sUrl);
        var matchKey = fusedMap[sUrl] ? sUrl : (sRecId && recIdToKey[sRecId]) ? recIdToKey[sRecId] : null;

        if (matchKey) {
          // Boost existing result -- appears in both systems
          fusedMap[matchKey].score += 1 / (RRF_K + sRank);
          // Prefer semantic URL (current slug) over stale Pagefind URL
          if (matchKey !== sUrl) fusedMap[matchKey].data.url = sUrl;
          // Enrich with type from semantic if Pagefind lacks it
          if (!fusedMap[matchKey].data.meta.type && sItem.type) {
            fusedMap[matchKey].data.meta.type = sItem.type;
          }
        } else {
          // Semantic-only result -- still valuable for intent matches Pagefind missed
          fusedMap[sUrl] = {
            score: 1 / (RRF_K + sRank),
            data: {
              url: sUrl, excerpt: '',
              meta: { title: sItem.title, authors: sItem.authors || '', year: sItem.year ? String(sItem.year) : '', type: sItem.type || 'Research' },
              _pfRank: -1
            }
          };
        }
      }

      // Sort by fused RRF score descending
      var fusedList = [];
      for (var fKey in fusedMap) {
        fusedList.push(fusedMap[fKey]);
      }
      fusedList.sort(function(a, b) { return b.score - a.score; });

      preloadedData = fusedList.map(function(f) { return f.data; });
      totalCount = preloadedData.length;
      shown = 0;
      isFirstPage = true;
      resultsEl.innerHTML = '';

      if (totalCount === 0) {
        resultsEl.innerHTML = '<p class="sr-empty">No results found for \u201c' + escHtml(query) + '\u201d</p>';
        positionResultsPanel();
        return;
      }

      var countEl = document.createElement('p');
      countEl.className = 'sr-count';
      countEl.textContent = totalCount + ' result' + (totalCount === 1 ? '' : 's');
      resultsEl.appendChild(countEl);
      await loadMore();
      positionResultsPanel();

      // If semantic timed out, merge late-arriving results as addenda
      if (!semanticData) {
        semanticPromise.then(function(lateData) {
          if (query !== currentQuery) return;
          var lateResults = (lateData && lateData.results || []).filter(function(sr) { return sr.score >= 0.5; });
          var existingUrls = {};
          var existingRecIds = {};
          for (var ei = 0; ei < preloadedData.length; ei++) {
            var eUrl = toRelative(preloadedData[ei].url);
            existingUrls[eUrl] = true;
            existingUrls[extractSlug(eUrl)] = true;
            var eRecId = extractRecId(eUrl);
            if (eRecId) existingRecIds[eRecId] = true;
          }
          var added = 0;
          for (var li = 0; li < lateResults.length; li++) {
            var lr = lateResults[li];
            var lrUrl = toRelative(lr.url);
            var lrRecId = extractRecId(lrUrl);
            if (existingUrls[lrUrl] || existingUrls[lr.slug] || (lrRecId && existingRecIds[lrRecId])) continue;
            preloadedData.push({
              url: lr.url, excerpt: '',
              meta: { title: lr.title, authors: lr.authors || '', year: lr.year ? String(lr.year) : '', type: lr.type || 'Research' },
              _pfRank: -1
            });
            added++;
          }
          if (added > 0) {
            totalCount = preloadedData.length;
            var countDisplay = resultsEl.querySelector('.sr-count');
            if (countDisplay) countDisplay.textContent = totalCount + ' result' + (totalCount === 1 ? '' : 's');
            var moreBtn = resultsEl.querySelector('.sr-more');
            if (moreBtn && shown < totalCount) {
              moreBtn.textContent = 'Show more (' + (totalCount - shown) + ' remaining)';
            } else if (!moreBtn && shown < totalCount) {
              var btn = document.createElement('button');
              btn.className = 'sr-more';
              btn.textContent = 'Show more (' + (totalCount - shown) + ' remaining)';
              btn.addEventListener('click', function() { loadMore(); });
              resultsEl.appendChild(btn);
            }
          }
        });
      }
    } catch(e) {
      resultsEl.innerHTML = '<p class="sr-empty">Search unavailable</p>';
      positionResultsPanel();
    }
  }

  async function loadMore() {
    var pageSize = isFirstPage ? INITIAL_PAGE : PER_PAGE;
    isFirstPage = false;
    var batch = preloadedData.slice(shown, shown + pageSize);
    var fragment = document.createDocumentFragment();
    for (var j = 0; j < batch.length; j++) {
      fragment.appendChild(renderResult(batch[j]));
    }
    // Remove old "load more" button
    var oldBtn = resultsEl.querySelector('.sr-more');
    if (oldBtn) oldBtn.remove();
    resultsEl.appendChild(fragment);
    shown += batch.length;
    if (shown < totalCount) {
      var btn = document.createElement('button');
      btn.className = 'sr-more';
      btn.textContent = 'Show more (' + (totalCount - shown) + ' remaining)';
      btn.addEventListener('click', function() { loadMore(); });
      resultsEl.appendChild(btn);
    }
  }

  function renderResult(data) {
    var a = document.createElement('a');
    a.className = 'sr-item';
    a.href = data.url;

    var title = data.meta && data.meta.title ? data.meta.title : '';
    var authors = data.meta && data.meta.authors ? data.meta.authors : '';
    var year = data.meta && data.meta.year ? data.meta.year : '';
    var type = data.meta && data.meta.type ? data.meta.type : '';
    var excerpt = data.excerpt || '';

    // Title row with type badge
    var titleRow = document.createElement('div');
    titleRow.className = 'sr-title-row';

    var h = document.createElement('h3');
    h.className = 'sr-title';
    h.textContent = title || 'Untitled';
    titleRow.appendChild(h);

    if (type) {
      var badge = document.createElement('span');
      badge.className = 'sr-type sr-type--' + type.toLowerCase();
      badge.textContent = type;
      titleRow.appendChild(badge);
    }
    a.appendChild(titleRow);

    // Meta line (short citation) -- only for Research and Article types
    if (authors && (type === 'Research' || type === 'Article' || !type)) {
      var meta = document.createElement('div');
      meta.className = 'sr-meta';
      var authSpan = document.createElement('span');
      authSpan.className = 'sr-authors';
      authSpan.textContent = authors;
      meta.appendChild(authSpan);
      a.appendChild(meta);
    }

    // Excerpt -- type-aware
    var displayExcerpt = excerpt;
    if (type === 'Course' && data.meta && data.meta.description) {
      displayExcerpt = data.meta.description;
    }
    if (displayExcerpt) {
      var p = document.createElement('p');
      p.className = 'sr-excerpt';
      // Strip Pagefind <mark> tags -- plain text excerpts look cleaner
      p.textContent = displayExcerpt.replace(/<\/?mark>/g, '');
      a.appendChild(p);
    }

    return a;
  }

  function escHtml(s) {
    var d = document.createElement('div');
    d.textContent = s;
    return d.innerHTML;
  }

  // Clear button
  clearBtn.addEventListener('click', function() {
    input.value = '';
    clearBtn.classList.add('hidden');
    resultsEl.innerHTML = '';
    currentResults = [];
    preloadedData = [];
    currentQuery = '';
    input.focus();
  });

  // Wire up input
  input.addEventListener('input', onInput);

  // Handle ?q= or ?topic= URL parameter
  var params = new URLSearchParams(window.location.search);
  var urlQ = params.get('q') || params.get('topic');
  if (urlQ) {
    input.value = urlQ;
    currentQuery = urlQ;
    clearBtn.classList.remove('hidden');
    // Small delay to let page settle, then search + position
    setTimeout(function() { doSearch(urlQ); }, 100);
  }

  // Results panel positioning handled by CSS

  // Preload pagefind on focus for faster first search
  input.addEventListener('focus', function() { ensurePagefind(); }, { once: true });
})();
</script>
