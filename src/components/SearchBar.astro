---
// Custom Pagefind search — uses the JS API directly for full control over result rendering.
// No pagefind-ui.js or pagefind-ui.css loaded.
---
<div class="search-wrapper" id="search">
  <div class="search-box">
    <svg class="search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
    <input
      type="search"
      class="search-input"
      placeholder="Search..."
      id="search-input"
      autocomplete="off"
      autofocus
    />
    <button class="search-clear hidden" id="search-clear" aria-label="Clear search">✕</button>
    <div class="search-results" id="search-results"></div>
  </div>
</div>

<style>
  .search-wrapper {
    position: relative;
    width: 100%;
    z-index: 10;
  }

  /* Search input — position: relative so .search-results is anchored to the input width */
  .search-box {
    position: relative;
    display: flex;
    align-items: center;
    width: 100%;
  }
  .search-icon {
    position: absolute;
    left: 14px;
    color: var(--text-muted);
    pointer-events: none;
  }
  .search-input {
    width: 100%;
    padding: 12px 40px 12px 42px;
    font-size: 16px;
    font-family: 'Inter', sans-serif;
    border: 1px solid var(--border-light);
    border-radius: var(--radius-pill);
    outline: none;
    background: var(--bg-surface);
    color: var(--text-primary);
    box-shadow: 0 4px 16px rgba(0,0,0,0.08), 0 1px 4px rgba(0,0,0,0.04);
    transition: border-color 0.15s, box-shadow 0.15s;
  }
  .search-input:focus {
    border-color: var(--sand-500);
    box-shadow: 0 4px 20px rgba(184,163,143,0.25), 0 0 0 3px rgba(184,163,143,0.12);
  }
  :global([data-theme="dark"]) .search-input {
    border-color: rgba(255,255,255,0.15);
    box-shadow: 0 4px 16px rgba(255,255,255,0.04), 0 1px 4px rgba(255,255,255,0.02);
  }
  :global([data-theme="dark"]) .search-input:focus {
    box-shadow: 0 4px 20px rgba(255,255,255,0.06), 0 0 0 3px var(--focus-ring);
  }
  .search-input::placeholder {
    color: var(--text-muted);
  }
  .search-input::-webkit-search-cancel-button {
    -webkit-appearance: none;
    display: none;
  }
  .search-clear {
    position: absolute;
    right: 12px;
    width: 24px;
    height: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: none;
    background: var(--bg-body);
    color: var(--text-tertiary);
    font-size: 14px;
    cursor: pointer;
    border-radius: 50%;
    padding: 0;
    transition: color 0.15s, background 0.15s;
  }
  .search-clear:hover {
    color: var(--text-primary);
    background: var(--border-light);
  }
  .search-clear.hidden {
    display: none;
  }

  /* Results area — overlay so it doesn't shift the hero layout.
     Width inset by ~24px each side so the panel aligns with the FLAT
     portion of the pill input (the rounded ends would otherwise stick
     out past the panel edges, which looks broken). */
  .search-results {
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    width: calc(100% - 48px);
    text-align: left;
    padding: 0 var(--space-5) var(--space-6);
    background: var(--bg-body);
    max-height: 60vh;
    overflow-y: auto;
    box-shadow: 0 8px 24px rgba(0,0,0,0.1);
    z-index: 100;
  }
  .search-results:empty {
    display: none;
  }

  /* Result count */
  .search-results :global(.sr-count) {
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    padding: var(--space-4) 0 var(--space-2);
  }

  /* Individual result card */
  .search-results :global(.sr-item) {
    display: block;
    padding: var(--space-5) 0;
    border-bottom: 1px solid var(--border-light, var(--border-color));
    text-decoration: none;
    transition: background 0.1s;
  }
  .search-results :global(.sr-item:first-of-type) {
    border-top: 1px solid var(--border-light, var(--border-color));
  }
  .search-results :global(.sr-item:hover) {
    text-decoration: none;
  }
  .search-results :global(.sr-item:hover .sr-title) {
    color: var(--accent);
  }

  /* Title */
  .search-results :global(.sr-title) {
    font-family: 'Cormorant Garamond', 'Georgia', serif;
    font-size: 1.125rem;
    font-weight: 600;
    line-height: 1.3;
    color: var(--text-primary);
    margin: 0 0 6px;
    transition: color 0.15s;
  }

  /* Meta line: authors · journal · year */
  .search-results :global(.sr-meta) {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 2px 0;
    font-size: 0.75rem;
    line-height: 1.5;
    margin-bottom: 8px;
  }
  .search-results :global(.sr-authors) {
    color: var(--text-secondary);
    font-weight: 500;
  }

  /* Excerpt */
  .search-results :global(.sr-excerpt) {
    font-size: 0.8125rem;
    line-height: 1.6;
    color: var(--text-secondary);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* Load more */
  .search-results :global(.sr-more) {
    display: block;
    width: 100%;
    margin-top: var(--space-5);
    padding: var(--space-3) var(--space-5);
    font-size: 0.8125rem;
    font-weight: 500;
    font-family: 'Inter', sans-serif;
    color: var(--text-secondary);
    background: var(--bg-surface);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-pill);
    cursor: pointer;
    transition: border-color 0.15s, color 0.15s;
  }
  .search-results :global(.sr-more:hover) {
    border-color: var(--accent);
    color: var(--accent);
  }

  /* Loading */
  .search-results :global(.sr-loading) {
    font-size: 0.8125rem;
    color: var(--text-muted);
    padding: var(--space-5) 0;
    display: flex;
    align-items: center;
    gap: 0.5em;
  }
  .search-results :global(.sr-loading-spinner) {
    display: inline-block;
    font-family: monospace;
    font-size: 1rem;
    line-height: 1;
  }

  /* No results */
  .search-results :global(.sr-empty) {
    font-size: 0.875rem;
    color: var(--text-tertiary);
    padding: var(--space-6) 0;
  }

  /* Type badge in title row */
  .search-results :global(.sr-title-row) {
    display: flex;
    align-items: baseline;
    gap: var(--space-2);
  }
  .search-results :global(.sr-type) {
    flex-shrink: 0;
    font-size: 0.5625rem;
    font-weight: 600;
    font-family: 'Inter', sans-serif;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 2px 6px;
    border-radius: 3px;
    white-space: nowrap;
  }
  .search-results :global(.sr-type--research) {
    color: var(--green-700);
    background: var(--green-100);
  }
  .search-results :global(.sr-type--course) {
    color: var(--purple-700);
    background: var(--purple-100);
  }
  .search-results :global(.sr-type--faq) {
    color: var(--amber-700);
    background: var(--amber-100);
  }
  .search-results :global(.sr-type--article) {
    color: var(--sage-700);
    background: var(--sage-100);
  }
  .search-results :global(.sr-type--guide) {
    color: var(--rose-700);
    background: var(--rose-100);
  }
  .search-results :global(.sr-type--glossary) {
    color: var(--sand-700);
    background: var(--sand-300);
  }

  /* ── Filter chip row ── */
  .search-results :global(.sr-chips) {
    display: flex;
    gap: 6px;
    padding: var(--space-4) 0 var(--space-3);
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    position: sticky;
    top: 0;
    background: var(--bg-body);
    z-index: 1;
    border-bottom: 1px solid var(--border-light);
    margin-bottom: var(--space-1);
  }
  .search-results :global(.sr-chips::-webkit-scrollbar) { display: none; }
  .search-results :global(.sr-chip) {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 12px;
    font-family: 'Inter', sans-serif;
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--text-secondary);
    background: var(--bg-surface);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-pill);
    cursor: pointer;
    white-space: nowrap;
    transition: color 0.15s, border-color 0.15s, background 0.15s;
  }
  .search-results :global(.sr-chip:hover) {
    color: var(--accent);
    border-color: var(--accent);
  }
  .search-results :global(.sr-chip-count) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 18px;
    height: 16px;
    padding: 0 5px;
    font-size: 0.625rem;
    font-weight: 600;
    color: var(--text-tertiary);
    background: var(--bg-body);
    border-radius: 8px;
    font-variant-numeric: tabular-nums;
  }
  .search-results :global(.sr-chip--active) {
    color: #fff;
    background: var(--accent);
    border-color: var(--accent);
  }
  .search-results :global(.sr-chip--active:hover) {
    color: #fff;
    border-color: var(--accent);
  }
  .search-results :global(.sr-chip--active .sr-chip-count) {
    color: var(--accent);
    background: #fff;
  }

  /* ── Grouped sections ── */
  .search-results :global(.sr-group) {
    padding-top: var(--space-4);
  }
  .search-results :global(.sr-group:first-child) {
    padding-top: var(--space-2);
  }
  .search-results :global(.sr-group-heading) {
    display: flex;
    align-items: center;
    gap: 8px;
    margin: 0 0 var(--space-2);
    padding: 0;
    font-family: 'Inter', sans-serif;
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-tertiary);
  }
  .search-results :global(.sr-group-count) {
    font-variant-numeric: tabular-nums;
    color: var(--text-muted);
    font-weight: 500;
  }
  /* Tighter row padding inside groups; remove the legacy "first-of-type top border" */
  .search-results :global(.sr-group .sr-item) {
    padding-top: var(--space-3);
    padding-bottom: var(--space-3);
  }
  .search-results :global(.sr-group .sr-item:first-of-type) {
    border-top: none;
  }
  /* Drop the per-type badge inside groups — the heading already states the type. */
  .search-results :global(.sr-group .sr-type) {
    display: none;
  }

  /* Default "all" mode: hide items past each group's preview limit */
  .search-results :global(.sr-groups[data-active-filter="all"] .sr-item[data-over-preview]) {
    display: none;
  }
  /* Filter active: hide every group, then re-show the targeted one */
  .search-results :global(.sr-groups[data-active-filter]:not([data-active-filter="all"]) .sr-group) {
    display: none;
  }
  .search-results :global(.sr-groups[data-active-filter="Guide"] .sr-group[data-group-type="Guide"]),
  .search-results :global(.sr-groups[data-active-filter="Glossary"] .sr-group[data-group-type="Glossary"]),
  .search-results :global(.sr-groups[data-active-filter="FAQ"] .sr-group[data-group-type="FAQ"]),
  .search-results :global(.sr-groups[data-active-filter="Course"] .sr-group[data-group-type="Course"]),
  .search-results :global(.sr-groups[data-active-filter="Article"] .sr-group[data-group-type="Article"]),
  .search-results :global(.sr-groups[data-active-filter="Research"] .sr-group[data-group-type="Research"]) {
    display: block;
  }
  /* Filter active: the "Show all" button is redundant — we're already showing all */
  .search-results :global(.sr-groups[data-active-filter]:not([data-active-filter="all"]) .sr-show-all) {
    display: none;
  }

  /* Show-all button (inline within a group, in default mode only) */
  .search-results :global(.sr-show-all) {
    display: block;
    width: 100%;
    margin-top: var(--space-3);
    padding: 8px 14px;
    font-family: 'Inter', sans-serif;
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--text-secondary);
    background: var(--bg-surface);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-pill);
    cursor: pointer;
    text-align: left;
    transition: color 0.15s, border-color 0.15s;
  }
  .search-results :global(.sr-show-all:hover) {
    color: var(--accent);
    border-color: var(--accent);
  }
</style>

<script is:inline>
(function() {
  var input = document.getElementById('search-input');
  var clearBtn = document.getElementById('search-clear');
  var resultsEl = document.getElementById('search-results');
  if (!input || !resultsEl) return;

  var pagefindReady = null;
  var debounceTimer = null;
  var lastBeaconedQuery = '';
  var totalCount = 0;
  var currentQuery = '';
  var PRELOAD_CAP = 50;
  var preloadedData = [];
  var activeFilter = 'all';
  var inflightSemanticCtl = null;

  // Grouped-result ordering (chip + section order, left-to-right).
  // Courses placed last; primary order is Brian-specified.
  var TYPE_ORDER = ['Guide', 'Research', 'Glossary', 'Article', 'FAQ', 'Course'];
  var TYPE_LABEL = { Guide: 'Guides', Glossary: 'Glossary', FAQ: 'FAQs', Course: 'Courses', Article: 'Commentary', Research: 'Research' };
  var GROUP_PREVIEW = { Guide: 5, Glossary: 5, FAQ: 5, Course: 5, Article: 3, Research: 3 };

  // Shared mutable context written by per-result pointerdown handlers and
  // committed once on pagehide. Single-listener pattern avoids the per-click
  // listener leak that {once:true} would still produce when the user re-clicks
  // without navigating (each click re-registers a listener; multi-click sessions
  // stack them up before pagehide finally fires).
  var pendingSearchContext = null;

  window.addEventListener('pagehide', function () {
    // Respect __rrmClearRequested__ flag set by [data-clear-shell-context]
    // pointerdowns in AppShellChrome -- otherwise SearchBar's pagehide writer
    // can re-poison sessionStorage after the user explicitly cleared context
    // by tapping a sidebar/drawer/bottom-nav link (/arise --deep #2).
    if (window.__rrmClearRequested__) return;
    if (!pendingSearchContext) return;
    try {
      sessionStorage.setItem('rrm-shell-context', JSON.stringify(pendingSearchContext));
    } catch (err) {}
  });

  // Waverows animation frames (from unicode-animations)
  var waveFrames = ['⠖⠉⠉⠑','⡠⠖⠉⠉','⣠⡠⠖⠉','⣄⣠⡠⠖','⠢⣄⣠⡠','⠙⠢⣄⣠','⠉⠙⠢⣄','⠊⠉⠙⠢','⠜⠊⠉⠙','⡤⠜⠊⠉','⣀⡤⠜⠊','⢤⣀⡤⠜','⠣⢤⣀⡤','⠑⠣⢤⣀','⠉⠑⠣⢤','⠋⠉⠑⠣'];
  var waveInterval = 160;
  var spinnerTimer = null;

  function startLoadingSpinner() {
    stopLoadingSpinner();
    resultsEl.innerHTML = '<p class="sr-loading">Searching <span class="sr-loading-spinner"></span></p>';
    var el = resultsEl.querySelector('.sr-loading-spinner');
    if (!el) return;
    var fi = 0;
    el.textContent = waveFrames[0];
    spinnerTimer = setInterval(function() {
      fi = (fi + 1) % waveFrames.length;
      el.textContent = waveFrames[fi];
    }, waveInterval);
  }

  function stopLoadingSpinner() {
    if (spinnerTimer) { clearInterval(spinnerTimer); spinnerTimer = null; }
  }

  // Beacon the user's search query + result count to /api/search/log for
  // content-gap analysis. Fire-and-forget, deduped per unique query, capped
  // at 500 chars, skipped for queries under 2 chars.
  function beaconQuery(query, resultsCount) {
    if (!query || query.length < 2 || query.length > 500) return;
    if (query === lastBeaconedQuery) return;
    lastBeaconedQuery = query;
    try {
      fetch('/api/search/log', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ query: query, results_count: resultsCount, source: 'pagefind' }),
        keepalive: true,
        credentials: 'same-origin',
      }).catch(function(){});
    } catch(e) {}
  }

  // Load Pagefind on first interaction — single shared promise prevents race conditions.
  // Tries direct import first (fastest), falls back to fetch+blob URL for browsers
  // whose extensions strip MIME types (e.g. Comet/Perplexity).
  function ensurePagefind() {
    if (!pagefindReady) {
      pagefindReady = import('/pagefind/pagefind.js').catch(function() {
        // Direct import failed (MIME stripped?) — try blob URL with explicit type
        return fetch('/pagefind/pagefind.js')
          .then(function(r) { return r.text(); })
          .then(function(js) {
            var blob = new Blob([js], { type: 'application/javascript' });
            return import(URL.createObjectURL(blob));
          });
      }).then(function(pf) {
        return pf.options({ basePath: '/pagefind/' }).then(function() { return pf.init(); }).then(function() { return pf; });
      }).catch(function(err) {
        pagefindReady = null;
        throw err;
      });
    }
    return pagefindReady;
  }

  // Debounced search
  function onInput() {
    var q = input.value.trim();
    clearBtn.classList.toggle('hidden', !q);
    clearTimeout(debounceTimer);
    if (!q) {
      stopLoadingSpinner();
      resultsEl.innerHTML = '';
      preloadedData = [];
      currentQuery = '';
      activeFilter = 'all';
      return;
    }
    currentQuery = q;
    debounceTimer = setTimeout(function() { doSearch(q); }, 150);
  }

  // Detect non-English titles to de-prioritize in results.
  // Two signals: (1) 3+ non-ASCII chars after stripping English loanwords,
  // or (2) title has 5+ words but almost none are common English function words.
  var _engWordRe = /^(the|of|in|and|for|with|a|an|to|from|by|on|at|or|is|are|was|were|after|before|between|during|through|about|into|over|its|their|this|that|these|those|which|who|has|have|had|not|but|can|may|should|will|be|been|do|each|all|both|more|most|some|such|no|only|other|same|so|also|new|based|using|associated|among|without|within|upon|including|following|versus|compared|effect|role|impact|review|study|analysis|treatment|outcomes|risk|women|patients|clinical|use|health)$/i;
  function isNonEnglish(title) {
    if (!title) return false;
    // Signal 1: non-ASCII density (catches French, German with accents/umlauts)
    var t = title.replace(/m\u00fcller\w*/gi, '').replace(/caf\u00e9/gi, '').replace(/na\u00efve/gi, '');
    var nonAscii = (t.match(/[^\x00-\x7F]/g) || []).length;
    if (nonAscii >= 3) return true;
    // Signal 2: lacks English function words (catches Polish, some Spanish with ASCII chars)
    var words = title.split(/[\s\-\u2013\u2014:,;.()]+/).filter(function(w) { return w.length > 0; });
    if (words.length < 5) return false;
    var engCount = 0;
    for (var i = 0; i < words.length; i++) {
      if (_engWordRe.test(words[i])) engCount++;
    }
    return (engCount / words.length) < 0.10;
  }

  function extractSlug(url) {
    var parts = url.replace(/\/$/, '').split('/');
    return parts[parts.length - 1];
  }

  async function doSearch(query) {
    startLoadingSpinner();

    try {
      // Fire both searches in parallel
      if (inflightSemanticCtl) inflightSemanticCtl.abort();
      inflightSemanticCtl = new AbortController();
      // Anchor the semantic timeout to fetch start, not to after-Pagefind. Cold-load
      // Pagefind (200-500ms) used to silently extend the semantic budget; now the
      // 300ms ceiling is consistent regardless of Pagefind warm/cold state.
      var semanticStart = Date.now();
      var semanticPromise = fetch('/api/search/semantic?q=' + encodeURIComponent(query), { signal: inflightSemanticCtl.signal })
        .then(function(r) { return r.json(); })
        .catch(function(err) {
          if (err && err.name === 'AbortError') return { results: [], aborted: true };
          console.warn('Semantic search failed:', err.message || err);
          return { results: [] };
        });

      var pf = await ensurePagefind();
      var search = await pf.search(query);
      if (query !== currentQuery) { stopLoadingSpinner(); return; }
      // Pre-load top Pagefind results for metadata access
      var toPreload = search.results.slice(0, PRELOAD_CAP);
      var pfLoaded = (await Promise.all(
        toPreload.map(function(r, i) {
          return r.data().then(function(d) {
            d._pfRank = i;
            // Non-English penalty: push far down the Pagefind ranking
            if (isNonEnglish(d.meta && d.meta.title)) d._pfRank += 1000;
            return d;
          }).catch(function() { return null; });
        })
      )).filter(Boolean);
      if (query !== currentQuery) { stopLoadingSpinner(); return; }

      // Wait for semantic with a 300ms budget measured from semanticStart. If
      // Pagefind took >=300ms, the remaining budget is 0 (semantic already
      // settled or timed out from the user's POV).
      var semanticRemaining = Math.max(0, 300 - (Date.now() - semanticStart));
      var semanticData = await Promise.race([
        semanticPromise,
        new Promise(function(resolve) { setTimeout(function() { resolve(null); }, semanticRemaining); })
      ]);
      if (query !== currentQuery) { stopLoadingSpinner(); return; }

      var semanticResults = (semanticData && semanticData.results || []).filter(function(sr) { return sr.score >= 0.5; });

      // --- Reciprocal Rank Fusion ---
      // RRF score = sum(1 / (K + rank)) across both systems
      // Items appearing in both lists get boosted; single-source items still included
      var RRF_K = 60;
      var fusedMap = {}; // url -> { score, data }

      // Normalize URLs to relative paths (Pagefind may return absolute pages.dev URLs)
      function toRelative(url) {
        try { return new URL(url).pathname; } catch(e) { return url; }
      }

      // Extract Airtable record ID from slug (e.g. "...-recXYZ123/" -> "recxyz123")
      // Used for dedup when slugs change but record ID stays the same
      function extractRecId(url) {
        var m = url.match(/-(rec[a-zA-Z0-9]{14})\/?$/);
        return m ? m[1].toLowerCase() : null;
      }

      var recIdToKey = {}; // recId -> fusedMap key (for cross-slug dedup)

      // Score Pagefind results (dedup by record ID within Pagefind too)
      for (var pi = 0; pi < pfLoaded.length; pi++) {
        var pItem = pfLoaded[pi];
        var pUrl = toRelative(pItem.url);
        pItem.url = pUrl;
        var pRecId = extractRecId(pUrl);
        var existingKey = pRecId && recIdToKey[pRecId];
        if (existingKey) {
          // Same article, different URL -- boost and keep higher-ranked
          fusedMap[existingKey].score += 1 / (RRF_K + pItem._pfRank);
        } else if (fusedMap[pUrl]) {
          fusedMap[pUrl].score += 1 / (RRF_K + pItem._pfRank);
        } else {
          fusedMap[pUrl] = {
            score: 1 / (RRF_K + pItem._pfRank),
            data: pItem
          };
          if (pRecId) recIdToKey[pRecId] = pUrl;
        }
      }

      // Score and merge semantic results
      for (var si = 0; si < semanticResults.length; si++) {
        var sItem = semanticResults[si];
        var sUrl = toRelative(sItem.url);
        var sRank = si;
        if (isNonEnglish(sItem.title)) sRank += 1000;

        // Match by URL first, then by record ID (handles slug renames)
        var sRecId = extractRecId(sUrl);
        var matchKey = fusedMap[sUrl] ? sUrl : (sRecId && recIdToKey[sRecId]) ? recIdToKey[sRecId] : null;

        if (matchKey) {
          // Boost existing result -- appears in both systems
          fusedMap[matchKey].score += 1 / (RRF_K + sRank);
          // Prefer semantic URL (current slug) over stale Pagefind URL
          if (matchKey !== sUrl) fusedMap[matchKey].data.url = sUrl;
          // Enrich with type from semantic if Pagefind lacks it
          if (fusedMap[matchKey].data.meta && !fusedMap[matchKey].data.meta.type && sItem.type) {
            fusedMap[matchKey].data.meta.type = sItem.type;
          }
        } else {
          // Semantic-only result -- still valuable for intent matches Pagefind missed
          var sMeta = { title: sItem.title, authors: sItem.authors || '', year: sItem.year ? String(sItem.year) : '', type: sItem.type || 'Research' };
          if (sItem.rrmRelevance) sMeta.rrmRelevance = sItem.rrmRelevance;
          fusedMap[sUrl] = {
            score: 1 / (RRF_K + sRank),
            data: {
              url: sUrl, excerpt: '',
              meta: sMeta,
              _pfRank: -1
            }
          };
          // Track record ID so subsequent semantic dupes merge here too
          if (sRecId && !recIdToKey[sRecId]) recIdToKey[sRecId] = sUrl;
        }
      }

      // Recency boost: additive RRF-style term (like a virtual 3rd ranking system)
      // Uses smaller K (30 vs 60) and gentler age curve so recent papers
      // meaningfully outrank older keyword-dense papers on broad queries.
      // 2026: +0.033, 2020: +0.021, 2012: +0.014, 2006: +0.008, <2006: 0
      var RECENCY_K = 30;
      var currentYear = new Date().getFullYear();
      for (var rKey in fusedMap) {
        var entry = fusedMap[rKey];
        var yr = parseInt(entry.data.meta && entry.data.meta.year, 10);
        if (yr > 0) {
          var age = Math.max(0, currentYear - yr);
          if (age < 20) {
            var recencyRank = Math.round(age * 2.5);
            entry.score += 1 / (RECENCY_K + recencyRank);
          }
        }
      }

      // RRM Relevance boost: 4th RRF signal based on rrmRelevance field.
      // Own content (Article/FAQ/Course/Guide) and Core RRM get max boost.
      // Tiebreaker strength (K=50) -- won't override strong keyword matches.
      var RELEVANCE_K = 50;
      var _relevanceMap = { '5 - Core RRM': 0, '4 - Highly Relevant': 10, '3 - Relevant': 25, '2 - Peripheral': 45, '1 - Not RRM': 60 };
      var _ownContentTypes = { 'Article': 1, 'FAQ': 1, 'Course': 1, 'Guide': 1, 'Glossary': 1 };
      for (var rlKey in fusedMap) {
        var rlEntry = fusedMap[rlKey];
        var rlMeta = rlEntry.data.meta || {};
        var rlRank = 30;
        if (_ownContentTypes[rlMeta.type]) {
          rlRank = 0;
        } else if (rlMeta.rrmRelevance && _relevanceMap[rlMeta.rrmRelevance] !== undefined) {
          rlRank = _relevanceMap[rlMeta.rrmRelevance];
        }
        rlEntry.score += 1 / (RELEVANCE_K + rlRank);

        // Sentiment penalty: demote hostile/critical articles
        var rlSentiment = rlMeta.sentiment;
        if (rlSentiment === 'hostile') rlEntry.score -= 0.02;
        else if (rlSentiment === 'critical') rlEntry.score -= 0.01;
      }

      // Sort by fused RRF score descending
      var fusedList = [];
      for (var fKey in fusedMap) {
        fusedList.push(fusedMap[fKey]);
      }
      fusedList.sort(function(a, b) { return b.score - a.score; });

      preloadedData = fusedList.map(function(f) { f.data._score = f.score; return f.data; });
      totalCount = preloadedData.length;
      activeFilter = 'all';
      stopLoadingSpinner();
      beaconQuery(query, totalCount);
      renderPanel();

      // If semantic timed out, merge late-arriving results as addenda
      if (!semanticData) {
        semanticPromise.then(function(lateData) {
          if (query !== currentQuery) return;
          if (lateData && lateData.aborted) return;
          var lateResults = (lateData && lateData.results || []).filter(function(sr) { return sr.score >= 0.5; });
          var existingUrls = {};
          var existingRecIds = {};
          for (var ei = 0; ei < preloadedData.length; ei++) {
            var eUrl = toRelative(preloadedData[ei].url).toLowerCase();
            existingUrls[eUrl] = true;
            var eRecId = extractRecId(eUrl);
            if (eRecId) existingRecIds[eRecId] = true;
          }
          var added = 0;
          for (var li = 0; li < lateResults.length; li++) {
            var lr = lateResults[li];
            var lrUrl = toRelative(lr.url).toLowerCase();
            var lrRecId = extractRecId(lrUrl);
            if (existingUrls[lrUrl] || (lrRecId && existingRecIds[lrRecId])) continue;
            var lrType = lr.type || 'Research';
            var lrTitle = lr.title || '';
            if (isNonEnglish(lrTitle)) continue;
            var lrRank = li;
            var lrScore = 1 / (RRF_K + lrRank);
            var lrYear = parseInt(lr.year, 10);
            if (lrYear > 0) {
              var lrAge = Math.max(0, currentYear - lrYear);
              if (lrAge < 20) lrScore += 1 / (RECENCY_K + Math.round(lrAge * 2.5));
            }
            var lrRelRank = 30;
            if (_ownContentTypes[lrType]) lrRelRank = 0;
            else if (lr.rrmRelevance && _relevanceMap[lr.rrmRelevance] !== undefined) lrRelRank = _relevanceMap[lr.rrmRelevance];
            lrScore += 1 / (RELEVANCE_K + lrRelRank);
            if (lr.sentiment === 'hostile') lrScore -= 0.02;
            else if (lr.sentiment === 'critical') lrScore -= 0.01;
            preloadedData.push({
              url: lr.url, excerpt: '',
              meta: { title: lrTitle, authors: lr.authors || '', year: lr.year ? String(lr.year) : '', type: lrType },
              _pfRank: -1,
              _score: lrScore
            });
            added++;
          }
          if (added > 0) {
            preloadedData.sort(function(a, b) { return (b._score || 0) - (a._score || 0); });
            totalCount = preloadedData.length;
            renderPanel();
          }
        });
      }
    } catch(e) {
      console.error('Search failed:', e);
      stopLoadingSpinner();
      if (query !== currentQuery) return;
      resultsEl.innerHTML = '<p class="sr-empty">Search unavailable</p>';
    }
  }

  function renderPanel() {
    resultsEl.innerHTML = '';
    if (totalCount === 0) {
      resultsEl.innerHTML = '<p class="sr-empty">No results found for "' + escHtml(currentQuery) + '"</p>';
      return;
    }

    // Bucket by type, preserving RRF order within each bucket.
    var buckets = {};
    for (var i = 0; i < preloadedData.length; i++) {
      var item = preloadedData[i];
      var t = (item.meta && item.meta.type) || 'Research';
      if (!buckets[t]) buckets[t] = [];
      buckets[t].push(item);
    }

    // Chip row — "All" first, then types in funnel order, only if non-empty.
    var chips = document.createElement('div');
    chips.className = 'sr-chips';
    chips.appendChild(makeChip('all', 'All', totalCount));
    for (var ci = 0; ci < TYPE_ORDER.length; ci++) {
      var ct = TYPE_ORDER[ci];
      if (buckets[ct] && buckets[ct].length) {
        chips.appendChild(makeChip(ct, TYPE_LABEL[ct], buckets[ct].length));
      }
    }
    resultsEl.appendChild(chips);

    // Groups
    var groupsEl = document.createElement('div');
    groupsEl.className = 'sr-groups';
    groupsEl.setAttribute('data-active-filter', activeFilter);
    for (var gi = 0; gi < TYPE_ORDER.length; gi++) {
      var gt = TYPE_ORDER[gi];
      var items = buckets[gt];
      if (!items || !items.length) continue;
      var section = document.createElement('section');
      section.className = 'sr-group';
      section.setAttribute('data-group-type', gt);

      var heading = document.createElement('h4');
      heading.className = 'sr-group-heading';
      heading.appendChild(document.createTextNode(TYPE_LABEL[gt]));
      if (items.length > 1) {
        var countSpan = document.createElement('span');
        countSpan.className = 'sr-group-count';
        countSpan.textContent = items.length;
        heading.appendChild(countSpan);
      }
      section.appendChild(heading);

      var preview = GROUP_PREVIEW[gt] || 3;
      for (var ii = 0; ii < items.length; ii++) {
        var a = renderResult(items[ii]);
        if (ii >= preview) a.setAttribute('data-over-preview', '');
        section.appendChild(a);
      }

      if (items.length > preview) {
        var showAll = document.createElement('button');
        showAll.className = 'sr-show-all';
        showAll.setAttribute('data-filter-target', gt);
        showAll.textContent = 'Show all ' + items.length + ' in ' + TYPE_LABEL[gt] + ' →';
        showAll.addEventListener('click', function(e) {
          setFilter(e.currentTarget.getAttribute('data-filter-target'));
        });
        section.appendChild(showAll);
      }

      groupsEl.appendChild(section);
    }
    resultsEl.appendChild(groupsEl);
  }

  function makeChip(value, label, count) {
    var chip = document.createElement('button');
    chip.className = 'sr-chip' + (activeFilter === value ? ' sr-chip--active' : '');
    chip.setAttribute('data-filter', value);
    chip.appendChild(document.createTextNode(label));
    var c = document.createElement('span');
    c.className = 'sr-chip-count';
    c.textContent = count;
    chip.appendChild(c);
    chip.addEventListener('click', function() {
      setFilter(chip.getAttribute('data-filter'));
    });
    return chip;
  }

  function setFilter(type) {
    activeFilter = type;
    var groupsEl = resultsEl.querySelector('.sr-groups');
    if (groupsEl) groupsEl.setAttribute('data-active-filter', type);
    var chipNodes = resultsEl.querySelectorAll('.sr-chip');
    for (var i = 0; i < chipNodes.length; i++) {
      var c = chipNodes[i];
      if (c.getAttribute('data-filter') === type) c.classList.add('sr-chip--active');
      else c.classList.remove('sr-chip--active');
    }
    if (resultsEl.scrollTo) resultsEl.scrollTo({ top: 0, behavior: 'smooth' });
    else resultsEl.scrollTop = 0;
  }

  function renderResult(data) {
    var a = document.createElement('a');
    a.className = 'sr-item';
    a.href = data.url;

    var title = data.meta && data.meta.title ? data.meta.title : '';
    var authors = data.meta && data.meta.authors ? data.meta.authors : '';
    var year = data.meta && data.meta.year ? data.meta.year : '';
    var type = data.meta && data.meta.type ? data.meta.type : '';
    var excerpt = data.excerpt || '';

    // Title row with type badge
    var titleRow = document.createElement('div');
    titleRow.className = 'sr-title-row';

    var h = document.createElement('h3');
    h.className = 'sr-title';
    h.textContent = title || 'Untitled';
    titleRow.appendChild(h);

    if (type) {
      var badge = document.createElement('span');
      badge.className = 'sr-type sr-type--' + type.toLowerCase();
      badge.textContent = type;
      titleRow.appendChild(badge);
    }
    a.appendChild(titleRow);

    // Meta line (short citation) -- only for Research and Article types
    if (authors && (type === 'Research' || type === 'Article' || !type)) {
      var meta = document.createElement('div');
      meta.className = 'sr-meta';
      var authSpan = document.createElement('span');
      authSpan.className = 'sr-authors';
      authSpan.textContent = authors;
      meta.appendChild(authSpan);
      a.appendChild(meta);
    }

    // Excerpt -- type-aware
    var displayExcerpt = excerpt;
    if (type === 'Course' && data.meta && data.meta.description) {
      displayExcerpt = data.meta.description;
    }
    if (displayExcerpt) {
      var p = document.createElement('p');
      p.className = 'sr-excerpt';
      // Strip Pagefind <mark> tags -- plain text excerpts look cleaner
      p.textContent = displayExcerpt.replace(/<\/?mark>/g, '');
      a.appendChild(p);
    }

    a.addEventListener('pointerdown', function (e) {
      // Determine source based on clicked anchor's path.
      var clickedHref = a.getAttribute('href') || '';
      var isCommentaryClick = clickedHref.indexOf('/commentary/') !== -1;
      var pathSubstring = isCommentaryClick ? '/commentary/' : '/library/';
      var resultSource = isCommentaryClick ? 'commentary' : 'library';

      // Capture only same-source visible result slugs + titles.
      var allLinks = document.querySelectorAll(
        '#search-results a[href*="' + pathSubstring + '"]'
      );
      var slugs = [];
      var titles = [];
      allLinks.forEach(function (link) {
        try {
          var u = new URL(link.getAttribute('href'), location.origin);
          var pm = u.pathname.match(/^\/(library|commentary)\/([a-z0-9][a-z0-9-]{0,250})\/?$/);
          if (!pm) return;
          // Only push if this link's type matches the clicked source.
          if (pm[1] !== resultSource) return;
          slugs.push(pm[2]);
          var titleEl = link.querySelector('.sr-title') ||
                        (link.closest('.sr-item') && link.closest('.sr-item').querySelector('.sr-title'));
          titles.push(titleEl ? (titleEl.textContent || '').trim().slice(0, 300) : '');
        } catch (err) { /* malformed URL — skip */ }
      });
      if (slugs.length === 0) return;
      pendingSearchContext = {
        source: resultSource,
        label: 'Search · "' + (currentQuery || '').slice(0, 80) + '" · ' + slugs.length + ' results',
        slugs: slugs.slice(0, 500),
        titles: titles.slice(0, 500),
        returnUrl: '/' + resultSource + '/?q=' + encodeURIComponent(currentQuery || ''),
        filters: { q: currentQuery || '' },
        writtenAt: Date.now()
      };
    });

    return a;
  }

  function escHtml(s) {
    var d = document.createElement('div');
    d.textContent = s;
    return d.innerHTML;
  }

  // Clear button
  clearBtn.addEventListener('click', function() {
    clearTimeout(debounceTimer);
    stopLoadingSpinner();
    input.value = '';
    clearBtn.classList.add('hidden');
    resultsEl.innerHTML = '';
    preloadedData = [];
    currentQuery = '';
    activeFilter = 'all';
    input.focus();
  });

  // Submit on Enter (debounced live search handles the rest)
  input.addEventListener('keydown', function(e) {
    if (e.key === 'Enter') {
      e.preventDefault();
      var q = input.value.trim();
      if (q) { clearTimeout(debounceTimer); doSearch(q); }
    }
  });

  // Wire up input
  input.addEventListener('input', onInput);

  // Handle ?q= or ?topic= URL parameter
  var params = new URLSearchParams(window.location.search);
  var urlQ = params.get('q') || params.get('topic');
  if (urlQ) {
    input.value = urlQ;
    currentQuery = urlQ;
    clearBtn.classList.remove('hidden');
    // Small delay to let page settle, then search + position
    setTimeout(function() { doSearch(urlQ); }, 100);
  }

  // Results panel positioning handled by CSS

  // Preload pagefind on focus for faster first search
  input.addEventListener('focus', function() { ensurePagefind().catch(function(){}); }, { once: true });
})();
</script>
