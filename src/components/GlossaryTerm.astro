---
// Single render path for a glossary term, used by:
//   - /glossary/ (pillar): headingLevel="h3", inline anchor IDs preserved
//   - /glossary/<slug>/ (spoke): headingLevel="h1", cross-refs rewritten to absolute URLs
//     (the component IS the page heading on a spoke; the spoke route does NOT add
//     a separate <h1>, otherwise the term name renders twice)
// Edit-once / render-twice. The term body lives in D1 (glossary_term.body_html);
// every visible rendering of it on the site flows through this component, which
// makes drift between the pillar and the spokes physically impossible.

interface GlossaryTerm {
  slug: string;
  name: string;
  bodyHtml: string;
  abbreviation: string | null;
  pillarLink: string | null;
}

interface Props {
  term: GlossaryTerm;
  headingLevel: 'h1' | 'h2' | 'h3';
  /** "spoke" rewrites href="#xxx" to absolute URLs; "pillar" leaves anchors as-is. */
  mode: 'pillar' | 'spoke';
  /**
   * On spoke pages that render their own per-term references list (Sources
   * block), pass true so href="#ref-N" stays as a same-page jump instead of
   * being rewritten to the pillar's master ref list at /glossary/#ref-N.
   */
  keepLocalRefAnchors?: boolean;
}

const { term, headingLevel, mode, keepLocalRefAnchors = false } = Astro.props;

// Cross-ref rewrite for spoke pages.
//   #ref-N                       -> /glossary/#ref-N         (jump back to pillar's references list,
//                                                             unless keepLocalRefAnchors -> stays #ref-N)
//   #abbreviations / #references -> /glossary/#<id>          (jump back to pillar's section anchors)
//   #<term-slug>                 -> /glossary/<term-slug>/   (link to sibling spoke)
// The pillar leaves these as same-page anchors, so this only fires when mode === 'spoke'.
function rewriteAnchors(html: string): string {
  return html.replace(/href=(["'])#([^"']+)\1/g, (_match, _quote, target: string) => {
    const t = target.toLowerCase();
    if (t.startsWith('ref-') || t === 'abbreviations' || t === 'references') {
      // Keep ref-N as same-page jumps when the spoke renders its own Sources
      // block (keepLocalRefAnchors=true). Otherwise (and always for the
      // abbreviations / references section anchors) jump back to the pillar.
      if (keepLocalRefAnchors && t.startsWith('ref-')) return `href="#${t}"`;
      return `href="/glossary/#${t}"`;
    }
    if (!/^[a-z0-9](?:[a-z0-9-]*[a-z0-9])?$/.test(t)) {
      return `href="/glossary/#${t}"`;
    }
    return `href="/glossary/${t}/"`;
  });
}

const renderedBody = mode === 'spoke' ? rewriteAnchors(term.bodyHtml) : term.bodyHtml;
const HeadingTag = headingLevel;
---

<HeadingTag id={term.slug}>
  {term.pillarLink
    ? <a href={term.pillarLink}>{term.name}</a>
    : term.name}
</HeadingTag>
<slot name="post-heading" />
<Fragment set:html={renderedBody} />
{mode === 'pillar' && (
  <p class="term-spoke-link">
    <a href={`/glossary/${term.slug}/`}>Open full entry &rarr;</a>
  </p>
)}
