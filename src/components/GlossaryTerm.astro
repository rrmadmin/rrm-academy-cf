---
// Single render path for a glossary term, used by:
//   - /glossary/ (pillar): headingLevel="h3", inline anchor IDs preserved
//   - /glossary/<slug>/ (spoke): headingLevel="h1", cross-refs rewritten to absolute URLs
//     (the component IS the page heading on a spoke; the spoke route does NOT add
//     a separate <h1>, otherwise the term name renders twice)
// Edit-once / render-twice. The term body lives in D1 (glossary_term.body_html);
// every visible rendering of it on the site flows through this component, which
// makes drift between the pillar and the spokes physically impossible.

interface DefinitionSource {
  sourceKey: string;
  sourceLabel: string;
  sourceUrl: string | null;
  code: string | null;
  definitionText: string;
  isVerbatim: boolean;
  isExcerpt?: boolean;
  visibility?: 'public' | 'internal_only';
  attribution: string | null;
  sortOrder: number;
}

interface CitedReference {
  refNum: number;
  anchorText: string;
  url: string | null;
  publisher: string | null;
  journal: string | null;
}

interface GlossaryTerm {
  slug: string;
  name: string;
  bodyHtml: string;
  abbreviation: string | null;
  pillarLink: string | null;
  definitionSources?: DefinitionSource[];
  citedReferences?: CitedReference[];
}

interface Props {
  term: GlossaryTerm;
  headingLevel: 'h1' | 'h2' | 'h3';
  /** "spoke" rewrites href="#xxx" to absolute URLs; "pillar" leaves anchors as-is. */
  mode: 'pillar' | 'spoke';
  /**
   * On spoke pages that render their own per-term references list (Sources
   * block), pass true so href="#ref-N" stays as a same-page jump instead of
   * being rewritten to the pillar's master ref list at /glossary/#ref-N.
   */
  keepLocalRefAnchors?: boolean;
  /** Whether to include the inline-citation list inside the references section. */
  includeCitedReferences?: boolean;
  /**
   * Known glossary slug set (lowercase). When provided, rewriteAnchors only
   * routes `href="#xxx"` to `/glossary/xxx/` if xxx is in this set; otherwise
   * it falls back to `/glossary/#xxx` (pillar same-page jump).
   */
  knownSlugs?: Set<string>;
}

const { term, headingLevel, mode, keepLocalRefAnchors = false, includeCitedReferences = false, knownSlugs } = Astro.props;

// Cross-ref rewrite for spoke pages.
//   #ref-N                       -> /glossary/#ref-N         (jump back to pillar's references list,
//                                                             unless keepLocalRefAnchors -> stays #ref-N)
//   #abbreviations / #references -> /glossary/#<id>          (jump back to pillar's section anchors)
//   #<term-slug>                 -> /glossary/<term-slug>/   (link to sibling spoke)
// The pillar leaves these as same-page anchors, so this only fires when mode === 'spoke'.
//
// PROOF GATE / KNOWN LIMITATION:
//   The regex below rewrites EVERY `href="#xxx"` it finds in the HTML, including
//   any that appear inside <code> or <pre> blocks. No glossary entry currently
//   documents HTML samples with literal anchor markup, so this is a speculative
//   concern only. If a future entry needs to display literal `<a href="#x">`
//   markup as documentation, escape the angle brackets in those samples
//   (e.g. `&lt;a href="#x"&gt;`) so the rewrite regex never matches them.
//   A full HTML-parsing fix is rejected as overkill for the current risk.
function rewriteAnchors(html: string): string {
  return html.replace(/href=(["'])#([^"']+)\1/g, (_match, _quote, target: string) => {
    const t = target.toLowerCase();
    if (t.startsWith('ref-') || t === 'abbreviations' || t === 'references') {
      // Keep ref-N as same-page jumps when the spoke renders its own Sources
      // block (keepLocalRefAnchors=true). Otherwise (and always for the
      // abbreviations / references section anchors) jump back to the pillar.
      if (keepLocalRefAnchors && t.startsWith('ref-')) return `href="#${t}"`;
      return `href="/glossary/#${t}"`;
    }
    if (!/^[a-z0-9](?:[a-z0-9-]*[a-z0-9])?$/.test(t)) {
      return `href="/glossary/#${t}"`;
    }
    if (knownSlugs && !knownSlugs.has(t)) {
      return `href="/glossary/#${t}"`;
    }
    return `href="/glossary/${t}/"`;
  });
}

const renderedBodyAfterCrossLinks = mode === 'spoke' ? rewriteAnchors(term.bodyHtml) : term.bodyHtml;

// Local citation renumbering (spoke mode only, when keeping refs on-page).
// Pillar has 100+ global ref_nums in a single References list, so sup<95> next
// to its 95th list item makes sense. A spoke that cites only refs 95-97 globally
// would render <sup>95</sup>...<sup>97</sup> in isolation -- the reader has no
// context for 1-94, and the page looks broken even when it isn't. Solution:
// in spoke mode, renumber inline citations to local 1, 2, 3 in order of first
// appearance, and render the per-spoke Cited block with those same local ids.
// Pillar rendering is unchanged.
function buildLocalRefMap(html: string): Map<number, number> {
  const order: number[] = [];
  const seen = new Set<number>();
  const re = /<sup\b[^>]*>\s*<a\b[^>]*href=["']#ref-(\d+)["']/g;
  let m: RegExpExecArray | null;
  while ((m = re.exec(html)) !== null) {
    const n = parseInt(m[1], 10);
    if (!seen.has(n)) {
      seen.add(n);
      order.push(n);
    }
  }
  const map = new Map<number, number>();
  order.forEach((n, i) => map.set(n, i + 1));
  return map;
}

function applyLocalRefNumbers(html: string, map: Map<number, number>): string {
  if (map.size === 0) return html;
  // Match: <sup ...><a ...href="#ref-N" ...>VISIBLE</a></sup>
  // Rewrite href target AND visible text to local M. Preserve any attributes
  // around them (class, etc.). Robust to single OR double quotes around the
  // href, and to attribute order before/after href.
  return html.replace(
    /(<sup[^>]*>\s*<a\b)([^>]*?)href=(["'])#ref-(\d+)\3([^>]*)>([^<]*)(<\/a>\s*<\/sup>)/g,
    (_full, supOpen, preAttrs, _q, hrefNum, postAttrs, _visible, supClose) => {
      const globalNum = parseInt(hrefNum, 10);
      const localNum = map.get(globalNum);
      if (!localNum) return _full;
      return `${supOpen}${preAttrs}href="#ref-${localNum}"${postAttrs}>${localNum}${supClose}`;
    },
  );
}

const citedSource = includeCitedReferences ? (term.citedReferences ?? []) : [];
const citedByGlobal = new Map(citedSource.map(r => [r.refNum, r]));

const useLocalRefs = mode === 'spoke' && keepLocalRefAnchors;
const rawLocalRefMap = useLocalRefs ? buildLocalRefMap(renderedBodyAfterCrossLinks) : new Map<number, number>();
const localRefMap = useLocalRefs
  ? new Map(
      Array.from(rawLocalRefMap.keys())
        .filter(globalNum => citedByGlobal.has(globalNum))
        .map((globalNum, i) => [globalNum, i + 1])
    )
  : new Map<number, number>();
const renderedBody = useLocalRefs
  ? applyLocalRefNumbers(renderedBodyAfterCrossLinks, localRefMap)
  : renderedBodyAfterCrossLinks;
const HeadingTag = headingLevel;

// PROOF GATES for definition sources (enforced at render time):
//   1. Drop visibility='internal_only' rows (Boyle archive, IIRRM private corpus)
//      so they never reach the public DOM.
//   2. Drop source_key='boyle_archive' belt-and-suspenders.
//   3. Strip 'D1: recXXX' prefixes from definition text (internal record IDs).
//   4. Strip occurrence-count metadata lines like
//      "(chapter -- Author -- N occurrence(s) of "Term")" — these are scanner
//      artifacts, not part of the source quote.
const PRIVATE_SOURCE_KEYS = new Set(['boyle_archive']);

function stripDefinitionMetadata(raw: string): string {
  if (!raw) return '';
  return raw
    .split(/\n+/)
    .filter(line => {
      const t = line.trim();
      if (!t) return false;
      // Drop "D1: recXXX" record-ID lines
      if (/^D1:\s*\S+/.test(t)) return false;
      // Drop occurrence-count metadata: "type -- author -- N occurrence(s) of "X""
      if (/--\s*\d+\s*occurrence\(s\)\s*of/.test(t)) return false;
      return true;
    })
    .join('\n')
    .trim();
}

// Trust boundary: definitionText is D1 TEXT, untrusted, injected into the DOM
// via `set:html` on the <blockquote>. escapeHtml() is the seal — every code
// path that reaches `set:html={textToParagraphs(...)}` MUST pass through it.
function escapeHtml(s: string): string {
  return s
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#39;');
}

// safeHref allows only known-safe schemes (http(s), mailto, tel) plus absolute
// paths and fragment-only anchors. Blocks javascript:, data:, vbscript:, etc.
// Applied to every <a href={...}> that reads from D1 TEXT columns.
function safeHref(url: string | null | undefined): string {
  if (!url) return '#';
  const trimmed = url.trim();
  if (/^(https?:|mailto:|tel:|\/|#)/i.test(trimmed)) {
    return trimmed;
  }
  return '#';
}

const sources = (term.definitionSources ?? [])
  .filter(s => s.visibility !== 'internal_only')
  .filter(s => !PRIVATE_SOURCE_KEYS.has((s.sourceKey || '').toLowerCase()))
  .map(s => ({ ...s, definitionText: stripDefinitionMetadata(s.definitionText) }))
  .filter(s => s.definitionText.length > 0)
  .sort((a, b) => a.sortOrder - b.sortOrder);

// Normalize cited refs: drop literal "None" strings (Python None serialized).
function normNone(v: string | null | undefined): string | null {
  if (!v) return null;
  const t = v.trim();
  if (!t || t.toLowerCase() === 'none') return null;
  return t;
}
// On spokes with local renumbering, build the cited list in order of first
// appearance in the body (matches the local 1, 2, 3 sequence) and stamp each
// entry with its LOCAL refNum so the <li id="ref-N"> anchors match the rewritten
// <sup> links. The localRefMap intersection above guarantees every entry has a
// citedByGlobal hit. On the pillar (or any spoke that doesn't keep local
// anchors), preserve the existing global ordering.
const cited = useLocalRefs
  ? Array.from(localRefMap.entries())
      .sort((a, b) => a[1] - b[1])
      .map(([globalNum, localNum]) => {
        const r = citedByGlobal.get(globalNum)!;
        return {
          refNum: localNum,
          anchorText: normNone(r.anchorText) || '',
          url: normNone(r.url),
          publisher: normNone(r.publisher),
          journal: normNone(r.journal),
        };
      })
  : citedSource.map(r => ({
      refNum: r.refNum,
      anchorText: normNone(r.anchorText) || '',
      url: normNone(r.url),
      publisher: normNone(r.publisher),
      journal: normNone(r.journal),
    }));

// Format a citation in clean APA-leaning style. Schema doesn't yet carry
// authors / year / volume / DOI -- those land in Phase 2 of the schema
// expansion. Until then we render: Title. Journal. URL  (or)  Title. Publisher. URL
// dropping any segment that is empty / "None".
function formatCitation(r: typeof cited[number]): { title: string; meta: string; url: string | null } {
  let title = r.anchorText;
  // Strip trailing period -- we add our own punctuation
  title = title.replace(/\.\s*$/, '');
  const metaParts: string[] = [];
  if (r.journal) metaParts.push(r.journal);
  if (r.publisher && r.publisher !== r.journal) metaParts.push(r.publisher);
  return { title, meta: metaParts.join('. '), url: r.url };
}

const hasSources = sources.length > 0 || cited.length > 0;

const sectionHeadingLevel: 'h2' | 'h3' | 'h4' =
  headingLevel === 'h1' ? 'h2' :
  headingLevel === 'h2' ? 'h3' : 'h4';
const SectionTag = sectionHeadingLevel;

// Convert plain text to HTML paragraphs (preserves line breaks within source quotes).
// Escapes HTML entities BEFORE wrapping so a hostile D1 row cannot inject markup
// through the `set:html` consumer.
function textToParagraphs(text: string): string {
  return text
    .split(/\n\s*\n/)
    .map(p => p.trim())
    .filter(Boolean)
    .map(p => `<p>${escapeHtml(p).replace(/\n/g, '<br>')}</p>`)
    .join('');
}
---

<HeadingTag id={term.slug}>
  {term.pillarLink
    ? <a href={safeHref(term.pillarLink)}>{term.name}</a>
    : term.name}
</HeadingTag>
<slot name="post-heading" />
<Fragment set:html={renderedBody} />
{cited.length > 0 && (
  <section class="cited-refs" aria-labelledby={`cited-refs-${term.slug}`}>
    <SectionTag id={`cited-refs-${term.slug}`} class="cited-refs__title">
      Cited in this entry
    </SectionTag>
    <ol class="cited-refs__list">
      {cited.map(r => {
        const c = formatCitation(r);
        // Guard against near-blank renders: if anchorText/meta/url are all empty
        // (Python None serialization edge case + missing schema fields), keep the
        // id anchor for ref-N back-links but emit no body content.
        if (!c.title && !c.meta && !c.url) return <li id={`ref-${r.refNum}`} class="cited-refs__item" />;
        return (
          <li id={`ref-${r.refNum}`} class="cited-refs__item">
            {c.title && <span class="cited-refs__title-text">{c.title}.</span>}
            {c.meta && <span class="cited-refs__meta"> <em>{c.meta}</em>.</span>}
            {c.url && (
              <>
                {' '}
                <a class="cited-refs__link" href={safeHref(c.url)} target="_blank" rel="noopener">{c.url}</a>
              </>
            )}
          </li>
        );
      })}
    </ol>
  </section>
)}
{mode === 'spoke' && sources.length > 0 && (
  <section class="def-sources" aria-labelledby={`def-sources-${term.slug}`}>
    <SectionTag id={`def-sources-${term.slug}`} class="def-sources__title">
      Authoritative References
    </SectionTag>
    <p class="def-sources__intro">
      How other clinical authorities define this term. RRM Academy curates these
      verbatim or under fair use so the medical consensus is visible alongside our
      RRM-contextualized definition above.
    </p>
    <ul class="def-sources__list">
      {sources.map(s => {
        // "excerpt" tag fires when this is a snippet from a larger work,
        // OR when it's paraphrased rather than a verbatim full definition.
        const showExcerptTag = s.isExcerpt || !s.isVerbatim;
        return (
          <li class={`def-source def-source--${s.sourceKey}`}>
            <div class="def-source__header">
              <span class="def-source__label">{s.sourceLabel}</span>
              {s.code && <span class="def-source__code">{s.code}</span>}
              {showExcerptTag && (
                <span class="def-source__excerpt-tag" title="Excerpt or paraphrase, not the full source definition">
                  excerpt
                </span>
              )}
            </div>
            <blockquote class="def-source__quote" set:html={textToParagraphs(s.definitionText)} />
            {(s.attribution || s.sourceUrl) && (
              <div class="def-source__footer">
                {s.attribution && <span class="def-source__attrib">{s.attribution}</span>}
                {s.sourceUrl && (
                  <a class="def-source__link" href={safeHref(s.sourceUrl)} rel="nofollow noopener" target="_blank">
                    Read source &rarr;
                  </a>
                )}
              </div>
            )}
          </li>
        );
      })}
    </ul>
  </section>
)}
{mode === 'pillar' && (
  <p class="term-spoke-link">
    <a href={`/glossary/${term.slug}/`}>Open full entry &rarr;</a>
  </p>
)}

<style is:global>
  /* Layered citation/reference sections.
     Uses RRM Academy design-system semantic tokens so light/dark themes
     auto-switch via the [data-theme] attribute on <html>. */
  .cited-refs {
    margin-top: 1.75rem;
    padding: 1.25rem 1.5rem;
    background: var(--bg-body);
    border-left: 3px solid var(--accent);
    border-radius: 4px;
  }
  .cited-refs__title {
    font-size: 1.05rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin: 0 0 0.75rem 0;
    color: var(--text-secondary);
    font-weight: 600;
  }
  .cited-refs__list {
    margin: 0;
    padding-left: 1.5rem;
    font-size: 0.92rem;
    color: var(--text-primary);
    line-height: 1.55;
  }
  .cited-refs__item {
    margin-bottom: 0.6rem;
  }
  .cited-refs__title-text {
    color: var(--text-primary);
  }
  .cited-refs__meta {
    color: var(--text-secondary);
  }
  .cited-refs__link {
    color: var(--accent);
    word-break: break-all;
    font-size: 0.85rem;
  }
  .cited-refs__link:hover {
    color: var(--accent-hover);
  }

  .def-sources {
    margin-top: 2rem;
    padding: 1.5rem;
    background: var(--bg-body);
    border-left: 3px solid var(--sand-500);
    border-radius: 4px;
  }
  .def-sources__title {
    font-size: 1.05rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin: 0 0 0.5rem 0;
    color: var(--text-secondary);
    font-weight: 600;
  }
  .def-sources__intro {
    font-size: 0.875rem;
    color: var(--text-secondary);
    margin: 0 0 1.25rem 0;
    line-height: 1.5;
  }
  .def-sources__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  .def-source {
    border-top: 1px solid var(--border-light);
    padding-top: 1rem;
  }
  .def-source:first-child {
    border-top: none;
    padding-top: 0;
  }
  .def-source__header {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 0.75rem;
    align-items: baseline;
    margin-bottom: 0.5rem;
  }
  .def-source__label {
    font-weight: 600;
    color: var(--text-primary);
    font-size: 0.95rem;
  }
  .def-source__code {
    font-family: ui-monospace, SFMono-Regular, monospace;
    font-size: 0.8rem;
    background: var(--neutral-200);
    padding: 0.125rem 0.4rem;
    border-radius: 3px;
    color: var(--text-primary);
  }
  .def-source__excerpt-tag {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    background: var(--neutral-200);
    color: var(--neutral-700);
    padding: 0.1rem 0.4rem;
    border-radius: 2px;
  }
  .def-source__quote {
    margin: 0 0 0.5rem 0;
    padding: 0 0 0 0.75rem;
    border-left: 2px solid var(--border-light);
    font-size: 0.95rem;
    color: var(--text-primary);
    line-height: 1.5;
    font-style: normal;
  }
  .def-source__quote p {
    margin: 0 0 0.5rem 0;
  }
  .def-source__quote p:last-child {
    margin-bottom: 0;
  }
  .def-source__footer {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1rem;
    font-size: 0.8rem;
    color: var(--text-secondary);
    align-items: baseline;
  }
  .def-source__attrib {
    font-style: italic;
  }
  .def-source__link {
    color: var(--accent);
    font-weight: 500;
    white-space: nowrap;
  }
  .def-source__link:hover {
    color: var(--accent-hover);
  }
</style>
