---
import type { Provider } from '../lib/providers';

interface Props {
  provider: Provider;
}

const { provider } = Astro.props;

const hasNpi = !!provider.npi_number;
const hasSpecialties = (provider.npi_specialties ?? []).length > 0;
const hasLicenses = (provider.npi_licenses ?? []).length > 0;
const hasPhoneConfirmed = (provider.phone_confirmed_by ?? []).length > 0;
const hasSources = (provider._all_sources ?? []).length > 0;
const hasLastVerified = !!provider.last_verified;

const shouldRender = hasNpi || hasSpecialties || hasLicenses;

// Format date like "March 16, 2026"
function formatDate(iso: string): string {
  try {
    const d = new Date(iso);
    return d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
  } catch {
    return iso;
  }
}

// Source key -> short display label (same logic as ProviderMethods)
function sourceDisplayLabel(key: string): string {
  if (key === 'facts-directory') return 'FACTS';
  if (key === 'femm-provider') return 'FEMM';
  if (key.startsWith('cfcmc')) return 'CFCMC';
  if (key === 'mycatholicdoctor') return 'MCD';
  const first = key.split(/[-_]/)[0];
  return first.charAt(0).toUpperCase() + first.slice(1);
}

const sourcesList = hasSources
  ? provider._all_sources.map(sourceDisplayLabel).join(', ')
  : provider.source_directory_label ?? '';

// npi_status may be present in data even if not typed — access safely
const npiStatusRaw = (provider as unknown as Record<string, unknown>)['npi_status'] as string | undefined;
const npiStatusLabel = provider.npi_number
  ? npiStatusRaw
    ? `${provider.npi_number} · ${npiStatusRaw}`
    : provider.npi_verified
      ? `${provider.npi_number} · Active`
      : provider.npi_number
  : '';
---

{shouldRender && (
  <div class="h-section">
    <div class="h-section-header">
      <span class="h-section-icon" aria-hidden="true">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="11" width="18" height="11" rx="2"/>
          <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
        </svg>
      </span>
      <h3>Credentials</h3>
    </div>
    <div class="detail-rows">
      {hasNpi && (
        <div class="detail-row">
          <span class="detail-label">NPI Number</span>
          <span class="detail-value">{npiStatusLabel}</span>
        </div>
      )}
      {hasSpecialties && (
        <div class="detail-row">
          <span class="detail-label">Specialty</span>
          <span class="detail-value">{provider.npi_specialties.join(', ')}</span>
        </div>
      )}
      {hasLicenses && (
        <div class="detail-row">
          <span class="detail-label">License</span>
          <span class="detail-value">
            {provider.npi_licenses.map((lic) => `${lic.state} ${lic.license}`).join(', ')}
          </span>
        </div>
      )}
      {hasPhoneConfirmed && (
        <div class="detail-row">
          <span class="detail-label">Phone confirmed by</span>
          <span class="detail-value">{provider.phone_confirmed_by.length} {provider.phone_confirmed_by.length === 1 ? 'source' : 'sources'}</span>
        </div>
      )}
      {sourcesList && (
        <div class="detail-row">
          <span class="detail-label">Listed in</span>
          <span class="detail-value">{sourcesList}</span>
        </div>
      )}
      {hasLastVerified && (
        <div class="detail-row">
          <span class="detail-label">Data last verified</span>
          <span class="detail-value">{formatDate(provider.last_verified)}</span>
        </div>
      )}
    </div>
  </div>
)}

<style>
  .h-section {
    margin: 0.5rem 0.75rem;
    background: var(--bg-surface);
    border-radius: 12px;
    padding: 0.875rem;
    box-shadow: var(--shadow-sm);
  }

  .h-section-header {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    margin-bottom: 0.6rem;
  }

  .h-section-icon {
    display: inline-flex;
    align-items: center;
    color: var(--text-tertiary);
    flex-shrink: 0;
  }

  .h-section-header h3 {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--text-primary);
    margin: 0;
  }

  .detail-rows {
    display: flex;
    flex-direction: column;
  }

  .detail-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 0.75rem;
    border-top: 1px solid #f7f5f3;
    padding: 0.3rem 0;
    font-size: 0.75rem;
  }

  .detail-label {
    color: #949392;
    flex-shrink: 0;
  }

  .detail-value {
    color: #313131;
    font-weight: 500;
    text-align: right;
  }
</style>
