---
import NewsletterSignup from './NewsletterSignup.astro';

const year = new Date().getFullYear();

// Footer nav — intentionally different from Header desktop/mobile navs.
// Three columns: Learn, Resources, Help. See Header.astro for the other lists.
const learnLinks = [
  { label: 'Guides', href: '/guides/', icon: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polygon points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76"/></svg>' },
  { label: 'FAQs', href: '/faqs/', icon: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>' },
  { label: 'Courses', href: '/courses/', icon: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c0 1.1 2.7 3 6 3s6-1.9 6-3v-5"/></svg>' },
  { label: 'What is RRM?', href: '/faqs/what-is-restorative-reproductive-medicine-rrm/', icon: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>' },
];

const resourceLinks = [
  { label: 'Research Library', href: '/library/', icon: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="8" height="18" x="3" y="3" rx="1"/><path d="M7 3v18"/><path d="M20.4 18.9c.2.5-.1 1.1-.6 1.3l-1.9.7c-.5.2-1.1-.1-1.3-.6L11.1 5.1c-.2-.5.1-1.1.6-1.3l1.9-.7c.5-.2 1.1.1 1.3.6Z"/></svg>' },
  { label: 'Endo Self-Survey', href: '/endo-survey/', icon: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><rect x="8" y="2" width="8" height="4" rx="1" ry="1"/></svg>', hoverIcon: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#FFD700" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 11.22C11 9.997 10 9 10 8a2 2 0 0 1 4 0c0 1-.998 2.002-2.01 3.22"/><path d="m12 18 2.57-3.5"/><path d="M6.243 9.016a7 7 0 0 1 11.507-.009"/><path d="M9.35 14.53 12 11.22"/><path d="M9.35 14.53C7.728 12.246 6 10.221 6 7a6 5 0 0 1 12 0c-.005 3.22-1.778 5.235-3.43 7.5l3.557 4.527a1 1 0 0 1-.203 1.43l-1.894 1.36a1 1 0 0 1-1.384-.215L12 18l-2.679 3.593a1 1 0 0 1-1.39.213l-1.865-1.353a1 1 0 0 1-.203-1.422z"/></svg>' },
  { label: 'Commentary', href: '/commentary/', icon: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>' },
  { label: 'Join Us', href: '/save-the-uterus-club/', id: 'stuc-footer-link', icon: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>' },
];

const helpLinks = [
  { label: 'My Account', href: '/account/', icon: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>' },
  { label: 'Contact', href: '/contact/', icon: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>' },
  { label: 'Donate', href: '/donate/', icon: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>', hoverIcon: '<svg width="14" height="14" viewBox="0 0 24 24" fill="#eb9fb8" stroke="#eb9fb8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>' },
  { label: 'About', href: '/about/', icon: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>' },
];
---
<footer class="site-footer">
  <div class="footer-inner container">
    <div class="footer-columns">
      <div class="footer-col">
        <h3 class="footer-heading">Learn</h3>
        <ul class="footer-links">
          {learnLinks.map((link) => (
            <li>
              <a href={link.href}>
                <span class="footer-icon" aria-hidden="true" set:html={link.icon} />
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div class="footer-col">
        <h3 class="footer-heading">Resources</h3>
        <ul class="footer-links">
          {resourceLinks.map((link) => (
            <li class:list={[{ 'has-hover-icon': link.hoverIcon }]}>
              <a href={link.href} id={link.id}>
                <span class="footer-icon" aria-hidden="true" set:html={link.icon} />
                {link.hoverIcon && <span class="footer-icon footer-icon--hover" aria-hidden="true" set:html={link.hoverIcon} />}
                <span class="footer-label">{link.label}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div class="footer-col">
        <h3 class="footer-heading">Help</h3>
        <ul class="footer-links">
          {helpLinks.map((link) => (
            <li class:list={[{ 'has-hover-icon': link.hoverIcon }]}>
              <a href={link.href}>
                <span class="footer-icon" aria-hidden="true" set:html={link.icon} />
                {link.hoverIcon && <span class="footer-icon footer-icon--hover" aria-hidden="true" set:html={link.hoverIcon} />}
                <span class="footer-label">{link.label}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <div class="footer-about">
      <div class="footer-about__text">
        <p class="footer-text">
          RRM Academy is a 501(c)(3) nonprofit providing free and low-cost education in restorative reproductive medicine for patients and healthcare professionals.
        </p>
        <p class="footer-text">
          This site is an educational resource and does not provide medical advice.
          Inclusion of a study does not imply endorsement of its findings.
          Always consult a qualified healthcare provider for diagnosis and treatment.
        </p>
      </div>
      <div class="footer-newsletter">
        <NewsletterSignup compact heading="Newsletter" />
      </div>
    </div>

    <div class="footer-bottom">
      <p class="footer-copyright">
        &copy; {year} RRM Academy &middot; All Rights Reserved
      </p>
      <address class="footer-address">
        Restorative Reproductive Medicine Foundation Inc. &middot; 3401 Hartzdale Dr, Ste 103B PMB 3518, Camp Hill, PA 17011 &middot; EIN: 93-4594315
      </address>
      <div class="footer-legal">
        <a href="/terms-of-use/">Terms of Use</a>
        <a href="/medical-disclaimer/">Medical Disclaimer</a>
        <a href="/privacy-policy/">Privacy Policy</a>
        <button class="footer-theme-toggle" id="footer-theme-toggle" aria-label="Toggle theme">
          <svg class="icon-moon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
          <svg class="icon-sun" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
        </button>
      </div>
    </div>
  </div>
</footer>

<script is:inline>
  // Footer theme toggle
  (function() {
    var btn = document.getElementById('footer-theme-toggle');
    if (!btn) return;

    function toggle() {
      var html = document.documentElement;
      var next = html.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
      html.setAttribute('data-theme', next);
      localStorage.setItem('rrm_theme', next);
    }

    btn.addEventListener('click', function(e) {
      if (!document.startViewTransition ||
          window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        toggle();
        return;
      }
      var transition = document.startViewTransition(toggle);
      transition.ready.then(function() {
        var rect = btn.getBoundingClientRect();
        var x = rect.left + rect.width / 2;
        var y = rect.top + rect.height / 2;
        var maxRadius = Math.hypot(
          Math.max(x, window.innerWidth - x),
          Math.max(y, window.innerHeight - y)
        );
        document.documentElement.animate(
          { clipPath: ['circle(0px at ' + x + 'px ' + y + 'px)', 'circle(' + maxRadius + 'px at ' + x + 'px ' + y + 'px)'] },
          { duration: 500, easing: 'ease-in-out', pseudoElement: '::view-transition-new(root)' }
        );
      });
    });
  })();
</script>

<script>
  // Defer: reuse Header's community status if available, otherwise fetch when idle
  (function() {
    function apply(data) {
      if (!data.ok || data.access !== 'member') return;
      var footerLink = document.getElementById('stuc-footer-link');
      if (footerLink) {
        var label = footerLink.querySelector('.footer-label');
        if (label) label.textContent = 'Save the Uterus Club';
        footerLink.href = '/community/';
      }
    }
    // Listen for Header's result to avoid a duplicate fetch
    window.addEventListener('rrm:community-status', function(e) { apply(e.detail); });
    // Fallback: if Header hasn't fired within 3s, fetch ourselves (deferred)
    var timer = setTimeout(function() {
      if ('requestIdleCallback' in window) requestIdleCallback(doFetch);
      else setTimeout(doFetch, 100);
    }, 3000);
    window.addEventListener('rrm:community-status', function() { clearTimeout(timer); }, { once: true });
    function doFetch() {
      fetch('/api/community/status', { credentials: 'same-origin' })
        .then(function(r) { return r.json(); })
        .then(apply).catch(function() {});
    }
  })();
</script>

<style>
  .site-footer {
    background: var(--footer-bg);
    color: var(--footer-text);
    margin-top: 0;
    padding: var(--space-12) 0 var(--space-8);
    transition: background 0.3s, color 0.3s;
  }
  .footer-columns {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: var(--space-10);
    margin-bottom: var(--space-10);
  }
  .footer-heading {
    font-family: 'Cormorant Garamond', 'Georgia', serif;
    font-size: 1.125rem;
    font-weight: 500;
    color: var(--footer-heading);
    margin-bottom: var(--space-5);
    letter-spacing: -0.01em;
  }
  .footer-links {
    list-style: none;
  }
  .footer-links li {
    margin-bottom: var(--space-2);
  }
  .footer-links a {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    font-size: 0.8125rem;
    color: var(--footer-link);
    text-decoration: none;
    transition: color 0.15s;
  }
  .footer-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 14px;
    height: 14px;
    flex-shrink: 0;
    opacity: 0.5;
  }
  .footer-links a:hover {
    color: var(--footer-link-hover);
    text-decoration: none;
  }
  .footer-icon--hover {
    display: none;
  }
  .has-hover-icon a:hover .footer-icon:not(.footer-icon--hover) {
    display: none;
  }
  .has-hover-icon a:hover .footer-icon--hover {
    display: inline-flex;
    opacity: 1;
  }
  .footer-text {
    font-size: 0.8125rem;
    color: var(--footer-text);
    line-height: 1.7;
  }
  .footer-text a {
    color: var(--footer-accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .footer-text a:hover {
    color: var(--footer-accent-hover);
  }
  .footer-about {
    display: flex;
    gap: var(--space-10);
    align-items: flex-start;
    padding-top: var(--space-8);
    border-top: 1px solid var(--footer-border);
    margin-bottom: var(--space-10);
  }
  .footer-about__text {
    flex: 1;
  }
  .footer-newsletter {
    flex-shrink: 0;
    width: 320px;
  }
  .footer-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    padding-top: var(--space-6);
    border-top: 1px solid var(--footer-border);
  }
  .footer-copyright {
    font-size: 0.75rem;
    color: var(--footer-muted);
  }
  .footer-legal {
    display: flex;
    gap: var(--space-6);
  }
  .footer-legal a {
    font-size: 0.75rem;
    color: var(--footer-muted);
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: color 0.15s;
  }
  .footer-legal a:hover {
    color: var(--footer-link);
  }
  .footer-theme-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: none;
    padding: 2px;
    color: var(--footer-muted);
    cursor: pointer;
    transition: color 0.15s;
  }
  .footer-theme-toggle:hover {
    color: var(--footer-link);
  }
  .footer-theme-toggle .icon-sun,
  .footer-theme-toggle .icon-moon { display: none; }
  :global([data-theme="light"]) .footer-theme-toggle .icon-moon { display: inline; }
  :global([data-theme="dark"]) .footer-theme-toggle .icon-sun { display: inline; }
  .footer-address {
    font-style: normal;
    font-size: 0.6875rem;
    color: var(--footer-muted);
    text-align: center;
    width: 100%;
    order: 3;
    margin-top: var(--space-3);
  }

  @media (max-width: 768px) {
    .footer-columns {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-8);
    }
    .footer-columns .footer-col:last-child {
      grid-column: 1 / -1;
    }
    .footer-about {
      flex-direction: column;
      gap: var(--space-6);
    }
    .footer-newsletter {
      width: 100%;
    }
    .footer-bottom {
      flex-direction: column;
      gap: var(--space-4);
      text-align: center;
    }
    .footer-legal {
      flex-wrap: wrap;
      justify-content: center;
    }
  }
</style>
