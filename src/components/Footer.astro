---
const wixBase = 'https://www.rrmacademy.org';
const year = new Date().getFullYear();
---
<footer class="site-footer">
  <div class="footer-inner container">
    <div class="footer-columns">
      <div class="footer-col">
        <h3 class="footer-heading">Education</h3>
        <ul class="footer-links">
          <li><a href={`${wixBase}/courses`}>Courses</a></li>
          <li><a href="/commentary">Commentary</a></li>
          <li><a href="/library">Research Library</a></li>
          <li><a href={`${wixBase}/3-tier-endometriosis-symptom-self-survey`}>Endometriosis Self-Survey</a></li>
          <li><a href="/faqs">Frequently Asked Questions</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h3 class="footer-heading">Help</h3>
        <ul class="footer-links">
          <li><a href={`${wixBase}/members-area`}>Login</a></li>
          <li><a href={`${wixBase}/about`}>About</a></li>
          <li><a href="/donate">Donate</a></li>
          <li><a href={`${wixBase}/save-the-uterus-club`}>Join Us</a></li>
          <li><a href={`${wixBase}/contact`}>Contact</a></li>
        </ul>
      </div>

      <div class="footer-col footer-col--wide">
        <h3 class="footer-heading">RRM Academy</h3>
        <p class="footer-text">
          The information on this site is for educational purposes only and is not medical advice.
          Always consult a licensed healthcare professional for diagnosis and treatment. By using
          this site, you agree to our <a href="/terms-of-use">Terms of Use</a> and
          <a href="/privacy-policy">Privacy Policy</a>.
        </p>
      </div>
    </div>

    <div class="footer-bottom">
      <p class="footer-copyright">
        &copy; {year} RRM Academy &middot; All Rights Reserved
      </p>
      <div class="footer-legal">
        <a href="/terms-of-use">Terms of Use</a>
        <a href="/terms-of-use">Medical Disclaimer</a>
        <a href="/privacy-policy">Privacy Policy</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--footer-bg);
    color: var(--footer-text);
    margin-top: 0;
    padding: var(--space-12) 0 var(--space-8);
    transition: background 0.3s, color 0.3s;
  }
  .footer-columns {
    display: grid;
    grid-template-columns: 1fr 1fr 2fr;
    gap: var(--space-10);
    margin-bottom: var(--space-10);
  }
  .footer-heading {
    font-family: 'Cormorant Garamond', 'Georgia', serif;
    font-size: 1.125rem;
    font-weight: 500;
    color: var(--footer-heading);
    margin-bottom: var(--space-5);
    letter-spacing: -0.01em;
  }
  .footer-links {
    list-style: none;
  }
  .footer-links li {
    margin-bottom: var(--space-2);
  }
  .footer-links a {
    font-size: 0.8125rem;
    color: var(--footer-link);
    text-decoration: none;
    transition: color 0.15s;
  }
  .footer-links a:hover {
    color: var(--footer-link-hover);
    text-decoration: none;
  }
  .footer-text {
    font-size: 0.8125rem;
    color: var(--footer-text);
    line-height: 1.7;
  }
  .footer-text a {
    color: var(--footer-accent);
    text-decoration: none;
  }
  .footer-text a:hover {
    color: var(--footer-accent-hover);
  }
  .footer-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: var(--space-6);
    border-top: 1px solid var(--footer-border);
  }
  .footer-copyright {
    font-size: 0.75rem;
    color: var(--footer-muted);
  }
  .footer-legal {
    display: flex;
    gap: var(--space-6);
  }
  .footer-legal a {
    font-size: 0.75rem;
    color: var(--footer-muted);
    text-decoration: none;
    transition: color 0.15s;
  }
  .footer-legal a:hover {
    color: var(--footer-link);
  }

  @media (max-width: 768px) {
    .footer-columns {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }
    .footer-bottom {
      flex-direction: column;
      gap: var(--space-4);
      text-align: center;
    }
    .footer-legal {
      flex-wrap: wrap;
      justify-content: center;
    }
  }
</style>
