---
// AppShellChrome.astro — left-sidebar app shell wrapper for /library/* and /commentary/*.
//
// Responsibilities (per spec §Component boundaries):
//   - Emit <main class="app-shell-main"> directly (BaseLayout chrome="shell" omits its <main>)
//   - Render desktop sidebar (above 900px), mobile bottom nav (≤900px), hamburger drawer
//   - Middle column DOM is emitted ONLY on article pages (`context === 'article'`).
//     Index and saved pages omit the <aside class="app-shell-middle-column"> entirely.
//     The G-SEO-6 grep (Task 30 step 6) reflects this — it filters to article paths
//     only. Do NOT switch to always-emit; doing so would carry an empty aside on
//     index/saved and break the G-SEO-6 grep semantics.
//   - Pre-paint inline script: read sessionStorage.rrm-shell-context, add .shell-no-context if absent
//   - Card-click writer: capture intent, commit on pagehide
//   - Theme toggle handler: shared __rrmThemeToggle__() IIFE
//
// All sessionStorage access wrapped in try/catch (per spec §Data flow).
//
// SCRIPT ORDERING CONTRACT (do not break):
//   AppShellChrome's pre-paint inline script defines `window.__rrmGetShellContext__`
//   (Task 9). AppShellSheet's mount script (Task 14) reads it. Both scripts are
//   `<script is:inline>` and rely on document order — AppShellChrome MUST execute
//   before AppShellSheet. Astro emits components in the order they're rendered,
//   and every wrap task (21, 25) renders <AppShellChrome> wrapping the page,
//   with <AppShellSheet> as a sibling AFTER it. Do not reorder these components
//   in any wrap task or AppShellSheet will see `window.__rrmGetShellContext__`
//   as undefined and silently no-op.

// Frontmatter import emits app-shell.css as a global stylesheet — matches the
// canonical pattern used by BaseLayout.astro (line 8: `import '../styles/global.css'`).
// Do NOT use `<style>@import '/src/styles/app-shell.css';</style>` — Astro <style>
// blocks are component-scoped (data-astro-cid hashing) and root-absolute @import
// paths do not resolve in production builds.
import '../styles/app-shell.css';
import Footer from './Footer.astro';
import Header from './Header.astro';
import pillarRegistry from '../../ssot/pillars.json';

// AppShellChrome runs INSIDE BaseLayout's slot. The `<body>` element belongs
// to BaseLayout (`<body class:list={[bodyClass]}>` around line 267), so this
// component cannot influence body classes from inside the slot. bodyClass is
// owned by BaseLayout — pass it there, not here. Adding `bodyClass` to this
// Props interface would create an inert prop that pages might pass and
// silently lose. Don't.
interface RelatedSection {
  heading: string;
  items: Array<{ href: string; label: string }>;
}

interface Props {
  /** Layout context.
   *  - 'index'   — list page with cards (writes sessionStorage on click for the rail)
   *  - 'article' — article page (emits middle column for the rail)
   *  - 'saved'   — Saved Articles page (2-col, no rail, no writer)
   *  - 'page'    — generic content page (2-col, no rail, no writer). Used for
   *                guides / faqs / account / pillar pages where there's no
   *                cards-list to capture and no per-article rail to render. */
  context: 'index' | 'article' | 'saved' | 'page';
  currentPath: string;
  /** Server-rendered related-content sections for the right rail.
   *  When provided, the rail renders these sections statically (Topics, By
   *  this author, Related research, etc). When absent, falls back to the
   *  legacy sessionStorage "Continue browsing" hydrator. */
  relatedSections?: RelatedSection[];
  /** Opt-in to a custom rail rendered via the `rail` named slot. Pages must
   *  set this to `true` AND pass `<Fragment slot="rail">…</Fragment>` for the
   *  rail to render. Used by /glossary/ to host its A-Z index in the rail
   *  instead of as a top-of-page <details> toggle.
   *  Why an explicit prop instead of `Astro.slots.has('rail')`: when forwarded
   *  through a wrapper component (MaybeShell), Astro reports the slot as
   *  "present" even when the upstream page passed no content. The prop is
   *  unambiguous. */
  hasRail?: boolean;
}

const { context, currentPath, relatedSections = [], hasRail = false } = Astro.props;
// `hasRelatedSections` was previously gated on `context === 'article'` because
// the original design only emitted a rail for articles. The 'page' context now
// also opts in (e.g. /glossary/<slug>/ Discussed-in groups), so any non-empty
// relatedSections array enables the rail.
const hasRelatedSections = relatedSections.length > 0;

// Identify current section for aria-current on sidebar links.
const inLibrary = currentPath === '/library' || currentPath === '/library/' || currentPath.startsWith('/library/');
const inCommentary = currentPath === '/commentary' || currentPath === '/commentary/' || currentPath.startsWith('/commentary/');
const inSaved = currentPath === '/library/saved' || currentPath === '/library/saved/';
const inFaqs = currentPath === '/faqs' || currentPath === '/faqs/' || currentPath.startsWith('/faqs/');
const inAccount = currentPath === '/account' || currentPath === '/account/' || currentPath.startsWith('/account/');
const inAsk = currentPath === '/ask' || currentPath === '/ask/' || currentPath.startsWith('/ask/');
// /courses/<slug>/ catalog + sales pages get the wrap; /courses/<slug>/<step>/
// (lesson player) does not. aria-current still highlights for both since the
// user is in the courses section regardless.
const inCourses = currentPath === '/courses' || currentPath === '/courses/' || currentPath.startsWith('/courses/');
const inCommunity = currentPath === '/community' || currentPath === '/community/' || currentPath.startsWith('/community/');
const inProviders = currentPath === '/providers' || currentPath === '/providers/' || currentPath.startsWith('/providers/');
// "Guides" surface = the /guides/ index AND the pillar guide pages, which live
// Derived from ssot/pillars.json (in_shell_guides_nav filter) + the /guides/
// catalogue. Adding a new pillar = adding it to pillars.json with
// in_shell_guides_nav=true; no edit required here. Glossary is wrapped by
// the same shell route but gets its own permanent sidebar link, so it
// stays in_shell_guides_nav=false and aria-current on Guides excludes
// /glossary/.
// Derive from ssot/pillars.json. Each pillar with in_shell_guides_nav=true
// contributes both slash forms (/foo and /foo/) so aria-current matches the
// canonical currentPath shape Astro renders. /glossary/ stays excluded via
// in_shell_guides_nav=false because the glossary has its own permanent sidebar
// link via the separate inGlossary check below.
const GUIDES_PATHS = new Set([
  '/guides', '/guides/',
  ...pillarRegistry.pillars
    .filter((p) => p.in_shell_guides_nav)
    .flatMap((p) => [`/${p.slug}`, `/${p.slug}/`]),
]);
const inGuides = GUIDES_PATHS.has(currentPath);
const inGlossary = currentPath === '/glossary' || currentPath === '/glossary/' || currentPath.startsWith('/glossary/');

// Pages can render arbitrary HTML in the right rail by setting `hasRail`
// AND passing `<Fragment slot="rail">…</Fragment>`. When `hasRail` is true,
// AppShellChrome emits the <aside> regardless of context and renders the
// slot content in place of the default relatedSections list. Used by
// /glossary/ to put the A-Z index in the rail.
const showRail = hasRelatedSections || hasRail || context === 'article';

// Lucide-style icon map keyed by destination href. Pulled from Footer.astro's
// learnLinks/resourceLinks/helpLinks for parity (same icon for the same link
// across surfaces). Saved Articles uses a bookmark glyph (no Footer source).
const NAV_ICONS: Record<string, string> = {
  '/library/': '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="8" height="18" x="3" y="3" rx="1"/><path d="M7 3v18"/><path d="M20.4 18.9c.2.5-.1 1.1-.6 1.3l-1.9.7c-.5.2-1.1-.1-1.3-.6L11.1 5.1c-.2-.5.1-1.1.6-1.3l1.9-.7c.5-.2 1.1.1 1.3.6Z"/></svg>',
  '/commentary/': '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>',
  '/library/saved/': '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m19 21-7-4-7 4V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v16z"/></svg>',
  '/guides/': '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polygon points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76"/></svg>',
  '/glossary/': '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/><path d="M9 6h6"/><path d="M9 10h6"/></svg>',
  '/faqs/': '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>',
  '/courses/': '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c0 1.1 2.7 3 6 3s6-1.9 6-3v-5"/></svg>',
  '/community/': '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>',
  '/providers/': '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 2v2"/><path d="M5 2v2"/><path d="M5 3H4a2 2 0 0 0-2 2v4a6 6 0 0 0 12 0V5a2 2 0 0 0-2-2h-1"/><path d="M8 15a6 6 0 0 0 12 0v-3"/><circle cx="20" cy="10" r="2"/></svg>',
  '/donate/': '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>',
  '/account/': '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>',
  '/endo-survey/': '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><rect x="8" y="2" width="8" height="4" rx="1" ry="1"/></svg>',
  '/ivf-success-calculator/': '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="2" width="16" height="20" rx="2"/><line x1="8" y1="6" x2="16" y2="6"/><line x1="8" y1="10" x2="10" y2="10"/><line x1="12" y1="10" x2="14" y2="10"/><line x1="16" y1="10" x2="16" y2="10"/><line x1="8" y1="14" x2="10" y2="14"/><line x1="12" y1="14" x2="14" y2="14"/><line x1="16" y1="14" x2="16" y2="14"/><line x1="8" y1="18" x2="10" y2="18"/><line x1="12" y1="18" x2="16" y2="18"/></svg>',
  '/ask/': '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>',
};
---

<div class="app-shell-layout" data-shell-context={context} data-has-related={(hasRelatedSections || hasRail) ? 'true' : 'false'}>
  {/* Mobile-only global header. Brian preference 2026-05-08: the desktop
      sidebar shell never affects mobile; mobile users get the same global
      Header + global mobile nav that non-shell pages use. CSS hides this at
      ≥901px and the legacy bottom-nav/drawer/sheet are hidden at all
      viewports. */}
  <div class="app-shell-mobile-header" data-pagefind-ignore="all">
    <Header />
  </div>

  <!-- Desktop sidebar -->
  <nav class="app-shell-nav" data-pagefind-ignore="all" aria-label="Primary">
    <a href="/" class="app-shell-nav__brand" aria-label="RRM Academy home" data-clear-shell-context>
      <strong>RRM Academy</strong>
    </a>

    <div class="app-shell-nav__section">
      <div class="app-shell-nav__heading">Reading</div>
      <a href="/library/saved/" class="app-shell-nav__link" aria-current={inSaved ? 'page' : undefined}>
        <span class="app-shell-nav__icon" aria-hidden="true" set:html={NAV_ICONS['/library/saved/']} />
        <span class="app-shell-nav__label">Saved Articles</span>
      </a>
      <a href="/library/" class="app-shell-nav__link" aria-current={inLibrary && !inSaved ? 'page' : undefined}>
        <span class="app-shell-nav__icon" aria-hidden="true" set:html={NAV_ICONS['/library/']} />
        <span class="app-shell-nav__label">Research Library</span>
      </a>
      <a href="/commentary/" class="app-shell-nav__link" aria-current={inCommentary ? 'page' : undefined}>
        <span class="app-shell-nav__icon" aria-hidden="true" set:html={NAV_ICONS['/commentary/']} />
        <span class="app-shell-nav__label">Commentary</span>
      </a>
    </div>

    <div class="app-shell-nav__section">
      <div class="app-shell-nav__heading">Explore</div>
      <a href="/ask/" class="app-shell-nav__link" aria-current={inAsk ? 'page' : undefined}>
        <span class="app-shell-nav__icon" aria-hidden="true" set:html={NAV_ICONS['/ask/']} />
        <span class="app-shell-nav__label">Ask</span>
      </a>
      <a href="/faqs/" class="app-shell-nav__link" aria-current={inFaqs ? 'page' : undefined}>
        <span class="app-shell-nav__icon" aria-hidden="true" set:html={NAV_ICONS['/faqs/']} />
        <span class="app-shell-nav__label">FAQs</span>
      </a>
      <a href="/glossary/" class="app-shell-nav__link" aria-current={inGlossary ? 'page' : undefined}>
        <span class="app-shell-nav__icon" aria-hidden="true" set:html={NAV_ICONS['/glossary/']} />
        <span class="app-shell-nav__label">Glossary</span>
      </a>
      <a href="/guides/" class="app-shell-nav__link" aria-current={inGuides ? 'page' : undefined}>
        <span class="app-shell-nav__icon" aria-hidden="true" set:html={NAV_ICONS['/guides/']} />
        <span class="app-shell-nav__label">Guides</span>
      </a>
      <a href="/courses/" class="app-shell-nav__link" aria-current={inCourses ? 'page' : undefined}>
        <span class="app-shell-nav__icon" aria-hidden="true" set:html={NAV_ICONS['/courses/']} />
        <span class="app-shell-nav__label">Courses</span>
      </a>
      <a href="/community/" class="app-shell-nav__link" aria-current={inCommunity ? 'page' : undefined}>
        <span class="app-shell-nav__icon" aria-hidden="true" set:html={NAV_ICONS['/community/']} />
        <span class="app-shell-nav__label">Community</span>
      </a>
      <a href="/providers/" class="app-shell-nav__link" aria-current={inProviders ? 'page' : undefined}>
        <span class="app-shell-nav__icon" aria-hidden="true" set:html={NAV_ICONS['/providers/']} />
        <span class="app-shell-nav__label">RRM Providers</span>
      </a>
      <a href="/endo-survey/" class="app-shell-nav__link">
        <span class="app-shell-nav__icon" aria-hidden="true" set:html={NAV_ICONS['/endo-survey/']} />
        <span class="app-shell-nav__label">Endo Self-Survey</span>
      </a>
      <a href="/ivf-success-calculator/" class="app-shell-nav__link">
        <span class="app-shell-nav__icon" aria-hidden="true" set:html={NAV_ICONS['/ivf-success-calculator/']} />
        <span class="app-shell-nav__label">IVF Success Calculator</span>
      </a>
    </div>

    <div class="app-shell-nav__spacer"></div>

    <a href="/donate/" class="app-shell-nav__cta">
      <span class="app-shell-nav__icon" aria-hidden="true" set:html={NAV_ICONS['/donate/']} />
      <span class="app-shell-nav__label">Donate</span>
    </a>

    <div class="app-shell-nav__footer">
      <a href="/account/" class="app-shell-nav__account" aria-current={inAccount ? 'page' : undefined}>
        <span class="app-shell-nav__icon" aria-hidden="true" set:html={NAV_ICONS['/account/']} />
        <span class="app-shell-nav__label">Account</span>
      </a>
      <button type="button" class="app-shell-nav__theme-toggle" aria-label="Toggle theme" data-theme-toggle>
        <svg class="icon-moon" aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
        <svg class="icon-sun" aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
      </button>
    </div>
  </nav>

  <main class="app-shell-main">
    <slot />
  </main>

  <!-- Footer at bottom of main column (sidebar + middle column wrap around).
       Grid area "footer" so legal links / newsletter / social stay with the
       shell instead of dangling below it. -->
  <div class="app-shell-footer-row" data-pagefind-ignore="all">
    <Footer />
  </div>

  <!-- Middle column: emitted on article pages (`context === 'article'`) OR
       when the page provides a `rail` named slot OR explicit relatedSections.
       Index/saved/page contexts that pass none of these still skip emission,
       so G-SEO-6 ("library index has no middle column") stays green.
       Visibility on article pages is class-gated by .shell-no-context (spec
       §No-context CSS gate). -->
  {showRail && (
    <aside class="app-shell-middle-column" data-pagefind-ignore="all" aria-label="Related content">
      <div class="app-shell-middle-column__inner">
        {hasRail ? (
          <slot name="rail" />
        ) : hasRelatedSections ? (
          relatedSections.map((section) => (
            <section class="app-shell-middle-column__section">
              <h2 class="app-shell-middle-column__heading">{section.heading}</h2>
              <ol class="app-shell-middle-column__list">
                {section.items.map((item) => (
                  <li>
                    <a href={item.href}>{item.label}</a>
                  </li>
                ))}
              </ol>
            </section>
          ))
        ) : (
          <section class="app-shell-middle-column__section">
            <h2 class="app-shell-middle-column__heading">Continue browsing</h2>
            <p class="app-shell-middle-column__meta"></p>
            <ol class="app-shell-middle-column__list"></ol>
          </section>
        )}
      </div>
    </aside>
  )}

  <!-- Mobile bottom nav -->
  <nav class="app-shell-bottom-nav" data-pagefind-ignore="all" aria-label="Mobile primary">
    <a href="/library/" class="app-shell-bottom-nav__tab" aria-current={inLibrary && !inSaved ? 'page' : undefined} data-clear-shell-context>Library</a>
    <a href="/commentary/" class="app-shell-bottom-nav__tab" aria-current={inCommentary ? 'page' : undefined} data-clear-shell-context>Commentary</a>
    <a href="/library/saved/" class="app-shell-bottom-nav__tab" aria-current={inSaved ? 'page' : undefined} data-clear-shell-context>Saved</a>
    <a href="/account/" class="app-shell-bottom-nav__tab" aria-current={inAccount ? 'page' : undefined} data-clear-shell-context>Account</a>
  </nav>

  <!-- Mobile hamburger drawer (mirrors sidebar contents) -->
  <button type="button" class="app-shell-drawer-toggle" aria-controls="app-shell-drawer" aria-expanded="false" aria-label="Open menu" data-pagefind-ignore="all">☰</button>
  <aside id="app-shell-drawer" class="app-shell-drawer" data-pagefind-ignore="all" aria-label="Mobile navigation">
    <button type="button" class="app-shell-drawer__close" aria-label="Close menu">×</button>
    <div class="app-shell-nav__section">
      <div class="app-shell-nav__heading">Reading</div>
      <a href="/library/saved/" class="app-shell-nav__link" aria-current={inSaved ? 'page' : undefined} data-clear-shell-context>
        <span class="app-shell-nav__icon" aria-hidden="true" set:html={NAV_ICONS['/library/saved/']} />
        <span class="app-shell-nav__label">Saved Articles</span>
      </a>
      <a href="/library/" class="app-shell-nav__link" aria-current={inLibrary && !inSaved ? 'page' : undefined} data-clear-shell-context>
        <span class="app-shell-nav__icon" aria-hidden="true" set:html={NAV_ICONS['/library/']} />
        <span class="app-shell-nav__label">Research Library</span>
      </a>
      <a href="/commentary/" class="app-shell-nav__link" aria-current={inCommentary ? 'page' : undefined} data-clear-shell-context>
        <span class="app-shell-nav__icon" aria-hidden="true" set:html={NAV_ICONS['/commentary/']} />
        <span class="app-shell-nav__label">Commentary</span>
      </a>
    </div>
    <div class="app-shell-nav__section">
      <div class="app-shell-nav__heading">Explore</div>
      <a href="/ask/" class="app-shell-nav__link" aria-current={inAsk ? 'page' : undefined} data-clear-shell-context>
        <span class="app-shell-nav__icon" aria-hidden="true" set:html={NAV_ICONS['/ask/']} />
        <span class="app-shell-nav__label">Ask</span>
      </a>
      <a href="/faqs/" class="app-shell-nav__link" aria-current={inFaqs ? 'page' : undefined} data-clear-shell-context>
        <span class="app-shell-nav__icon" aria-hidden="true" set:html={NAV_ICONS['/faqs/']} />
        <span class="app-shell-nav__label">FAQs</span>
      </a>
      <a href="/glossary/" class="app-shell-nav__link" aria-current={inGlossary ? 'page' : undefined} data-clear-shell-context>
        <span class="app-shell-nav__icon" aria-hidden="true" set:html={NAV_ICONS['/glossary/']} />
        <span class="app-shell-nav__label">Glossary</span>
      </a>
      <a href="/guides/" class="app-shell-nav__link" aria-current={inGuides ? 'page' : undefined} data-clear-shell-context>
        <span class="app-shell-nav__icon" aria-hidden="true" set:html={NAV_ICONS['/guides/']} />
        <span class="app-shell-nav__label">Guides</span>
      </a>
      <a href="/courses/" class="app-shell-nav__link" aria-current={inCourses ? 'page' : undefined} data-clear-shell-context>
        <span class="app-shell-nav__icon" aria-hidden="true" set:html={NAV_ICONS['/courses/']} />
        <span class="app-shell-nav__label">Courses</span>
      </a>
      <a href="/community/" class="app-shell-nav__link" aria-current={inCommunity ? 'page' : undefined} data-clear-shell-context>
        <span class="app-shell-nav__icon" aria-hidden="true" set:html={NAV_ICONS['/community/']} />
        <span class="app-shell-nav__label">Community</span>
      </a>
      <a href="/providers/" class="app-shell-nav__link" aria-current={inProviders ? 'page' : undefined} data-clear-shell-context>
        <span class="app-shell-nav__icon" aria-hidden="true" set:html={NAV_ICONS['/providers/']} />
        <span class="app-shell-nav__label">RRM Providers</span>
      </a>
      <a href="/endo-survey/" class="app-shell-nav__link" data-clear-shell-context>
        <span class="app-shell-nav__icon" aria-hidden="true" set:html={NAV_ICONS['/endo-survey/']} />
        <span class="app-shell-nav__label">Endo Self-Survey</span>
      </a>
      <a href="/ivf-success-calculator/" class="app-shell-nav__link" data-clear-shell-context>
        <span class="app-shell-nav__icon" aria-hidden="true" set:html={NAV_ICONS['/ivf-success-calculator/']} />
        <span class="app-shell-nav__label">IVF Success Calculator</span>
      </a>
    </div>
    <a href="/donate/" class="app-shell-nav__cta" data-clear-shell-context>
      <span class="app-shell-nav__icon" aria-hidden="true" set:html={NAV_ICONS['/donate/']} />
      <span class="app-shell-nav__label">Donate</span>
    </a>
    <a href="/account/" class="app-shell-nav__link" aria-current={inAccount ? 'page' : undefined} data-clear-shell-context>
      <span class="app-shell-nav__icon" aria-hidden="true" set:html={NAV_ICONS['/account/']} />
      <span class="app-shell-nav__label">Account</span>
    </a>
    <button type="button" class="app-shell-nav__theme-toggle" aria-label="Toggle theme" data-theme-toggle>
      <svg class="icon-moon" aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
      <svg class="icon-sun" aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
    </button>
  </aside>
  <div class="app-shell-drawer__overlay" aria-hidden="true"></div>
