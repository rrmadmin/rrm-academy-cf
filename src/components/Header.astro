---
// Navigation matching current Wix site
const navItems = [
  { label: 'Research Library', href: '/library/', current: true },
  { label: 'Commentary', href: '/commentary/' },
  {
    label: 'Courses',
    href: '/courses/',
    children: [
      { label: 'RRM vs IVF', href: '/courses/rrm-vs-ivf/' },
      { label: 'Postpartum Depression & Anxiety', href: '/courses/postpartum-depression-anxiety/' },
      { label: 'Long-term Endometriosis Management', href: '/courses/long-term-endometriosis-management/' },
      { label: 'Masterclass in Endometriosis & Surgery', href: '/courses/masterclass-in-endometriosis-and-surgery/' },
    ],
  },
  // STUC-CUTOVER: uncomment to add Community to desktop nav
  // { label: 'Community', href: '/community/' },
];

// Mobile menu — full site navigation (desktop nav stays unchanged)
// SVG icons for mobile nav (16x16, stroke-based)
const icons: Record<string, string> = {
  'help-circle': '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>',
  'graduation': '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c0 1.1 2.7 3 6 3s6-1.9 6-3v-5"/></svg>',
  'pen': '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>',
  'library-big': '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="8" height="18" x="3" y="3" rx="1"/><path d="M7 3v18"/><path d="M20.4 18.9c.2.5-.1 1.1-.6 1.3l-1.9.7c-.5.2-1.1-.1-1.3-.6L11.1 5.1c-.2-.5.1-1.1.6-1.3l1.9-.7c.5-.2 1.1.1 1.3.6Z"/></svg>',
  'clipboard': '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><rect x="8" y="2" width="8" height="4" rx="1" ry="1"/></svg>',
  'info': '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>',
  'heart': '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>',
  'users': '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>',
  'mail': '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>',
};

const mobileNavSections = [
  {
    heading: 'Education',
    items: [
      { label: 'FAQ', href: '/faqs/', icon: 'help-circle' },
      {
        label: 'Courses',
        href: '/courses/',
        icon: 'graduation',
        children: [
          { label: 'RRM vs IVF', href: '/courses/rrm-vs-ivf/' },
          { label: 'Postpartum Depression & Anxiety', href: '/courses/postpartum-depression-anxiety/' },
          { label: 'Long-term Endometriosis Management', href: '/courses/long-term-endometriosis-management/' },
          { label: 'Masterclass in Endometriosis & Surgery', href: '/courses/masterclass-in-endometriosis-and-surgery/' },
        ],
      },
      { label: 'Commentary', href: '/commentary/', icon: 'pen' },
      { label: 'Research Library', href: '/library/', icon: 'library-big' },
      { label: 'Endo Self-Survey', href: '/endo-survey/', icon: 'clipboard', hoverIcon: '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#FFD700" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 11.22C11 9.997 10 9 10 8a2 2 0 0 1 4 0c0 1-.998 2.002-2.01 3.22"/><path d="m12 18 2.57-3.5"/><path d="M6.243 9.016a7 7 0 0 1 11.507-.009"/><path d="M9.35 14.53 12 11.22"/><path d="M9.35 14.53C7.728 12.246 6 10.221 6 7a6 5 0 0 1 12 0c-.005 3.22-1.778 5.235-3.43 7.5l3.557 4.527a1 1 0 0 1-.203 1.43l-1.894 1.36a1 1 0 0 1-1.384-.215L12 18l-2.679 3.593a1 1 0 0 1-1.39.213l-1.865-1.353a1 1 0 0 1-.203-1.422z"/></svg>' },
      // STUC-CUTOVER: uncomment to add Community to mobile nav
      // { label: 'Community', href: '/community/', icon: 'users' },
    ],
  },
  {
    heading: 'Help',
    items: [
      { label: 'About', href: '/about/', icon: 'info' },
      { label: 'Join Us', href: '/save-the-uterus-club/', icon: 'users' },
      { label: 'Contact', href: '/contact/', icon: 'mail' },
    ],
  },
];
---
<header class="site-header">
  <div class="header-inner container">
    <a href="/" class="logo">
      <span class="logo__text">RRM Academy</span>
    </a>

    <nav class="main-nav" aria-label="Site">
      <ul class="nav-list">
        {navItems.map((item) => (
          <li class:list={['nav-item', { 'has-dropdown': item.children }]}>
            {item.current ? (
              <a href="/library/" class="nav-link nav-link--active">{item.label}</a>
            ) : item.children ? (
              <button class="nav-link nav-link--dropdown" type="button">
                {item.label}
                <svg class="chevron" width="10" height="10" viewBox="0 0 10 10"><path d="M2.5 4L5 6.5L7.5 4" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </button>
            ) : (
              <a href={item.href} class="nav-link">{item.label}</a>
            )}
            {item.children && (
              <div class="dropdown">
                <div class="dropdown__grid">
                  {item.children.map((child) => (
                    <a href={child.href} class="dropdown-link">{child.label}</a>
                  ))}
                </div>
              </div>
            )}
          </li>
        ))}
      </ul>

      <!-- Mobile nav — full site navigation (hidden on desktop, replaces nav-list on mobile) -->
      <div class="mobile-nav-sections">
        {mobileNavSections.map((section) => (
          <div class="mobile-nav-group">
            <div class="mobile-nav-group__heading">{section.heading}</div>
            <ul class="mobile-nav-group__list">
              {section.items.map((item) => (
                <li class:list={[{ 'mobile-has-dropdown': item.children, 'has-hover-icon': item.hoverIcon }]}>
                  {item.children ? (
                    <button class="mobile-nav-link mobile-nav-link--dropdown" type="button">
                      <span class="mobile-nav-icon" aria-hidden="true" set:html={icons[item.icon!]} />
                      {item.label}
                      <svg class="chevron" width="10" height="10" viewBox="0 0 10 10"><path d="M2.5 4L5 6.5L7.5 4" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    </button>
                  ) : (
                    <a href={item.href} class="mobile-nav-link">
                      <span class="mobile-nav-icon" aria-hidden="true" set:html={icons[item.icon!]} />
                      {item.hoverIcon && <span class="mobile-nav-icon mobile-nav-icon--hover" aria-hidden="true" set:html={item.hoverIcon} />}
                      {item.label}
                    </a>
                  )}
                  {item.children && (
                    <div class="mobile-dropdown">
                      {item.children.map((child) => (
                        <a href={child.href} class="mobile-dropdown-link">{child.label}</a>
                      ))}
                    </div>
                  )}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>

      <!-- Mobile-only footer inside nav panel -->
      <div class="mobile-nav-footer">
        <div class="mobile-nav-footer__actions">
          <a href="/donate/" class="donate-btn">Donate</a>
          <div class="mobile-nav-footer__utils">
            <a href="/library/saved/" class="saved-link mobile-saved-link" id="mobile-saved-link" title="Saved articles">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 2v8l3-3 3 3V2"/><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H19a1 1 0 0 1 1 1v18a1 1 0 0 1-1 1H6.5a1 1 0 0 1 0-5H20"/></svg>
              <span class="saved-count" id="mobile-saved-count">0</span>
            </a>
            <button class="theme-toggle" id="mobile-theme-toggle" aria-label="Toggle theme">
            <svg class="icon-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
            <svg class="icon-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
          </button>
          </div>
        </div>
      </div>
    </nav>

    <form class="header-search" action="/library/" method="get" role="search">
      <svg class="header-search__icon" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      <input type="search" name="q" class="header-search__input" placeholder="Search articles..." autocomplete="off" />
    </form>

    <div class="header-actions">
      <a href="/library/saved/" class="saved-link" id="saved-link" title="Saved articles">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 2v8l3-3 3 3V2"/><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H19a1 1 0 0 1 1 1v18a1 1 0 0 1-1 1H6.5a1 1 0 0 1 0-5H20"/></svg>
        <span class="saved-count" id="saved-count">0</span>
      </a>
      <button class="theme-toggle" id="theme-toggle" aria-label="Toggle theme">
        <svg class="icon-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
        <svg class="icon-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
      </button>
      <a href="/donate/" class="donate-btn">Donate</a>
    </div>

    <button class="mobile-toggle" aria-label="Menu" aria-expanded="false">
      <span class="hamburger"></span>
    </button>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--bg-header);
    box-shadow: 0 1px 0 var(--border-light);
    transition: background 0.3s;
  }
  .header-inner {
    display: flex;
    align-items: center;
    height: 48px;
    gap: var(--space-6);
    position: relative;
  }

  /* Logo */
  .logo {
    display: flex;
    align-items: center;
    text-decoration: none;
    white-space: nowrap;
  }
  .logo:hover { text-decoration: none; }
  .logo__text {
    font-family: 'Cormorant Garamond', 'Georgia', serif;
    font-weight: 600;
    font-size: 1.625rem;
    color: var(--text-primary);
    letter-spacing: normal;
    line-height: 1.4;
  }

  /* Nav */
  .main-nav { flex: 1; }
  /* Hide nav on library pages */
  :global(.page-library) .main-nav { display: none; }
  .nav-list {
    display: flex;
    list-style: none;
    gap: 0;
    align-items: center;
  }
  .nav-item {
    position: relative;
    display: flex;
    align-items: center;
  }
  .nav-link {
    display: inline-flex;
    align-items: center;
    gap: 3px;
    padding: 4px 16px;
    font-size: 0.875rem;
    font-weight: 400;
    line-height: 1.4;
    color: var(--text-primary);
    text-decoration: none;
    background: none;
    border: none;
    border-bottom: 2px solid transparent;
    cursor: pointer;
    font-family: 'Inter', sans-serif;
    transition: color 0.15s, border-color 0.15s;
  }
  .nav-link:hover {
    color: var(--accent);
    text-decoration: none;
  }
  .nav-link--active {
    font-weight: 400;
  }

  /* Chevron */
  .chevron {
    transition: transform 0.2s;
    margin-top: 1px;
  }
  .has-dropdown:hover .chevron {
    transform: rotate(180deg);
  }

  /* Dropdown */
  .dropdown {
    display: none;
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    min-width: 380px;
    padding-top: 12px;
    z-index: 10;
  }
  .has-dropdown:hover .dropdown {
    display: block;
  }
  .dropdown__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-2) var(--space-6);
    background: var(--bg-surface);
    border: 1px solid var(--border-color);
    box-shadow: var(--shadow-lg);
    padding: var(--space-5) var(--space-6);
  }
  .dropdown-link {
    font-size: 0.8125rem;
    font-weight: 400;
    color: var(--text-secondary);
    text-decoration: none;
    padding: var(--space-1) 0;
    transition: color 0.15s;
    white-space: nowrap;
  }
  .dropdown-link:hover {
    color: var(--accent);
    text-decoration: none;
  }

  /* Donate button — pill shape */
  .donate-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: 'Inter', sans-serif;
    font-size: 0.8125rem;
    font-weight: 500;
    line-height: 1;
    padding: 8px 24px;
    color: var(--white);
    background: var(--purple-700);
    border: 1px solid var(--purple-700);
    border-radius: var(--radius-pill);
    text-decoration: none;
    transition: background 0.15s, border-color 0.15s;
  }
  .donate-btn:hover {
    background: var(--purple-900);
    border-color: var(--purple-900);
    color: var(--white);
    text-decoration: none;
  }

  /* Header search — only on library pages, absolutely centered */
  .header-search {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    width: 320px;
    display: none;
    align-items: center;
  }
  @media (min-width: 769px) {
    :global(.page-synopsis) .header-search {
      display: flex;
    }
  }
  .header-search__icon {
    position: absolute;
    left: 10px;
    color: var(--text-muted);
    pointer-events: none;
  }
  .header-search__input {
    width: 100%;
    padding: 7px 12px 7px 32px;
    font-size: 0.8125rem;
    font-family: 'Inter', sans-serif;
    border: 1px solid var(--border-color);
    border-radius: var(--radius-pill);
    outline: none;
    background: var(--bg-surface);
    color: var(--text-primary);
    transition: border-color 0.15s, box-shadow 0.15s;
  }
  .header-search__input:focus {
    border-color: var(--accent);
    box-shadow: 0 0 0 2px var(--focus-ring);
  }
  .header-search__input::placeholder {
    color: var(--text-muted);
  }
  .header-search__input::-webkit-search-cancel-button {
    -webkit-appearance: none;
    display: none;
  }

  /* Actions — desktop */
  .header-actions {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-left: auto;
  }
  .saved-link {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--text-tertiary);
    text-decoration: none;
    padding: 5px 8px;
    transition: color 0.15s;
  }
  .saved-link:hover {
    color: var(--accent);
    text-decoration: none;
  }
  .saved-link.has-items { color: var(--accent); }
  .saved-count { font-variant-numeric: tabular-nums; }
  .saved-link:not(.has-items) { display: none; }

  /* Theme toggle */
  .theme-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: none;
    padding: 4px;
    color: var(--text-tertiary);
    cursor: pointer;
    transition: color 0.15s;
  }
  .theme-toggle:hover {
    color: var(--accent);
  }
  .theme-toggle .icon-sun,
  .theme-toggle .icon-moon { display: none; }
  :global([data-theme="light"]) .theme-toggle .icon-moon { display: inline; }
  :global([data-theme="dark"]) .theme-toggle .icon-sun { display: inline; }

  /* Mobile nav sections + footer — hidden on desktop */
  .mobile-nav-sections,
  .mobile-nav-footer {
    display: none;
  }

  /* Mobile hamburger */
  .mobile-toggle {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: var(--space-2);
    margin-left: auto;
  }
  .hamburger {
    display: block;
    width: 18px;
    height: 2px;
    background: var(--text-primary);
    position: relative;
    border-radius: 1px;
    transition: background 0.2s;
  }
  .hamburger::before,
  .hamburger::after {
    content: '';
    position: absolute;
    left: 0;
    width: 100%;
    height: 2px;
    background: var(--text-primary);
    border-radius: 1px;
    transition: transform 0.2s, top 0.2s;
  }
  .hamburger::before { top: -6px; }
  .hamburger::after { top: 6px; }

  /* Hamburger → X when open */
  .site-header.nav-open .hamburger {
    background: transparent;
  }
  .site-header.nav-open .hamburger::before {
    top: 0;
    transform: rotate(45deg);
  }
  .site-header.nav-open .hamburger::after {
    top: 0;
    transform: rotate(-45deg);
  }

  /* ═══════════════════════════════════════════
     MOBILE — clean full-width panel
     ═══════════════════════════════════════════ */
  @media (max-width: 768px) {
    .header-inner {
      gap: var(--space-3);
    }

    /* Header bar: logo + hamburger only */
    .main-nav { display: none; }
    .header-search { display: none; }
    .header-actions { display: none; }
    .mobile-toggle { display: block; }

    /* ── Nav panel (open state) ── */
    .site-header.nav-open .main-nav {
      display: flex;
      flex-direction: column;
      position: absolute;
      top: 56px;
      left: 0;
      right: 0;
      background: var(--bg-header);
      border-bottom: 1px solid var(--border-color);
      box-shadow: 0 8px 24px rgba(0,0,0,0.08);
      padding: var(--space-4) 0;
      z-index: 50;
      max-height: calc(100dvh - 56px);
      overflow-y: auto;
      -webkit-overflow-scrolling: touch;
    }

    /* Hide desktop nav-list on mobile, show mobile nav sections */
    .site-header.nav-open .nav-list {
      display: none;
    }
    .site-header.nav-open .mobile-nav-sections {
      display: block;
    }

    /* ── Mobile nav sections ── */
    .mobile-nav-group {
      padding: 0 0 var(--space-2);
    }
    .mobile-nav-group + .mobile-nav-group {
      border-top: 1px solid var(--border-light);
      padding-top: var(--space-2);
    }
    .mobile-nav-group__heading {
      padding: var(--space-1) var(--space-6) var(--space-1);
      font-family: 'Inter', sans-serif;
      font-size: 0.6875rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      color: var(--text-muted);
    }
    .mobile-nav-group__list {
      list-style: none;
      padding: 0;
      margin: 0;
    }
    .mobile-nav-icon {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 18px;
      height: 18px;
      flex-shrink: 0;
      color: var(--text-muted);
      vertical-align: middle;
    }
    .mobile-nav-icon--hover {
      display: none;
    }
    .has-hover-icon .mobile-nav-link:hover .mobile-nav-icon:not(.mobile-nav-icon--hover) {
      display: none;
    }
    .has-hover-icon .mobile-nav-link:hover .mobile-nav-icon--hover {
      display: inline-flex;
    }
    .mobile-nav-link {
      display: flex;
      align-items: center;
      gap: 18px; /* optical spacing for touch targets */
      width: 100%;
      padding: 8px var(--space-6);
      margin: 0;
      font-family: 'Inter', sans-serif;
      font-size: 0.9375rem;
      font-weight: 400;
      color: var(--text-primary);
      text-decoration: none;
      background: none;
      border: none;
      cursor: pointer;
      transition: color 0.15s;
      line-height: 1.4;
    }
    .mobile-nav-link:hover {
      color: var(--accent);
      text-decoration: none;
    }
    .mobile-nav-link:active {
      background: var(--bg-surface);
    }

    /* Mobile dropdown — collapsed by default, toggled by JS */
    .mobile-dropdown {
      display: none;
    }
    .mobile-has-dropdown.dropdown-open .mobile-dropdown {
      display: block;
    }
    .mobile-has-dropdown.dropdown-open .chevron {
      transform: rotate(180deg);
    }
    .mobile-dropdown-link {
      display: block;
      padding: 8px var(--space-6) 8px var(--space-10);
      font-family: 'Inter', sans-serif;
      font-size: 0.8125rem;
      font-weight: 400;
      color: var(--text-secondary);
      text-decoration: none;
      transition: color 0.15s;
    }
    .mobile-dropdown-link:hover {
      color: var(--accent);
      text-decoration: none;
    }
    .mobile-dropdown-link:active {
      background: var(--bg-surface);
    }

    /* ── Mobile nav footer ── */
    .site-header.nav-open .mobile-nav-footer {
      display: block;
      padding: var(--space-4) var(--space-6) var(--space-2);
      margin-top: var(--space-2);
      border-top: 1px solid var(--border-light);
    }

    .mobile-nav-footer__actions {
      display: flex;
      align-items: center;
      gap: var(--space-4);
    }
    .mobile-nav-footer__utils {
      display: flex;
      align-items: center;
      gap: var(--space-3);
      margin-left: auto;
    }
  }
</style>

<script is:inline>
  // Mobile menu toggle
  var toggle = document.querySelector('.mobile-toggle');
  var header = document.querySelector('.site-header');
  if (toggle && header) {
    toggle.addEventListener('click', function() {
      var expanded = toggle.getAttribute('aria-expanded') === 'true';
      toggle.setAttribute('aria-expanded', String(!expanded));
      header.classList.toggle('nav-open');
      // Lock/unlock body scroll
      document.body.style.overflow = expanded ? '' : 'hidden';
      // Close any open dropdowns when menu closes
      if (expanded) {
        var openDropdowns = header.querySelectorAll('.dropdown-open');
        for (var i = 0; i < openDropdowns.length; i++) {
          openDropdowns[i].classList.remove('dropdown-open');
        }
      }
    });
  }

  // Desktop dropdown toggle (tap to expand/collapse on mobile)
  var dropdownButtons = document.querySelectorAll('.nav-link--dropdown');
  for (var i = 0; i < dropdownButtons.length; i++) {
    dropdownButtons[i].addEventListener('click', function() {
      if (window.innerWidth <= 768) {
        this.closest('.has-dropdown').classList.toggle('dropdown-open');
      }
    });
  }

  // Mobile nav dropdown toggle (Courses submenu)
  var mobileDropdownButtons = document.querySelectorAll('.mobile-nav-link--dropdown');
  for (var i = 0; i < mobileDropdownButtons.length; i++) {
    mobileDropdownButtons[i].addEventListener('click', function() {
      this.closest('.mobile-has-dropdown').classList.toggle('dropdown-open');
    });
  }

  // Theme toggle (both desktop and mobile)
  function handleThemeToggle() {
    var html = document.documentElement;
    var current = html.getAttribute('data-theme');
    var next = current === 'dark' ? 'light' : 'dark';
    html.setAttribute('data-theme', next);
    localStorage.setItem('rrm_theme', next);
  }

  var themeToggle = document.getElementById('theme-toggle');
  var mobileThemeToggle = document.getElementById('mobile-theme-toggle');
  if (themeToggle) themeToggle.addEventListener('click', handleThemeToggle);
  if (mobileThemeToggle) mobileThemeToggle.addEventListener('click', handleThemeToggle);

  // Saved articles badge (desktop + mobile)
  (function() {
    function setBadge(n) {
      var ids = ['saved-link', 'mobile-saved-link'];
      var countIds = ['saved-count', 'mobile-saved-count'];
      for (var i = 0; i < ids.length; i++) {
        var link = document.getElementById(ids[i]);
        var count = document.getElementById(countIds[i]);
        if (count) count.textContent = n;
        if (link) {
          if (n > 0) link.classList.add('has-items');
          else link.classList.remove('has-items');
        }
      }
    }

    try {
      var saved = JSON.parse(localStorage.getItem('rrm_saved') || '[]');
      if (saved.length > 0) setBadge(saved.length);
    } catch(e) {}

    // If logged in, sync with server and update badge with merged count
    fetch('/api/auth/session', { credentials: 'same-origin' })
      .then(function(r) { return r.json(); })
      .then(function(data) {
        if (!data.ok || !data.user) return;
        var local = [];
        try { local = JSON.parse(localStorage.getItem('rrm_saved') || '[]'); } catch(e) {}
        if (local.length > 0) {
          // Sync local → server, get merged set back
          fetch('/api/saved', {
            method: 'POST',
            credentials: 'same-origin',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ articles: local })
          })
            .then(function(r) { return r.json(); })
            .then(function(result) {
              if (result.ok && result.articles) {
                // Merge into localStorage
                var slugMap = {};
                local.forEach(function(a) { slugMap[a.slug] = a; });
                result.articles.forEach(function(a) { slugMap[a.slug] = a; });
                var merged = Object.values(slugMap);
                merged.sort(function(a, b) { return (b.savedAt || '').localeCompare(a.savedAt || ''); });
                localStorage.setItem('rrm_saved', JSON.stringify(merged));
                setBadge(merged.length);
              }
            }).catch(function() {});
        } else {
          // No local saves — fetch server saves
          fetch('/api/saved', { credentials: 'same-origin' })
            .then(function(r) { return r.json(); })
            .then(function(result) {
              if (result.ok && result.articles && result.articles.length > 0) {
                localStorage.setItem('rrm_saved', JSON.stringify(result.articles));
                setBadge(result.articles.length);
              }
            }).catch(function() {});
        }
      }).catch(function() {});
  })();
</script>
