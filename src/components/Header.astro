---
// Navigation matching current Wix site
const navItems = [
  { label: 'Research Library', href: '/library', current: true },
  {
    label: 'Commentary',
    href: '/commentary',
    children: [
      { label: 'Restorative Reproductive Medicine', href: '/commentary/categories/restorative-reproductive-medicine' },
      { label: 'RRM Physician Spotlight', href: '/commentary/categories/rrm-physician-spotlight' },
      { label: 'RRM Research Library', href: '/commentary/categories/rrm-research-library' },
      { label: 'Case Studies', href: '/commentary/categories/case-studies' },
    ],
  },
  {
    label: 'Courses',
    href: '/courses',
    children: [
      { label: 'RRM vs IVF', href: '/courses/rrm-vs-ivf' },
      { label: 'Postpartum Depression & Anxiety', href: '/courses/postpartum-depression-anxiety' },
      { label: 'Long-term Endometriosis Management', href: '/courses/long-term-endometriosis-management' },
      { label: 'Masterclass in Endometriosis & Surgery', href: '/courses/masterclass-in-endometriosis-surgery' },
    ],
  },
  { label: 'About', href: '/about' },
  { label: 'Contact', href: '/contact' },
];

const wixBase = 'https://www.rrmacademy.org';
---
<header class="site-header">
  <div class="header-inner container">
    <a href="/" class="logo">
      <span class="logo__text">RRM Academy</span>
    </a>

    <nav class="main-nav" aria-label="Site">
      <ul class="nav-list">
        {navItems.map((item) => (
          <li class:list={['nav-item', { 'has-dropdown': item.children }]}>
            {item.current ? (
              <a href="/library" class="nav-link nav-link--active">{item.label}</a>
            ) : item.children ? (
              <button class="nav-link nav-link--dropdown" type="button">
                {item.label}
                <svg class="chevron" width="10" height="10" viewBox="0 0 10 10"><path d="M2.5 4L5 6.5L7.5 4" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </button>
            ) : (
              <a href={`${wixBase}${item.href}`} class="nav-link">{item.label}</a>
            )}
            {item.children && (
              <div class="dropdown">
                <div class="dropdown__grid">
                  {item.children.map((child) => (
                    <a href={`${wixBase}${child.href}`} class="dropdown-link">{child.label}</a>
                  ))}
                </div>
              </div>
            )}
          </li>
        ))}
      </ul>
    </nav>

    <div class="header-actions">
      <a href="/library/saved" class="saved-link" id="saved-link" title="Saved articles">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/></svg>
        <span class="saved-count" id="saved-count">0</span>
      </a>
      <button class="theme-toggle" id="theme-toggle" aria-label="Toggle theme">
        <svg class="icon-moon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
        <svg class="icon-sun" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
      </button>
      <a href="/donate" class="donate-btn">Donate</a>
    </div>

    <a href="/library/saved" class="mobile-saved" id="mobile-saved-link" title="Saved articles">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/></svg>
    </a>

    <button class="mobile-toggle" aria-label="Menu" aria-expanded="false">
      <span class="hamburger"></span>
    </button>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--bg-header);
    border-bottom: 1px solid var(--border-color);
    transition: background 0.3s;
  }
  .header-inner {
    display: flex;
    align-items: center;
    height: 56px;
    gap: var(--space-6);
  }

  /* Logo */
  .logo {
    display: flex;
    align-items: center;
    text-decoration: none;
    white-space: nowrap;
  }
  .logo:hover { text-decoration: none; }
  .logo__text {
    font-family: 'Cormorant Garamond', 'Georgia', serif;
    font-weight: 600;
    font-size: 1.25rem;
    color: var(--text-primary);
    letter-spacing: -0.01em;
  }

  /* Nav */
  .main-nav { flex: 1; }
  .nav-list {
    display: flex;
    list-style: none;
    gap: 0;
    align-items: center;
  }
  .nav-item {
    position: relative;
  }
  .nav-link {
    display: inline-flex;
    align-items: center;
    gap: 3px;
    padding: 4px 16px;
    font-size: 0.875rem;
    font-weight: 400;
    color: var(--text-primary);
    text-decoration: none;
    background: none;
    border: none;
    border-bottom: 2px solid transparent;
    cursor: pointer;
    font-family: 'Inter', sans-serif;
    transition: color 0.15s, border-color 0.15s;
  }
  .nav-link:hover {
    color: var(--accent);
    text-decoration: none;
  }
  .nav-link--active {
    font-weight: 500;
  }

  /* Chevron */
  .chevron {
    transition: transform 0.2s;
    margin-top: 1px;
  }
  .has-dropdown:hover .chevron {
    transform: rotate(180deg);
  }

  /* Dropdown */
  .dropdown {
    display: none;
    position: absolute;
    top: calc(100% + 12px);
    left: 50%;
    transform: translateX(-50%);
    min-width: 380px;
    background: var(--bg-surface);
    border: 1px solid var(--border-color);
    box-shadow: var(--shadow-lg);
    padding: var(--space-5) var(--space-6);
    z-index: 10;
  }
  .has-dropdown:hover .dropdown {
    display: block;
  }
  .dropdown__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-2) var(--space-6);
  }
  .dropdown-link {
    font-size: 0.8125rem;
    font-weight: 400;
    color: var(--text-secondary);
    text-decoration: none;
    padding: var(--space-1) 0;
    transition: color 0.15s;
    white-space: nowrap;
  }
  .dropdown-link:hover {
    color: var(--accent);
    text-decoration: none;
  }

  /* Donate button — pill shape */
  .donate-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: 'Inter', sans-serif;
    font-size: 0.8125rem;
    font-weight: 500;
    padding: 8px 24px;
    color: var(--white);
    background: var(--purple-700);
    border: 1px solid var(--purple-700);
    border-radius: var(--radius-pill);
    text-decoration: none;
    transition: background 0.15s, border-color 0.15s;
  }
  .donate-btn:hover {
    background: var(--purple-900);
    border-color: var(--purple-900);
    color: var(--white);
    text-decoration: none;
  }

  /* Actions */
  .header-actions {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }
  .saved-link {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--text-tertiary);
    text-decoration: none;
    padding: 5px 8px;
    transition: color 0.15s;
  }
  .saved-link:hover {
    color: var(--accent);
    text-decoration: none;
  }
  .saved-link.has-items { color: var(--accent); }
  .saved-count { font-variant-numeric: tabular-nums; }
  .saved-link:not(.has-items) { display: none; }

  /* Theme toggle */
  .theme-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: 1px solid var(--border-color);
    border-radius: var(--radius-pill);
    padding: 5px 8px;
    color: var(--text-tertiary);
    cursor: pointer;
    transition: border-color 0.15s, color 0.15s;
  }
  .theme-toggle:hover {
    border-color: var(--accent);
    color: var(--accent);
  }
  .theme-toggle .icon-sun,
  .theme-toggle .icon-moon { display: none; }
  :global([data-theme="light"]) .theme-toggle .icon-moon { display: inline; }
  :global([data-theme="dark"]) .theme-toggle .icon-sun { display: inline; }

  /* Mobile saved icon */
  .mobile-saved {
    display: none;
    color: var(--text-muted);
    padding: var(--space-1);
    margin-left: auto;
    margin-right: var(--space-2);
  }
  .mobile-saved.has-items { color: var(--accent); }

  /* Mobile */
  .mobile-toggle {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: var(--space-2);
  }
  .hamburger {
    display: block;
    width: 18px;
    height: 2px;
    background: var(--text-primary);
    position: relative;
    border-radius: 1px;
  }
  .hamburger::before,
  .hamburger::after {
    content: '';
    position: absolute;
    left: 0;
    width: 100%;
    height: 2px;
    background: var(--text-primary);
    border-radius: 1px;
  }
  .hamburger::before { top: -6px; }
  .hamburger::after { top: 6px; }

  @media (max-width: 768px) {
    .main-nav, .header-actions { display: none; }
    .mobile-saved { display: block; }
    .mobile-saved:not(.has-items) { display: none; }
    .mobile-toggle { display: block; }
    .site-header.nav-open .main-nav {
      display: block;
      position: absolute;
      top: 56px;
      left: 0;
      right: 0;
      background: var(--bg-header);
      border-bottom: 1px solid var(--border-color);
      box-shadow: var(--shadow-lg);
      padding: var(--space-4);
    }
    .site-header.nav-open .nav-list {
      flex-direction: column;
      align-items: flex-start;
    }
    .site-header.nav-open .dropdown {
      position: static;
      transform: none;
      border: none;
      box-shadow: none;
      min-width: 0;
      padding: var(--space-2) 0 var(--space-2) var(--space-4);
    }
    .site-header.nav-open .dropdown__grid {
      grid-template-columns: 1fr;
    }
    .site-header.nav-open .has-dropdown .dropdown {
      display: block;
    }
    .site-header.nav-open .header-actions {
      display: flex;
      padding: var(--space-4) 0 0;
    }
  }
</style>

<script is:inline>
  // Mobile menu toggle
  var toggle = document.querySelector('.mobile-toggle');
  var header = document.querySelector('.site-header');
  if (toggle && header) {
    toggle.addEventListener('click', function() {
      var expanded = toggle.getAttribute('aria-expanded') === 'true';
      toggle.setAttribute('aria-expanded', String(!expanded));
      header.classList.toggle('nav-open');
    });
  }

  // Theme toggle
  var themeToggle = document.getElementById('theme-toggle');
  if (themeToggle) {
    themeToggle.addEventListener('click', function() {
      var html = document.documentElement;
      var current = html.getAttribute('data-theme');
      var next = current === 'dark' ? 'light' : 'dark';
      html.setAttribute('data-theme', next);
      localStorage.setItem('rrm_theme', next);
    });
  }

  // Saved articles badge (desktop + mobile)
  (function() {
    try {
      var saved = JSON.parse(localStorage.getItem('rrm_saved') || '[]');
      if (saved.length > 0) {
        var link = document.getElementById('saved-link');
        var count = document.getElementById('saved-count');
        var mobileLink = document.getElementById('mobile-saved-link');
        if (link) { link.classList.add('has-items'); }
        if (count) { count.textContent = saved.length; }
        if (mobileLink) { mobileLink.classList.add('has-items'); }
      }
    } catch(e) {}
  })();
</script>
