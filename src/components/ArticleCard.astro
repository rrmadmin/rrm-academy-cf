---
import type { Article } from '../lib/airtable';

interface Props {
  article: Article;
  compact?: boolean;
  basePath?: string;
}

const { article, compact = false, basePath = '/library/' } = Astro.props;
const href = `${basePath}${article.slug}/`;
const truncLen = compact ? 120 : 200;
const truncatedAbstract = article.abstract
  ? article.abstract.slice(0, truncLen) + (article.abstract.length > truncLen ? '...' : '')
  : '';

// Parse short citation parts. Year is always rendered as its own
// non-truncating span so it survives ellipsis on long author strings
// (e.g. "Practice Committee of the American Society for Reproductive
// Medicine, 2026" would otherwise truncate before the year).
const firstAuthor = article.authors?.split(';')[0]?.split(',')[0]?.trim() || '';
const yearStr = article.year ? String(article.year) : '';
let authorsForDisplay = '';
if (article.shortCitation) {
  // Strip a trailing ", YYYY" or " YYYY" so the year span isn't duplicated.
  authorsForDisplay = article.shortCitation.replace(/[,\s]+\d{4}\.?\s*$/, '').trim();
} else if (firstAuthor) {
  authorsForDisplay = `${firstAuthor}${article.authors?.includes(';') ? ' et al.' : ''}`;
}

// Show journal if available
const journalDisplay = article.journal || article.journalAbbv || '';

// Build COinS (ContextObjects in Spans) for Zotero multi-select
function buildCOinS(a: Article): string {
  const params: string[] = [
    'ctx_ver=Z39.88-2004',
    'rft_val_fmt=info%3Aofi%2Ffmt%3Akev%3Amtx%3Ajournal',
    'rft.genre=article',
  ];
  if (a.title) params.push('rft.atitle=' + encodeURIComponent(a.title));
  if (a.journal) params.push('rft.jtitle=' + encodeURIComponent(a.journal));
  if (a.volume) params.push('rft.volume=' + encodeURIComponent(a.volume));
  if (a.issue) params.push('rft.issue=' + encodeURIComponent(a.issue));
  if (a.pages) {
    const [sp, ep] = a.pages.split(/[-–]/);
    if (sp) params.push('rft.spage=' + encodeURIComponent(sp.trim()));
    if (ep) params.push('rft.epage=' + encodeURIComponent(ep.trim()));
  }
  if (a.datePublished) params.push('rft.date=' + encodeURIComponent(a.datePublished));
  else if (a.year) params.push('rft.date=' + encodeURIComponent(String(a.year)));
  // Authors
  const authors = a.authors?.split(';').map(s => s.trim()).filter(Boolean) || [];
  authors.forEach(au => params.push('rft.au=' + encodeURIComponent(au)));
  // Identifiers
  if (a.doi) params.push('rft_id=' + encodeURIComponent('info:doi/' + a.doi));
  if (a.pmid) params.push('rft_id=' + encodeURIComponent('info:pmid/' + a.pmid));
  return params.join('&');
}

const coinsTitle = buildCOinS(article);
---
<article class:list={['article-card', { 'article-card--compact': compact }]} data-article-card data-slug={article.slug} data-title={article.title || ''}>
  <span class="Z3988" title={coinsTitle}></span>
  <a href={href} class="article-card__link">
    <h3 class="article-card__title">{article.title}</h3>
  </a>

  <div class="article-card__meta">
    <span class="article-card__authors">{authorsForDisplay}</span>
    {yearStr && <span class="article-card__year">{yearStr}</span>}
    {article.accessLevel === 'open' && (
      <span class="access-badge access-badge--open" title={article.oaType ? `${article.oaType} Open Access` : 'Open Access'}>
        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 9.9-1"/></svg>
        Open Access
      </span>
    )}
    {article.accessLevel === 'free' && (
      <span class="access-badge access-badge--free" title="Free to Read (Bronze OA)">
        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 9.9-1"/></svg>
        Free to Read
      </span>
    )}
    {article.accessLevel === 'restricted' && article.isCopyrighted && (
      <span class="access-badge access-badge--restricted" title="Restricted">
        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
      </span>
    )}
    {journalDisplay && (
      <span class="article-card__journal">{journalDisplay}</span>
    )}
  </div>

  {!compact && truncatedAbstract && (
    <p class="article-card__abstract">{truncatedAbstract}</p>
  )}

  {!compact && article.topics.length > 0 && (
    <div class="article-card__topics">
      {article.topics.slice(0, 3).map(t => {
        const leaf = t.split('>').pop()?.trim() || t;
        return <span class="article-card__topic" title={t}>{leaf}</span>;
      })}
    </div>
  )}
</article>

<style>
  /* Full card — outlined sheet matching the library homepage Recently Published
     cards: 1px border, hover lifts + tints border with the accent. */
  .article-card {
    position: relative;
    background: var(--bg-surface);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
    padding: var(--space-5);
    transition: border-color 0.15s, transform 0.15s, box-shadow 0.2s;
    display: flex;
    flex-direction: column;
    min-width: 0;
    overflow: hidden;
  }
  .article-card:hover {
    border-color: var(--accent);
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
    cursor: pointer;
  }
  .article-card:focus-within {
    border-color: var(--purple-700);
    box-shadow: 0 0 0 3px var(--focus-ring);
  }

  .article-card__link {
    text-decoration: none;
    color: inherit;
  }
  .article-card__link::after {
    content: '';
    position: absolute;
    inset: 0;
  }
  .article-card__link:hover {
    text-decoration: none;
  }

  .article-card__title {
    font-family: 'Cormorant Garamond', 'Georgia', serif;
    font-weight: 600;
    font-size: 1.125rem;
    line-height: 1.3;
    color: var(--text-primary);
    margin-bottom: var(--space-2);
    transition: color 0.15s;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .article-card:hover .article-card__title {
    color: var(--accent);
  }

  .article-card__meta {
    display: flex;
    flex-wrap: nowrap;
    align-items: center;
    gap: var(--space-1);
    margin-bottom: var(--space-3);
    font-size: 0.75rem;
    line-height: 1.5;
    min-width: 0;
    white-space: nowrap;
  }
  .article-card__authors {
    color: var(--text-secondary);
    font-weight: 500;
    overflow: hidden;
    text-overflow: ellipsis;
    min-width: 0;
  }
  /* Year is rendered as its own span so it never truncates with the
     authors string. Authors get ellipsis; year is always visible. */
  .article-card__year {
    color: var(--text-secondary);
    font-weight: 500;
    font-variant-numeric: tabular-nums;
    flex-shrink: 0;
    white-space: nowrap;
  }
  .article-card__year::before {
    content: ', ';
    color: var(--text-secondary);
  }
  .article-card__journal {
    color: var(--text-secondary);
    font-style: italic;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .article-card__journal::before {
    content: '\b7';
    margin-right: var(--space-1);
    font-style: normal;
    color: var(--text-muted);
  }

  .article-card__abstract {
    font-size: 0.8125rem;
    color: var(--text-secondary);
    line-height: 1.6;
    margin-bottom: var(--space-3);
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    flex: 1;
  }

  .article-card__topics {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }
  .article-card__topic {
    font-size: 0.625rem;
    font-weight: 500;
    color: var(--text-secondary);
    background: var(--neutral-100);
    padding: 2px 8px;
    border-radius: var(--radius-sm);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    min-width: 0;
    max-width: 100%;
  }

  /* Compact variant — clean text row */
  .article-card--compact {
    background: transparent;
    border: 0;
    border-bottom: 1px solid var(--border-light);
    border-radius: 0;
    padding: var(--space-3) 0;
  }
  .article-card--compact:hover {
    border-color: var(--border-light);
    transform: none;
    box-shadow: none;
  }
  .article-card--compact .article-card__title {
    font-family: 'Inter', sans-serif;
    font-size: 0.875rem;
    font-weight: 500;
    line-height: 1.4;
    margin-bottom: var(--space-1);
  }
  .article-card--compact .article-card__meta {
    margin-bottom: 0;
    font-size: 0.6875rem;
  }
</style>
