---
import type { Article } from '../lib/airtable';

interface Props {
  article: Article;
  compact?: boolean;
}

const { article, compact = false } = Astro.props;
const href = `/library/${article.slug}`;
const truncLen = compact ? 120 : 200;
const truncatedAbstract = article.abstract
  ? article.abstract.slice(0, truncLen) + (article.abstract.length > truncLen ? '...' : '')
  : '';

// Parse short citation parts
const firstAuthor = article.authors?.split(';')[0]?.split(',')[0]?.trim() || '';
const authorDisplay = article.shortCitation || `${firstAuthor}${article.authors?.includes(';') ? ' et al.' : ''}, ${article.year || ''}`;

// Show journal if available
const journalDisplay = article.journal || article.journalAbbv || '';

// Build COinS (ContextObjects in Spans) for Zotero multi-select
function buildCOinS(a: Article): string {
  const params: string[] = [
    'ctx_ver=Z39.88-2004',
    'rft_val_fmt=info%3Aofi%2Ffmt%3Akev%3Amtx%3Ajournal',
    'rft.genre=article',
  ];
  if (a.title) params.push('rft.atitle=' + encodeURIComponent(a.title));
  if (a.journal) params.push('rft.jtitle=' + encodeURIComponent(a.journal));
  if (a.volume) params.push('rft.volume=' + encodeURIComponent(a.volume));
  if (a.issue) params.push('rft.issue=' + encodeURIComponent(a.issue));
  if (a.pages) {
    const [sp, ep] = a.pages.split(/[-–]/);
    if (sp) params.push('rft.spage=' + encodeURIComponent(sp.trim()));
    if (ep) params.push('rft.epage=' + encodeURIComponent(ep.trim()));
  }
  if (a.datePublished) params.push('rft.date=' + encodeURIComponent(a.datePublished));
  else if (a.year) params.push('rft.date=' + encodeURIComponent(String(a.year)));
  // Authors
  const authors = a.authors?.split(';').map(s => s.trim()).filter(Boolean) || [];
  authors.forEach(au => params.push('rft.au=' + encodeURIComponent(au)));
  // Identifiers
  if (a.doi) params.push('rft_id=' + encodeURIComponent('info:doi/' + a.doi));
  if (a.pmid) params.push('rft_id=' + encodeURIComponent('info:pmid/' + a.pmid));
  return params.join('&');
}

const coinsTitle = buildCOinS(article);
---
<article class:list={['article-card', { 'article-card--compact': compact }]}>
  <span class="Z3988" title={coinsTitle}></span>
  <a href={href} class="article-card__link">
    <h3 class="article-card__title">{article.title}</h3>
  </a>

  <div class="article-card__meta">
    <span class="article-card__authors">{authorDisplay}</span>
    {journalDisplay && (
      <span class="article-card__journal">{journalDisplay}</span>
    )}
    {article.isOpenAccess && (
      <span class="access-icon access-icon--open" title="Open Access">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 9.9-1"/></svg>
      </span>
    )}
    {article.isCopyrighted && (
      <span class="access-icon access-icon--locked" title="Copyrighted">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
      </span>
    )}
  </div>

  {!compact && truncatedAbstract && (
    <p class="article-card__abstract">{truncatedAbstract}</p>
  )}

  {!compact && article.topics.length > 0 && (
    <div class="article-card__topics">
      {article.topics.slice(0, 3).map(t => (
        <span class="article-card__topic">{t}</span>
      ))}
    </div>
  )}
</article>

<style>
  /* Full card — paper sheet, uniform height */
  .article-card {
    background: var(--bg-surface);
    border-radius: var(--radius-md);
    padding: var(--space-5);
    transition: box-shadow 0.2s;
    display: flex;
    flex-direction: column;
    min-width: 0;
    overflow: hidden;
  }
  .article-card:hover {
    box-shadow: var(--shadow-md);
  }

  .article-card__link {
    text-decoration: none;
    color: inherit;
  }
  .article-card__link:hover {
    text-decoration: none;
  }

  .article-card__title {
    font-family: 'Cormorant Garamond', 'Georgia', serif;
    font-weight: 600;
    font-size: 1.125rem;
    line-height: 1.3;
    color: var(--text-primary);
    margin-bottom: var(--space-2);
    transition: color 0.15s;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .article-card__link:hover .article-card__title {
    color: var(--accent);
  }

  .article-card__meta {
    display: flex;
    flex-wrap: nowrap;
    align-items: baseline;
    gap: var(--space-1);
    margin-bottom: var(--space-3);
    font-size: 0.75rem;
    line-height: 1.5;
    overflow: hidden;
    white-space: nowrap;
    text-overflow: ellipsis;
  }
  .article-card__authors {
    color: var(--text-secondary);
    font-weight: 500;
  }
  .article-card__journal {
    color: var(--text-tertiary);
    font-style: italic;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .article-card__journal::before {
    content: '\b7';
    margin-right: var(--space-1);
    font-style: normal;
    color: var(--text-muted);
  }

  .article-card__abstract {
    font-size: 0.8125rem;
    color: var(--text-secondary);
    line-height: 1.6;
    margin-bottom: var(--space-3);
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    flex: 1;
  }

  .article-card__topics {
    display: flex;
    flex-wrap: nowrap;
    gap: var(--space-2);
    overflow: hidden;
    margin-top: auto;
  }
  .article-card__topic {
    font-size: 0.625rem;
    font-weight: 500;
    color: var(--text-tertiary);
    background: var(--neutral-100);
    padding: 2px 8px;
    border-radius: var(--radius-sm);
    white-space: nowrap;
    flex-shrink: 0;
  }

  /* Compact variant — clean text row */
  .article-card--compact {
    background: transparent;
    border-radius: 0;
    padding: var(--space-3) 0;
    border-bottom: 1px solid var(--border-light);
  }
  .article-card--compact:hover {
    box-shadow: none;
  }
  .article-card--compact .article-card__title {
    font-family: 'Inter', sans-serif;
    font-size: 0.875rem;
    font-weight: 500;
    line-height: 1.4;
    margin-bottom: var(--space-1);
  }
  .article-card--compact .article-card__meta {
    margin-bottom: 0;
    font-size: 0.6875rem;
  }
</style>
