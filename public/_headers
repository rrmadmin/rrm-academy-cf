# Cache static assets for 1 year (hashed filenames)
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Cache all static images for 1 week — unhashed filenames break on deploys
# when CF Pages edge nodes haven't propagated yet (max-age=0 default = 404).
# Covers /images/og/, /images/authors/, /images/course-covers/, loose files, etc.
/images/*
  Cache-Control: public, max-age=604800

# Pagefind: no-store prevents browsers from caching fragments across deploys.
# CF Pages returns 200 (not 404) for missing files, so no-cache + revalidation
# causes browsers to cache HTML 404 pages as valid fragment data after deploys.
# Fragments are small (~2-5KB) and only loaded on search, so no-store is fine.
/pagefind/*
  Cache-Control: no-store

# API endpoints — no caching, lock CORS to production origin
/api/*
  Cache-Control: no-store
  Access-Control-Allow-Origin: https://rrmacademy.org

# ==============================================
# Agent discovery — RFC 8288 Link headers
# Homepage advertises sitemap, llms.txt, openapi, markdown fallback, and
# API catalog so AI agents can discover integration points from HTTP headers
# alone (no HTML parse required).
# ==============================================

/
  Cache-Control: public, max-age=0, s-maxage=3600, stale-while-revalidate=86400
  Link: </sitemap.xml>; rel="sitemap"; type="application/xml"
  Link: </schemamap.xml>; rel="describedby"; type="application/xml"; title="Schema Map"
  Link: </library-feed.jsonl>; rel="alternate"; type="application/x-ndjson"; title="Library Feed (JSONL)"
  Link: </llms.txt>; rel="describedby"; type="text/plain"; title="llms.txt"
  Link: </llms-full.txt>; rel="describedby"; type="text/plain"; title="llms-full.txt"
  Link: </openapi.json>; rel="service-desc"; type="application/vnd.oai.openapi+json;version=3.1"
  Link: </.well-known/api-catalog>; rel="api-catalog"; type="application/linkset+json"
  Link: </index.md>; rel="alternate"; type="text/markdown"; title="Markdown"
  Link: </pricing.md>; rel="alternate"; type="text/markdown"; title="Pricing"

