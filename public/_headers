# ──────────────────────────────────────────────
# Security headers — all pages
# NOTE: This /* rule causes CF Pages to convert internal trailing-slash
# 301 redirects to 200, but browsers follow the Location header anyway.
# Security headers applied here + reinforced by middleware.
# ──────────────────────────────────────────────
/*
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  X-Frame-Options: SAMEORIGIN
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'wasm-unsafe-eval' blob: https://challenges.cloudflare.com https://embed.cloudflarestream.com https://static.cloudflareinsights.com; style-src 'self' 'unsafe-inline'; img-src 'self' https: data:; font-src 'self'; connect-src 'self' https://challenges.cloudflare.com https://cloudflareinsights.com; frame-src https://challenges.cloudflare.com https://customer-99owhsi4yh33gohc.cloudflarestream.com; object-src 'none'; base-uri 'self'; form-action 'self'

# ──────────────────────────────────────────────
# Cache-Control rules
# ──────────────────────────────────────────────

# HTML pages — always revalidate with origin on refresh
/library/*
  Cache-Control: public, max-age=0, must-revalidate

/linkinbio
  Cache-Control: public, max-age=0, must-revalidate

# Course pages — always revalidate
/courses/*
  Cache-Control: public, max-age=0, must-revalidate

# Cache static assets for 1 year (hashed filenames)
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Cache all static images for 1 week — unhashed filenames break on deploys
# when CF Pages edge nodes haven't propagated yet (max-age=0 default = 404).
# Covers /images/og/, /images/authors/, /images/course-covers/, loose files, etc.
/images/*
  Cache-Control: public, max-age=604800

# Pagefind: no-store prevents browsers from caching fragments across deploys.
# CF Pages returns 200 (not 404) for missing files, so no-cache + revalidation
# causes browsers to cache HTML 404 pages as valid fragment data after deploys.
# Fragments are small (~2-5KB) and only loaded on search, so no-store is fine.
/pagefind/*
  Cache-Control: no-store

# API endpoints — no caching, lock CORS to production origin
/api/*
  Cache-Control: no-store
  Access-Control-Allow-Origin: https://rrmacademy.org
