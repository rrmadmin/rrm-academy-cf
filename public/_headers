# Security headers and CSP for all paths are injected by
# functions/_middleware.js (withSecurityHeaders helper). The previous /*
# catch-all here corrupted CF Pages internal 3xx redirects to 200, and the
# same engine path flattens function 4xx responses to 200 + text/html.
# Per-path Cache-Control and CORS rules below are safe and stay.

# ==============================================
# Cache-Control rules
# ==============================================

# HTML pages — always revalidate with origin on refresh
/library/*
  Cache-Control: public, max-age=0, must-revalidate

/linkinbio
  Cache-Control: public, max-age=0, must-revalidate

# Course pages — always revalidate
/courses/*
  Cache-Control: public, max-age=0, must-revalidate

# Cache static assets for 1 year (hashed filenames)
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Cache all static images for 1 week — unhashed filenames break on deploys
# when CF Pages edge nodes haven't propagated yet (max-age=0 default = 404).
# Covers /images/og/, /images/authors/, /images/course-covers/, loose files, etc.
/images/*
  Cache-Control: public, max-age=604800

# Pagefind: no-store prevents browsers from caching fragments across deploys.
# CF Pages returns 200 (not 404) for missing files, so no-cache + revalidation
# causes browsers to cache HTML 404 pages as valid fragment data after deploys.
# Fragments are small (~2-5KB) and only loaded on search, so no-store is fine.
/pagefind/*
  Cache-Control: no-store

# API endpoints — no caching, lock CORS to production origin
/api/*
  Cache-Control: no-store
  Access-Control-Allow-Origin: https://rrmacademy.org
