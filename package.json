{
  "name": "rrm-library-site",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "node src/lib/enrich-glossary.mjs && node scripts/build-og-index.mjs && node scripts/generate-page-dates.mjs && node scripts/build-library-feed.mjs && node scripts/build-guides-data.mjs && node scripts/build-pillar-reviews.mjs && SITE_SSOT_ENABLED=${SITE_SSOT_ENABLED:-1} node scripts/ssot-prebuild.mjs && astro build && npx pagefind --site dist",
    "build:astro": "astro build",
    "ssot:validate": "node ../../tools/site-ssot/bin/ssot-validate.mjs --project .",
    "ssot:smoke": "node ../../tools/site-ssot/bin/ssot-smoke.mjs --project .",
    "ssot:emit": "SITE_SSOT_ENABLED=1 node ../../tools/site-ssot/bin/ssot-emit.mjs --project .",
    "ssot:dry-run": "SITE_SSOT_ENABLED=1 node ../../tools/site-ssot/bin/ssot-emit.mjs --project . --dry-run",
    "ssot:schemamap": "node ../../tools/site-ssot/bin/ssot-schemamap.mjs --project .",
    "standards": "node --max-old-space-size=8192 ../../tools/standards-gate/run.mjs dist/",
    "standards:strict": "node --max-old-space-size=8192 ../../tools/standards-gate/run.mjs dist/ --strict",
    "postbuild": "node scripts/ssot-postbuild.mjs",
    "page-dates": "node scripts/generate-page-dates.mjs",
    "preview": "astro preview",
    "fetch-data": "node src/lib/fetch-data.mjs",
    "fetch-blog": "node src/lib/fetch-blog-data.mjs",
    "fetch-faqs": "node src/lib/fetch-faq-data.mjs",
    "fetch-courses": "node src/lib/fetch-courses-data.mjs",
    "fetch-partners": "node src/lib/fetch-partners-data.mjs",
    "fetch-glossary": "node src/lib/fetch-glossary-data.mjs",
    "build-guides": "node scripts/build-guides-data.mjs",
    "fetch-survey-count": "node src/lib/fetch-survey-count.mjs",
    "enrich-glossary": "node src/lib/enrich-glossary.mjs",
    "snapshot:glossary": "node scripts/glossary-snapshot.mjs",
    "snapshot:spokes": "node scripts/glossary-snapshot.mjs --spokes",
    "snapshot:spokes:live": "node scripts/glossary-snapshot.mjs --spokes --live",
    "fetch-all": "node src/lib/fetch-data.mjs && node src/lib/fetch-blog-data.mjs && node src/lib/fetch-faq-data.mjs && node src/lib/fetch-courses-data.mjs && node src/lib/fetch-partners-data.mjs && node src/lib/fetch-glossary-data.mjs && node src/lib/fetch-survey-count.mjs",
    "guard": "node scripts/guard.mjs",
    "guard:update": "node scripts/guard.mjs --update",
    "guard:install": "cp hooks/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit",
    "guard:ios-zoom": "node scripts/guard-ios-zoom.mjs",
    "guard:agent-discovery": "node scripts/agent-discovery-check.mjs",
    "guard:agent-skills:regen": "node scripts/regen-agent-skills-digests.mjs",
    "design-tokens": "node scripts/generate-design-tokens.mjs",
    "design-tokens:check": "node scripts/generate-design-tokens.mjs --check",
    "design-tokens:audit": "node scripts/audit-design-tokens.mjs",
    "design-tokens:audit:strict": "node scripts/audit-design-tokens.mjs --strict",
    "verify-hamburger": "node scripts/verify-mobile-hamburger.mjs",
    "sync-ecosystem": "node scripts/sync-ecosystem.mjs",
    "embed": "npx wrangler dev scripts/embed-library.mjs --port 8688 --compatibility-date 2025-01-01",
    "pipeline:snapshot": "node scripts/pipeline.mjs snapshot",
    "pipeline:dry-run": "node scripts/pipeline.mjs dry-run",
    "pipeline:report": "node scripts/pipeline.mjs report",
    "pipeline:validate": "node scripts/pipeline.mjs validate",
    "pipeline:status": "node scripts/pipeline.mjs status",
    "fetch-all:dry": "node src/lib/fetch-data.mjs --dry-run && node src/lib/fetch-blog-data.mjs --dry-run && node src/lib/fetch-faq-data.mjs --dry-run && node src/lib/fetch-courses-data.mjs --dry-run && node src/lib/fetch-partners-data.mjs --dry-run && node src/lib/fetch-glossary-data.mjs --dry-run",
    "verify-citations": "node scripts/verify-citations.mjs",
    "lint": "eslint functions/",
    "test": "node --test test/*.test.js",
    "baseline:capture": "bash scripts/baseline/capture-current.sh",
    "baseline:diff": "node scripts/baseline/diff.mjs --report text",
    "baseline:diff:hard": "node scripts/baseline/diff.mjs --gate hard --report text",
    "baseline:diff:json": "node scripts/baseline/diff.mjs --gate hard --report json",
    "test:e2e": "npx playwright test",
    "test:e2e:mobile": "npx playwright test --project=iphone-se --project=iphone-xr",
    "check-types": "node scripts/check-types.mjs",
    "check-types:update": "node scripts/check-types.mjs --update",
    "verify-templates": "node scripts/verify-templates.mjs",
    "quality:coverage": "node scripts/quality/coverage.mjs",
    "quality:mutation": "node scripts/quality/mutation.mjs",
    "quality:crap": "node scripts/quality/crap.mjs",
    "quality:deps": "node scripts/quality/deps.mjs",
    "quality:all": "node scripts/quality/dashboard.mjs",
    "quality:fast": "node scripts/quality/dashboard.mjs --skip-mutation",
    "gates": "node scripts/gates/validate-fact-pipeline.mjs",
    "gates:check": "node scripts/gates/validate-fact-pipeline.mjs --quick",
    "gates:glossary": "node scripts/gates/validate-glossary-pipeline.mjs",
    "gates:glossary:check": "node scripts/gates/validate-glossary-pipeline.mjs --quick",
    "gates:payment": "node scripts/gates/validate-payment-pipeline.mjs"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.3.0",
    "@fontsource/cormorant-garamond": "^5.2.11",
    "@fontsource/inter": "^5.2.8",
    "@lucide/astro": "^1.16.0",
    "astro": "^5.3.0",
    "aws4fetch": "^1.0.20",
    "jspdf": "^4.2.0",
    "marked": "^15.0.12",
    "stripe": "^20.3.1",
    "workers-og": "^0.0.27"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.7",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@resvg/resvg-js": "^2.6.2",
    "@stryker-mutator/api": "^9.6.1",
    "@stryker-mutator/core": "^9.6.1",
    "@typescript-eslint/parser": "^8.59.0",
    "c8": "^10.1.3",
    "dependency-cruiser": "^16.10.4",
    "eslint": "^10.0.2",
    "node-html-parser": "^7.1.0",
    "pagefind": "^1.3.0",
    "satori": "^0.25.0"
  }
}
