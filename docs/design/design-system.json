  "brand": {
    "name": "RRM Academy",
    "wordmark": {
      "text": "RRM Academy",
      "fontFamily": "Cormorant Garamond",
      "fontWeight": 600,
      "colorToken": "--text-primary",
      "rules": [
        "The brand is a pure Cormorant Garamond 600 text wordmark. No graphic mark exists.",
        "Do NOT invent a circle+R monogram, seal, glyph, badge mark, or any icon. The tree logo was deprecated.",
        "In any branded asset (badge, OG image, certificate), the wordmark is the biggest element. Eyebrow labels and descriptors are always secondary.",
        "Canonical treatment lives in src/components/Header.astro .logo__text (Cormorant 600, 1.625rem, --text-primary)."
      ]
    },
    "accent": {
      "colorToken": "--accent",
      "lightValue": "#725e7e",
      "darkValue": "#b8a3c4",
      "einkValue": "#5a5045",
      "rules": [
        "Brand accent is purple. Never rose, never sand, never any other palette.",
        "Rose is a semantic palette used for community/feminine UI accents and is NOT a brand accent.",
        "Purple is used sparingly: accent links, buttons, interactive states. It never competes with content."
      ]
    },
    "darkAssetPalette": {
      "note": "When designing a dark variant of any branded asset, use these tokens so the asset reads as native to the site footer.",
      "bgToken": "--footer-bg",
      "bgValue": "#313131",
      "textValue": "#ffffff",
      "accentToken": "--footer-accent",
      "accentValue": "#c9b8d3"
    },
    "philosophy": "Purple as authority. The brand purple (#725e7e) is used sparingly -- accent links, buttons, interactive states. It never competes with content."
  },
