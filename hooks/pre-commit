#!/bin/sh
# Pre-commit hook: runs security guard on critical file changes,
# and iOS auto-zoom guard on any staged .astro/.css change.
# Install: npm run guard:install
# Bypass: git commit --no-verify

CRITICAL_FILES="
functions/api/auth/_shared.js
functions/api/auth/login.js
functions/api/auth/signup.js
functions/api/auth/google-callback.js
functions/api/stripe-webhook.js
functions/api/create-checkout.js
functions/api/billing/status.js
functions/api/billing/portal.js
functions/_middleware.js
wrangler.toml
scripts/guard.mjs
guard-manifest.json
"

STAGED=$(git diff --cached --name-only)

# --- iOS auto-zoom guard: any staged .astro or .css file under src/ ---
if echo "$STAGED" | grep -qE '^src/.*\.(astro|css)$'; then
  node scripts/guard-ios-zoom.mjs
  if [ $? -ne 0 ]; then
    echo ""
    echo "Commit blocked by iOS auto-zoom guard."
    echo "Fix sub-16px font-size on form controls, or bypass with --no-verify."
    exit 1
  fi
fi

# --- Agent discovery guard: any staged .well-known/ or agent-readiness file ---
if echo "$STAGED" | grep -qE '^public/(\.well-known/|agents\.md|llms(-full)?\.txt|openapi\.json)'; then
  node scripts/agent-discovery-check.mjs
  if [ $? -ne 0 ]; then
    echo ""
    echo "Commit blocked by agent-discovery guard."
    echo "If a SKILL.md changed: run 'npm run guard:agent-skills:regen' to refresh digests."
    echo "Otherwise fix the drift the guard reported, or bypass with --no-verify."
    exit 1
  fi
fi

# --- Glossary spoke pipeline gates: any staged GlossaryTerm component or glossary route ---
if echo "$STAGED" | grep -qE '^src/components/GlossaryTerm\.astro$|^src/pages/glossary/.*\.astro$'; then
  node scripts/gates/validate-glossary-pipeline.mjs --quick
  if [ $? -ne 0 ]; then
    echo ""
    echo "Commit blocked by glossary spoke pipeline gates."
    echo "Status filter, render path, rewriter coverage, heading levels, or schema @ids drifted."
    echo "Fix the failures above, or bypass with --no-verify."
    exit 1
  fi
fi

# --- Payment pipeline gates: any staged stripe-webhook, create-checkout, or billing/* ---
if echo "$STAGED" | grep -qE '^functions/api/(stripe-webhook|create-checkout)\.js$|^functions/api/billing/.*\.js$|^scripts/gates/validate-payment-pipeline\.mjs$'; then
  node scripts/gates/validate-payment-pipeline.mjs
  if [ $? -ne 0 ]; then
    echo ""
    echo "Commit blocked by payment pipeline gates."
    echo "Webhook signature/dedup, err.message leak, enrollment revocation discipline, or atomicity drifted."
    echo "Fix the failures above, or bypass with --no-verify."
    exit 1
  fi
fi

# --- Security guard: only on critical file changes ---
TRIGGER=0
for file in $CRITICAL_FILES; do
  case "$STAGED" in
    *"$file"*) TRIGGER=1; break ;;
  esac
done

if [ "$TRIGGER" = "0" ]; then
  exit 0
fi

echo "Security guard: critical file change detected, running checks..."
node scripts/guard.mjs

if [ $? -ne 0 ]; then
  echo ""
  echo "Commit blocked. Fix issues or run 'npm run guard:update' after intentional changes."
  echo "Emergency bypass: git commit --no-verify"
  exit 1
fi
